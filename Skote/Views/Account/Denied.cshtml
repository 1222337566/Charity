@{
    ViewData["Title"] = "غير مصرح";
    Layout = "~/Views/Shared/_BlankLayout.cshtml";
}

<div class="container joud-auth-shell py-4">
    <div class="row g-0 joud-auth-grid w-100">
        <div class="col-lg-5 d-none d-lg-block">
            <div class="joud-brand-panel h-100">
                <div class="joud-brand-content">
                    <div class="joud-brand-badge">
                        <img src="~/assets/images/joud/joud-square-logo.svg" alt="Joud Charity" />
                        <div>
                            <strong>جود الخيري</strong><br />
                            <small>Joud Charity</small>
                        </div>
                    </div>
                    <h1 class="joud-brand-title">الوصول مرفوض</h1>
                    <p class="joud-brand-subtitle">ليست لديك صلاحية للوصول إلى هذه الصفحة وفقًا للأدوار والصلاحيات الحالية.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-7 bg-white">
            <div class="joud-auth-form-wrap d-flex align-items-center justify-content-center h-100">
                <div class="w-100" style="max-width:480px;">
                    <div class="joud-auth-logo mb-4">
                        <img src="~/assets/images/joud/joud-square-logo.svg" alt="Joud Charity" />
                        <div>
                            <h2>غير مصرح</h2>
                            <p>تحقق من الصلاحيات أو عد إلى الصفحة الرئيسية.</p>
                        </div>
                    </div>
                    <div class="joud-form-card text-center">
                        <div class="alert alert-danger mb-3">
                            ليس لديك صلاحية للوصول إلى هذه الصفحة.
                        </div>
                        <a class="btn joud-btn-primary w-100" asp-controller="Dashboard" asp-action="Index">الرجوع للرئيسية</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

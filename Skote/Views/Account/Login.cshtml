@model LoginDto
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "~/Views/Shared/_BlankLayout.cshtml";
}

<div class="container joud-auth-shell py-4">
    <div class="row g-0 joud-auth-grid w-100">
        <div class="col-lg-5 d-none d-lg-block">
            <div class="joud-brand-panel h-100">
                <div class="joud-brand-content">
                    <div class="joud-brand-badge">
                        <img src="~/assets/images/joud-square-logo.svg" alt="Joud Charity" />
                        <div>
                            <strong>جود الخيري</strong><br />
                            <small>Joud Charity</small>
                        </div>
                    </div>
                    <h1 class="joud-brand-title">منصة موحدة لإدارة أعمال الجمعية</h1>
                    <p class="joud-brand-subtitle">
                        إدارة المستفيدين والمساعدات، المشروعات، الحوكمة، المحاضر، والتقارير الذكية من مكان واحد.
                    </p>
                    <ul class="joud-brand-list">
                        <li><i class="bx bx-check-circle"></i><span>متابعة المستفيدين ودورات الصرف والكفالات.</span></li>
                        <li><i class="bx bx-check-circle"></i><span>متابعة المشروعات والأنشطة والمراحل والـ timeline.</span></li>
                        <li><i class="bx bx-check-circle"></i><span>تقارير ولوحات متابعة مصممة للإدارة والجهات المانحة.</span></li>
                    </ul>
                    <div class="mt-4 text-center">
                        <img src="~/assets/images/joud-auth-hero.svg" alt="Joud" class="img-fluid rounded-4" />
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-7 bg-white">
            <div class="joud-auth-form-wrap">
                <div class="joud-auth-logo">
                    <img src="~/assets/images/joud-square-logo.svg" alt="Joud Charity" />
                    <div>
                        <h2>مرحبًا بعودتك</h2>
                        <p>سجل الدخول للمتابعة إلى منصة جود الخيري.</p>
                    </div>
                </div>

                <div class="joud-form-card">
                    <form asp-action="Login" method="post" class="form-horizontal">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label">اسم المستخدم</label>
                            <input asp-for="UserName" class="form-control" placeholder="اسم المستخدم" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">كلمة المرور</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="كلمة المرور" />
                        </div>
                        <div class="form-check mb-3">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">تذكرني</label>
                        </div>
                        <button class="btn joud-btn-primary w-100" type="submit">تسجيل الدخول</button>
                        <div class="text-danger mt-3 small">@Html.ValidationSummary()</div>
                    </form>
                </div>

                <div class="joud-mini-note mt-3">
                    هذا النظام مخصص لإدارة أعمال الجمعية والحوكمة والتقارير والتشغيل اليومي.
                </div>

                <div class="mt-4 joud-auth-footer text-center">
                    ليس لديك حساب؟
                    <a href="@Url.Action("Register", "Account")" class="joud-link">إنشاء حساب</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/js/app.js"></script>
}

@model RegisterWithInfoDto
@{
    ViewData["Title"] = "إنشاء حساب";
    Layout = "~/Views/Shared/_BlankLayout.cshtml";
}

<div class="container joud-auth-shell py-4">
    <div class="row g-0 joud-auth-grid w-100">
        <div class="col-lg-5 d-none d-lg-block">
            <div class="joud-brand-panel h-100">
                <div class="joud-brand-content">
                    <div class="joud-brand-badge">
                        <img src="~/assets/images/joud/joud-square-logo.svg" alt="Joud Charity" />
                        <div>
                            <strong>جود الخيري</strong><br />
                            <small>Joud Charity</small>
                        </div>
                    </div>
                    <h1 class="joud-brand-title">إنشاء حساب جديد</h1>
                    <p class="joud-brand-subtitle">
                        أضف مستخدمًا جديدًا للنظام مع بياناته الأساسية بما يتماشى مع هوية جود الخيري.
                    </p>
                    <ul class="joud-brand-list">
                        <li><i class="bx bx-check-circle"></i><span>صلاحيات وأدوار متعددة حسب منصب الموظف.</span></li>
                        <li><i class="bx bx-check-circle"></i><span>إمكانية ربط الحساب بالبيانات الوظيفية لاحقًا.</span></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-7 bg-white">
            <div class="joud-auth-form-wrap">
                <div class="joud-auth-logo">
                    <img src="~/assets/images/joud/joud-square-logo.svg" alt="Joud Charity" />
                    <div>
                        <h2>حساب جديد</h2>
                        <p>أنشئ حسابًا جديدًا للمستخدم داخل النظام.</p>
                    </div>
                </div>

                <div class="joud-form-card">
                    <form asp-controller="Account" asp-action="Register" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label">اسم المستخدم</label>
                            <input asp-for="UserName" class="form-control" />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Password" class="form-label">كلمة المرور</label>
                                <input asp-for="Password" type="password" class="form-control" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ConfirmPassword" class="form-label">تأكيد كلمة المرور</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label">الاسم الكامل</label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="NationalId" class="form-label">الرقم القومي</label>
                                <input asp-for="NationalId" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="BirthDate" class="form-label">تاريخ الميلاد</label>
                                <input asp-for="BirthDate" type="date" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label">رقم الهاتف</label>
                                <input asp-for="Phone" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Department" class="form-label">الإدارة</label>
                                <input asp-for="Department" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="JobTitle" class="form-label">المسمى الوظيفي</label>
                                <input asp-for="JobTitle" class="form-control" />
                            </div>
                            <div class="col-12 mb-3">
                                <label asp-for="Address" class="form-label">العنوان</label>
                                <input asp-for="Address" class="form-control" />
                            </div>
                            <div class="col-12 mb-3">
                                <label asp-for="Gender" class="form-label">النوع</label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">-- اختر --</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProfileImage" class="form-label">الصورة الشخصية</label>
                            <input asp-for="ProfileImage" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-control" />
                            <small class="text-muted">الحد الأقصى 2MB</small>
                        </div>

                        <button class="btn joud-btn-primary w-100" type="submit">إنشاء الحساب</button>
                    </form>
                </div>

                <div class="mt-4 joud-auth-footer text-center">
                    لديك حساب بالفعل؟
                    <a href="@Url.Action("Login", "Account")" class="joud-link">تسجيل الدخول</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/assets/js/pages/validation.init.js"></script>
    <script src="~/assets/js/app.js"></script>
    <partial name="_ValidationScriptsPartial" />
}

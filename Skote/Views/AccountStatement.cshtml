@functions
{
    private static string GetSourceTypeLabel(string? sourceType) => sourceType switch
    {
        "Donation" => "تبرع",
        "Expense" => "مصروف",
        "Payroll" => "مرتبات",
        "StoreIssue" => "صرف مخزني",
        "StoreReceipt" => "إضافة مخزنية",
        "GrantInstallment" => "دفعة منحة",
        _ => sourceType ?? "-"
    };
}

@using InfrastructureManagmentWebFramework.Models.AccountingReports
@model AccountStatementPageVm

@{
    ViewData["Title"] = "كشف حساب";
}

<div class="container-fluid">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card mb-3">
        <div class="card-header"><h4 class="mb-0">كشف حساب</h4></div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">الحساب</label>
                    <select asp-for="Filter.AccountId" asp-items="Model.Filter.Accounts" class="form-select" required>
                        <option value="">اختر الحساب</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">الفترة المالية</label>
                    <select asp-for="Filter.FiscalPeriodId" asp-items="Model.Filter.FiscalPeriods" class="form-select">
                        <option value="">الكل</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">من تاريخ</label>
                    <input asp-for="Filter.FromDate" class="form-control" type="date" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">إلى تاريخ</label>
                    <input asp-for="Filter.ToDate" class="form-control" type="date" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Statement != null)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div><strong>الحساب:</strong> @Model.Statement.AccountCode - @Model.Statement.AccountNameAr</div>
                        <div><strong>الفئة:</strong> @Model.Statement.Category</div>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div><strong>رصيد افتتاحي:</strong> @Model.Statement.OpeningBalance.ToString("N2")</div>
                        <div><strong>رصيد ختامي:</strong> @Model.Statement.ClosingBalance.ToString("N2")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                @if (Model.Statement.Rows.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>التاريخ</th>
                                    <th>رقم القيد</th>
                                    <th>المصدر</th>
                                    <th>الوصف</th>
                                    <th>مركز التكلفة</th>
                                    <th>المشروع</th>
                                    <th>مدين</th>
                                    <th>دائن</th>
                                    <th>الرصيد الجاري</th>
                                    <th>تفاصيل</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.Statement.Rows)
                                {
                                    <tr>
                                        <td>@row.EntryDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            <a asp-controller="JournalEntries" asp-action="Details" asp-route-id="@row.JournalEntryId">@row.EntryNumber</a>
                                        </td>
                                        <td>@GetSourceTypeLabel(row.SourceType)</td>
                                        <td>@row.Description</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.CostCenterNameAr) ? "-" : row.CostCenterNameAr)</td>
                                        <td>@(row.ProjectId?.ToString() ?? "-")</td>
                                        <td>@row.DebitAmount.ToString("N2")</td>
                                        <td>@row.CreditAmount.ToString("N2")</td>
                                        <td>@row.RunningBalance.ToString("N2")</td>
                                        <td>
                                            <a asp-controller="JournalEntries" asp-action="Details" asp-route-id="@row.JournalEntryId" class="btn btn-sm btn-outline-secondary">عرض القيد</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td colspan="6">الإجمالي</td>
                                    <td>@Model.Statement.TotalDebit.ToString("N2")</td>
                                    <td>@Model.Statement.TotalCredit.ToString("N2")</td>
                                    <td>@Model.Statement.ClosingBalance.ToString("N2")</td>
                                    <td>-</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">لا توجد حركات للحساب المحدد ضمن الفلاتر الحالية.</div>
                }
            </div>
        </div>
    }
</div>

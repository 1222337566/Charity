@{
    ViewData["Title"] = "المحاسبة";
    var accountsCount = ViewBag.AccountsCount ?? 0;
    var costCentersCount = ViewBag.CostCentersCount ?? 0;
    var currentFiscalPeriod = ViewBag.CurrentFiscalPeriod;
}

<div class="container-fluid">
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="card h-100 border-primary">
                <div class="card-body">
                    <div class="text-muted">الدليل المحاسبي</div>
                    <h3 class="mb-0">@accountsCount</h3>
                    <small class="text-muted">عدد الحسابات المسجلة</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-success">
                <div class="card-body">
                    <div class="text-muted">مراكز التكلفة</div>
                    <h3 class="mb-0">@costCentersCount</h3>
                    <small class="text-muted">مراكز نشطة/مهيأة للربط التشغيلي</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-info">
                <div class="card-body">
                    <div class="text-muted">الفترة الحالية</div>
                    @if (currentFiscalPeriod != null)
                    {
                        <h5 class="mb-1">@currentFiscalPeriod.PeriodCode - @currentFiscalPeriod.PeriodNameAr</h5>
                        <small class="text-muted">@currentFiscalPeriod.StartDate.ToString("yyyy-MM-dd") إلى @currentFiscalPeriod.EndDate.ToString("yyyy-MM-dd")</small>
                    }
                    else
                    {
                        <h5 class="mb-1 text-warning">لا توجد فترة حالية</h5>
                        <small class="text-muted">أضف فترة مالية مفتوحة قبل ترحيل القيود.</small>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3"><a class="btn btn-outline-primary w-100 p-4" href="/FinancialAccount">الدليل المحاسبي</a></div>
        <div class="col-md-3"><a class="btn btn-outline-primary w-100 p-4" href="/CostCenters">مراكز التكلفة</a></div>
        <div class="col-md-3"><a class="btn btn-outline-primary w-100 p-4" href="/FiscalPeriods">الفترات المالية</a></div>
        <div class="col-md-3"><a class="btn btn-outline-primary w-100 p-4" href="/JournalEntries">القيود اليومية</a></div>
        <div class="col-md-4"><a class="btn btn-outline-success w-100 p-4" href="/AccountingReports">التقارير المحاسبية</a></div>
        <div class="col-md-4"><a class="btn btn-outline-success w-100 p-4" href="/AccountingReports/CostCenterStatement">كشف مركز تكلفة</a></div>
        <div class="col-md-4"><a class="btn btn-outline-success w-100 p-4" href="/OperationalJournalEntries">ربط الحركات بالقيود</a></div>
        <div class="col-md-4"><a class="btn btn-outline-dark w-100 p-4" href="/AccountingIntegrationProfiles">Profiles الربط</a></div>
        <div class="col-md-4"><a class="btn btn-outline-dark w-100 p-4" href="/ProjectAccountingProfiles">Profiles محاسبة المشروعات</a></div>
        <div class="col-md-4"><a class="btn btn-outline-dark w-100 p-4" href="/ProjectExpenseLinks">ربط المصروفات بالمشروعات</a></div>
        <div class="col-md-6"><a class="btn btn-outline-secondary w-100 p-4" href="/ProjectAccountingReports/ProjectCostSummary">ملخص تكلفة المشروعات</a></div>
        <div class="col-md-6"><a class="btn btn-outline-secondary w-100 p-4" href="/ProjectAccountingReports/ProjectLedger">دفتر أستاذ المشروع</a></div>
    </div>
</div>

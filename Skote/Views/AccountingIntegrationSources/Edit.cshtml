@model InfrastructureManagmentWebFramework.Models.AccountingIntegration.EditAccountingIntegrationSourceDefinitionVm
@{
    ViewData["Title"] = "تعديل مصدر ربط محاسبي";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h4 class="mb-3">تعديل مصدر ربط محاسبي</h4>
            @if (Model.IsSystem)
            {
                <div class="alert alert-warning small">هذا مصدر أساسي. يمكن تعديل الاسم والترتيب والحالة، لكن يفضل عدم تغيير الكود إلا لو عارف تأثيره على إنشاء القيود.</div>
            }
            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />
                <input asp-for="IsSystem" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                @await Html.PartialAsync("_Form", Model)
                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">حفظ</button>
                    <a asp-action="Index" class="btn btn-light">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>

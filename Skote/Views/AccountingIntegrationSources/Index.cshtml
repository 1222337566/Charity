@model List<InfrastrfuctureManagmentCore.Domains.Accounting.Integration.AccountingIntegrationSourceDefinition>
@{
    ViewData["Title"] = "مصادر الربط المحاسبي";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-1">مصادر الربط المحاسبي</h4>
            <div class="text-muted">تعريف مصادر القيود ديناميكيًا بدل الاعتماد على قائمة ثابتة داخل الكود.</div>
        </div>
        <div class="d-flex gap-2">
            <form asp-action="SeedDefaults" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary">تهيئة المصادر الأساسية</button>
            </form>
            <a asp-controller="AccountingIntegrationProfiles" asp-action="Index" class="btn btn-outline-primary">Profiles</a>
            <a asp-action="Create" class="btn btn-primary">إضافة مصدر</a>
        </div>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>الموديول</th>
                        <th>الترتيب</th>
                        <th>النوع</th>
                        <th>الحالة</th>
                        <th>التوليد الديناميكي</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><code>@item.SourceType</code></td>
                        <td>
                            <div class="fw-semibold">@item.NameAr</div>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <div class="text-muted small">@item.Description</div>
                            }
                        </td>
                        <td>@item.ModuleCode</td>
                        <td>@item.SortOrder</td>
                        <td>
                            @if (item.IsSystem)
                            {
                                <span class="badge bg-info">أساسي</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border">مخصص</span>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">نشط</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">موقوف</span>
                            }
                        </td>
                        <td>
                            @if (item.IsDynamicPostingEnabled)
                            {
                                <span class="badge bg-primary">مفعل</span>
                                @if (!string.IsNullOrWhiteSpace(item.EntityClrTypeName))
                                {
                                    <div class="small text-muted text-truncate" style="max-width:260px" title="@item.EntityClrTypeName">@item.EntityClrTypeName</div>
                                }
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border">غير مفعل</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

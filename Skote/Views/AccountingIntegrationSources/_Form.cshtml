@model InfrastructureManagmentWebFramework.Models.AccountingIntegration.CreateAccountingIntegrationSourceDefinitionVm

<style>
.ai-section{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 2px 8px rgba(14,111,115,.05);overflow:hidden;margin-bottom:16px}
.ai-head{padding:12px 18px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.9rem;font-weight:700;color:#0a5f63;background:rgba(14,111,115,.03);display:flex;align-items:center;gap:8px}
.ai-body{padding:16px 18px}
.prop-select{border-radius:8px;border:.5px solid rgba(14,111,115,.2);padding:6px 10px;font-size:.83rem;width:100%;background:#fff}
.prop-select:focus{outline:none;border-color:#0e6f73;box-shadow:0 0 0 2px rgba(14,111,115,.1)}
.kind-badge{padding:1px 7px;border-radius:5px;font-size:.68rem;font-weight:700;margin-right:4px}
</style>

@* ── البيانات الأساسية ── *@
<div class="ai-section">
  <div class="ai-head"><i class="bx bx-info-circle"></i>البيانات الأساسية</div>
  <div class="ai-body">
    <div class="row g-3">
      <div class="col-md-3">
        <label asp-for="SourceType" class="form-label fw-semibold" style="font-size:.83rem"></label>
        <input asp-for="SourceType" class="form-control" style="border-radius:10px" placeholder="Donation"/>
        <div class="form-text">كود ثابت إنجليزي — القيود تعتمد عليه</div>
        <span asp-validation-for="SourceType" class="text-danger small"></span>
      </div>
      <div class="col-md-3">
        <label asp-for="NameAr" class="form-label fw-semibold" style="font-size:.83rem"></label>
        <input asp-for="NameAr" class="form-control" style="border-radius:10px"/>
        <span asp-validation-for="NameAr" class="text-danger small"></span>
      </div>
      <div class="col-md-3">
        <label asp-for="NameEn" class="form-label fw-semibold" style="font-size:.83rem"></label>
        <input asp-for="NameEn" class="form-control" style="border-radius:10px"/>
      </div>
      <div class="col-md-3">
        <label asp-for="ModuleCode" class="form-label fw-semibold" style="font-size:.83rem"></label>
        <select asp-for="ModuleCode" class="prop-select">
          <option value="">-- اختر الموديول --</option>
          <option value="Charity">Charity</option>
          <option value="Stores">Stores</option>
          <option value="HR">HR</option>
          <option value="Accounting">Accounting</option>
          <option value="Donors">Donors</option>
          <option value="Projects">Projects</option>
          <option value="Kafala">Kafala</option>
        </select>
      </div>
      <div class="col-md-2">
        <label asp-for="SortOrder" class="form-label fw-semibold" style="font-size:.83rem"></label>
        <input asp-for="SortOrder" type="number" class="form-control" style="border-radius:10px"/>
      </div>
      <div class="col-md-4 d-flex align-items-end gap-4">
        <div class="form-check form-switch">
          <input asp-for="IsActive" class="form-check-input"/>
          <label asp-for="IsActive" class="form-check-label fw-semibold" style="font-size:.83rem"></label>
        </div>
        <div class="form-check form-switch">
          <input asp-for="IsDynamicPostingEnabled" class="form-check-input"/>
          <label asp-for="IsDynamicPostingEnabled" class="form-check-label fw-semibold" style="font-size:.83rem"></label>
        </div>
      </div>
      <div class="col-12">
        <label asp-for="Description" class="form-label fw-semibold" style="font-size:.83rem"></label>
        <textarea asp-for="Description" rows="2" class="form-control" style="border-radius:10px"></textarea>
      </div>
    </div>
  </div>
</div>

@* ── خريطة التوليد الديناميكي ── *@
<div class="ai-section">
  <div class="ai-head">
    <i class="bx bx-git-merge"></i>
    خريطة التوليد الديناميكي للقيد
    <span style="font-size:.75rem;font-weight:400;opacity:.7">اختر الكيان ثم ستظهر الحقول تلقائياً</span>
  </div>
  <div class="ai-body">
    <div class="row g-3">

      @* Entity Type Dropdown *@
      <div class="col-md-8">
        <label asp-for="EntityClrTypeName" class="form-label fw-semibold" style="font-size:.83rem">
          اسم الكيان الكامل (EntityClrTypeName)
        </label>
        <select id="entityTypeSelect" asp-for="EntityClrTypeName" class="prop-select"
                onchange="loadProperties()">
          <option value="">-- جارٍ التحميل... --</option>
        </select>
        <span asp-validation-for="EntityClrTypeName" class="text-danger small"></span>
      </div>
      <div class="col-md-4">
        <label asp-for="IdPropertyName" class="form-label fw-semibold" style="font-size:.83rem">حقل المفتاح</label>
        <select asp-for="IdPropertyName" class="prop-select" id="prop-IdPropertyName">
          <option value="Id">Id</option>
        </select>
      </div>

      @* Property Dropdowns ── كلها ستتملى من JS *@
      @{
        var propFields = new (string Field, string Label, string Kind, string Hint)[]
        {
          ("DatePropertyName",                "حقل التاريخ",              "date",   "التواريخ"),
          ("AmountPropertyName",              "حقل القيمة",               "amount", "الأرقام العشرية"),
          ("FinancialAccountIdPropertyName",  "حقل الحساب المالي",        "id",     "المعرّفات Guid"),
          ("NumberPropertyName",              "حقل الرقم / المرجع",       "text",   "النصوص والأرقام"),
          ("TitlePropertyName",               "حقل البيان",               "text",   "النصوص"),
          ("EventCodePropertyName",           "حقل كود الحدث",            "text",   "النصوص"),
          ("ProjectIdPropertyName",           "حقل المشروع",              "id",     "المعرّفات Guid"),
          ("CostCenterIdPropertyName",        "حقل مركز التكلفة",         "id",     "المعرّفات Guid"),
          ("AidTypeIdPropertyName",           "حقل نوع المساعدة",         "id",     "المعرّفات Guid"),
          ("DonationTypePropertyName",        "حقل نوع التبرع",           "text",   "النصوص"),
          ("TargetingScopeCodePropertyName",  "حقل نطاق التوجيه",         "text",   "النصوص"),
          ("PurposeNamePropertyName",         "حقل اسم الغرض",            "text",   "النصوص"),
          ("StoreMovementTypePropertyName",   "حقل نوع حركة المخزن",      "text",   "النصوص"),
        };
      }

      @foreach (var (field, label, kind, hint) in propFields)
      {
        <div class="col-md-4">
          <label class="form-label fw-semibold" style="font-size:.83rem">@label</label>
          <select name="@field" class="prop-select" id="prop-@field"
                  data-kind="@kind"
                  data-current="@(typeof(InfrastructureManagmentWebFramework.Models.AccountingIntegration.CreateAccountingIntegrationSourceDefinitionVm).GetProperty(field)?.GetValue(Model)?.ToString() ?? "")">
            <option value="">-- اختر حقلاً --</option>
          </select>
          <div class="form-text" style="font-size:.68rem">@hint</div>
        </div>
      }

      <div class="col-12">
        <label asp-for="DescriptionTemplate" class="form-label fw-semibold" style="font-size:.83rem"></label>
        <input asp-for="DescriptionTemplate" class="form-control" style="border-radius:10px"
               placeholder="{DonationNumber} - {Amount}"/>
        <div class="form-text" style="font-size:.72rem">
          استخدم {اسم_الحقل} — مثال: <code>إثبات تبرع رقم {DonationNumber} بمبلغ {Amount}</code>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
var _allProps = [];

// تحميل قائمة الـ Entities عند فتح الصفحة
(async function loadEntities() {
    var sel = document.getElementById('entityTypeSelect');
    var currentVal = '@Html.Raw(Model?.EntityClrTypeName?.Replace("'","\'") ?? "")';
    try {
        var res  = await fetch('/AccountingIntegrationSources/GetEntityTypes');
        var list = await res.json();

        // Group by module
        var groups = {};
        list.forEach(function(e) {
            if (!groups[e.module]) groups[e.module] = [];
            groups[e.module].push(e);
        });

        sel.innerHTML = '<option value="">-- اختر الكيان --</option>';
        Object.keys(groups).sort().forEach(function(mod) {
            var og = document.createElement('optgroup');
            og.label = mod;
            groups[mod].forEach(function(e) {
                var opt = document.createElement('option');
                opt.value = e.fullName;
                opt.textContent = e.shortName + ' (' + e.fullName + ')';
                if (currentVal && e.fullName === currentVal) opt.selected = true;
                og.appendChild(opt);
            });
            sel.appendChild(og);
        });

        // If editing - load properties for current entity
        if (currentVal) {
            await loadProperties();
        }
    } catch(e) {
        console.warn('Entity load error:', e);
        sel.innerHTML = '<option value="">خطأ في تحميل القائمة</option>';
    }
})();

async function loadProperties() {
    var typeName = document.getElementById('entityTypeSelect').value;
    if (!typeName) {
        clearAllPropertyDropdowns();
        return;
    }

    try {
        var res = await fetch('/AccountingIntegrationSources/GetEntityProperties?typeName=' + encodeURIComponent(typeName));
        _allProps = await res.json();
        fillPropertyDropdowns();
    } catch(e) {
        console.warn('Props load error:', e);
    }
}

function fillPropertyDropdowns() {
    var selects = document.querySelectorAll('[id^="prop-"][data-kind]');
    selects.forEach(function(sel) {
        var kind = sel.dataset.kind;
        var current = sel.dataset.current || sel.value;

        sel.innerHTML = '<option value="">-- اختر --</option>';

        // دائماً أضف "لا شيء"
        var filtered;
        if (kind === 'date')   filtered = _allProps.filter(p => p.kind === 'date');
        else if (kind === 'amount') filtered = _allProps.filter(p => p.kind === 'amount');
        else if (kind === 'id')     filtered = _allProps.filter(p => p.kind === 'id' || p.name.endsWith('Id'));
        else                        filtered = _allProps.filter(p => p.kind === 'text' || p.kind === 'id');

        // If not matching kind - also add all as fallback
        if (filtered.length === 0) filtered = _allProps;

        filtered.forEach(function(p) {
            var opt = document.createElement('option');
            opt.value = p.name;
            opt.textContent = p.name + '  [' + p.typeName + ']';
            if (p.name === current) opt.selected = true;
            sel.appendChild(opt);
        });

        // أعد تحديد القيمة الحالية
        if (current) sel.value = current;
    });

    // IdPropertyName
    var idSel = document.getElementById('prop-IdPropertyName');
    if (idSel) {
        var idProps = _allProps.filter(p => p.kind === 'id' || p.name === 'Id');
        idSel.innerHTML = '<option value="">-- اختر --</option>';
        idProps.forEach(function(p) {
            var opt = document.createElement('option');
            opt.value = p.name;
            opt.textContent = p.name + '  [' + p.typeName + ']';
            if (p.name === 'Id') opt.selected = true;
            idSel.appendChild(opt);
        });
        idSel.value = idSel.dataset?.current || 'Id';
    }
}

function clearAllPropertyDropdowns() {
    document.querySelectorAll('[id^="prop-"]').forEach(function(sel) {
        sel.innerHTML = '<option value="">-- اختر الكيان أولاً --</option>';
    });
}
</script>

@using InfrastructureManagmentWebFramework.Models.AccountingReports
@model BalanceSheetPageVm

@{
    ViewData["Title"] = "المركز المالي / الميزانية";
}

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-header"><h4 class="mb-0">المركز المالي / الميزانية</h4></div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label" for="fiscalPeriodId">الفترة المالية</label>
                    <select name="fiscalPeriodId" id="fiscalPeriodId" class="form-select">
                        <option value="">الكل</option>
                        @foreach (var period in Model.Filter.FiscalPeriods)
                        {
                            <option value="@period.Value" selected="@(Model.Filter.FiscalPeriodId?.ToString() == period.Value ? "selected" : null)">@period.Text</option>
                        }
                    </select>
                    <small class="text-muted">للمركز المالي الكامل اترك الفترة فارغة إذا كانت القيود الافتتاحية في فترات سابقة.</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="asOfDate">حتى تاريخ</label>
                    <input name="asOfDate" id="asOfDate" class="form-control" type="date" value="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted">إجمالي الأصول</div><h4>@Model.Result.TotalAssets.ToString("N2")</h4></div></div></div>
        <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted">إجمالي الالتزامات</div><h4>@Model.Result.TotalLiabilities.ToString("N2")</h4></div></div></div>
        <div class="col-md-3"><div class="card h-100"><div class="card-body"><div class="text-muted">حقوق الملكية + الفائض</div><h4>@Model.Result.TotalEquityAfterSurplus.ToString("N2")</h4></div></div></div>
        <div class="col-md-3"><div class="card h-100 border-warning"><div class="card-body"><div class="text-muted">فرق التوازن</div><h4>@Model.Result.BalanceDifference.ToString("N2")</h4></div></div></div>
    </div>

    @if (Math.Abs(Model.Result.BalanceDifference) > 0.01m)
    {
        <div class="alert alert-warning">
            يوجد فرق توازن. راجع القيود غير المرحلة، القيود الافتتاحية، أو اختيار الفترة المالية.
        </div>
    }

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header bg-light"><h5 class="mb-0">الأصول</h5></div>
                <div class="card-body">
                    @await Html.PartialAsync("_BalanceSheetRows", Model.Result.AssetRows)
                    <div class="fw-bold text-end mt-2">إجمالي الأصول: @Model.Result.TotalAssets.ToString("N2")</div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card mb-3">
                <div class="card-header bg-light"><h5 class="mb-0">الالتزامات</h5></div>
                <div class="card-body">
                    @await Html.PartialAsync("_BalanceSheetRows", Model.Result.LiabilityRows)
                    <div class="fw-bold text-end mt-2">إجمالي الالتزامات: @Model.Result.TotalLiabilities.ToString("N2")</div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-light"><h5 class="mb-0">حقوق الملكية / صافي الأصول</h5></div>
                <div class="card-body">
                    @await Html.PartialAsync("_BalanceSheetRows", Model.Result.EquityRows)
                    <table class="table table-sm table-bordered mt-2">
                        <tr>
                            <th>صافي فائض / عجز الفترة غير المقفل</th>
                            <td class="text-end">@Model.Result.CurrentPeriodSurplusOrDeficit.ToString("N2")</td>
                        </tr>
                        <tr class="table-light fw-bold">
                            <th>إجمالي حقوق الملكية بعد الفائض</th>
                            <td class="text-end">@Model.Result.TotalEquityAfterSurplus.ToString("N2")</td>
                        </tr>
                    </table>
                    <div class="fw-bold text-end mt-2">إجمالي الالتزامات وحقوق الملكية: @Model.Result.TotalLiabilitiesAndEquity.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
</div>

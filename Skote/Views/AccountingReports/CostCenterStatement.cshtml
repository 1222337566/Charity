@using InfrastructureManagmentWebFramework.Models.AccountingReports
@model CostCenterStatementPageVm

@{
    ViewData["Title"] = "كشف مركز تكلفة";
}

<div class="container-fluid">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card mb-3">
        <div class="card-header"><h4 class="mb-0">كشف مركز تكلفة</h4></div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="costCenterId">مركز التكلفة</label>
                    <select name="costCenterId" id="costCenterId" class="form-select" required>
                        <option value="">اختر مركز التكلفة</option>
                         @foreach (var costCenter in Model.Filter.CostCenters)
                        {
                            <option value="@costCenter.Value" selected="@(Model.Filter.CostCenterId?.ToString() == costCenter.Value ? "selected" : null)">@costCenter.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="fiscalPeriodId">الفترة المالية</label>
                    <select name="fiscalPeriodId" id="fiscalPeriodId" class="form-select">
                        <option value="">الكل</option>
                         @foreach (var period in Model.Filter.FiscalPeriods)
                        {
                            <option value="@period.Value" selected="@(Model.Filter.FiscalPeriodId?.ToString() == period.Value ? "selected" : null)">@period.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="fromDate">من تاريخ</label>
                    <input name="fromDate" id="fromDate" class="form-control" type="date" value="@(Model.Filter.FromDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="toDate">إلى تاريخ</label>
                    <input name="toDate" id="toDate" class="form-control" type="date" value="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Statement != null)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div><strong>مركز التكلفة:</strong> @Model.Statement.CostCenterCode - @Model.Statement.CostCenterNameAr</div>
                        <div><strong>عدد الحركات:</strong> @Model.Statement.Rows.Count.ToString("N0")</div>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div><strong>رصيد افتتاحي:</strong> @Model.Statement.OpeningBalance.ToString("N2")</div>
                        <div><strong>رصيد ختامي:</strong> @Model.Statement.ClosingBalance.ToString("N2")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                @if (Model.Statement.Rows.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>التاريخ</th>
                                    <th>رقم القيد</th>
                                    <th>الحساب</th>
                                    <th>الوصف</th>
                                    <th>المصدر</th>
                                    <th>المشروع</th>
                                    <th>مدين</th>
                                    <th>دائن</th>
                                    <th>الرصيد الجاري</th>
                                    <th>الإجراء</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.Statement.Rows)
                                {
                                    <tr>
                                        <td>@row.EntryDate.ToString("yyyy-MM-dd")</td>
                                        <td>@row.EntryNumber</td>
                                        <td>@row.AccountCode - @row.AccountNameAr</td>
                                        <td>@row.Description</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.SourceType) ? "-" : row.SourceType)</td>
                                        <td>@(row.ProjectId?.ToString() ?? "-")</td>
                                        <td>@row.DebitAmount.ToString("N2")</td>
                                        <td>@row.CreditAmount.ToString("N2")</td>
                                        <td>@row.RunningBalance.ToString("N2")</td>
                                        <td>
                                            <a asp-controller="JournalEntries" asp-action="Details" asp-route-id="@row.JournalEntryId" class="btn btn-sm btn-outline-primary">
                                                عرض القيد
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td colspan="6">الإجمالي</td>
                                    <td>@Model.Statement.TotalDebit.ToString("N2")</td>
                                    <td>@Model.Statement.TotalCredit.ToString("N2")</td>
                                    <td>@Model.Statement.ClosingBalance.ToString("N2")</td>
                                    <td>-</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">لا توجد حركات لمركز التكلفة المحدد ضمن الفلاتر الحالية.</div>
                }
            </div>
        </div>
    }
</div>

@using InfrastructureManagmentWebFramework.Models.AccountingReports
@model GeneralLedgerPageVm

@{
    ViewData["Title"] = "الأستاذ العام";
}

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-header"><h4 class="mb-0">الأستاذ العام</h4></div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="fiscalPeriodId">الفترة المالية</label>
                    <select name="fiscalPeriodId" id="fiscalPeriodId" class="form-select">
                        <option value="">الكل</option>
                         @foreach (var period in Model.Filter.FiscalPeriods)
                        {
                            <option value="@period.Value" selected="@(Model.Filter.FiscalPeriodId?.ToString() == period.Value ? "selected" : null)">@period.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="fromDate">من تاريخ</label>
                    <input name="fromDate" id="fromDate" class="form-control" type="date" value="@(Model.Filter.FromDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="toDate">إلى تاريخ</label>
                    <input name="toDate" id="toDate" class="form-control" type="date" value="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Rows.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>كود الحساب</th>
                                <th>اسم الحساب</th>
                                <th>الفئة</th>
                                <th>رصيد افتتاحي</th>
                                <th>مدين الفترة</th>
                                <th>دائن الفترة</th>
                                <th>رصيد ختامي</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Rows)
                            {
                                <tr>
                                    <td>@row.AccountCode</td>
                                    <td>@row.AccountNameAr</td>
                                    <td>@row.Category</td>
                                    <td>@row.OpeningBalance.ToString("N2")</td>
                                    <td>@row.PeriodDebit.ToString("N2")</td>
                                    <td>@row.PeriodCredit.ToString("N2")</td>
                                    <td>@row.ClosingBalance.ToString("N2")</td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            <a asp-controller="FinancialAccount"
                                               asp-action="Details"
                                               asp-route-id="@row.AccountId"
                                               asp-route-fiscalPeriodId="@Model.Filter.FiscalPeriodId"
                                               asp-route-fromDate="@(Model.Filter.FromDate?.ToString("yyyy-MM-dd"))"
                                               asp-route-toDate="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))"
                                               class="btn btn-sm btn-outline-primary">
                                                التفاصيل
                                            </a>
                                            <a asp-action="AccountStatement"
                                               asp-route-accountId="@row.AccountId"
                                               asp-route-fiscalPeriodId="@Model.Filter.FiscalPeriodId"
                                               asp-route-fromDate="@(Model.Filter.FromDate?.ToString("yyyy-MM-dd"))"
                                               asp-route-toDate="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))"
                                               class="btn btn-sm btn-outline-secondary">
                                                كشف الحساب
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="3">الإجمالي</td>
                                <td>@Model.OpeningBalanceTotal.ToString("N2")</td>
                                <td>@Model.PeriodDebitTotal.ToString("N2")</td>
                                <td>@Model.PeriodCreditTotal.ToString("N2")</td>
                                <td>@Model.ClosingBalanceTotal.ToString("N2")</td>
                                <td>-</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">لا توجد بيانات لعرضها حسب الفلاتر المحددة.</div>
            }
        </div>
    </div>
</div>

@{
    ViewData["Title"] = "التقارير المحاسبية";
}

<div class="container-fluid">
    <div class="row g-3">
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5>ميزان المراجعة</h5>
                    <p class="text-muted flex-grow-1">إجمالي مدين ودائن وصافي رصيد لكل حساب خلال المدة المحددة.</p>
                    <a asp-action="TrialBalance" class="btn btn-primary">فتح التقرير</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5>الأستاذ العام</h5>
                    <p class="text-muted flex-grow-1">ملخص الحركات الافتتاحية وحركة الفترة والرصيد الختامي لكل حساب.</p>
                    <a asp-action="GeneralLedger" class="btn btn-primary">فتح التقرير</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5>كشف حساب</h5>
                    <p class="text-muted flex-grow-1">تفاصيل حركات حساب واحد مع الرصيد الجاري سطرًا بسطر.</p>
                    <a asp-action="AccountStatement" class="btn btn-primary">فتح التقرير</a>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 border-success">
                <div class="card-body d-flex flex-column">
                    <h5>كشف مركز تكلفة</h5>
                    <p class="text-muted flex-grow-1">متابعة حركات مركز تكلفة واحد وربطها بالحساب والقيد والمشروع.</p>
                    <a asp-action="CostCenterStatement" class="btn btn-success">فتح التقرير</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-primary">
                <div class="card-body d-flex flex-column">
                    <h5>قائمة الدخل</h5>
                    <p class="text-muted flex-grow-1">إيرادات ومصروفات الفترة وصافي الفائض أو العجز.</p>
                    <a asp-action="IncomeStatement" class="btn btn-primary">فتح التقرير</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-primary">
                <div class="card-body d-flex flex-column">
                    <h5>المركز المالي / الميزانية</h5>
                    <p class="text-muted flex-grow-1">الأصول والالتزامات وحقوق الملكية حتى تاريخ محدد.</p>
                    <a asp-action="BalanceSheet" class="btn btn-primary">فتح التقرير</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-info">
                <div class="card-body d-flex flex-column">
                    <h5>ملخص الإيرادات والمصروفات</h5>
                    <p class="text-muted flex-grow-1">لوحة مختصرة لإجماليات الدخل والمركز المالي.</p>
                    <a asp-action="RevenueExpenseSummary" class="btn btn-info">فتح التقرير</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-info">
                <div class="card-body d-flex flex-column">
                    <h5>مطابقة الفواتير مع المخزون</h5>
                    
                    <a asp-controller="InventoryAuditReports"
                       asp-action="InvoiceStockReconciliation"
                       class="btn btn-outline-primary">
                        <i class="bx bx-check-shield me-1"></i>
                        مطابقة الفواتير مع أذون المخزن
                    </a>
                    <a asp-controller="InventoryAccountingReconciliationReports"
                       asp-action="Index"
                       class="btn btn-outline-primary">
                        مطابقة المخزون مع الحسابات
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

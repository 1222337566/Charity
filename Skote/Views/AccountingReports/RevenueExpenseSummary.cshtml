@using InfrastructureManagmentWebFramework.Models.AccountingReports
@model RevenueExpenseSummaryPageVm

@{
    ViewData["Title"] = "ملخص الإيرادات والمصروفات";
}

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-header"><h4 class="mb-0">ملخص الإيرادات والمصروفات</h4></div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" for="fiscalPeriodId">الفترة المالية</label>
                    <select name="fiscalPeriodId" id="fiscalPeriodId" class="form-select">
                        <option value="">الكل</option>
                        @foreach (var period in Model.Filter.FiscalPeriods)
                        {
                            <option value="@period.Value" selected="@(Model.Filter.FiscalPeriodId?.ToString() == period.Value ? "selected" : null)">@period.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="fromDate">من تاريخ</label>
                    <input name="fromDate" id="fromDate" class="form-control" type="date" value="@(Model.Filter.FromDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="toDate">إلى تاريخ</label>
                    <input name="toDate" id="toDate" class="form-control" type="date" value="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4"><div class="card border-success"><div class="card-body"><div class="text-muted">إجمالي الإيرادات</div><h3>@Model.Result.TotalRevenue.ToString("N2")</h3></div></div></div>
        <div class="col-md-4"><div class="card border-danger"><div class="card-body"><div class="text-muted">إجمالي المصروفات</div><h3>@Model.Result.TotalExpense.ToString("N2")</h3></div></div></div>
        <div class="col-md-4"><div class="card border-primary"><div class="card-body"><div class="text-muted">صافي الفائض / العجز</div><h3>@Model.Result.NetSurplusOrDeficit.ToString("N2")</h3></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الأصول</div><h3>@Model.Result.TotalAssets.ToString("N2")</h3></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الالتزامات</div><h3>@Model.Result.TotalLiabilities.ToString("N2")</h3></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">حقوق الملكية + الفائض</div><h3>@Model.Result.TotalEquity.ToString("N2")</h3></div></div></div>
    </div>

    <div class="mt-3 d-flex gap-2 flex-wrap">
        <a asp-action="IncomeStatement" asp-route-fiscalPeriodId="@Model.Filter.FiscalPeriodId" asp-route-fromDate="@(Model.Filter.FromDate?.ToString("yyyy-MM-dd"))" asp-route-toDate="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))" class="btn btn-outline-primary">عرض قائمة الدخل التفصيلية</a>
        <a asp-action="BalanceSheet" asp-route-fiscalPeriodId="@Model.Filter.FiscalPeriodId" asp-route-asOfDate="@(Model.Filter.ToDate?.ToString("yyyy-MM-dd"))" class="btn btn-outline-primary">عرض المركز المالي</a>
    </div>
</div>

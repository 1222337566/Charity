@model List<Skote.Controllers.PhaseAssignmentRow>
@{
    ViewData["Title"] = "تسكين المستفيدين في الأنشطة";
    var project      = ViewBag.Project as InfrastrfuctureManagmentCore.Domains.Charity.Projects.CharityProject;
    var targetGroups = ViewBag.TargetGroups as List<string> ?? new();
}

<style>
:root{--teal:#0e6f73}
.ab-hero{background:linear-gradient(135deg,#1e3a5f,#0e6f73);border-radius:16px;padding:18px 24px;color:#fff;margin-bottom:18px}
.phase-card{border-radius:14px;border:.5px solid rgba(14,111,115,.13);box-shadow:0 2px 10px rgba(14,111,115,.06);margin-bottom:16px;overflow:hidden;background:#fff}
.phase-head{background:linear-gradient(90deg,rgba(14,111,115,.07),rgba(14,111,115,.02));padding:12px 18px;display:flex;align-items:center;gap:10px;border-bottom:.5px solid rgba(14,111,115,.08)}
.phase-num{width:36px;height:36px;border-radius:10px;background:var(--teal);color:#fff;font-size:.85rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ab-table{width:100%;border-collapse:collapse;font-size:.82rem}
.ab-table th{padding:8px 14px;font-size:.73rem;font-weight:700;color:#6b7d80;background:#f4f9f9;text-align:right;border-bottom:.5px solid rgba(14,111,115,.1);white-space:nowrap}
.ab-table td{padding:9px 14px;border-bottom:.5px solid rgba(14,111,115,.04);vertical-align:middle}
.ab-table tr:hover td{background:rgba(14,111,115,.015)}
.tg-cell{display:flex;flex-wrap:wrap;gap:4px}
.tg-chip{padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700;cursor:pointer;text-decoration:none;transition:all .18s;border:.5px solid transparent}
.tg-chip.has-data{background:rgba(14,111,115,.1);color:var(--teal);border-color:rgba(14,111,115,.2)}
.tg-chip.empty{background:#f0f4f8;color:#adb5bd}
.tg-chip:hover{background:var(--teal);color:#fff!important;border-color:var(--teal)}
.prog-bar{height:5px;border-radius:999px;background:#e2e8f0;overflow:hidden;width:70px;display:inline-block;vertical-align:middle}
.prog-fill{height:100%;border-radius:999px;background:var(--teal)}
.assign-btn{padding:4px 12px;border-radius:8px;font-size:.75rem;font-weight:600;background:var(--teal);color:#fff;text-decoration:none;transition:opacity .2s;white-space:nowrap}
.assign-btn:hover{opacity:.85;color:#fff}
.tg-legend{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px}
.tg-legend span{padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:600;background:rgba(14,111,115,.08);color:var(--teal);border:.5px solid rgba(14,111,115,.15)}
</style>

<div class="container-fluid">

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show">@TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Hero ── *@
<div class="ab-hero">
    <div class="fw-bold" style="font-size:1.05rem">@project?.Name</div>
    <div style="font-size:.8rem;opacity:.75">تسكين المستفيدين في الأنشطة حسب الفئة المستهدفة</div>
    <div class="d-flex gap-2 mt-2 flex-wrap">
        @foreach (var tg in targetGroups)
        {
            <span style="background:rgba(255,255,255,.18);padding:3px 12px;border-radius:20px;font-size:.72rem;font-weight:700">
                @tg
            </span>
        }
    </div>
</div>

@* ── مفتاح الفئات ── *@
@if (targetGroups.Any())
{
    <div class="tg-legend">
        <span style="background:#f0f4f8;color:#6b7d80">الفئات المستهدفة:</span>
        @foreach (var tg in targetGroups)
        {
            <span>@tg</span>
        }
    </div>
}

@* ── المراحل والأنشطة ── *@
@{ int phIdx = 0; }
@foreach (var row in Model)
{
    phIdx++;
    <div class="phase-card">
        <div class="phase-head">
            <div class="phase-num">@phIdx</div>
            <div class="flex-grow-1">
                <span class="fw-bold" style="font-size:.9rem;color:#1e3a5f">@row.Phase.Name</span>
                <span class="text-muted ms-2" style="font-size:.75rem">
                    @row.Phase.PlannedStartDate.ToString("yyyy/MM/dd") ← @row.Phase.PlannedEndDate.ToString("yyyy/MM/dd")
                </span>
            </div>
            <span style="font-size:.78rem;color:var(--teal);font-weight:700">
                إجمالي المسكَّنين: @row.TotalAssigned
            </span>
        </div>

        @if (!row.Activities.Any())
        {
            <div class="text-center py-3 text-muted small">لا توجد أنشطة مسكَّنة في هذه المرحلة</div>
        }
        else
        {
            <div style="overflow-x:auto">
                <table class="ab-table">
                    <thead>
                        <tr>
                            <th style="min-width:200px">النشاط</th>
                            <th style="width:110px">المخطط</th>
                            <th style="width:110px">المسكَّنون</th>
                            <th style="width:100px">الإنجاز</th>
                            @foreach (var tg in targetGroups)
                            {
                                <th style="min-width:110px">@tg</th>
                            }
                            <th style="width:100px">تسكين</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ar in row.Activities)
                        {
                            var act = ar.Assignment.Activity;
                            <tr>
                                <td>
                                    <div class="fw-semibold" style="font-size:.85rem">@act?.Title</div>
                                    @if (!string.IsNullOrEmpty(act?.TargetGroup))
                                    {
                                        <div style="font-size:.7rem;color:#adb5bd">@act.TargetGroup</div>
                                    }
                                </td>
                                <td class="text-center text-muted">@ar.PlannedTotal</td>
                                <td class="text-center fw-bold" style="color:var(--teal)">@ar.TotalAssigned</td>
                                <td>
                                    <div class="d-flex align-items-center gap-1">
                                        <div class="prog-bar">
                                            <div class="prog-fill"
                                                 style="width:@ar.FillPercent%;@(ar.FillPercent>=100?"background:#34c38f":"")">
                                            </div>
                                        </div>
                                        <span style="font-size:.72rem;color:var(--teal)">@ar.FillPercent.ToString("N0")%</span>
                                    </div>
                                </td>

                                @* خلية لكل فئة مستهدفة *@
                                @foreach (var tg in targetGroups)
                                {
                                    var gc = ar.GroupCounts.FirstOrDefault(g => g.GroupName == tg);
                                    <td>
                                        <a asp-action="Assign"
                                           asp-route-projectId="@project!.Id"
                                           asp-route-activityId="@ar.Assignment.ActivityId"
                                           asp-route-phaseId="@ar.Assignment.PhaseId"
                                           asp-route-targetGroup="@tg"
                                           class="tg-chip @(gc?.Total > 0 ? "has-data" : "empty")"
                                           title="تسكين في @tg">
                                            @if (gc?.Total > 0)
                                            {
                                                <span>👥 @gc.Total</span>
                                                @if (gc.Participants > 0)
                                                { <span class="ms-1" style="font-size:.65rem">(م: @gc.Participants)</span> }
                                            }
                                            else
                                            {
                                                <span>+ تسكين</span>
                                            }
                                        </a>
                                    </td>
                                }

                                <td>
                                    <a asp-action="Assign"
                                       asp-route-projectId="@project!.Id"
                                       asp-route-activityId="@ar.Assignment.ActivityId"
                                       asp-route-phaseId="@ar.Assignment.PhaseId"
                                       class="assign-btn">
                                        <i class="bx bx-user-plus me-1"></i>تسكين
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

<div class="mt-2">
    <a asp-controller="ActivityPhaseTracking" asp-action="PhaseOverview"
       asp-route-projectId="@project?.Id" class="btn btn-light btn-sm">
        <i class="bx bx-arrow-back me-1"></i>متابعة المراحل
    </a>
</div>

</div>

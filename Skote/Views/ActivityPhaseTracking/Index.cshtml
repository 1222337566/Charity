@model List<InfrastrfuctureManagmentCore.Domains.Charity.Projects.ActivityPhaseAssignment>
@using InfrastrfuctureManagmentCore.Domains.Charity.Projects
@{
    ViewData["Title"] = "تتبع النشاط عبر المراحل";
    var act     = ViewBag.Activity as ProjectSubGoalActivity;
    var project = ViewBag.Project as CharityProject;

    string Sc(string s) => s switch {
        "Completed"=>"#34c38f","InProgress"=>"#556ee6","Planned"=>"#adb5bd","Cancelled"=>"#f46a6a",_=>"#adb5bd"};
    string Sa(string s) => s switch {
        "Completed"=>"مكتمل","InProgress"=>"جارٍ","Planned"=>"مخطط","Cancelled"=>"ملغى",_=>s};

    var totalPlanned    = Model.Sum(p => p.PlannedQuantity);
    var totalActual     = Model.Sum(p => p.ActualQuantity);
    var totalPlanCost   = Model.Sum(p => p.PlannedCost);
    var totalActualCost = Model.Sum(p => p.ActualCost);
    var overallProgress = act?.ProgressPercent ?? 0;
}

<style>
.apt-hero{background:linear-gradient(135deg,#1e3a5f,#2d5282);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:18px}
.apt-stat{background:rgba(255,255,255,.12);border-radius:12px;padding:10px 14px;text-align:center;flex:1;min-width:80px}
.apt-stat .n{font-size:1.2rem;font-weight:800;line-height:1}
.apt-stat .l{font-size:.67rem;opacity:.8;margin-top:2px}

/* Timeline Phases */
.phase-timeline{display:flex;gap:0;overflow-x:auto;padding:16px 0 10px;position:relative}
.phase-timeline::before{content:'';position:absolute;top:34px;right:40px;left:40px;height:3px;background:#e2e8f0;z-index:0}
.phase-node{flex:1;min-width:100px;max-width:160px;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1;padding:0 6px}
.ph-circle{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:800;color:#fff;flex-shrink:0;border:3px solid transparent}
.ph-circle.completed{background:#34c38f;border-color:#34c38f;box-shadow:0 2px 10px rgba(52,195,143,.3)}
.ph-circle.inprogress{background:#556ee6;border-color:#556ee6;box-shadow:0 0 0 5px rgba(85,110,230,.15);animation:pulse-ph 1.8s infinite}
.ph-circle.planned{background:#f8fbfb;border-color:#e2e8f0;color:#adb5bd}
.ph-circle.cancelled{background:#f46a6a;border-color:#f46a6a}
keyframes pulse-ph{0%,100%{box-shadow:0 0 0 5px rgba(85,110,230,.15)}50%{box-shadow:0 0 0 9px rgba(85,110,230,.06)}}

.ph-label{margin-top:8px;font-size:.75rem;font-weight:700;text-align:center;color:#1e3a5f;line-height:1.3}
.ph-sub  {font-size:.65rem;color:#adb5bd;text-align:center;margin-top:2px}

/* Connector between circles */
.ph-connector{position:absolute;top:22px;right:calc(50% + 22px);width:calc(100% - 44px);height:3px;z-index:0}
.ph-connector.done{background:#34c38f}
.ph-connector.active{background:linear-gradient(to left,#e2e8f0 50%,#556ee6 50%)}
.ph-connector.wait{background:#e2e8f0}

/* Detail cards */
.phase-card{background:#fff;border-radius:16px;border:.5px solid rgba(30,58,95,.1);box-shadow:0 2px 10px rgba(30,58,95,.05);margin-bottom:12px;overflow:hidden}
.phase-card-head{padding:13px 18px;border-bottom:.5px solid rgba(30,58,95,.07);display:flex;align-items:center;gap:10px;background:rgba(30,58,95,.02)}
.metric-row{display:flex;gap:20px;flex-wrap:wrap;padding:14px 18px}
.metric{flex:1;min-width:80px}
.metric .lbl{font-size:.72rem;color:#6b7d80;margin-bottom:3px}
.metric .val{font-size:.95rem;font-weight:700;color:#1e3a5f}
.metric .val.good{color:#34c38f}
.metric .val.warn{color:#f1b44c}
.metric .val.danger{color:#f46a6a}
.progress-wrap{height:8px;border-radius:999px;background:#e2e8f0;overflow:hidden;margin-top:4px}
.progress-fill{height:100%;border-radius:999px;transition:width .35s}

/* Contribution badge */
.contrib-badge{padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700;background:rgba(30,58,95,.1);color:#1e3a5f}

/* Activity summary */
.act-summary{background:rgba(14,111,115,.04);border-radius:14px;padding:14px 18px;border:.5px solid rgba(14,111,115,.12);margin-bottom:16px}
</style>

@* Hero *@
<div class="apt-hero">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h5 class="fw-bold mb-1 text-white">
        <i class="bx bx-git-branch me-2"></i>تتبع النشاط عبر المراحل
      </h5>
      <div style="opacity:.75;font-size:.8rem">
        @project?.Name — @act?.SubGoal?.Goal?.Title — @act?.SubGoal?.Title
      </div>
    </div>
    <a asp-controller="ProjectGoals" asp-action="Index" asp-route-projectId="@project?.Id"
       class="btn btn-light btn-sm fw-bold" style="border-radius:10px">← رجوع للأهداف</a>
  </div>
  <div class="d-flex gap-3 flex-wrap">
    <div class="apt-stat" style="background:rgba(85,110,230,.2)">
      <div class="n" style="color:#c7d2fe">@overallProgress.ToString("N1")%</div>
      <div class="l">الإنجاز الكلي للنشاط</div>
    </div>
    <div class="apt-stat">
      <div class="n">@Model.Count</div><div class="l">المراحل المعينة</div>
    </div>
    <div class="apt-stat">
      <div class="n">@totalPlanned.ToString("N0")</div>
      <div class="l">ك. مخططة</div>
    </div>
    <div class="apt-stat" style="background:rgba(52,195,143,.2)">
      <div class="n" style="color:#a7f3d0">@totalActual.ToString("N0")</div>
      <div class="l">ك. فعلية</div>
    </div>
    <div class="apt-stat">
      <div class="n">@totalPlanCost.ToString("N0")</div>
      <div class="l">تكلفة مخططة</div>
    </div>
    <div class="apt-stat" style="background:rgba(241,180,76,.15)">
      <div class="n" style="color:#fde68a">@totalActualCost.ToString("N0")</div>
      <div class="l">تكلفة فعلية</div>
    </div>
  </div>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">
    <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

@* ملخص النشاط الكلي *@
<div class="act-summary">
  <div class="d-flex align-items-center gap-3 flex-wrap">
    <div style="flex:1">
      <div class="fw-bold" style="font-size:.95rem;color:#0a5f63">@act?.Title</div>
      <div style="font-size:.78rem;color:#6b7d80;margin-top:2px">
        @act?.TargetGroup · @act?.PlannedQuantity @act?.QuantityUnit
        @if (act?.PlannedDurationDays != 0)
        { <span>· @act.PlannedDurationDays يوم</span>
          @if (act.PlannedHoursPerDay != 0) { <span>× @act.PlannedHoursPerDay ساعة/يوم</span> } }
      </div>
      @* شريط الإنجاز الكلي *@
      <div class="d-flex align-items-center gap-2 mt-2">
        <div style="flex:1;height:10px;border-radius:999px;background:#e2e8f0;overflow:hidden">
          <div style="width:@overallProgress.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;height:100%;border-radius:999px;background:@(overallProgress>=100?"#34c38f":"#556ee6");transition:width .3s"></div>
        </div>
        <span class="fw-bold" style="color:@(overallProgress>=100?"#34c38f":"#556ee6");font-size:.9rem;min-width:40px">@overallProgress.ToString("N1")%</span>
      </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(act?.PerformanceIndicator))
    {
      <div style="max-width:280px;font-size:.78rem;color:#6b7d80;background:rgba(14,111,115,.04);border-radius:10px;padding:8px 12px">
        <strong>مؤشر الأداء:</strong> @act.PerformanceIndicator
      </div>
    }
  </div>
</div>

@if (!Model.Any())
{
  <div class="text-center py-5" style="background:#fff;border-radius:16px;color:#adb5bd">
    <i class="bx bx-git-branch" style="font-size:3rem;display:block;margin-bottom:12px"></i>
    <p>لم يتم تعيين هذا النشاط لأي مرحلة بعد</p>
    <a asp-controller="ProjectGoals" asp-action="Index" asp-route-projectId="@project?.Id"
       class="btn btn-primary fw-bold" style="border-radius:12px">
      <i class="bx bx-plus me-1"></i>تعيين مرحلة
    </a>
  </div>
}
else
{
  @* خط زمني المراحل *@
  <div style="background:#fff;border-radius:16px;padding:18px;border:.5px solid rgba(30,58,95,.1);box-shadow:0 2px 10px rgba(30,58,95,.05);margin-bottom:16px;overflow-x:auto">
    <div class="fw-bold mb-3" style="font-size:.88rem;color:#1e3a5f">
      <i class="bx bx-git-branch me-2"></i>الخط الزمني عبر المراحل
    </div>
    <div class="phase-timeline">
      @for (int i = 0; i < Model.Count; i++)
      {
        var pa = Model[i];
        string circCls = pa.Status switch {
            "Completed"  => "completed",
            "InProgress" => "inprogress",
            "Cancelled"  => "cancelled",
            _ => "planned"
        };
        <div class="phase-node">
          @if (i > 0)
          {
            var prevDone = Model[i-1].Status == "Completed";
            var thisCurr = pa.Status == "InProgress";
            string connCls = prevDone ? "done" : (thisCurr ? "active" : "wait");
            <div class="ph-connector @connCls"></div>
          }
          <div class="ph-circle @circCls">@pa.SortOrder</div>
          <div class="ph-label">@(pa.Phase?.Name ?? "مرحلة")</div>
          <div class="ph-sub">@pa.ContributionPercent%</div>
          <div class="ph-sub" style="margin-top:2px">
            @pa.ProgressPercent.ToString("N0")% ✓
          </div>
        </div>
      }
    </div>
  </div>

  @* بطاقة تفصيلية لكل مرحلة *@
  @foreach (var pa in Model)
  {
    var phasePct    = pa.ProgressPercent;
    var qPct        = pa.PlannedQuantity > 0 ? pa.ActualQuantity / pa.PlannedQuantity * 100m : 0;
    var costPct     = pa.PlannedCost > 0 ? pa.ActualCost / pa.PlannedCost * 100m : 0;
    var paId        = $"pa-{pa.Id:N}";

    <div class="phase-card">
      <div class="phase-card-head">
        <div class="ph-circle @(pa.Status switch {"Completed"=>"completed","InProgress"=>"inprogress","Cancelled"=>"cancelled",_=>"planned"})" style="width:32px;height:32px;font-size:.72rem">
          @pa.SortOrder
        </div>
        <div class="flex-grow-1">
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="fw-bold" style="font-size:.9rem;color:#1e3a5f">@(pa.Phase?.Name ?? "—")</span>
            <span class="contrib-badge">نسبة المساهمة: @pa.ContributionPercent%</span>
            <span style="padding:2px 8px;border-radius:5px;font-size:.7rem;font-weight:700;background:@(Sc(pa.Status))22;color:@Sc(pa.Status)">
              @Sa(pa.Status)
            </span>
          </div>
          <div style="font-size:.72rem;color:#adb5bd;margin-top:2px">
            @if (pa.PlannedStartDate.HasValue)
            { <span>@pa.PlannedStartDate.Value.ToString("d/M/yyyy") ← @(pa.PlannedEndDate?.ToString("d/M/yyyy") ?? "—")</span> }
          </div>
        </div>
        <button type="button" class="btn btn-sm fw-semibold"
                style="border-radius:9px;background:rgba(30,58,95,.08);color:#1e3a5f;border:none"
                onclick="tog('@paId')">
          <i class="bx bx-edit me-1"></i>تحديث
        </button>
      </div>

      @* المقاييس *@
      <div class="metric-row">
        <div class="metric">
          <div class="lbl">نسبة الإنجاز</div>
          <div class="val @(phasePct>=100?"good":phasePct>=50?"warn":"")">@phasePct.ToString("N1")%</div>
          <div class="progress-wrap">
            <div class="progress-fill" style="width:@(Math.Min(phasePct,100)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:@Sc(pa.Status)"></div>
          </div>
        </div>
        <div class="metric">
          <div class="lbl">الكمية المخططة</div>
          <div class="val">@pa.PlannedQuantity.ToString("N0")</div>
        </div>
        <div class="metric">
          <div class="lbl">الكمية الفعلية</div>
          <div class="val @(pa.ActualQuantity >= pa.PlannedQuantity ? "good" : pa.ActualQuantity>0?"warn":"")">
            @pa.ActualQuantity.ToString("N0")
          </div>
          @if (pa.PlannedQuantity > 0)
          {
            <div class="progress-wrap">
              <div class="progress-fill" style="width:@(Math.Min(qPct,100)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:#34c38f"></div>
            </div>
          }
        </div>
        <div class="metric">
          <div class="lbl">المدة المخططة</div>
          <div class="val">@(pa.PlannedDurationDays.HasValue ? $"{pa.PlannedDurationDays} يوم" : "—")</div>
        </div>
        <div class="metric">
          <div class="lbl">المدة الفعلية</div>
          <div class="val @(pa.ActualDurationDays <= pa.PlannedDurationDays ? "good" : "warn")">
            @(pa.ActualDurationDays.HasValue ? $"{pa.ActualDurationDays} يوم" : "—")
          </div>
        </div>
        <div class="metric">
          <div class="lbl">التكلفة المخططة</div>
          <div class="val">@pa.PlannedCost.ToString("N0")</div>
        </div>
        <div class="metric">
          <div class="lbl">التكلفة الفعلية</div>
          <div class="val @(pa.ActualCost <= pa.PlannedCost ? "good" : "danger")">@pa.ActualCost.ToString("N0")</div>
          @if (pa.PlannedCost > 0)
          {
            <div class="progress-wrap">
              <div class="progress-fill" style="width:@(Math.Min(costPct,100)).ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%;background:@(costPct>100?"#f46a6a":"#34c38f")"></div>
            </div>
          }
        </div>
      </div>

      @if (!string.IsNullOrWhiteSpace(pa.Notes))
      {
        <div style="padding:8px 18px 12px;font-size:.78rem;color:#6b7d80">
          <i class="bx bx-comment me-1"></i>@pa.Notes
        </div>
      }

      @* نموذج التحديث *@
      <div id="@paId" style="display:none;border-top:.5px solid rgba(30,58,95,.08);padding:14px 18px;background:#fafcff">
        <form asp-action="UpdatePhase" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" name="assignmentId" value="@pa.Id"/>
          <input type="hidden" name="activityId"   value="@act?.Id"/>
          <div class="row g-3">
            <div class="col-md-3">
              <label class="form-label fw-semibold" style="font-size:.82rem">نسبة الإنجاز %</label>
              <input type="range" name="progress" value="@pa.ProgressPercent" min="0" max="100"
                     class="form-range" id="range-@pa.Id"
                     oninput="document.getElementById('rangeval-@pa.Id').textContent=this.value+'%'"/>
              <div class="text-center fw-bold" id="rangeval-@pa.Id"
                   style="color:#556ee6;font-size:1rem">@pa.ProgressPercent%</div>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-semibold" style="font-size:.82rem">الحالة</label>
              <select name="status" class="form-select" style="border-radius:10px">
                @foreach (var s in new[]{("Planned","مخطط"),("InProgress","جارٍ"),("Completed","مكتمل"),("Cancelled","ملغى")})
                { <option value="@s.Item1"selected=@(pa.Status==s.Item1)>@s.Item2</option> }
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-semibold" style="font-size:.82rem">كمية فعلية</label>
              <input type="number" name="actualQuantity" value="@pa.ActualQuantity" step="0.01" min="0"
                     class="form-control" style="border-radius:10px"/>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-semibold" style="font-size:.82rem">تكلفة فعلية</label>
              <input type="number" name="actualCost" value="@pa.ActualCost" step="0.01" min="0"
                     class="form-control" style="border-radius:10px"/>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-semibold" style="font-size:.82rem">مدة فعلية (أيام)</label>
              <input type="number" name="actualDurationDays" value="@pa.ActualDurationDays" min="0"
                     class="form-control" style="border-radius:10px"/>
            </div>
            <div class="col-md-1 d-flex align-items-end">
              <button type="submit" class="btn btn-primary fw-bold w-100" style="border-radius:10px">
                <i class="bx bx-save"></i>
              </button>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold" style="font-size:.82rem">ملاحظات</label>
              <textarea name="notes" class="form-control" rows="1" style="border-radius:10px">@pa.Notes</textarea>
            </div>
          </div>
        </form>
      </div>
    </div>
  }

  @* جدول مقارنة إجمالي ──  *@
  <div style="background:#fff;border-radius:16px;border:.5px solid rgba(30,58,95,.1);padding:16px 18px;box-shadow:0 2px 10px rgba(30,58,95,.05)">
    <div class="fw-bold mb-3" style="font-size:.88rem;color:#1e3a5f">
      <i class="bx bx-bar-chart me-2"></i>مقارنة المخطط بالفعلي — كل المراحل
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:.83rem">
      <thead>
        <tr style="background:#f8fbfb">
          <th style="padding:8px 12px;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.08)">المرحلة</th>
          <th style="padding:8px 12px;text-align:center;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.08)">نسبة المساهمة</th>
          <th style="padding:8px 12px;text-align:center;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.08)">ك. مخططة</th>
          <th style="padding:8px 12px;text-align:center;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.08)">ك. فعلية</th>
          <th style="padding:8px 12px;text-align:center;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.08)">تكلفة مخططة</th>
          <th style="padding:8px 12px;text-align:center;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.08)">تكلفة فعلية</th>
          <th style="padding:8px 12px;text-align:center;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.08)">الإنجاز</th>
          <th style="padding:8px 12px;text-align:center;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.08)">الحالة</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var pa in Model)
        {
          <tr style="border-top:.5px solid rgba(30,58,95,.05)">
            <td style="padding:8px 12px;font-weight:600;color:#1e3a5f">@(pa.Phase?.Name ?? "—")</td>
            <td style="padding:8px 12px;text-align:center">@pa.ContributionPercent%</td>
            <td style="padding:8px 12px;text-align:center">@pa.PlannedQuantity.ToString("N0")</td>
            <td style="padding:8px 12px;text-align:center;font-weight:600;color:@(pa.ActualQuantity>=pa.PlannedQuantity?"#34c38f":"#374151")">@pa.ActualQuantity.ToString("N0")</td>
            <td style="padding:8px 12px;text-align:center">@pa.PlannedCost.ToString("N0")</td>
            <td style="padding:8px 12px;text-align:center;color:@(pa.ActualCost<=pa.PlannedCost?"#34c38f":"#f46a6a");font-weight:600">@pa.ActualCost.ToString("N0")</td>
            <td style="padding:8px 12px;text-align:center">
              <div class="d-flex align-items-center gap-2">
                <div style="width:60px;height:5px;border-radius:999px;background:#e2e8f0;overflow:hidden">
                  <div style="width:@(Math.Min(pa.ProgressPercent,100)).ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%;height:100%;background:@Sc(pa.Status)"></div>
                </div>
                <span class="fw-semibold">@pa.ProgressPercent.ToString("N0")%</span>
              </div>
            </td>
            <td style="padding:8px 12px;text-align:center">
              <span style="padding:2px 8px;border-radius:5px;font-size:.7rem;font-weight:700;background:@(Sc(pa.Status))22;color:@Sc(pa.Status)">@Sa(pa.Status)</span>
            </td>
          </tr>
        }
      </tbody>
      <tfoot>
        <tr style="background:#f8fbfb;border-top:.5px solid rgba(30,58,95,.1);font-weight:700">
          <td style="padding:9px 12px">الإجمالي</td>
          <td style="padding:9px 12px;text-align:center">100%</td>
          <td style="padding:9px 12px;text-align:center">@totalPlanned.ToString("N0")</td>
          <td style="padding:9px 12px;text-align:center;color:#34c38f">@totalActual.ToString("N0")</td>
          <td style="padding:9px 12px;text-align:center">@totalPlanCost.ToString("N0")</td>
          <td style="padding:9px 12px;text-align:center;color:@(totalActualCost<=totalPlanCost?"#34c38f":"#f46a6a")">@totalActualCost.ToString("N0")</td>
          <td style="padding:9px 12px;text-align:center;color:#556ee6;font-size:1rem">@overallProgress.ToString("N1")%</td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>
}

@section Scripts {
<script>
function tog(id) {
    var el = document.getElementById(id);
    if (el) el.style.display = el.style.display === 'none' ? '' : 'none';
}
</script>
}

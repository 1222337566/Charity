@{
    ViewData["Title"] = "Active Directory - Directory Users";
     Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <h4 class="card-title mb-3">Directory (LDAP snapshot)</h4>

        <div class="row g-2 align-items-end mb-3">
          <div class="col-md-3">
            <label class="form-label">OU (اختياري)</label>
            <input id="ouDn" class="form-control" placeholder="OU=People,DC=yourdomain,DC=local">
          </div>
          <div class="col-md-3">
            <label class="form-label">بحث</label>
            <input id="query" class="form-control" placeholder="name/email/upn">
          </div>
          <div class="col-md-6 text-end">
            <button id="btn-refresh" class="btn btn-outline-primary">
              <i class="bx bx-refresh"></i> Refresh from LDAP
            </button>
            <button id="btn-promote" class="btn btn-success ms-2" disabled>
              <i class="bx bx-upload"></i> Promote selected
            </button>
          </div>
        </div>

        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th style="width:40px"><input type="checkbox" id="chk-all"></th>
                <th>Display Name</th>
                <th>UPN</th>
                <th>Email</th>
                <th>Department</th>
                <th>ObjectId</th>
                <th>Fetched</th>
                <th>Log On</th>
              </tr>
            </thead>
            <tbody id="dir-rows">
              <tr><td colspan="7" class="text-muted">ابدأ البحث أو حدّد Refresh</td>
               
              
              
              </tr>
            </tbody>
          </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
          <div><small id="result-info" class="text-muted"></small></div>
          <div>
            <button id="btn-prev" class="btn btn-outline-secondary" disabled>السابق</button>
            <button id="btn-next" class="btn btn-outline-secondary" disabled>التالي</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
<!-- DHCP Leases Modal -->
<div class="modal fade" id="dhcpModal" tabindex="-1" aria-labelledby="dhcpModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="dhcpModalLabel">DHCP Leases</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="dhcpModalBody">
        <!-- dynamic content -->
      </div>
      <div class="modal-footer">
        <div class="me-auto small text-muted" id="dhcpMeta"></div>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إغلاق</button>
      </div>
    </div>
  </div>
</div>
@section Scripts {
  <script src="~/assets/js/ad.directory.init.js?v=1"></script>


  <script>
async function viewDevices(id){
  const r = await fetch(`https://localhost7106/admin/ad/devices/${id}`);
  const j = await r.json();
  if(!Array.isArray(j)) return alert('لا توجد بيانات');
  console.table(j);
  alert(j.map(x => `${x.hostName} | ${x.ipAddress||'-'} | ${x.macAddress||'-'}`).join('\n') || 'لا توجد أجهزة');
}

async function refreshDevices(id){
  const r = await fetch(`https://localhost7106/admin/ad/devices/refresh/${id}`, { method:'POST' });
  const j = await r.json();
  if(r.ok){
    (window.toastr?.success||alert)(`تم تحديث ${j.updated} جهازًا من DHCP`);
    await viewDevices(id);
  }else{
    (window.toastr?.error||alert)(j.message||'فشل التحديث');
  }
}
        // ---- HGScript dynamic buttons (devices & dhcp) ----
        
</script>
}

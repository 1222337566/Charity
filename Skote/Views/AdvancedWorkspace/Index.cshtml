function toggleDef(header) {
    const body = header.nextElementSibling;
    body.style.display = body.style.display === 'none' ? 'block' : 'none';
}

// New definition
document.getElementById('btnNewDef').addEventListener('click', () => {
    document.getElementById('defId').value = '';
    document.getElementById('defEntityType').value = '';
    document.getElementById('defDisplayName').value = '';
    document.getElementById('defNotes').value = '';
    document.getElementById('defIsActive').checked = true;
    document.getElementById('defEntityType').disabled = false;
    new bootstrap.Modal(document.getElementById('modalWorkflowDef')).show();
});

// Edit definition buttons
document.querySelectorAll('.btn-edit-def').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('defId').value          = btn.dataset.defId;
        document.getElementById('defEntityType').value  = btn.dataset.entity;
        document.getElementById('defDisplayName').value = btn.dataset.name;

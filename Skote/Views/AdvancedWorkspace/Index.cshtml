// Show add step modal
function showAddStep(defId) {
    document.getElementById('stepId').value  = '';
    document.getElementById('stepDefId').value = defId;
    document.getElementById('stepName').value  = '';
    document.getElementById('stepRole').value  = '';
    document.getElementById('stepOrder').value = 1;

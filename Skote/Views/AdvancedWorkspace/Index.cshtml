document.getElementById('btnSaveDef').addEventListener('click', async () => {
    const id          = document.getElementById('defId').value;
    const entityType  = document.getElementById('defEntityType').value;
    const displayName = document.getElementById('defDisplayName').value.trim();
    if (!displayName || !entityType) { alert('نوع الكيان والاسم مطلوبان'); return; }

    const res = await postJson('/AdvancedWorkspace/SaveWorkflowDefinition', {
        id: id || null, entityType, displayName,
        notes: document.getElementById('defNotes').value,
        isActive: document.getElementById('defIsActive').checked
    });
    if (res.success) {
        bootstrap.Modal.getInstance(document.getElementById('modalWorkflowDef'))?.hide();
        toast('تم الحفظ — سيتم تحديث الصفحة');
        setTimeout(() => location.reload(), 800);
    } else toast('حدث خطأ', false);
});

// Delete definition
document.querySelectorAll('.btn-del-def').forEach(btn => {
    btn.addEventListener('click', async () => {
        if (!confirm('هل تريد حذف هذا المسار وجميع خطواته؟')) return;
        const res = await postJson('/AdvancedWorkspace/DeleteWorkflowDefinition',
            { id: btn.dataset.defId });
        if (res.success) { toast('تم الحذف'); btn.closest('.wf-def-card').remove(); }

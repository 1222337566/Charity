}

// Edit step
document.querySelectorAll('.btn-edit-step').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('stepId').value    = btn.dataset.stepId;
        document.getElementById('stepDefId').value = btn.dataset.defId;
        document.getElementById('stepName').value  = btn.dataset.name;
        document.getElementById('stepRole').value  = btn.dataset.role;
        document.getElementById('stepOrder').value = btn.dataset.order;
        document.getElementById('stepDesc').value  = btn.dataset.desc || '';
        new bootstrap.Modal(document.getElementById('modalWorkflowStep')).show();
    });
});

document.getElementById('btnSaveStep').addEventListener('click', async () => {
    const stepName = document.getElementById('stepName').value.trim();
    const stepRole = document.getElementById('stepRole').value;
    const defId    = document.getElementById('stepDefId').value;
    if (!stepName || !stepRole) { alert('اسم الخطوة والدور مطلوبان'); return; }

    const id = document.getElementById('stepId').value;
    const res = await postJson('/AdvancedWorkspace/SaveWorkflowStep', {
        id: id || null, definitionId: defId,
        stepName, assignedRole: stepRole,
        stepOrder: parseInt(document.getElementById('stepOrder').value) || 1,
        description: document.getElementById('stepDesc').value
    });

    if (res.success) {
        bootstrap.Modal.getInstance(document.getElementById('modalWorkflowStep'))?.hide();
        toast('تم الحفظ — جاري تحديث المسار');
        setTimeout(() => location.reload(), 600);
    } else toast('حدث خطأ', false);
});

// Delete step
document.querySelectorAll('.btn-del-step').forEach(btn => {
    btn.addEventListener('click', async () => {
        if (!confirm('حذف هذه الخطوة؟')) return;
        const res = await postJson('/AdvancedWorkspace/DeleteWorkflowStep',
            { id: btn.dataset.stepId });
        if (res.success) {
            toast('تم الحذف');
            btn.closest('.wf-step-item').remove();
        } else toast('حدث خطأ', false);
    });
});

// ── Drag & Drop for steps ──
let draggedStep = null;
document.querySelectorAll('.wf-step-item').forEach(item => {
    item.addEventListener('dragstart', () => { draggedStep = item; item.style.opacity = '.4'; });
    item.addEventListener('dragend',   () => { draggedStep = null; item.style.opacity = '1'; });
    item.addEventListener('dragover',  e => { e.preventDefault(); item.classList.add('drag-over'); });
    item.addEventListener('dragleave', () => item.classList.remove('drag-over'));
    item.addEventListener('drop', async e => {
        e.preventDefault();
        item.classList.remove('drag-over');
        if (!draggedStep || draggedStep === item) return;
        const parent = item.closest('.wf-steps-list');
        const items  = [...parent.querySelectorAll('.wf-step-item')];
        const fromI  = items.indexOf(draggedStep);
        const toI    = items.indexOf(item);
        if (fromI < toI) item.after(draggedStep);
        else item.before(draggedStep);

        // Renumber and save
        const newItems = [...parent.querySelectorAll('.wf-step-item')];
        const reorder  = newItems.map((el, i) => {
            el.querySelector('.wf-step-order').textContent = i + 1;
            return { id: el.dataset.stepId, order: i + 1 };
        });
        await postJson('/AdvancedWorkspace/ReorderWorkflowSteps', { items: reorder });
        toast('تم إعادة الترتيب');
    });
});
</script>

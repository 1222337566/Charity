// LOOKUPS
// ══════════════════════════════════════════════════════════════════════
let currentLookupType = null;

const LOOKUP_LABELS = {
    AidType: 'أنواع المساعدة', BeneficiaryStatus: 'حالات المستفيد',
    Governorate: 'المحافظات',   City: 'المدن',
    Gender: 'الجنس',            MaritalStatus: 'الحالة الاجتماعية'
};

document.querySelectorAll('.lookup-type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.lookup-type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentLookupType = btn.dataset.ltype;
        loadLookups(currentLookupType);
    });
});

async function loadLookups(type) {
    document.getElementById('lookupPanel').innerHTML =
        '<div class="p-4 text-center"><div class="spinner-border text-primary"></div></div>';
    const r = await fetch(`/AdvancedWorkspace/GetLookups?type=${type}`);
    const items = await r.json();
    renderLookupTable(type, items);
}

function renderLookupTable(type, items) {
    const label = LOOKUP_LABELS[type] || type;
    let rows = items.map(it => `
        <tr>
            <td class="fw-semibold">${it.nameAr || '—'}</td>
            <td>${it.nameEn || '—'}</td>
            <td>${it.isActive !== false
                ? '<span class="badge bg-success">نشط</span>'
                : '<span class="badge bg-secondary">غير نشط</span>'}</td>
            <td>
                <button class="btn btn-sm btn-light btn-edit-lookup"
                    data-id="${it.id}" data-namear="${it.nameAr}" data-nameen="${it.nameEn||''}"
                    data-active="${it.isActive!==false}">
                    <i class="mdi mdi-pencil-outline"></i>
                </button>
                <button class="btn btn-sm btn-danger btn-del-lookup" data-id="${it.id}">
                    <i class="mdi mdi-delete-outline"></i>
                </button>
            </td>
        </tr>`).join('');

    if (!rows) rows = '<tr><td colspan="4" class="text-center text-muted py-3">لا توجد بيانات</td></tr>';

    document.getElementById('lookupPanel').innerHTML = `
        <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
            <h6 class="mb-0 fw-bold">${label}</h6>
            <button class="btn btn-sm btn-primary btn-add-lookup">
                <i class="mdi mdi-plus me-1"></i>إضافة
            </button>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>الاسم (عربي)</th><th>الاسم (إنجليزي)</th><th>الحالة</th><th style="width:90px">إجراءات</th></tr>
                </thead>
                <tbody>${rows}</tbody>
            </table>
        </div>`;

    // Add button
    document.querySelector('.btn-add-lookup').addEventListener('click', () => {
        document.getElementById('lookupId').value   = '';
        document.getElementById('lookupType').value = type;
        document.getElementById('lookupNameAr').value = '';
        document.getElementById('lookupNameEn').value = '';
        document.getElementById('lookupIsActive').checked = true;
        document.getElementById('lookupModalTitle').textContent = `إضافة — ${label}`;
        new bootstrap.Modal(document.getElementById('modalLookup')).show();
    });

    // Edit buttons
    document.querySelectorAll('.btn-edit-lookup').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('lookupId').value    = btn.dataset.id;
            document.getElementById('lookupType').value  = type;
            document.getElementById('lookupNameAr').value = btn.dataset.namear;
            document.getElementById('lookupNameEn').value = btn.dataset.nameen;
            document.getElementById('lookupIsActive').checked = btn.dataset.active === 'true';
            document.getElementById('lookupModalTitle').textContent = `تعديل — ${label}`;
            new bootstrap.Modal(document.getElementById('modalLookup')).show();
        });
    });

    // Delete buttons
    document.querySelectorAll('.btn-del-lookup').forEach(btn => {
        btn.addEventListener('click', async () => {
            if (!confirm('هل تريد حذف هذا العنصر؟')) return;
            const res = await postJson('/AdvancedWorkspace/DeleteLookup',
                { id: btn.dataset.id, type });
            if (res.success) { toast('تم الحذف'); loadLookups(type); }
            else toast(res.message || 'حدث خطأ', false);
        });
    });
}

document.getElementById('btnSaveLookup').addEventListener('click', async () => {
    const id    = document.getElementById('lookupId').value;
    const type  = document.getElementById('lookupType').value;
    const nameAr = document.getElementById('lookupNameAr').value.trim();
    if (!nameAr) { alert('الاسم بالعربية مطلوب'); return; }

    const res = await postJson('/AdvancedWorkspace/SaveLookup', {
        id: id || null, type,
        nameAr, nameEn: document.getElementById('lookupNameEn').value.trim(),
        isActive: document.getElementById('lookupIsActive').checked
    });
    if (res.success) {
        bootstrap.Modal.getInstance(document.getElementById('modalLookup'))?.hide();
        toast('تم الحفظ بنجاح');
        loadLookups(type);
    } else toast(res.message || 'حدث خطأ', false);
});


@model InfrastructureManagmentWebFramework.Models.Charity.AidCycles.AddAidCycleBeneficiariesVm
@{
    ViewData["Title"] = "إضافة مستحقين إلى الدورة";
}

<div class="card">
    <div class="card-body">
        <h4 class="mb-1">إضافة مستحقين إلى الدورة</h4>
        <div class="text-muted mb-3">@Model.AidCycleTitle</div>

        <form asp-action="Add" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="AidCycleId" type="hidden" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label asp-for="ApprovedAmount" class="form-label">المبلغ الافتراضي</label>
                    <input asp-for="ApprovedAmount" class="form-control" />
                </div>
                <div class="col-md-9">
                    <label asp-for="Notes" class="form-label">ملاحظات</label>
                    <input asp-for="Notes" class="form-control" />
                </div>
            </div>

            <div class="alert alert-info small">
                تظهر هنا فقط الحالات التي لديها <strong>قرار لجنة معتمد</strong>، وإذا كانت الدورة مرتبطة بنوع مساعدة محدد فسيتم إظهار الحالات المطابقة لهذا النوع فقط.
            </div>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead>
                        <tr>
                            <th style="width:50px;"><input type="checkbox" id="check-all" /></th>
                            <th>الكود</th>
                            <th>الاسم</th>
                            <th>الرقم القومي</th>
                            <th>الهاتف</th>
                            <th>الحالة</th>
                            <th>نوع المساعدة</th>
                            <th>القيمة المعتمدة</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td><input type="checkbox" name="SelectedBeneficiaryIds" value="@item.BeneficiaryId" /></td>
                                <td>@item.Code</td>
                                <td>@item.FullName</td>
                                <td>@item.NationalId</td>
                                <td>@item.PhoneNumber</td>
                                <td>@item.StatusName</td>
                                <td>@item.AidType</td>
                                <td>@item.ApprovedAmount?.ToString("n2")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">لا يوجد مستحقون متاحون للإضافة للدورة الحالية.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">إضافة المحدد</button>
                <a asp-action="Index" asp-route-aidCycleId="@Model.AidCycleId" class="btn btn-light">رجوع</a>
            </div>
        </form>
    </div>
</div>

@section Scripts{
<script>
document.getElementById('check-all')?.addEventListener('change', function(){
    document.querySelectorAll('input[name="SelectedBeneficiaryIds"]').forEach(cb => cb.checked = this.checked);
});
</script>
}

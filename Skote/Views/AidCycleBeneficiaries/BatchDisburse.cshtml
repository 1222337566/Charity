@using Skote.Helpers
@model InfrastructureManagmentWebFramework.Models.Charity.AidCycles.AidCycleBatchDisbursementVm
@{
    var canManageAidOps = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.AidDisbursementManage);
}

<partial name="~/Views/Shared/AidCycles/_AidCycleHeader.cshtml" />

<h4 class="mb-3">صرف جماعي لدورة الصرف</h4>
@if (!canManageAidOps)
{
    <div class="alert alert-warning">هذه الشاشة مخصصة للأدمن أو المحاسب فقط.</div>
}
<form asp-action="BatchDisburse" method="post">
    <input asp-for="AidCycleId" type="hidden" />
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label asp-for="DisbursementDate" class="form-label"></label>
            <input asp-for="DisbursementDate" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="PaymentMethodId" class="form-label"></label>
            <select asp-for="PaymentMethodId" asp-items="Model.PaymentMethods" class="form-select">
                <option value="">-- اختر --</option>
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="FinancialAccountId" class="form-label"></label>
            <select asp-for="FinancialAccountId" asp-items="Model.FinancialAccounts" class="form-select">
                <option value="">-- اختر --</option>
            </select>
        </div>
        <div class="col-md-12">
            <label asp-for="Notes" class="form-label"></label>
            <input asp-for="Notes" class="form-control" />
        </div>
    </div>

    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <th style="width:40px"></th>
                <th>الكود</th>
                <th>الاسم</th>
                <th>القيمة</th>
                <th>الحالة</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.EligibleLines.Count; i++)
        {
            <tr>
                <td>
                    <input type="checkbox" name="SelectedLineIds" value="@Model.EligibleLines[i].Id" checked />
                </td>
                <td>@Model.EligibleLines[i].BeneficiaryCode</td>
                <td>@Model.EligibleLines[i].BeneficiaryName</td>
                <td>@(Model.EligibleLines[i].ApprovedAmount?.ToString("n2"))</td>
                <td>@Model.EligibleLines[i].Status</td>
            </tr>
        }
        </tbody>
    </table>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">تنفيذ الصرف</button>
        <a asp-action="Index" asp-route-aidCycleId="@Model.AidCycleId" class="btn btn-light">رجوع</a>
    </div>
</form>

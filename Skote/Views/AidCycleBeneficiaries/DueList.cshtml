@model List<InfrastructureManagmentWebFramework.Models.Charity.AidCycles.AidCycleBeneficiaryListItemVm>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-1">قائمة الاستحقاق القادمة</h3>
        <div class="text-muted">مستوحاة من شاشات lastdate / helped / not_helped في المشروع القديم</div>
    </div>
    <form method="get" class="d-flex gap-2">
        <input type="date" name="dueDate" value="@ViewBag.DueDate" class="form-control" />
        <button type="submit" class="btn btn-primary">عرض</button>
    </form>
</div>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>الكود</th>
            <th>الاسم</th>
            <th>نوع المساعدة</th>
            <th>القيمة</th>
            <th>آخر صرف</th>
            <th>الاستحقاق القادم</th>
            <th>الحالة</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.BeneficiaryCode</td>
            <td>@item.BeneficiaryName</td>
            <td>@item.AidType</td>
            <td>@(item.ApprovedAmount?.ToString("n2"))</td>
            <td>@item.LastDisbursementDate?.ToString("yyyy-MM-dd")</td>
            <td>@item.NextDueDate?.ToString("yyyy-MM-dd")</td>
            <td>@item.Status</td>
        </tr>
    }
    </tbody>
</table>

@model InfrastructureManagmentWebFramework.Models.Charity.AidCycles.EditAidCycleBeneficiaryVm

<partial name="~/Views/Shared/AidCycles/_AidCycleHeader.cshtml" />

<h4 class="mb-3">تعديل مستحق داخل الدورة</h4>
<form asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="AidCycleId" type="hidden" />
    <div class="row g-3">
        <div class="col-md-12">
            <label class="form-label">المستفيد</label>
            <input class="form-control" value="@Model.BeneficiaryDisplay" disabled />
        </div>
        <div class="col-md-3">
            <label asp-for="ScheduledAmount" class="form-label"></label>
            <input asp-for="ScheduledAmount" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="ApprovedAmount" class="form-label"></label>
            <input asp-for="ApprovedAmount" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="LastDisbursementDate" class="form-label"></label>
            <input asp-for="LastDisbursementDate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="NextDueDate" class="form-label"></label>
            <input asp-for="NextDueDate" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                <option value="Eligible">مستحق</option>
                <option value="Deferred">مؤجل</option>
                <option value="Disbursed">تم الصرف</option>
                <option value="Stopped">موقوف</option>
                <option value="Cancelled">ملغي</option>
            </select>
        </div>
        <div class="col-md-8">
            <label asp-for="StopReason" class="form-label"></label>
            <input asp-for="StopReason" class="form-control" />
        </div>
        <div class="col-md-12">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">حفظ</button>
        <a asp-action="Index" asp-route-aidCycleId="@Model.AidCycleId" class="btn btn-light">رجوع</a>
    </div>
</form>

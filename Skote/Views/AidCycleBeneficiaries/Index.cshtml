@using Skote.Helpers
@model List<InfrastructureManagmentWebFramework.Models.Charity.AidCycles.AidCycleBeneficiaryListItemVm>
@{
    var canManageAidOps = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.AidDisbursementManage);
}
@if (ViewBag.AidCycleId != null && canManageAidOps)
{
    <div class="mb-3">
        <a asp-controller="AidCycleBeneficiaries"
           asp-action="Add"
           asp-route-aidCycleId="@ViewBag.AidCycleId"
           class="btn btn-primary">
            إضافة مستحقين
        </a>
    </div>
}
<partial name="~/Views/Shared/AidCycles/_AidCycleHeader.cshtml" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">المستحقون داخل الدورة</h4>
    <div class="d-flex gap-2">
        @if (canManageAidOps)
        {
            <a asp-action="BatchDisburse" asp-route-aidCycleId="@ViewBag.AidCycleId" class="btn btn-primary">صرف جماعي</a>
        }
        <a asp-action="DueList" class="btn btn-outline-secondary">قائمة الاستحقاق</a>
    </div>
</div>

<table class="table table-bordered table-hover align-middle">
    <thead>
        <tr>
            <th>الكود</th>
            <th>الاسم</th>
            <th>نوع المساعدة</th>
            <th>القيمة</th>
            <th>الحالة</th>
            <th>أضيف بواسطة</th>
            <th>تاريخ الإضافة</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.BeneficiaryCode</td>
            <td>@item.BeneficiaryName</td>
            <td>@item.AidType</td>
            <td>@(item.ApprovedAmount?.ToString("n2"))</td>
            <td>@item.Status</td>
            <td>@item.AddedByUserId</td>
            <td>@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
            <td>
                @if (canManageAidOps)
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a>
                }
                else
                {
                    <span class="text-muted">عرض فقط</span>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

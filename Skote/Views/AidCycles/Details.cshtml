@using Skote.Helpers
@model InfrastrfuctureManagmentCore.Domains.Charity.AidCycles.AidCycle

@{
    var canManageAidOps = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.AidDisbursementManage);
    ViewBag.AidCycleId = Model.Id;
    ViewBag.AidCycleNumber = Model.CycleNumber;
    ViewBag.AidCycleTitle = Model.Title;
    ViewBag.AidCycleStatus = Model.Status;
}

<partial name="~/Views/Shared/AidCycles/_AidCycleHeader.cshtml" />

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card"><div class="card-body">
            <h5>بيانات الدورة</h5>
            <div>نوع الدورة: <strong>@Model.CycleType</strong></div>
            <div>نوع المساعدة: <strong>@(Model.AidType?.NameAr ?? "حسب القرار")</strong></div>
            <div>الفترة: <strong>@Model.PeriodYear / @Model.PeriodMonth</strong></div>
            <div>الصرف المخطط: <strong>@Model.PlannedDisbursementDate.ToString("yyyy-MM-dd")</strong></div>
            <div>المستحقون: <strong>@Model.BeneficiariesCount</strong></div>
            <div>إجمالي مخطط: <strong>@(Model.TotalPlannedAmount?.ToString("n2"))</strong></div>
            <div>إجمالي مصروف: <strong>@(Model.TotalDisbursedAmount?.ToString("n2"))</strong></div>
            <hr />
            <div>@Model.Notes</div>
        </div></div>
    </div>
    <div class="col-lg-8">
        <div class="card"><div class="card-body">
            <div class="d-flex gap-2 flex-wrap mb-3">
                @if (canManageAidOps)
                {
                    <form asp-action="Generate" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-outline-primary">توليد المستحقين</button>
                    </form>
                    <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-outline-success">اعتماد الدورة</button>
                    </form>
                    <form asp-action="Close" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-outline-danger">إغلاق الدورة</button>
                    </form>
                }
                <a asp-controller="AidCycleBeneficiaries" asp-action="Index" asp-route-aidCycleId="@Model.Id" class="btn btn-primary">المستحقون</a>
            </div>
            <h5 class="mb-3">ملخص المستحقين</h5>
            <table class="table table-sm table-bordered">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>النوع</th>
                        <th>القيمة</th>
                        <th>الحالة</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Beneficiaries.Take(10))
                {
                    <tr>
                        <td>@item.Beneficiary?.Code</td>
                        <td>@item.Beneficiary?.FullName</td>
                        <td>@item.AidType?.NameAr</td>
                        <td>@((item.ApprovedAmount ?? item.ScheduledAmount)?.ToString("n2"))</td>
                        <td>@item.Status</td>
                    </tr>
                }
                </tbody>
            </table>
        </div></div>
    </div>
</div>

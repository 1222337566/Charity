@using Skote.Helpers
@model List<InfrastructureManagmentWebFramework.Models.Charity.AidCycles.AidCycleListItemVm>
@{
    var canManageAidOps = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.AidDisbursementManage);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-1">دورات الصرف</h3>
        <div class="text-muted">مستوحاة من التشغيل الفعلي بالمشروع القديم: monthlyHelp / allPay / lastdate</div>
    </div>
    @if (canManageAidOps)
    {
        <a asp-action="Create" class="btn btn-primary">إنشاء دورة صرف</a>
    }
</div>

<table class="table table-bordered table-hover align-middle">
    <thead>
        <tr>
            <th>رقم الدورة</th>
            <th>الاسم</th>
            <th>النوع</th>
            <th>المساعدة</th>
            <th>الفترة</th>
            <th>تاريخ الصرف</th>
            <th>الحالة</th>
            <th>المستحقون</th>
            <th>الإجمالي</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CycleNumber</td>
            <td>@item.Title</td>
            <td>@item.CycleType</td>
            <td>@item.AidType</td>
            <td>@(item.PeriodYear)-@(item.PeriodMonth)</td>
            <td>@item.PlannedDisbursementDate.ToString("yyyy-MM-dd")</td>
            <td>@item.Status</td>
            <td>@item.BeneficiariesCount</td>
            <td>@(item.TotalPlannedAmount?.ToString("n2"))</td>
            <td class="text-nowrap">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تفاصيل</a>
                @if (canManageAidOps)
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@model List<InfrastrfuctureManagmentCore.Domains.Charity.Lookups.AidTypeLookup>
@{
    ViewData["Title"] = "أنواع المساعدات";
}

<style>
    .at-hero {
        background: linear-gradient(135deg,#0a5659,#0e6f73);
        border-radius: 18px;
        padding: 20px 26px;
        color: #fff;
        margin-bottom: 20px
    }

    .at-card {
        background: #fff;
        border-radius: 16px;
        border: .5px solid rgba(14,111,115,.12);
        box-shadow: 0 2px 10px rgba(14,111,115,.05);
        overflow: hidden
    }

    .at-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 18px;
        border-bottom: .5px solid rgba(14,111,115,.06);
        transition: .12s
    }

        .at-row:last-child {
            border-bottom: none
        }

        .at-row:hover {
            background: rgba(14,111,115,.02)
        }

    .at-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0
    }

    .at-badge {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .7rem;
        font-weight: 700
    }

    .edit-form input, .edit-form select {
        border-radius: 8px;
        border: .5px solid rgba(14,111,115,.2);
        padding: 5px 10px;
        font-size: .82rem
    }

        .edit-form input:focus {
            outline: none;
            border-color: #0e6f73
        }

    .add-card {
        background: rgba(14,111,115,.04);
        border-radius: 16px;
        border: 1.5px dashed rgba(14,111,115,.25);
        padding: 20px;
        margin-bottom: 16px
    }

    /* Modal */
    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.4);
        z-index: 9999;
        align-items: center;
        justify-content: center
    }

        .modal-overlay.show {
            display: flex
        }

    .modal-box {
        background: #fff;
        border-radius: 20px;
        padding: 28px;
        width: 480px;
        max-width: 90vw
    }
</style>

<div class="at-hero">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h4 class="fw-bold mb-1 text-white"><i class="bx bx-heart me-2"></i>أنواع المساعدات</h4>
            <div style="opacity:.75;font-size:.82rem">
                إدارة أنواع المساعدات — نقدي، غذائي، شنطة رمضان، زكاة الفطر، تدريب...
            </div>
        </div>
        <span class="badge" style="background:rgba(255,255,255,.2);font-size:.85rem;padding:8px 16px">
            @Model.Count(x => x.IsActive) نوع نشط
        </span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">
        <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" style="border-radius:12px">
        <i class="bx bx-error-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── إضافة نوع جديد ── *@
<div class="add-card mb-3">
    <div class="fw-bold mb-3" style="color:#0a5f63;font-size:.92rem">
        <i class="bx bx-plus-circle me-2"></i>إضافة نوع مساعدة جديد
    </div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold" style="font-size:.8rem">اسم النوع بالعربي <span class="text-danger">*</span></label>
                <input name="nameAr" class="form-control" style="border-radius:10px"
                       placeholder="مثال: شنطة رمضان، زكاة الفطر، تدريب..." required />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold" style="font-size:.8rem">الاسم بالإنجليزي</label>
                <input name="nameEn" class="form-control" style="border-radius:10px"
                       placeholder="Ramadan Box, Zakat..." />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold" style="font-size:.8rem">الفئة</label>
                <select name="category" class="form-select" style="border-radius:10px;font-size:.84rem">
                    <option value="Financial">مالية</option>
                    <option value="InKind">عينية</option>
                    <option value="Service">خدمية</option>
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label fw-semibold" style="font-size:.8rem">الترتيب</label>
                <input name="displayOrder" type="number" value="99" min="1" max="999"
                       class="form-control" style="border-radius:10px" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary fw-bold w-100" style="border-radius:10px">
                    <i class="bx bx-plus me-1"></i>إضافة
                </button>
            </div>
        </div>
    </form>
</div>

@* ── قائمة الأنواع ── *@
<div class="at-card">
    <div style="padding:14px 18px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.88rem;font-weight:700;color:#0a5f63;display:flex;align-items:center;justify-content:space-between">
        <span><i class="bx bx-list-ul me-2"></i>الأنواع الحالية (@Model.Count)</span>
        <small style="color:#adb5bd;font-weight:400">انقر على الاسم للتعديل</small>
    </div>

    @foreach (var item in Model)
    {
        <div class="at-row" id="row-@item.Id">
            @* أيقونة الفئة *@
            <div class="at-icon" style="background:rgba(14,111,115,.08);color:#0e6f73;font-size:.9rem">
                💚
            </div>

            @* معلومات العرض *@
            <div class="flex-grow-1" id="display-@item.Id">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="fw-bold" style="font-size:.92rem">@item.NameAr</span>
                    @if (!string.IsNullOrWhiteSpace(item.NameEn))
                    {
                        <span style="font-size:.75rem;color:#adb5bd">@item.NameEn</span>
                    }
                    <span class="at-badge" style="background:@(item.Category=="Financial"?"rgba(14,111,115,.1)":item.Category=="InKind"?"rgba(52,195,143,.1)":"rgba(241,180,76,.1)");color:@(item.Category=="Financial"?"#0a5f63":item.Category=="InKind"?"#065f46":"#92400e")">
                        @(item.Category switch { "Financial" => "مالية", "InKind" => "عينية", "Service" => "خدمية", _ => item.Category })
                    </span>
                    @if (!item.IsActive)
                    {
                        <span class="at-badge" style="background:#fee2e2;color:#991b1b">معطّل</span>
                    }
                    else
                    {
                        <span class="at-badge" style="background:#d1fae5;color:#065f46">نشط</span>
                    }
                </div>
                <div class="d-flex gap-2 flex-wrap mt-2">
                    <a asp-controller="BeneficiaryAidRequests" asp-action="Index"
                       asp-route-aidTypeId="@item.Id"
                       class="btn btn-sm fw-semibold"
                       style="border-radius:8px;background:rgba(14,111,115,.08);color:#0e6f73;border:.5px solid rgba(14,111,115,.15);font-size:.75rem">
                        <i class="bx bx-list-ul me-1"></i>طلبات المساعدة
                    </a>
                    <a asp-controller="BeneficiaryAidDisbursements" asp-action="Index"
                       asp-route-aidTypeId="@item.Id"
                       class="btn btn-sm fw-semibold"
                       style="border-radius:8px;background:rgba(52,195,143,.08);color:#065f46;border:.5px solid rgba(52,195,143,.15);font-size:.75rem">
                        <i class="bx bx-receipt me-1"></i>سجل الصرف
                    </a>
                </div>
            </div>

            @* نموذج التعديل — مخفي ──*@
            <form asp-action="Edit" method="post" class="edit-form d-none align-items-center gap-2 flex-grow-1"
                  id="edit-@item.Id">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@item.Id" />
                <input name="nameAr" value="@item.NameAr" placeholder="اسم النوع" required
                       style="flex:1;min-width:130px" />
                <input name="nameEn" value="@item.NameEn" placeholder="English"
                       style="width:120px" />
                <input name="displayOrder" type="number" value="@item.DisplayOrder"
                       style="width:65px;text-align:center" />
                <select name="IsActive" style="width:90px;border-radius:8px;border:.5px solid rgba(14,111,115,.2);padding:5px 8px;font-size:13px">
                    <option value="true" selected="@(item.IsActive ? "selected" : null)">نشط</option>
                    <option value="false" selected="@(!item.IsActive ? "selected" : null)">معطل</option>
                </select>
                <button type="submit" class="btn btn-sm btn-success fw-bold" style="border-radius:8px">حفظ</button>
                <button type="button" class="btn btn-sm btn-light" style="border-radius:8px"
                        onclick="cancelEdit('@item.Id')">
                    إلغاء
                </button>
            </form>

            @* أزرار الإجراء *@
            <div class="d-flex gap-2" id="actions-@item.Id">
                <button type="button" class="btn btn-sm fw-semibold"
                        style="border-radius:8px;background:rgba(14,111,115,.08);color:#0e6f73;border:none;font-size:.75rem"
                        onclick="startEdit('@item.Id')">
                    <i class="bx bx-edit"></i>
                </button>

                <form asp-action="Toggle" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id" />
                    <button type="submit" class="btn btn-sm fw-semibold"
                            style="border-radius:8px;background:@(item.IsActive ? "rgba(244,106,106,.1)" : "rgba(52,195,143,.1)");color:@(item.IsActive ? "#f46a6a" : "#34c38f");border:none;font-size:.75rem"
                            title="@(item.IsActive ? "تعطيل" : "تفعيل")">
                        <i class="bx @(item.IsActive ? "bx-toggle-right" : "bx-toggle-left")"></i>
                    </button>
                </form>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5" style="font-size:.88rem">
            <i class="bx bx-heart" style="font-size:2.5rem;color:#d1fae5;display:block;margin-bottom:10px"></i>
            لا توجد أنواع مساعدات — أضف أول نوع من الحقل أعلاه
        </div>
    }
</div>

@* أمثلة سريعة *@
<div class="mt-3" style="background:rgba(14,111,115,.05);border-radius:12px;padding:14px 18px">
    <div class="fw-semibold mb-2" style="font-size:.82rem;color:#0a5f63">
        <i class="bx bx-bulb me-1"></i>أمثلة للإضافة السريعة:
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @foreach (var ex in new[] {
        ("شنطة رمضان","Ramadan Box"),("زكاة الفطر","Zakat Al-Fitr"),
        ("مساعدة غذائية","Food Aid"),("دورة تدريبية","Training"),
        ("أضحية","Udhiyah"),("كسوة العيد","Eid Clothes"),
        ("مصاريف دراسية","School Fees"),("علاج طارئ","Emergency Medical")
        })
        {
            <button type="button"
                    class="btn btn-sm"
                    style="border-radius:20px;background:#fff;border:.5px solid rgba(14,111,115,.2);color:#0a5f63;font-size:.76rem"
                    onclick="quickAdd('@ex.Item1','@ex.Item2')">
                + @ex.Item1
            </button>
        }
    </div>
</div>

@section Scripts {
    <script>
        function startEdit(id) {
            document.getElementById('display-' + id).classList.add('d-none');
            document.getElementById('actions-' + id).classList.add('d-none');
            var ef = document.getElementById('edit-' + id);
            ef.classList.remove('d-none');
            ef.classList.add('d-flex');
        }
        function cancelEdit(id) {
            document.getElementById('display-' + id).classList.remove('d-none');
            document.getElementById('actions-' + id).classList.remove('d-none');
            var ef = document.getElementById('edit-' + id);
            ef.classList.add('d-none');
            ef.classList.remove('d-flex');
        }
        function quickAdd(ar, en) {
            document.querySelector('[name="nameAr"]').value = ar;
            document.querySelector('[name="nameEn"]').value = en;
            document.querySelector('[name="nameAr"]').focus();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
}

@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "~/Views/Shared/_BlankLayout.cshtml";
}

<div class="container joud-auth-shell py-4">
    <div class="row g-0 joud-auth-grid w-100">
        <div class="col-lg-5 d-none d-lg-block">
            <div class="joud-brand-panel h-100">
                <div class="joud-brand-content">
                    <div class="joud-brand-badge">
                        <img src="~/assets/images/joud/joud-square-logo.svg" alt="Joud Charity" />
                        <div>
                            <strong>جود الخيري</strong><br />
                            <small>Joud Charity</small>
                        </div>
                    </div>
                    <h1 class="joud-brand-title">نظام إدارة رقمي ذكي للجمعية</h1>
                    <p class="joud-brand-subtitle">
                        هذه شاشة دخول بديلة متناسقة مع هوية جود الخيري في حال استخدام مسار Auth/Login داخل المشروع.
                    </p>
                    <ul class="joud-brand-list">
                        <li><i class="bx bx-check-circle"></i><span>هوية موحدة في الـ login وfavicon والصفحات الأساسية.</span></li>
                        <li><i class="bx bx-check-circle"></i><span>ألوان teal + gold مستوحاة من الشعار.</span></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-7 bg-white">
            <div class="joud-auth-form-wrap d-flex align-items-center justify-content-center h-100">
                <div class="w-100" style="max-width:420px;">
                    <div class="joud-auth-logo">
                        <img src="~/assets/images/joud/joud-square-logo.svg" alt="Joud Charity" />
                        <div>
                            <h2>تسجيل الدخول</h2>
                            <p>استخدم هذه الصفحة إذا كان المسار الفعلي عندك هو Auth/Login.</p>
                        </div>
                    </div>
                    <div class="joud-form-card text-center">
                        <p class="mb-3">هذه الواجهة جاهزة ويمكنك ربطها بمسار الدخول الفعلي أو إبقاؤها كصفحة تحويل.</p>
                        <a class="btn joud-btn-primary w-100" href="@Url.Action("Login", "Account")">الانتقال إلى صفحة الدخول الفعلية</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

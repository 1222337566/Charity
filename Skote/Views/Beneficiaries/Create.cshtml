@model InfrastructureManagmentWebFramework.Models.Charity.Beneficiaries.CreateBeneficiaryVm
@{
    ViewData["Title"] = "إضافة مستفيد";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">إضافة مستفيد</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <partial name="_Form" model="Model" />
                <button type="submit" class="btn btn-primary">حفظ</button>
                <a asp-action="Index" class="btn btn-secondary">رجوع</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

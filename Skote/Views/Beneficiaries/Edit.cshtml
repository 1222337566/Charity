@model InfrastructureManagmentWebFramework.Models.Charity.Beneficiaries.EditBeneficiaryVm
@{
    ViewData["Title"] = "تعديل مستفيد";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">تعديل مستفيد</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <partial name="_Form" model="Model" />
                <div class="form-check form-switch mb-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
                <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">رجوع</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

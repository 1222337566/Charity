@using InfrastructureManagmentWebFramework.Models.Charity.Beneficiaries
@using Skote.Helpers
@model BeneficiaryListPageVm
@{
    ViewData["Title"] = "المستفيدون";
}

@* ═══════════════════════════════════════════════════
    CSS & Libraries
═══════════════════════════════════════════════════ *@
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/searchpanes/2.3.0/css/searchPanes.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/fixedheader/3.4.0/css/fixedHeader.bootstrap5.min.css" />

<style>
    :root {
        --primary:   #2563eb;
        --primary-light: #eff6ff;
        --success:   #16a34a;
        --danger:    #dc2626;
        --warning:   #d97706;
        --surface:   #ffffff;
        --border:    #e2e8f0;
        --text-muted:#64748b;
        --radius:    10px;
    }

    /* ── Stats Cards ── */
    .stat-card {
        border: none;
        border-radius: var(--radius);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 1px 4px rgba(0,0,0,.07);
        transition: transform .18s, box-shadow .18s;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 6px 18px rgba(0,0,0,.1); }
    .stat-icon {
        width: 52px; height: 52px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center; font-size: 1.5rem; flex-shrink: 0;
    }
    .stat-card.total  { background: linear-gradient(135deg,#eff6ff,#dbeafe); }
    .stat-card.active { background: linear-gradient(135deg,#f0fdf4,#dcfce7); }
    .stat-card.approved { background: linear-gradient(135deg,#fefce8,#fef9c3); }
    .stat-card.total  .stat-icon { background:#2563eb22; color:#2563eb; }
    .stat-card.active .stat-icon { background:#16a34a22; color:#16a34a; }
    .stat-card.approved .stat-icon { background:#d9770622; color:#d97706; }
    .stat-label { font-size: .82rem; color: var(--text-muted); margin-bottom: .2rem; }
    .stat-value { font-size: 1.75rem; font-weight: 700; line-height: 1; color: #1e293b; }

    /* ── Card ── */
    .main-card { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
    .main-card .card-header {
        background: #fff; border-bottom: 1px solid var(--border);
        border-radius: 14px 14px 0 0; padding: 1rem 1.5rem;
    }

    /* ── Search area ── */
    .search-area {
        background: var(--primary-light);
        border: 1px solid #bfdbfe;
        border-radius: var(--radius);
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.25rem;
    }
    .search-area .form-label { font-size: .8rem; font-weight: 600; color: #1e3a8a; margin-bottom: .35rem; }

    /* ── Autocomplete dropdown ── */
    #autocomplete-list {
        position: absolute; z-index: 1000; width: 100%;
        background: #fff; border: 1px solid #bfdbfe;
        border-top: none; border-radius: 0 0 8px 8px;
        box-shadow: 0 6px 18px rgba(0,0,0,.1);
        max-height: 260px; overflow-y: auto;
        display: none;
    }
    #autocomplete-list .ac-item {
        padding: .55rem .9rem; cursor: pointer;
        display: flex; align-items: center; gap: .6rem;
        font-size: .88rem; border-bottom: 1px solid #f1f5f9;
        transition: background .12s;
    }
    #autocomplete-list .ac-item:last-child { border-bottom: none; }
    #autocomplete-list .ac-item:hover, #autocomplete-list .ac-item.active { background: #eff6ff; }
    #autocomplete-list .ac-item .ac-code { font-size: .75rem; color: var(--text-muted); }
    #autocomplete-list .ac-item mark { background: #bfdbfe; border-radius: 3px; padding: 0 2px; }
    .search-wrapper { position: relative; }
    #searchInput { padding-left: 2.4rem !important; }
    .search-icon-inside { position: absolute; left: .75rem; top: 50%; transform: translateY(-50%); color: #93c5fd; pointer-events: none; }

    /* ── Table ── */
    #beneficiariesTable thead th {
        background: #f8fafc; font-size: .82rem; font-weight: 600;
        color: #475569; white-space: nowrap; vertical-align: middle;
    }
    #beneficiariesTable thead th.sorting:after,
    #beneficiariesTable thead th.sorting_asc:after,
    #beneficiariesTable thead th.sorting_desc:after { opacity: .8; }

    /* Per-column filter inputs */
    #beneficiariesTable tfoot th { padding: .4rem .5rem; }
    #beneficiariesTable tfoot th input,
    #beneficiariesTable tfoot th select {
        width: 100%; font-size: .76rem;
        border: 1px solid var(--border); border-radius: 6px;
        padding: .3rem .5rem; outline: none;
        transition: border-color .15s;
    }
    #beneficiariesTable tfoot th input:focus,
    #beneficiariesTable tfoot th select:focus { border-color: #93c5fd; }

    .badge-active   { background: #dcfce7; color: #166534; font-size: .73rem; padding: .25em .6em; border-radius: 20px; }
    .badge-inactive { background: #fee2e2; color: #991b1b; font-size: .73rem; padding: .25em .6em; border-radius: 20px; }
    .badge-status   { background: #f1f5f9; color: #475569; font-size: .73rem; padding: .25em .6em; border-radius: 20px; }

    /* Action buttons */
    .btn-action { padding: .28rem .7rem; font-size: .78rem; border-radius: 6px; }

    /* DataTables override */
    div.dataTables_wrapper div.dataTables_filter { display: none; } /* we have custom search */
    div.dataTables_length select { border-radius: 6px !important; border-color: var(--border) !important; }
    div.dataTables_info { font-size: .82rem; color: var(--text-muted); }
    .dt-buttons .btn { font-size: .8rem; border-radius: 6px; }

    /* Date range row */
    .date-range-row { display: flex; gap: .6rem; align-items: center; flex-wrap: wrap; }
    .date-range-row input[type=date] { font-size: .82rem; padding: .35rem .6rem; border: 1px solid var(--border); border-radius: 7px; }
    .date-range-row input[type=date]:focus { outline: none; border-color: #93c5fd; }
</style>

@* ══════════════════════════════════════════════════════ *@

<div class="container-fluid">

  
    <div class="row g-3 mb-4">
        <div class="col-xl-4 col-md-6">
            <div class="stat-card total">
                <div class="stat-icon"><i class="ri-group-line"></i></div>
                <div>
                    <div class="stat-label">إجمالي المستفيدين</div>
                    <div class="stat-value">@Model.TotalCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="stat-card active">
                <div class="stat-icon"><i class="ri-user-follow-line"></i></div>
                <div>
                    <div class="stat-label">المستفيدون النشطون</div>
                    <div class="stat-value">@Model.ActiveCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="stat-card approved">
                <div class="stat-icon"><i class="ri-file-check-line"></i></div>
                <div>
                    <div class="stat-label">الملفات المعتمدة</div>
                    <div class="stat-value">@Model.ApprovedCount</div>
                </div>
            </div>
        </div>
    </div>

   
    <div class="card main-card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="ri-list-check-3 me-2 text-primary"></i>قائمة المستفيدين</h5>
            <authz policy="BeneficiariesManage">
                <a asp-action="Create" class="btn btn-primary btn-sm">
                    <i class="ri-user-add-line me-1"></i> إضافة مستفيد
                </a>
            </authz>
        </div>

        <div class="card-body">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="ri-checkbox-circle-line me-1"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form method="get" class="row g-3 mb-3">
            <div class="search-area">
                <div class="row g-2 align-items-end">

                   
                    <div class="col-md-5">
                        <label class="form-label"><i class="ri-search-line me-1"></i>بحث سريع</label>
                        <div class="search-wrapper">
                            <span class="search-icon-inside"><i class="ri-search-line"></i></span>
                            <input name="q" id="searchInput" type="text"
                                   class="form-control"
                                   placeholder="ابحث بالاسم / الكود / الرقم القومي / الهاتف..."
                                   autocomplete="off"
                                   value="@Model.Filter.Q" />
                            <div id="autocomplete-list"></div>
                        </div>
                    </div>

                  
                    <div class="col-md-3">
                        <label class="form-label"><i class="ri-folder-line me-1"></i>حالة الملف</label>
                            <select name="statusId"  @* id="filterStatus" *@ class="form-select form-select-sm">
                                <option value="">الكل</option>
                                @foreach (var status in Model.Filter.Statuses)
                                {
                                    if (Model.Filter.StatusId?.ToString() == status.Value)
                                    {
                                        <option value="@status.Value" selected>@status.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@status.Value">@status.Text</option>
                                    }
                                }
                        </select>
                    </div>

                  
                    <div class="col-md-2">
                        <label class="form-label"><i class="ri-toggle-line me-1"></i>الحالة</label>
                            <select name="isActive" @* id="filterActive" *@ class="form-select form-select-sm">
                                <option value="">الكل</option>
                                <option value="true" selected="@(Model.Filter.IsActive == true ? "selected" : null)">نشط</option>
                                <option value="false" selected="@(Model.Filter.IsActive == false ? "selected" : null)">غير نشط</option>
                        </select>
                    </div>

             
                    <div class="col-md-2">
                        <button id="btnReset" class="btn btn-outline-secondary btn-sm w-100">
                            <i class="ri-refresh-line me-1"></i>إعادة ضبط
                        </button>
                    </div>
                </div>

             
                <div class="mt-2 date-range-row">
                    <label class="form-label mb-0"><i class="ri-calendar-line me-1"></i>تاريخ التسجيل من</label>
                    <input type="date" id="dateFrom" />
                    <label class="form-label mb-0">إلى</label>
                    <input type="date" id="dateTo" />
                        <button @* id="btnDateFilter" *@ type="submit" class="btn btn-primary btn-sm">
                        <i class="ri-filter-line me-1"></i>تصفية
                    </button>
                </div>
            </div>
            </form>
          
            <div class="table-responsive">
                <table id="beneficiariesTable"
                       class="table table-bordered table-hover align-middle w-100"
                       data-url="@Url.Action("SearchAutocomplete", "Beneficiaries")">
                    <thead>
                        <tr>
                            <th>الكود</th>
                            <th>الاسم</th>
                            <th>الرقم القومي</th>
                            <th>الهاتف</th>
                            <th>المحافظة</th>
                            <th>حالة الملف</th>
                            <th>الحالة</th>
                            <th>تاريخ التسجيل</th>
                            <th class="no-sort">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Rows)
                        {
                            <tr>
                                <td>@item.Code</td>
                                <td>@item.FullName</td>
                                <td>@(item.NationalId ?? "-")</td>
                                <td>@(item.PhoneNumber ?? "-")</td>
                                <td>@(item.GovernorateName ?? "-")</td>
                                <td><span class="badge-status">@(item.StatusText ?? "-")</span></td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-active">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">غير نشط</span>
                                    }
                                </td>
                                <td data-order="@item.RegistrationDate.ToString("yyyy-MM-dd")">
                                    @item.RegistrationDate.ToString("yyyy-MM-dd")
                                </td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-info btn-action">
                                            <i class="ri-eye-line me-1"></i>الملف
                                        </a>
                                        <authz policy="BeneficiariesManage">
                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-primary btn-action">
                                                <i class="ri-edit-line me-1"></i>تعديل
                                            </a>
                                        </authz>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th><input type="text"  placeholder="فلتر الكود" /></th>
                            <th><input type="text"  placeholder="فلتر الاسم" /></th>
                            <th><input type="text"  placeholder="فلتر الرقم القومي" /></th>
                            <th><input type="text"  placeholder="فلتر الهاتف" /></th>
                            <th><input type="text"  placeholder="فلتر المحافظة" /></th>
                            <th><input type="text"  placeholder="فلتر الحالة" /></th>
                            <th>
                                <select>
                                    <option value="">الكل</option>
                                    <option value="نشط">نشط</option>
                                    <option value="غير نشط">غير نشط</option>
                                </select>
                            </th>
                            <th><input type="text"  placeholder="مثال: 2024" /></th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>

        </div>
    </div>

</div>

@* ═══════════════════════════════════════════════════
    Scripts
═══════════════════════════════════════════════════ *@
@section Scripts {
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
<script src="https://cdn.datatables.net/fixedheader/3.4.0/js/dataTables.fixedHeader.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

<script>
$(function () {

    // ─────────────────────────────────────────────
    //  1. DataTable init
    // ─────────────────────────────────────────────
    var table = $('#beneficiariesTable').DataTable({
        language: {
            url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/ar.json'
        },
        order: [[7, 'desc']],          // sort by date desc by default
        pageLength: 25,
                lengthMenu: [[10, 25, 50, 100,-1],[10,25,50,100,'الكل']],
        fixedHeader: true,
        columnDefs: [
            { orderable: false, targets: -1 },   // no sort on actions col
            { type: 'date', targets: 7 }          // date column
        ],
        dom:
            "<'row align-items-center mb-2'" +
                "<'col-sm-6'l>" +
                "<'col-sm-6 text-end'B>" +
            ">" +
            "<'row'<'col-12'tr>>" +
            "<'row mt-2'<'col-sm-5'i><'col-sm-7'p>>",
        buttons: [
            {
                extend: 'excelHtml5',
                text: '<i class="ri-file-excel-line me-1"></i>Excel',
                className: 'btn btn-sm btn-outline-success',
                title: 'قائمة المستفيدين',
                exportOptions: { columns: ':not(:last-child)' }
            },
            {
                extend: 'pdfHtml5',
                text: '<i class="ri-file-pdf-line me-1"></i>PDF',
                className: 'btn btn-sm btn-outline-danger',
                title: 'قائمة المستفيدين',
                exportOptions: { columns: ':not(:last-child)' }
            },
            {
                extend: 'print',
                text: '<i class="ri-printer-line me-1"></i>طباعة',
                className: 'btn btn-sm btn-outline-secondary',
                exportOptions: { columns: ':not(:last-child)' }
            },
            {
                extend: 'copy',
                text: '<i class="ri-clipboard-line me-1"></i>نسخ',
                className: 'btn btn-sm btn-outline-info',
                exportOptions: { columns: ':not(:last-child)' }
            }
        ]
    });

    // ─────────────────────────────────────────────
    //  2. Per-column footer filters
    // ─────────────────────────────────────────────
    table.columns().every(function () {
        var col = this;
        $('input, select', this.footer()).on('keyup change', function () {
            if (col.search() !== this.value) {
                col.search(this.value).draw();
            }
        });
    });

    // ─────────────────────────────────────────────
    //  3. Top search bar → global filter
    // ─────────────────────────────────────────────
    var searchTimer;
    $('#searchInput').on('keyup', function () {
        clearTimeout(searchTimer);
        var val = $(this).val();
        searchTimer = setTimeout(function () {
            table.search(val).draw();
        }, 250);
    });

    // ─────────────────────────────────────────────
    //  4. Status & Active dropdowns
    // ─────────────────────────────────────────────
    $('#filterStatus').on('change', function () {
        table.column(5).search($(this).val()).draw();
    });
    $('#filterActive').on('change', function () {
        table.column(6).search($(this).val()).draw();
    });

    // ─────────────────────────────────────────────
    //  5. Date range filter (custom)
    // ─────────────────────────────────────────────
    $.fn.dataTable.ext.search.push(function (settings, data) {
        if (settings.nTable.id !== 'beneficiariesTable') return true;
        var from = $('#dateFrom').val();
        var to   = $('#dateTo').val();
        var rowDate = data[7]; // col index 7 = تاريخ التسجيل
        if (!from && !to) return true;
        if (from && rowDate < from) return false;
        if (to   && rowDate > to)   return false;
        return true;
    });
    $('#btnDateFilter').on('click', function () { table.draw(); });

    // ─────────────────────────────────────────────
    //  6. Reset all filters
    // ─────────────────────────────────────────────
    $('#btnReset').on('click', function () {
        $('#searchInput').val('');
        $('#filterStatus').val('');
        $('#filterActive').val('');
        $('#dateFrom').val('');
        $('#dateTo').val('');
        $('#beneficiariesTable tfoot input').val('');
        $('#beneficiariesTable tfoot select').val('');
        table.search('').columns().search('').draw();
    });

    // ─────────────────────────────────────────────
    //  7. Autocomplete
    //     Calls /Beneficiaries/SearchAutocomplete?q=...
    //     Expects JSON: [{id,code,fullName,nationalId,phone}]
    //     Falls back gracefully if endpoint doesn't exist yet.
    // ─────────────────────────────────────────────
    var acTimer, acXhr;
    var autocompleteUrl = $('#beneficiariesTable').data('url') || '';
    var $acList = $('#autocomplete-list');

    function highlight(text, query) {
        if (!query) return text;
        var re = new RegExp('(' + query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        return text.replace(re, '<mark>$1</mark>');
    }

    function showAutoComplete(items, q) {
        $acList.empty();
        if (!items.length) { $acList.hide(); return; }
        items.forEach(function (item) {
            var $el = $('<div class="ac-item">')
                .html(
                    '<div>' +
                        '<div>' + highlight(item.fullName || '', q) + '</div>' +
                        '<div class="ac-code">' + (item.code || '') + ' • ' + (item.nationalId || '') + '</div>' +
                    '</div>'
                )
                .on('mousedown', function (e) {
                    e.preventDefault(); // keep focus
                    $('#searchInput').val(item.fullName || item.code || '');
                    $acList.hide();
                    table.search($('#searchInput').val()).draw();
                });
            $acList.append($el);
        });
        $acList.show();
    }

    $('#searchInput').on('input', function () {
        var q = $(this).val().trim();
        clearTimeout(acTimer);
        if (acXhr) acXhr.abort();
        if (q.length < 2) { $acList.hide(); return; }

        // first filter the DataTable immediately
        table.search(q).draw();

        if (!autocompleteUrl) return;

        acTimer = setTimeout(function () {
            acXhr = $.getJSON(autocompleteUrl, { q: q })
                .done(function (data) { showAutoComplete(data, q); })
                .fail(function () { $acList.hide(); });
        }, 300);
    });

    // keyboard navigation in autocomplete
    $('#searchInput').on('keydown', function (e) {
        var $items = $acList.find('.ac-item');
        var $active = $items.filter('.active');
        if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (!$active.length) $items.first().addClass('active');
            else { $active.removeClass('active'); $active.next('.ac-item').addClass('active'); }
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if ($active.length) { $active.removeClass('active'); $active.prev('.ac-item').addClass('active'); }
        } else if (e.key === 'Enter') {
            if ($active.length) { e.preventDefault(); $active.trigger('mousedown'); }
        } else if (e.key === 'Escape') {
            $acList.hide();
        }
    });

    $(document).on('click', function (e) {
        if (!$(e.target).closest('.search-wrapper').length) $acList.hide();
    });

});
</script>
}

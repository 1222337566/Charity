@using InfrastructureManagmentServices.Charity.Beneficiaries
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.AidDisbursements
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Shared
@model List<BeneficiaryAidDisbursementListItemVm>
@{
    ViewData["Title"] = "سجل الصرف";
    var filterTypeName        = ViewBag.FilterAidTypeName as string;
    var hasBeneficiaryContext = (bool?)ViewBag.HasBeneficiaryContext ?? false;
    var beneficiaryId         = ViewBag.BeneficiaryId as Guid?;

    string ApprColor(string s) => s switch {
        "Approved" => "#34c38f", "Rejected" => "#f46a6a", _ => "#f1b44c" };
    string ApprAr(string s) => s switch {
        "Approved" => "معتمد", "Rejected" => "مرفوض", _ => "قيد الاعتماد" };
    string ExecColor(string? s) => s switch {
        AidDisbursementExecutionStatusCodes.FullyDisbursed    => "#34c38f",
        AidDisbursementExecutionStatusCodes.PartiallyDisbursed=> "#f1b44c",
        AidDisbursementExecutionStatusCodes.Cancelled         => "#f46a6a",
        _ => "#adb5bd" };
}


<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css"/>
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css"/>

@if (beneficiaryId.HasValue && beneficiaryId != Guid.Empty)
{
    var h = new BeneficiaryHeaderVm {
        Id = beneficiaryId.Value,
        Code       = ViewBag.BeneficiaryCode        as string ?? "",
        FullName   = ViewBag.BeneficiaryName        as string ?? "",
        NationalId = ViewBag.BeneficiaryNationalId  as string ?? "",
        PhoneNumber= ViewBag.BeneficiaryPhoneNumber as string ?? "",
        StatusName = ViewBag.BeneficiaryStatusName  as string ?? ""
    };
    <partial name="~/Views/Shared/Beneficiaries/_BeneficiaryHeader.cshtml" model="h"/>
}

@if (!string.IsNullOrWhiteSpace(filterTypeName))
{
  <div class="d-flex align-items-center gap-2 mb-3"
       style="background:rgba(52,195,143,.07);border-radius:12px;padding:10px 14px;border:.5px solid rgba(52,195,143,.2)">
    <i class="bx bx-filter-alt" style="color:#34c38f"></i>
    <span style="font-size:.84rem;color:#065f46"><strong>نوع المساعدة:</strong> @filterTypeName</span>
    <a asp-action="Index" class="btn btn-sm ms-auto fw-bold"
       style="border-radius:8px;background:rgba(52,195,143,.15);color:#065f46;border:none">
      <i class="bx bx-x me-1"></i>مسح
    </a>
  </div>
}

<style>
/* ── Hero ── */
.dis-hero{background:linear-gradient(135deg,#065f46,#0e9b6a);border-radius:16px;padding:14px 20px;color:#fff;margin-bottom:16px}
.dis-stat{background:rgba(255,255,255,.12);border-radius:10px;padding:8px 12px;text-align:center;flex:1;min-width:60px}
.dis-stat .n{font-size:1.1rem;font-weight:800;line-height:1}
.dis-stat .l{font-size:.63rem;opacity:.8;margin-top:1px}

    .row {
        background-color: #f0faf5;
        color: #6b7d80;
        font-weight:700;
    }
/* ── Table base ── */
.dis-table{width:100% !important;border-collapse:collapse}
.dis-table th{padding:9px 12px;background:#f0faf5;font-size:.76rem;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(6,95,70,.1);white-space:nowrap}
.dis-table td{padding:9px 12px;border-bottom:.5px solid rgba(6,95,70,.04);font-size:.83rem;vertical-align:middle}
.dis-table tr:hover td{background:rgba(6,95,70,.02)}
.dis-table tr:last-child td{border-bottom:none}

    #disTable_length {
        margin-top: 10px;
        margin-right: 10px;
    }
.pill{padding:2px 8px;border-radius:20px;font-size:.7rem;font-weight:700;white-space:nowrap}
.act-btn{padding:2px 8px;border-radius:7px;font-size:.73rem;font-weight:600;border:none;cursor:pointer;text-decoration:none;white-space:nowrap}
.fund-mini{font-size:.72rem;line-height:1.5;color:#6b7d80}

/* ── DataTables overrides ── */
div.dataTables_wrapper { direction: rtl; margin-top:0;}
div.dataTables_length select,
div.dataTables_filter input { border-radius:8px; border:1px solid rgba(6,95,70,.2); padding:4px 8px; font-size:.82rem; }
div.dataTables_length label,
div.dataTables_filter label { font-size:.82rem; color:#6b7d80; }
div.dataTables_info { font-size:.78rem; color:#adb5bd; }
div.dataTables_paginate .paginate_button { border-radius:8px !important; font-size:.8rem !important; }
div.dataTables_paginate .paginate_button.current {
    background: linear-gradient(135deg,#065f46,#0e9b6a) !important;
    color: #fff !important; border: none !important; }
table.dataTable thead .sorting:before,
table.dataTable thead .sorting:after,
table.dataTable thead .sorting_asc:before,
table.dataTable thead .sorting_asc:after,
table.dataTable thead .sorting_desc:before,
table.dataTable thead .sorting_desc:after { opacity:.5; }

/* ── Column filter row ── */
.col-filter-row th { padding:4px 6px !important; background:#f8fffe !important; }
.col-filter-row input,
.col-filter-row select {
    width:100%; border-radius:6px; border:1px solid rgba(6,95,70,.18);
    padding:3px 6px; font-size:.74rem; color:#3d5a53;
    background:#fff; transition: border .2s;
}
.col-filter-row input:focus,
.col-filter-row select:focus { outline:none; border-color:#0e9b6a; }

/* ── Global autocomplete search bar ── */
.search-wrapper { position:relative; max-width:380px; }
.search-wrapper input {
    width:100%; border-radius:10px; border:1.5px solid rgba(6,95,70,.2);
    padding:7px 36px 7px 14px; font-size:.85rem; transition:border .2s;
}
.search-wrapper input:focus { outline:none; border-color:#0e9b6a; box-shadow:0 0 0 3px rgba(14,155,106,.12); }
.search-wrapper .search-icon { position:absolute; left:10px; top:50%; transform:translateY(-50%); color:#adb5bd; pointer-events:none; }
.autocomplete-list {
    position:absolute; top:calc(100% + 4px); right:0; left:0; z-index:9999;
    background:#fff; border-radius:10px; border:1px solid rgba(6,95,70,.15);
    box-shadow:0 8px 24px rgba(6,95,70,.12); max-height:260px; overflow-y:auto;
    display:none;
}
.autocomplete-list.show { display:block; }
.ac-item { padding:8px 14px; font-size:.82rem; cursor:pointer; display:flex; align-items:center; gap:8px; color:#2d3d38; border-bottom:.5px solid rgba(6,95,70,.06); }
.ac-item:last-child { border-bottom:none; }
.ac-item:hover, .ac-item.active { background:rgba(6,95,70,.06); }
.ac-item .ac-label { font-weight:600; }
.ac-item .ac-sub { font-size:.72rem; color:#adb5bd; }
.ac-highlight { color:#0e9b6a; font-weight:700; }

/* ── Toolbar row ── */
.tbl-toolbar { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; padding:12px 14px; border-bottom:.5px solid rgba(6,95,70,.07); }
</style>

<div class="dis-hero">
  <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
    <h5 class="fw-bold mb-0 text-white"><i class="bx bx-money me-2"></i>سجل الصرف</h5>
    @if (hasBeneficiaryContext)
    { <a asp-action="Create" asp-route-beneficiaryId="@beneficiaryId" class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">+ إضافة صرف</a> }
    else
    { <a asp-action="Create" class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">+ إضافة صرف</a> }
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <div class="dis-stat"><div class="n">@Model.Count</div><div class="l">إجمالي</div></div>
    <div class="dis-stat" style="background:rgba(52,195,143,.2)">
      <div class="n" style="color:#a7f3d0">@Model.Count(x=>x.ApprovalStatusCode==AidDisbursementApprovalStatusCodes.Approved)</div><div class="l">معتمد</div>
    </div>
    <div class="dis-stat" style="background:rgba(241,180,76,.2)">
      <div class="n">@Model.Count(x=>x.ApprovalStatusCode==AidDisbursementApprovalStatusCodes.Pending)</div><div class="l">قيد الاعتماد</div>
    </div>
    <div class="dis-stat" style="background:rgba(85,110,230,.2)">
      <div class="n" style="color:#c7d2fe">@Model.Sum(x=>x.Amount??0).ToString("N0")</div><div class="l">إجمالي المصروف</div>
    </div>
    <div class="dis-stat" style="background:rgba(52,195,143,.15)">
      <div class="n" style="color:#a7f3d0">@Model.Count(x=>x.IsJournalPosted)</div><div class="l">مقيدة</div>
    </div>
  </div>
    <div class="tbl-toolbar">
        <div class="search-wrapper" id="acWrapper">
            <input type="text" id="acInput" placeholder="" autocomplete="off" />
            <i class="bx bx-search search-icon"></i>
            <div class="autocomplete-list" id="acList"></div>
        </div>
        <div class="d-flex gap-2 align-items-center" style="font-size:.8rem;color:#6b7d80">
            <i class="bx bx-info-circle"></i>
            <span style="color:aliceblue">انقر على رأس العمود للترتيب • استخدم الفلاتر أسفل الرؤوس</span>
        </div>
    </div>
</div>

<div style="background:#fff;border-radius:14px;border:.5px solid rgba(6,95,70,.1);box-shadow:0 2px 8px rgba(6,95,70,.05);overflow:hidden">

 
 

  <div style="overflow-x:auto">
        <table style="margin-top:0px !important;" id="disbTable" class="dis-table">
      <thead>
        <tr>
          @if (!hasBeneficiaryContext) { <th>المستفيد</th><th>المنفذ</th> }
          <th>التاريخ</th>
          <th>نوع المساعدة</th>
          <th style="text-align:center">المبلغ</th>
          <th>مصدر التمويل</th>
          <th>طريقة الصرف</th>
          <th style="text-align:center">الاعتماد</th>
          <th style="text-align:center">التنفيذ</th>
          <th style="text-align:center">المحاسبة</th>
          <th style="text-align:center" class="no-sort">إجراءات</th>
        </tr>
       
      </thead>
      <tbody>
        @if (!Model.Any())
        {
          <tr>
            <td colspan="11" style="text-align:center;padding:32px;color:#adb5bd">
              <i class="bx bx-money" style="font-size:2rem;display:block;margin-bottom:8px"></i>
              لا توجد عمليات صرف
            </td>
          </tr>
        }
        @foreach (var item in Model)
        {
          <tr>
            @if (!hasBeneficiaryContext)
            {
              <td>
                <div class="fw-semibold" style="color:#1e3a5f;font-size:.84rem">@(item.BeneficiaryName ?? "—")</div>
                <div style="font-size:.7rem;color:#adb5bd">@item.BeneficiaryCode</div>
              </td>
              <td style="font-size:.78rem;color:#6b7d80;white-space:nowrap">
                <i class="bx bx-user me-1" style="opacity:.5"></i>@(item.ExecutionStatusName ?? "—")
              </td>
            }
           
            <td data-order="@item.DisbursementDate.ToString("yyyy-MM-dd")" style="white-space:nowrap;color:#6b7d80">
              @item.DisbursementDate.ToString("d/M/yyyy")
            </td>
            <td>
              <span style="padding:2px 8px;border-radius:5px;font-size:.75rem;font-weight:600;background:rgba(6,95,70,.08);color:#065f46">
                @(item.AidType ?? "—")
              </span>
            </td>
            <td data-order="@(item.Amount ?? 0)" style="text-align:center;font-weight:700;color:#1e3a5f">
              @(item.Amount?.ToString("N0") ?? "—")
            </td>
            <td>
              <div class="fund-mini">
                @if (!string.IsNullOrWhiteSpace(item.ProjectName))
                { <div><i class="bx bx-briefcase me-1"></i>@item.ProjectName</div> }
                @if (!string.IsNullOrWhiteSpace(item.DonationNumber))
                { <div><i class="bx bx-heart me-1"></i>@item.DonationNumber</div> }
                @if (!string.IsNullOrWhiteSpace(item.GrantAgreementNumber))
                { <div><i class="bx bx-file me-1"></i>@item.GrantAgreementNumber</div> }
                @if (string.IsNullOrWhiteSpace(item.ProjectName) && string.IsNullOrWhiteSpace(item.DonationNumber) && string.IsNullOrWhiteSpace(item.GrantAgreementNumber))
                { <span style="color:#adb5bd">—</span> }
              </div>
            </td>
            <td style="font-size:.8rem;color:#6b7d80">
              @if (item.IsInKindDisbursement)
              {
                <span class="pill" style="background:rgba(85,110,230,.1);color:#3546a0">عيني / مخزن</span>
                @if (!string.IsNullOrWhiteSpace(item.StoreIssueNumber))
                {
                  <div style="font-size:.7rem;color:#6b7d80;margin-top:3px">إذن: @item.StoreIssueNumber</div>
                }
              }
              else
              {
                @(item.PaymentMethod ?? "—")
              }
            </td>
            <td style="text-align:center">
              <span class="pill"
                    style="background:@(ApprColor(item.ApprovalStatusCode))18;color:@ApprColor(item.ApprovalStatusCode)">
                @ApprAr(item.ApprovalStatusCode)
              </span>
              @if (item.ApprovedAtUtc.HasValue || item.RejectedAtUtc.HasValue)
              {
                <div style="font-size:.67rem;color:#adb5bd;margin-top:2px">
                  @((item.ApprovedAtUtc ?? item.RejectedAtUtc)?.ToString("d/M/yy HH:mm"))
                </div>
              }
            </td>
            <td style="text-align:center">
              <span class="pill"
                    style="background:@(ExecColor(item.ExecutionStatusCode))18;color:@ExecColor(item.ExecutionStatusCode)">
                @(item.ExecutionStatusName ?? "—")
              </span>
              @if (item.ExecutedAmount.HasValue && item.ExecutedAmount > 0)
              {<div style="font-size:.7rem;color:#adb5bd">@item.ExecutedAmount?.ToString("N0")</div>}
            </td>
            <td style="text-align:center">
              @if (item.IsJournalPosted)
              {<span class="pill" style="background:rgba(52,195,143,.1);color:#065f46">مقيد</span>}
              else
              {<span class="pill" style="background:rgba(173,181,189,.1);color:#6b7d80">غير مقيد</span>}
            </td>
            <td style="text-align:center">
              <div class="d-flex gap-1 justify-content-center flex-wrap">
                <a asp-action="Print" asp-route-id="@item.Id" target="_blank"
                   class="act-btn" style="background:rgba(30,58,95,.08);color:#1e3a5f">
                  <i class="bx bx-printer"></i>
                </a>
                @if (item.ApprovalStatusCode != AidDisbursementApprovalStatusCodes.Approved)
                {
                  <a asp-action="Edit" asp-route-id="@item.Id"
                     class="act-btn" style="background:rgba(241,180,76,.12);color:#92400e">
                    <i class="bx bx-edit"></i>
                  </a>
                }
                @if (item.CanCreateStoreIssue)
                {
                  <form asp-controller="CharityStoreIssues" asp-action="CreateFromAidDisbursement" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="disbursementId" value="@item.Id" />
                    <button type="submit" class="act-btn" style="background:rgba(85,110,230,.12);color:#3546a0"
                            onclick="return confirm('إنشاء إذن صرف مخزني لهذا السجل؟')">
                      <i class="bx bx-package"></i>
                    </button>
                  </form>
                }
                @if (item.StoreIssueId.HasValue)
                {
                  <a asp-controller="CharityStoreIssues" asp-action="Details" asp-route-id="@item.StoreIssueId"
                     class="act-btn" style="background:rgba(85,110,230,.12);color:#3546a0" title="عرض إذن الصرف المخزني">
                    <i class="bx bx-detail"></i>
                  </a>
                }
                @if (item.CanExecuteCash)
                {
                  <form asp-controller="BeneficiaryAidDisbursements" asp-action="ExecuteFromTreasury1" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id"/>
                    <input type="hidden" name="beneficiaryId" value="@item.BeneficiaryId"/>
                    <button type="submit" class="act-btn" style="background:rgba(52,195,143,.12);color:#065f46"
                            onclick="return confirm('تنفيذ الصرف من الخزينة؟')">
                      <i class="bx bx-wallet"></i>
                    </button>
                  </form>
                }
                @if (item.ApprovalStatusCode == AidDisbursementApprovalStatusCodes.Pending)
                {
                  <form asp-action="Approve" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id"/>
                    <input type="hidden" name="beneficiaryId" value="@item.BeneficiaryId"/>
                    <button type="submit" class="act-btn" style="background:rgba(52,195,143,.12);color:#065f46"
                            onclick="return confirm('اعتماد الصرف؟')">اعتماد</button>
                  </form>
                  <form asp-action="Reject" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@item.Id"/>
                    <input type="hidden" name="beneficiaryId" value="@item.BeneficiaryId"/>
                    <button type="submit" class="act-btn" style="background:rgba(244,106,106,.1);color:#991b1b"
                            onclick="return confirm('رفض الصرف؟')">رفض</button>
                  </form>
                }
                @if (!hasBeneficiaryContext)
                {
                  <a asp-action="Index" asp-route-beneficiaryId="@item.BeneficiaryId"
                     class="act-btn" style="background:rgba(30,58,95,.08);color:#1e3a5f">
                    <i class="bx bx-user"></i>
                  </a>
                }
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>

@section Scripts {
    @* لو الـ Layout لا يحمل jQuery، فعّل السطر التالي *@
    @* <script src="~/assets/libs/jquery/jquery.min.js"></script> *@

    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        if (typeof window.jQuery === 'undefined') {
            console.error('jQuery is not loaded. Please load jQuery before DataTables.');
        } else {
            $(function () {

                var hasBenefContext = @(hasBeneficiaryContext.ToString().ToLower());

                var filterRow = $('<tr class="col-filter-row"></tr>');
                $('#disbTable thead tr:first th').each(function (i) {
                    var th = $(this);
                    var cell = $('<th></th>');
                    var colText = th.text().trim();

                    if (th.hasClass('no-sort')) {
                        cell.append('<span></span>');
                        filterRow.append(cell);
                        return;
                    }

                    var dropdownCols = ['الاعتماد', 'التنفيذ', 'المحاسبة', 'طريقة الصرف', 'نوع المساعدة'];
                    if (dropdownCols.includes(colText)) {
                        var sel = $('<select><option value="">الكل</option></select>')
                            .attr('data-col', i)
                            .addClass('col-select');
                        cell.append(sel);
                    } else {
                        var inp = $('<input type="text"/>')
                            .attr('placeholder', 'فلتر...')
                            .attr('data-col', i)
                            .addClass('col-input');
                        cell.append(inp);
                    }

                    filterRow.append(cell);
                });

                $('#disbTable thead').append(filterRow);

                var table = $('#disbTable').DataTable({
                    language: {
                        url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/ar.json'
                    },
                    pageLength: 25,
                    lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, 'الكل']],
                    order: [[hasBenefContext ? 0 : 2, 'desc']],
                    columnDefs: [
                        { orderable: false, targets: -1 }
                    ],
                    dom: '<"row"<"col-sm-6"l><"col-sm-6 text-end"i>>rt<"row"<"col-sm-12"p>>',
                    drawCallback: function () {
                        populateSelects();
                    }
                });

                function populateSelects() {
                    $('#disbTable thead .col-select').each(function () {
                        var $sel = $(this);
                        var col = parseInt($sel.attr('data-col'));
                        var current = $sel.val();

                        $sel.find('option:not(:first)').remove();

                        var unique = [];

                        table.column(col).data().each(function (d) {
                            var txt = $('<div>').html(d).text().trim();
                            if (txt && txt !== '—' && !unique.includes(txt)) {
                                unique.push(txt);
                            }
                        });

                        unique.sort().forEach(function (v) {
                            $sel.append('<option value="' + $('<div>').text(v).html() + '">' + $('<div>').text(v).html() + '</option>');
                        });

                        $sel.val(current);
                    });
                }

                $('#disbTable thead').on('input change', '.col-input, .col-select', function () {
                    var col = parseInt($(this).attr('data-col'));
                    var val = $(this).val().trim();
                    table.column(col).search(val, false, true).draw();
                });

                $('#disbTable thead').on('click', '.col-filter-row input, .col-filter-row select', function (e) {
                    e.stopPropagation();
                });

                var acInput = document.getElementById('acInput');
                var acList = document.getElementById('acList');
                var acIndex = -1;

                function buildSuggestions(query) {
                    if (!query || query.length < 1) {
                        hideSuggestions();
                        return;
                    }

                    var q = query.trim().toLowerCase();
                    var seen = new Set();
                    var results = [];

                    table.rows().every(function () {
                        $(this.node()).find('td').each(function () {
                            var txt = $(this).text().trim();

                            if (!txt || txt === '—') return;

                            txt.split(/[\n\r]+/).forEach(function (part) {
                                part = part.trim();

                                if (part.length < 2) return;

                                if (part.toLowerCase().includes(q) && !seen.has(part)) {
                                    seen.add(part);
                                    results.push(part);
                                }
                            });
                        });
                    });

                    if (!results.length) {
                        hideSuggestions();
                        return;
                    }

                    results = results.slice(0, 8);

                    acList.innerHTML = results.map(function (r, i) {
                        var hi = r.replace(
                            new RegExp('(' + escRe(query.trim()) + ')', 'gi'),
                            '<span class="ac-highlight">$1</span>'
                        );

                        return '<div class="ac-item" data-val="' + escAttr(r) + '" data-idx="' + i + '">' +
                            '<i class="bx bx-search" style="opacity:.4;font-size:.85rem"></i>' +
                            '<span class="ac-label">' + hi + '</span></div>';
                    }).join('');

                    acList.classList.add('show');
                    acIndex = -1;
                }

                function hideSuggestions() {
                    acList.classList.remove('show');
                    acIndex = -1;
                }

                function applySearch(val) {
                    acInput.value = val;
                    hideSuggestions();
                    table.search(val).draw();
                }

                acInput.addEventListener('input', function () {
                    buildSuggestions(this.value);
                    table.search(this.value).draw();
                });

                acInput.addEventListener('keydown', function (e) {
                    var items = acList.querySelectorAll('.ac-item');

                    if (!items.length) return;

                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        acIndex = Math.min(acIndex + 1, items.length - 1);
                        items.forEach(function (el, i) {
                            el.classList.toggle('active', i === acIndex);
                        });
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        acIndex = Math.max(acIndex - 1, -1);
                        items.forEach(function (el, i) {
                            el.classList.toggle('active', i === acIndex);
                        });
                    } else if (e.key === 'Enter') {
                        if (acIndex >= 0) {
                            applySearch(items[acIndex].dataset.val);
                        } else {
                            hideSuggestions();
                        }
                    } else if (e.key === 'Escape') {
                        hideSuggestions();
                    }
                });

                acList.addEventListener('click', function (e) {
                    var item = e.target.closest('.ac-item');
                    if (item) {
                        applySearch(item.dataset.val);
                    }
                });

                document.addEventListener('click', function (e) {
                    if (!e.target.closest('#acWrapper')) {
                        hideSuggestions();
                    }
                });

                function escRe(s) {
                    return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                }

                function escAttr(s) {
                    return s.replace(/"/g, '&quot;');
                }

                populateSelects();
            });
        }
    </script>
}
@using InfrastructureManagmentServices.Charity.Beneficiaries
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.AidDisbursements
@using InfrastrfuctureManagmentCore.Domains.Charity.Beneficiaries
@model BeneficiaryAidDisbursement
@{
    Layout = null;
    var approvalStatusName = ViewBag.ApprovalStatusName as string ?? AidDisbursementApprovalStatusCodes.ToDisplayName(Model.ApprovalStatus);
    var executionStatusName = ViewBag.ExecutionStatusName as string ?? AidDisbursementExecutionStatusCodes.ToDisplayName(Model.ExecutionStatus);
    var fundingTraceSummary = ViewBag.FundingTraceSummary as string;
    var printedAt = ViewBag.PrintedAt is DateTime dt ? dt : DateTime.Now;
    var isInKindDisbursement = ViewBag.IsInKindDisbursement is bool b && b;
    var inKindItems = ViewBag.InKindItems as List<BeneficiaryAidDisbursementInKindPrintItemVm> ?? new List<BeneficiaryAidDisbursementInKindPrintItemVm>();
    var storeIssueNumber = ViewBag.StoreIssueNumber as string;
    var storeIssueDate = ViewBag.StoreIssueDate as DateTime?;
    var storeIssueWarehouseName = ViewBag.StoreIssueWarehouseName as string;
    var isApproved = string.Equals(Model.ApprovalStatus, AidDisbursementApprovalStatusCodes.Approved, StringComparison.OrdinalIgnoreCase);
    var isPaid = string.Equals(Model.ExecutionStatus, AidDisbursementExecutionStatusCodes.FullyDisbursed, StringComparison.OrdinalIgnoreCase);
    var isPending = string.Equals(Model.ApprovalStatus, AidDisbursementApprovalStatusCodes.Pending, StringComparison.OrdinalIgnoreCase);
    var title = isInKindDisbursement
     ? (isPaid ? "سند صرف عيني" : isApproved ? "إذن صرف عيني" : "مسودة صرف عيني")
     : (isPaid ? "سند صرف مساعدة" : isApproved ? "إذن صرف مساعدة" : "مسودة صرف مساعدة");
    var documentNumber = Model.Id.ToString()[..8].ToUpperInvariant();
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>@title - @documentNumber</title>
    <style>
        :root {
            --border: #222;
            --muted: #666;
            --soft: #f4f6f8;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 24px;
            font-family: Tahoma, Arial, sans-serif;
            color: #111;
            background: #fff;
            font-size: 14px;
            line-height: 1.7;
        }

        .print-page {
            max-width: 900px;
            margin: 0 auto;
            border: 1px solid var(--border);
            padding: 24px;
            position: relative;
            min-height: 1080px;
        }

        .toolbar {
            max-width: 900px;
            margin: 0 auto 12px auto;
            display: flex;
            justify-content: space-between;
            gap: 8px;
        }

        .btn {
            border: 1px solid #333;
            background: #fff;
            color: #111;
            padding: 8px 14px;
            border-radius: 6px;
            cursor: pointer;
            text-decoration: none;
            font-size: 14px;
        }

        .btn-primary {
            background: #111;
            color: #fff;
        }

        .header {
            display: grid;
            grid-template-columns: 1fr 1.5fr 1fr;
            gap: 12px;
            align-items: start;
            border-bottom: 2px solid var(--border);
            padding-bottom: 16px;
            margin-bottom: 18px;
        }

        .org h2,
        .doc-title h1 {
            margin: 0;
        }

        .org small,
        .meta small,
        .muted {
            color: var(--muted);
        }

        .doc-title {
            text-align: center;
        }

        .doc-title h1 {
            font-size: 26px;
            border: 2px solid var(--border);
            padding: 8px 12px;
            display: inline-block;
            min-width: 260px;
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border: 1px solid var(--border);
            border-radius: 999px;
            font-size: 12px;
            margin-top: 8px;
        }

        .watermark {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 86px;
            font-weight: bold;
            color: rgba(0,0,0,.06);
            transform: rotate(-25deg);
            pointer-events: none;
            z-index: 0;
        }

        .content {
            position: relative;
            z-index: 1;
        }

        .section-title {
            font-weight: bold;
            background: var(--soft);
            border: 1px solid var(--border);
            padding: 6px 10px;
            margin: 16px 0 8px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
        }

        th,
        td {
            border: 1px solid var(--border);
            padding: 7px 9px;
            vertical-align: top;
        }

        th {
            background: var(--soft);
            width: 22%;
            text-align: right;
        }

        .amount-box {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 16px 0;
        }

        .amount-card {
            border: 2px solid var(--border);
            padding: 14px;
            text-align: center;
        }

        .amount-card strong {
            font-size: 24px;
            display: block;
        }

        .notice {
            border: 1px dashed var(--border);
            padding: 10px;
            margin-top: 12px;
            color: #333;
        }

        .signatures {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            margin-top: 44px;
        }

        .signature {
            min-height: 95px;
            border-top: 1px solid var(--border);
            text-align: center;
            padding-top: 8px;
        }

        .footer {
            margin-top: 32px;
            border-top: 1px solid var(--border);
            padding-top: 8px;
            display: flex;
            justify-content: space-between;
            color: var(--muted);
            font-size: 12px;
        }

        @@media print {
            body {
                padding: 0;
            }

            .toolbar {
                display: none;
            }

            .print-page {
                border: none;
                max-width: none;
                min-height: auto;
                padding: 12mm;
            }
        }
    </style>
</head>
<body>
    <div class="toolbar">
        <button type="button" class="btn btn-primary" onclick="window.print()">طباعة</button>
        <a class="btn" href="javascript:window.close()">إغلاق</a>
    </div>

    <main class="print-page">
        @if (!isApproved || isPending)
        {
            <div class="watermark">غير معتمد</div>
        }
        else if (!isPaid)
        {
            <div class="watermark">إذن صرف</div>
        }

        <div class="content">
            <header class="header">
                <div class="org">
                    <h2>الجمعية</h2>
                    <small>نظام إدارة الجمعيات</small>
                </div>

                <div class="doc-title">
                    <h1>@title</h1>
                    <div>
                        <span class="badge">حالة الاعتماد: @approvalStatusName</span>
                        <span class="badge">حالة التنفيذ: @executionStatusName</span>
                    </div>
                </div>

                <div class="meta">
                    <table>
                        <tr><th>رقم المستند</th><td>@documentNumber</td></tr>
                        <tr><th>تاريخ المستند</th><td>@Model.DisbursementDate.ToString("yyyy-MM-dd")</td></tr>
                        <tr><th>وقت الطباعة</th><td>@printedAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
                    </table>
                </div>
            </header>

            <div class="section-title">بيانات المستفيد</div>
            <table>
                <tr>
                    <th>كود المستفيد</th>
                    <td>@(Model.Beneficiary?.Code ?? "-")</td>
                    <th>اسم المستفيد</th>
                    <td>@(Model.Beneficiary?.FullName ?? "-")</td>
                </tr>
                <tr>
                    <th>الرقم القومي</th>
                    <td>@(Model.Beneficiary?.NationalId ?? "-")</td>
                    <th>رقم الهاتف</th>
                    <td>@(Model.Beneficiary?.PhoneNumber ?? "-")</td>
                </tr>
                <tr>
                    <th>العنوان</th>
                    <td colspan="3">@(Model.Beneficiary?.AddressLine ?? "-")</td>
                </tr>
            </table>

            <div class="section-title">بيانات الصرف</div>
            <table>
                <tr>
                    <th>نوع المساعدة</th>
                    <td>@(Model.AidType?.NameAr ?? "-")</td>
                    <th>نوع الصرف</th>
                    <td>@(isInKindDisbursement ? "صرف عيني" : "صرف نقدي")</td>
                </tr>
                @if (isInKindDisbursement)
                {
                    <tr>
                        <th>رقم إذن الصرف المخزني</th>
                        <td>@(string.IsNullOrWhiteSpace(storeIssueNumber) ? "لم يتم إنشاء إذن مخزني بعد" : storeIssueNumber)</td>
                        <th>تاريخ إذن الصرف</th>
                        <td>@(storeIssueDate.HasValue ? storeIssueDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                    </tr>
                    <tr>
                        <th>المخزن</th>
                        <td>@(storeIssueWarehouseName ?? "-")</td>
                        <th>طلب المساعدة</th>
                        <td>@(Model.AidRequestId?.ToString() ?? "-")</td>
                    </tr>
                }
                else
                {
                    <tr>
                        <th>طريقة الدفع</th>
                        <td>@(Model.PaymentMethod?.MethodNameAr ?? "-")</td>
                        <th>الحساب المالي</th>
                        <td>@(Model.FinancialAccount == null ? "-" : $"{Model.FinancialAccount.AccountCode} - {Model.FinancialAccount.AccountNameAr}")</td>
                    </tr>
                    <tr>
                        <th>طلب المساعدة</th>
                        <td colspan="3">@(Model.AidRequestId?.ToString() ?? "-")</td>
                    </tr>
                }

                <tr>
                    <th>مصدر التمويل</th>
                    <td colspan="3">@(string.IsNullOrWhiteSpace(fundingTraceSummary) ? "-" : fundingTraceSummary)</td>
                </tr>
                <tr>
                    <th>ملاحظات</th>
                    <td colspan="3">@(Model.Notes ?? "-")</td>
                </tr>
            </table>
            @if (isInKindDisbursement)
            {
                <div class="section-title">الأصناف العينية المصروفة</div>
                <table>
                    <thead>
                        <tr>
                            <th style="width:5%">#</th>
                            <th>الصنف</th>
                            <th style="width:12%">الكود</th>
                            <th style="width:12%">الكمية</th>
                            <th style="width:16%">المخزن</th>
                            <th style="width:16%">رقم التبرع</th>
                            <th style="width:14%">قيمة تقديرية</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (inKindItems.Count == 0)
                        {
                            <tr>
                                <td colspan="7" style="text-align:center;color:#666">لا توجد أصناف عينية مرتبطة بسجل الصرف.</td>
                            </tr>
                        }
                        else
                        {
                            var rowNo = 1;
                            foreach (var item in inKindItems)
                            {
                                <tr>
                                    <td>@rowNo</td>
                                    <td>
                                        <strong>@item.ItemName</strong>
                                        @if (!string.IsNullOrWhiteSpace(item.BatchNo) || item.ExpiryDate.HasValue || !string.IsNullOrWhiteSpace(item.Notes))
                                        {
                                            <div class="muted" style="font-size:12px">
                                                @if (!string.IsNullOrWhiteSpace(item.BatchNo))
                                                {
                                                    <span>تشغيلة: @item.BatchNo</span>
                                                }
                                                @if (item.ExpiryDate.HasValue)
                                                {
                                                    <span> — صلاحية: @item.ExpiryDate.Value.ToString("yyyy-MM-dd")</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(item.Notes))
                                                {
                                                    <span> — @item.Notes</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>@(item.ItemCode ?? "-")</td>
                                    <td>@item.Quantity.ToString("N2")</td>
                                    <td>@(item.WarehouseName ?? "-")</td>
                                    <td>@(item.DonationNumber ?? "-")</td>
                                    <td>@((item.EstimatedTotalValue ?? 0m).ToString("N2"))</td>
                                </tr>
                                rowNo++;
                            }
                        }
                    </tbody>
                </table>
            }

            @if (isInKindDisbursement)
            {
                <div class="amount-box">
                    <div class="amount-card">
                        <span>إجمالي الكمية المصروفة / المطلوب صرفها</span>
                        <strong>@inKindItems.Sum(x => x.Quantity).ToString("N2")</strong>
                    </div>
                    <div class="amount-card">
                        <span>إجمالي القيمة التقديرية للأصناف</span>
                        <strong>@inKindItems.Sum(x => x.EstimatedTotalValue ?? 0m).ToString("N2")</strong>
                    </div>
                </div>
            }
            else
            {
                <div class="amount-box">
                    <div class="amount-card">
                        <span>المبلغ المعتمد للصرف</span>
                        <strong>@((Model.Amount ?? 0m).ToString("N2"))</strong>
                    </div>
                    <div class="amount-card">
                        <span>المبلغ المنفذ فعليًا</span>
                        <strong>@((Model.ExecutedAmount ?? (isPaid ? Model.Amount : 0m) ?? 0m).ToString("N2"))</strong>
                    </div>
                </div>
            }

            <div class="notice">
                @if (isInKindDisbursement)
                {
                    if (isPaid)
                    {
                        <span>هذا المستند يفيد تنفيذ الصرف العيني فعليًا طبقًا للأصناف والكميات الموضحة أعلاه.</span>
                    }
                    else if (isApproved)
                    {
                        <span>هذا المستند إذن صرف عيني معتمد، ولا يعد إثباتًا بخروج الأصناف من المخزن إلا بعد اعتماد إذن الصرف المخزني وتحديث حالة التنفيذ إلى: تم الصرف.</span>
                    }
                    else
                    {
                        <span>هذا المستند مسودة صرف عيني داخلية ولا يعتد به قبل الاعتماد.</span>
                    }
                }
                else
                {
                    if (isPaid)
                    {
                        <span>هذا المستند يفيد تنفيذ الصرف النقدي فعليًا طبقًا للحالة المسجلة بالنظام.</span>
                    }
                    else if (isApproved)
                    {
                        <span>هذا المستند إذن صرف نقدي معتمد، ولا يعد إثباتًا بخروج النقدية إلا بعد تنفيذ الصرف وتحديث حالة التنفيذ إلى: تم الصرف.</span>
                    }
                    else
                    {
                        <span>هذا المستند مسودة داخلية ولا يعتد به للصرف قبل الاعتماد.</span>
                    }
                }

            </div>

            <div class="signatures">
                <div class="signature">إعداد</div>
                <div class="signature">مراجعة</div>
                <div class="signature">اعتماد</div>
                <div class="signature">@(isInKindDisbursement ? "أمين المخزن / توقيع المستفيد" : "توقيع المستفيد / أمين الخزينة")</div>
            </div>
            <footer class="footer">
                <span>تمت الطباعة من نظام إدارة الجمعيات</span>
                <span>رقم العملية: @Model.Id</span>
            </footer>
        </div>
    </main>
</body>
</html>

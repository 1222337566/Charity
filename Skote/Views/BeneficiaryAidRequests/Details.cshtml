@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.AidRequests
@model BeneficiaryAidRequestListItemVm

@{
    ViewData["Title"] = "تفاصيل طلب المساعدة";
    var needRequestsByLine = ViewBag.NeedRequestsByLine as Dictionary<Guid, string>;
}

<div class="container-fluid" dir="rtl">
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">مختصر طلب المساعدة</h5>
            <a asp-action="Index"
               asp-route-beneficiaryId="@Model.BeneficiaryId"
               class="btn btn-secondary btn-sm">
                رجوع
            </a>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <strong>المستفيد:</strong>
                    <div>@Model.BeneficiaryName</div>
                </div>

                <div class="col-md-4">
                    <strong>كود المستفيد:</strong>
                    <div>@Model.BeneficiaryCode</div>
                </div>

                <div class="col-md-4">
                    <strong>تاريخ الطلب:</strong>
                    <div>@Model.RequestDate.ToString("yyyy-MM-dd")</div>
                </div>

                <div class="col-md-4">
                    <strong>نوع المساعدة:</strong>
                    <div>@Model.AidType</div>
                </div>

                <div class="col-md-4">
                    <strong>القيمة المطلوبة:</strong>
                    <div>@(Model.RequestedAmount?.ToString("N2") ?? "0.00")</div>
                </div>

                <div class="col-md-4">
                    <strong>درجة الأهمية:</strong>
                    <div>@Model.UrgencyLevel</div>
                </div>

                <div class="col-md-4">
                    <strong>الحالة:</strong>
                    <div>@Model.Status</div>
                </div>

                <div class="col-md-4">
                    <strong>حالة التمويل:</strong>
                    <div>@Model.FundingStatusName</div>
                </div>

                <div class="col-md-4">
                    <strong>حالة الصرف:</strong>
                    <div>@Model.DisbursementStatusName</div>
                </div>

                <div class="col-md-4">
                    <strong>الممول:</strong>
                    <div>@Model.FundedAmount.ToString("N2")</div>
                </div>

                <div class="col-md-4">
                    <strong>المصروف:</strong>
                    <div>@Model.DisbursedAmount.ToString("N2")</div>
                </div>

                <div class="col-md-4">
                    <strong>المتبقي على الطلب:</strong>
                    <div>@Model.RemainingOnRequestAmount.ToString("N2")</div>
                </div>

                <div class="col-md-12">
                    <strong>سبب الطلب:</strong>
                    <div class="border rounded p-2 bg-light">
                        @(string.IsNullOrWhiteSpace(Model.Reason) ? "لا يوجد" : Model.Reason)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">تفاصيل الأصناف / الخدمات المطلوبة</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Lines == null || !Model.Lines.Any())
            {
                <div class="p-3 text-muted">لا توجد تفاصيل بنود مسجلة لهذا الطلب.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>الصنف / الخدمة</th>
                                <th>الوصف</th>
                                <th>الكمية المطلوبة</th>
                                <th>الكمية المعتمدة</th>
                                <th>قيمة الوحدة</th>
                                <th>الإجمالي</th>
                                <th>طريقة التنفيذ</th>
                                <th>الحالة</th>
                                <th>ملاحظات</th>
                                <th style="width:170px">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.Lines)
                            {
                                <tr>
                                    <td>@(line.ItemNameSnapshot ?? line.ItemId?.ToString() ?? "-")</td>
                                    <td>@(line.Description ?? "-")</td>
                                    <td>@(line.RequestedQuantity?.ToString("N2") ?? "-")</td>
                                    <td>@(line.ApprovedQuantity?.ToString("N2") ?? "-")</td>
                                    <td>@(line.EstimatedUnitValue?.ToString("N2") ?? "-")</td>
                                    <td>@(line.EstimatedTotalValue?.ToString("N2") ?? "-")</td>
                                    <td>@BeneficiaryAidRequestFulfillmentMethodOption.ToDisplayName(line.FulfillmentMethod)</td>
                                    <td>@line.Status</td>
                                    <td>@(line.Notes ?? "-")</td>
                                    <td>
                                        @if (line.FulfillmentMethod == BeneficiaryAidRequestFulfillmentMethodOption.PurchaseNeedRequest && line.Id.HasValue)
                                        {
                                            string? needValue = null;
                                            needRequestsByLine?.TryGetValue(line.Id.Value, out needValue);

                                            if (!string.IsNullOrWhiteSpace(needValue))
                                            {
                                                var parts = needValue.Split('|');
                                                var needId = parts.Length > 0 ? parts[0] : string.Empty;
                                                var needNo = parts.Length > 1 ? parts[1] : "طلب احتياج";
                                                <a asp-controller="StockNeedRequests" asp-action="Details" asp-route-id="@needId" class="btn btn-outline-info btn-sm">
                                                    @needNo
                                                </a>
                                            }
                                            else
                                            {
                                                <form asp-controller="StockNeedRequests" asp-action="CreateFromAidRequestLine" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="aidRequestId" value="@Model.Id" />
                                                    <input type="hidden" name="lineId" value="@line.Id" />
                                                    <button type="submit" class="btn btn-warning btn-sm">إنشاء طلب احتياج</button>
                                                </form>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

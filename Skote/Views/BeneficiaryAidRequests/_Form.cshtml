@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.AidRequests
@model CreateBeneficiaryAidRequestVm

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="BeneficiaryId" class="form-label"></label>
        <select asp-for="BeneficiaryId" asp-items="Model.Beneficiaries" class="form-select">
            <option value="">-- اختر المستفيد --</option>
        </select>
        <span asp-validation-for="BeneficiaryId" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="RequestDate" class="form-label"></label>
        <input asp-for="RequestDate" type="date" class="form-control" />
        <span asp-validation-for="RequestDate" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="AidTypeId" class="form-label"></label>
        <select asp-for="AidTypeId" asp-items="Model.AidTypes" class="form-select">
            <option value="">-- اختر --</option>
        </select>
        <span asp-validation-for="AidTypeId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="RequestedAmount" class="form-label"></label>
        <input asp-for="RequestedAmount" class="form-control" id="RequestedAmount" />
        <span asp-validation-for="RequestedAmount" class="text-danger"></span>
        <small class="text-muted">يتم احتسابها تلقائيًا من إجمالي البنود عند إدخال تفاصيل أصناف/خدمات.</small>
    </div>
    <div class="col-md-4">
        <label asp-for="ProjectId" class="form-label"></label>
        <select asp-for="ProjectId" asp-items="Model.Projects" class="form-select">
            <option value="">-- بدون مشروع --</option>
        </select>
        <span asp-validation-for="ProjectId" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="UrgencyLevel" class="form-label"></label>
        <input asp-for="UrgencyLevel" class="form-control" />
        <span asp-validation-for="UrgencyLevel" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Model.Statuses" class="form-select"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Reason" class="form-label"></label>
        <textarea asp-for="Reason" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Reason" class="text-danger"></span>
    </div>

    <div class="col-12">
        <div class="card border shadow-none mt-2">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0">تفاصيل الأصناف / الخدمات المطلوبة</h6>
                    <small class="text-muted">للمساعدات الغذائية أو العلاجية أو الملابس: أدخل الصنف/الخدمة والكمية والقيمة وطريقة التنفيذ.</small>
                </div>
                <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddAidLine">إضافة بند</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0" id="aidRequestLinesTable">
                        <thead class="table-light">
                            <tr>
                                <th style="min-width:210px">الصنف المخزني</th>
                                <th style="min-width:180px">صنف/خدمة غير مخزنية</th>
                                <th style="min-width:220px">الوصف</th>
                                <th style="min-width:115px">الكمية</th>
                                <th style="min-width:130px">قيمة الوحدة</th>
                                <th style="min-width:130px">الإجمالي</th>
                                <th style="min-width:170px">طريقة التنفيذ</th>
                                <th style="min-width:170px">المخزن</th>
                                <th style="min-width:170px">ملاحظات</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Lines.Count; i++)
                            {
                                <tr class="aid-line-row">
                                    <td>
                                        <input asp-for="Lines[i].Id" type="hidden" />
                                        <select asp-for="Lines[i].ItemId" asp-items="Model.Items" class="form-select form-select-sm aid-line-input">
                                            <option value="">-- بدون --</option>
                                        </select>
                                        <span asp-validation-for="Lines[i].ItemId" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <input asp-for="Lines[i].ItemNameSnapshot" class="form-control form-control-sm aid-line-input" placeholder="مثال: كشف طبي / دواء" />
                                        <span asp-validation-for="Lines[i].ItemNameSnapshot" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <input asp-for="Lines[i].Description" class="form-control form-control-sm aid-line-input" />
                                        <span asp-validation-for="Lines[i].Description" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <input asp-for="Lines[i].RequestedQuantity" class="form-control form-control-sm aid-qty aid-line-input" />
                                        <span asp-validation-for="Lines[i].RequestedQuantity" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <input asp-for="Lines[i].EstimatedUnitValue" class="form-control form-control-sm aid-unit aid-line-input" />
                                        <span asp-validation-for="Lines[i].EstimatedUnitValue" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <input asp-for="Lines[i].EstimatedTotalValue" class="form-control form-control-sm aid-total aid-line-input" />
                                        <span asp-validation-for="Lines[i].EstimatedTotalValue" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <select asp-for="Lines[i].FulfillmentMethod" asp-items="Model.FulfillmentMethods" class="form-select form-select-sm aid-line-input"></select>
                                        <span asp-validation-for="Lines[i].FulfillmentMethod" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <select asp-for="Lines[i].WarehouseId" asp-items="Model.Warehouses" class="form-select form-select-sm aid-line-input">
                                            <option value="">-- بدون --</option>
                                        </select>
                                        <span asp-validation-for="Lines[i].WarehouseId" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <input asp-for="Lines[i].Notes" class="form-control form-control-sm aid-line-input" />
                                        <input asp-for="Lines[i].Status" type="hidden" />
                                        <span asp-validation-for="Lines[i].Notes" class="text-danger small"></span>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove-aid-line">حذف</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <th colspan="5" class="text-end">إجمالي البنود</th>
                                <th><span id="AidLinesTotal">0.00</span></th>
                                <th colspan="4"></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const table = document.getElementById('aidRequestLinesTable');
        const addButton = document.getElementById('btnAddAidLine');
        const requestedAmount = document.getElementById('RequestedAmount');
        const linesTotal = document.getElementById('AidLinesTotal');

        if (!table || !addButton) return;

        function parseNumber(value) {
            if (!value) return 0;
            const normalized = value.toString().replace(',', '.');
            const number = parseFloat(normalized);
            return isNaN(number) ? 0 : number;
        }

        function reindexRows() {
            const rows = table.querySelectorAll('tbody tr.aid-line-row');
            rows.forEach((row, index) => {
                row.querySelectorAll('input, select, textarea, span').forEach(el => {
                    ['name', 'id', 'for', 'data-valmsg-for'].forEach(attr => {
                        const current = el.getAttribute(attr);
                        if (current) {
                            el.setAttribute(attr, current.replace(/Lines_\d+__/g, `Lines_${index}__`).replace(/Lines\[\d+\]/g, `Lines[${index}]`));
                        }
                    });
                });
            });
        }

        function recalcRow(row) {
            const qty = parseNumber(row.querySelector('.aid-qty')?.value);
            const unit = parseNumber(row.querySelector('.aid-unit')?.value);
            const totalInput = row.querySelector('.aid-total');
            const currentTotal = parseNumber(totalInput?.value);
            if (totalInput && qty > 0 && unit > 0 && currentTotal === 0) {
                totalInput.value = (qty * unit).toFixed(2);
            }
        }

        function recalcAll() {
            let total = 0;
            table.querySelectorAll('tbody tr.aid-line-row').forEach(row => {
                recalcRow(row);
                total += parseNumber(row.querySelector('.aid-total')?.value);
            });

            if (linesTotal) linesTotal.textContent = total.toFixed(2);
            if (requestedAmount && total > 0) requestedAmount.value = total.toFixed(2);
        }

        addButton.addEventListener('click', function () {
            const tbody = table.querySelector('tbody');
            const source = tbody.querySelector('tr.aid-line-row');
            if (!source) return;
            const clone = source.cloneNode(true);
            clone.querySelectorAll('input').forEach(input => {
                if (input.type === 'hidden' && input.name && input.name.endsWith('.Status')) {
                    input.value = 'Pending';
                } else {
                    input.value = '';
                }
            });
            clone.querySelectorAll('select').forEach(select => select.selectedIndex = 0);
            clone.querySelectorAll('span.text-danger').forEach(span => span.textContent = '');
            tbody.appendChild(clone);
            reindexRows();
            recalcAll();
        });

        table.addEventListener('click', function (e) {
            if (!e.target.classList.contains('btn-remove-aid-line')) return;
            const rows = table.querySelectorAll('tbody tr.aid-line-row');
            const row = e.target.closest('tr');
            if (rows.length === 1) {
                row.querySelectorAll('input').forEach(input => input.value = input.type === 'hidden' && input.name.endsWith('.Status') ? 'Pending' : '');
                row.querySelectorAll('select').forEach(select => select.selectedIndex = 0);
            } else {
                row.remove();
            }
            reindexRows();
            recalcAll();
        });

        table.addEventListener('input', function (e) {
            if (e.target.classList.contains('aid-line-input')) recalcAll();
        });

        recalcAll();
    })();
</script>

@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Assessments
@model EditBeneficiaryAssessmentVm
@{ ViewData["Title"] = "تعديل بحث اجتماعي"; }
<div class="container-fluid">
    <partial name="~/Views/Shared/Beneficiaries/_BeneficiaryHeader.cshtml" />
    <div class="card"><div class="card-header"><h5 class="mb-0">تعديل بحث اجتماعي</h5></div><div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <partial name="_Form" model="Model" />
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">حفظ التعديل</button>
                <a asp-action="Index" asp-route-beneficiaryId="@Model.BeneficiaryId" class="btn btn-secondary">رجوع</a>
            </div>
        </form>
    </div></div>
</div>
@section Scripts{<partial name="_ValidationScriptsPartial" />}

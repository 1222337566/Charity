@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Assessments
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Shared
@model List<BeneficiaryAssessmentListItemVm>
@{ 
    ViewData["Title"] = "البحث الاجتماعي"; 
    var hasBeneficiaryContext = (bool?)ViewBag.HasBeneficiaryContext ?? false;
    var beneficiaryId = ViewBag.BeneficiaryId as Guid?;
    var beneficiaryName = ViewBag.BeneficiaryName as string;
    var beneficiaryCode = ViewBag.BeneficiaryCode as string;
    var beneficiaryNationalId = ViewBag.BeneficiaryNationalId as string;
    var beneficiaryPhone = ViewBag.BeneficiaryPhoneNumber as string;
    var beneficiaryStatus = ViewBag.BeneficiaryStatusName as string;


}
@if (beneficiaryId.HasValue)
{
    var beneficiaryHeader = new BeneficiaryHeaderVm
                {
                    Id = beneficiaryId.Value,
                    Code = beneficiaryCode ?? string.Empty,
                    FullName = beneficiaryName ?? string.Empty,
                    NationalId = beneficiaryNationalId ?? string.Empty,
                    PhoneNumber = beneficiaryPhone ?? string.Empty,
                    StatusName = beneficiaryStatus ?? string.Empty
                };

    <partial name="~/Views/Shared/Beneficiaries/_BeneficiaryHeader.cshtml" model="beneficiaryHeader" />
}
<div class="container-fluid">
    
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">البحث الاجتماعي</h5>
            <a asp-action="Create" asp-route-beneficiaryId="@ViewBag.BeneficiaryId" class="btn btn-primary btn-sm">إضافة تقييم</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light"><tr><th>التاريخ</th><th>نوع المساعدة المقترح</th><th>القيمة</th><th>الدرجة</th><th>القرار المقترح</th><th style="width:120px">إجراءات</th></tr></thead>
                    <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.VisitDate.ToString("yyyy-MM-dd")</td>
                                <td>@(item.RecommendedAidType ?? "-")</td>
                                <td>@(item.RecommendationAmount?.ToString("N2") ?? "-")</td>
                                <td>@(item.AssessmentScore?.ToString("N2") ?? "-")</td>
                                <td>@(item.DecisionSuggested ?? "-")</td>
                                <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-soft-primary">تعديل</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted">لا توجد تقييمات</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

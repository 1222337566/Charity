  <div class="ew-section">
    <div class="ew-section-head">
      <span class="ew-section-title">
        <span style="width:8px;height:8px;border-radius:50%;background:#556ee6;display:inline-block"></span>
        متابعات تواصل مستحقة
      </span>
      <span class="badge" style="background:rgba(85,110,230,.15);color:#3145a3">@Model.OverdueFollowUps.Count</span>
    </div>
    <table class="ew-table">
      <thead><tr><th>المستفيد</th><th>الكود</th><th>الهاتف</th><th>التفاصيل</th><th>الأيام</th><th></th></tr></thead>
      <tbody>
        @foreach (var item in Model.OverdueFollowUps)
        {
          <tr>
            <td class="fw-semibold">@item.BeneficiaryName</td>
            <td class="text-muted" style="font-size:.78rem">@item.Code</td>
            <td style="font-size:.8rem">@(item.Phone ?? "—")</td>
            <td style="font-size:.8rem;color:#6b7d80">@item.Detail</td>
            <td><span class="days-badge" style="background:rgba(85,110,230,.12);color:#3145a3">@item.DaysSince يوم</span></td>
            <td><a asp-controller="BeneficiaryCard" asp-action="Index" asp-route-id="@item.BeneficiaryId"
                   class="btn btn-sm" style="border-radius:8px;background:rgba(14,111,115,.08);color:#0e6f73;border:none;font-size:.75rem">البطاقة</a></td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

@if (Model.OverdueKafalas.Any())
{
  <div class="ew-section">
    <div class="ew-section-head">
      <span class="ew-section-title">
        <span style="width:8px;height:8px;border-radius:50%;background:#dba44a;display:inline-block"></span>
        كفالات متأخرة
      </span>
      <span class="badge" style="background:rgba(219,164,74,.15);color:#8a5f00">@Model.OverdueKafalas.Count</span>
    </div>
    <table class="ew-table">
      <thead><tr><th>المستفيد</th><th>الكود</th><th>الهاتف</th><th>التفاصيل</th><th>الأيام</th><th></th></tr></thead>
      <tbody>
        @foreach (var item in Model.OverdueKafalas)
        {
          <tr>
            <td class="fw-semibold">@item.BeneficiaryName</td>
            <td class="text-muted" style="font-size:.78rem">@item.Code</td>
            <td style="font-size:.8rem">@(item.Phone ?? "—")</td>
            <td style="font-size:.8rem;color:#6b7d80">@item.Detail</td>
            <td><span class="days-badge" style="background:rgba(219,164,74,.15);color:#8a5f00">@item.DaysSince يوم</span></td>
            <td><a asp-controller="BeneficiaryCard" asp-action="Index" asp-route-id="@item.BeneficiaryId"
                   class="btn btn-sm" style="border-radius:8px;background:rgba(14,111,115,.08);color:#0e6f73;border:none;font-size:.75rem">البطاقة</a></td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

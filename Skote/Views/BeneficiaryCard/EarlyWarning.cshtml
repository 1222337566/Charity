@model Skote.Controllers.EarlyWarningVm
@{ ViewData["Title"] = "لوحة الإنذار المبكر"; }

<style>
.ew-hero{background:linear-gradient(135deg,#7b1e1e,#b83232,#c94545);border-radius:18px;padding:20px 26px;color:#fff;margin-bottom:20px}
.ew-stat{padding:10px 18px;border-radius:12px;text-align:center;flex:1;min-width:80px;background:rgba(255,255,255,.15)}
.ew-stat .n{font-size:1.4rem;font-weight:800;line-height:1}
.ew-stat .l{font-size:.68rem;opacity:.8;margin-top:2px}
.ew-section{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 2px 10px rgba(14,111,115,.05);margin-bottom:18px;overflow:hidden}
.ew-section-head{padding:14px 18px;border-bottom:.5px solid rgba(14,111,115,.08);display:flex;align-items:center;justify-content:space-between}
.ew-section-title{font-size:.92rem;font-weight:700;color:#0a5f63;display:flex;align-items:center;gap:8px}
.ew-table{width:100%;border-collapse:collapse}
.ew-table th{padding:9px 14px;font-size:.78rem;font-weight:700;color:#6b7d80;background:#f8fbfb;text-align:right}
.ew-table td{padding:10px 14px;font-size:.84rem;border-top:.5px solid rgba(14,111,115,.06);vertical-align:middle}
.ew-table tr:hover td{background:rgba(14,111,115,.02)}
.days-badge{padding:2px 8px;border-radius:6px;font-size:.7rem;font-weight:700;display:inline-flex;align-items:center}
</style>

<div class="ew-hero">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
    <div>
      <h4 class="mb-1 text-white fw-bold"><i class="bx bx-error-circle me-2"></i>لوحة الإنذار المبكر</h4>
      <div style="opacity:.8;font-size:.82rem">حالات تحتاج تدخل — @DateTime.Today.ToString("d MMMM yyyy")</div>
    </div>
    <a asp-controller="Beneficiaries" asp-action="Index" class="btn btn-light btn-sm fw-bold">
      <i class="bx bx-list-ul me-1"></i>كل المستفيدين
    </a>
  </div>
  <div class="d-flex gap-3 flex-wrap">
    <div class="ew-stat"><div class="n">@Model.TotalCount</div><div class="l">إجمالي التنبيهات</div></div>
    <div class="ew-stat"><div class="n">@Model.NoDisbursement.Count</div><div class="l">بدون صرف 6 أشهر</div></div>
    <div class="ew-stat"><div class="n">@Model.OldPendingRequests.Count</div><div class="l">طلبات متأخرة</div></div>
    <div class="ew-stat"><div class="n">@Model.OverdueFollowUps.Count</div><div class="l">متابعات مستحقة</div></div>
    <div class="ew-stat"><div class="n">@Model.OverdueKafalas.Count</div><div class="l">كفالات متأخرة</div></div>
  </div>
</div>

@if (Model.TotalCount == 0)
{
  <div class="text-center py-5" style="background:#fff;border-radius:16px">
    <i class="bx bx-check-shield" style="font-size:4rem;color:#34c38f;display:block;margin-bottom:16px"></i>
    <h5 style="color:#0a5f63">لا تنبيهات حالياً</h5>
    <p class="text-muted">جميع المستفيدين في وضع جيد</p>
  </div>
}

@if (Model.NoDisbursement.Any())
{
  <div class="ew-section">
    <div class="ew-section-head">
      <span class="ew-section-title">
        <span style="width:8px;height:8px;border-radius:50%;background:#f46a6a;display:inline-block"></span>
        لم يُصرف لهم منذ 6 أشهر أو أكثر
      </span>
      <span class="badge" style="background:rgba(244,106,106,.15);color:#ab2b2b">@Model.NoDisbursement.Count</span>
    </div>
    <table class="ew-table">
      <thead><tr><th>المستفيد</th><th>الكود</th><th>الهاتف</th><th>التفاصيل</th><th>الأيام</th><th></th></tr></thead>
      <tbody>
        @foreach (var item in Model.NoDisbursement)
        {
          var dc = item.DaysSince > 365 ? "#f46a6a" : "#f1b44c";
          <tr>
            <td class="fw-semibold">@item.BeneficiaryName</td>
            <td class="text-muted" style="font-size:.78rem">@item.Code</td>
            <td style="font-size:.8rem">@(item.Phone ?? "—")</td>
            <td style="font-size:.8rem;color:#6b7d80">@item.Detail</td>
            <td><span class="days-badge" style="background:rgba(244,106,106,.12);color:@dc">@item.DaysSince يوم</span></td>
            <td><a asp-controller="BeneficiaryCard" asp-action="Index" asp-route-id="@item.BeneficiaryId"
                   class="btn btn-sm" style="border-radius:8px;background:rgba(14,111,115,.08);color:#0e6f73;border:none;font-size:.75rem">البطاقة</a></td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}

@if (Model.OldPendingRequests.Any())
{
  <div class="ew-section">
    <div class="ew-section-head">
      <span class="ew-section-title">
        <span style="width:8px;height:8px;border-radius:50%;background:#f1b44c;display:inline-block"></span>
        طلبات مساعدة معلقة أكثر من 14 يوم
      </span>
      <span class="badge" style="background:rgba(241,180,76,.15);color:#8a5f00">@Model.OldPendingRequests.Count</span>
    </div>
    <table class="ew-table">
      <thead><tr><th>المستفيد</th><th>الكود</th><th>الهاتف</th><th>التفاصيل</th><th>الأيام</th><th></th></tr></thead>
      <tbody>
        @foreach (var item in Model.OldPendingRequests)
        {
          <tr>
            <td class="fw-semibold">@item.BeneficiaryName</td>
            <td class="text-muted" style="font-size:.78rem">@item.Code</td>
            <td style="font-size:.8rem">@(item.Phone ?? "—")</td>
            <td style="font-size:.8rem;color:#6b7d80">@item.Detail</td>
            <td><span class="days-badge" style="background:rgba(241,180,76,.15);color:#8a5f00">@item.DaysSince يوم</span></td>
            <td><a asp-controller="BeneficiaryCard" asp-action="Index" asp-route-id="@item.BeneficiaryId"
                   class="btn btn-sm" style="border-radius:8px;background:rgba(14,111,115,.08);color:#0e6f73;border:none;font-size:.75rem">البطاقة</a></td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}


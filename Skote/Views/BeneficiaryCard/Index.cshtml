@model Skote.Controllers.BeneficiaryCardVm
@{ 
    ViewData["Title"] = "بطاقة المستفيد";
    var ben  = Model.Beneficiary;
    var age  = ben.BirthDate.HasValue ? (int)((DateTime.Today - ben.BirthDate.Value).TotalDays / 365) : 0;
    string ScoreColor(int s) => s >= 70 ? "#f46a6a" : s >= 40 ? "#f1b44c" : "#34c38f";
    string ScoreLabel(int s) => s >= 70 ? "أولوية عالية" : s >= 40 ? "أولوية متوسطة" : "أولوية عادية";
    string StatusColor(string? s) => s switch {
        "Pending" => "#f1b44c", "Approved" => "#34c38f",
        "Rejected" => "#f46a6a", "UnderReview" => "#556ee6", _ => "#adb5bd"
    };
    string StatusAr(string? s) => s switch {
        "Pending" => "قيد المراجعة", "Approved" => "معتمد",
        "Rejected" => "مرفوض", "UnderReview" => "تحت المراجعة",
        "Active" => "نشط", "Closed" => "مغلق", _ => s ?? "—"
    };
    string ContactIcon(string t) => t switch {
        "PhoneCall" => "bx-phone", "Visit" => "bx-home",
        "WhatsApp" => "bxl-whatsapp", "Email" => "bx-envelope", _ => "bx-chat"
    };
    string ContactAr(string t) => t switch {
        "PhoneCall" => "مكالمة هاتفية", "Visit" => "زيارة ميدانية",
        "WhatsApp" => "واتساب", "Email" => "بريد إلكتروني", _ => "أخرى"
    };
    string OutcomeAr(string o) => o switch {
        "Reached" => "تم التواصل", "NotReached" => "لم يرد",
        "Pending" => "في الانتظار", "FollowUp" => "يحتاج متابعة", _ => o
    };
    string OutcomeColor(string o) => o switch {
        "Reached" => "#34c38f", "NotReached" => "#f46a6a",
        "Pending" => "#f1b44c", "FollowUp" => "#556ee6", _ => "#adb5bd"
    };
}

<style>
.bc-hero{background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:20px;padding:22px 28px;color:#fff;margin-bottom:20px}
.bc-avatar{width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:800;color:#fff;flex-shrink:0;border:2px solid rgba(255,255,255,.4)}
.bc-score-ring{width:64px;height:64px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;border:3px solid}
.bc-stat{background:rgba(255,255,255,.13);border-radius:12px;padding:10px 16px;text-align:center;flex:1;min-width:80px}
.bc-stat .n{font-size:1.3rem;font-weight:800;line-height:1}
.bc-stat .l{font-size:.67rem;opacity:.8;margin-top:2px}

.bc-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 2px 10px rgba(14,111,115,.05);margin-bottom:16px}
.bc-card-head{padding:14px 18px 12px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.92rem;font-weight:700;color:#0a5f63;display:flex;align-items:center;justify-content:space-between}
.bc-card-body{padding:14px 18px}

.timeline{position:relative;padding-right:20px}
.timeline::before{content:'';position:absolute;right:9px;top:0;bottom:0;width:2px;background:rgba(14,111,115,.10)}
.tl-item{position:relative;margin-bottom:16px;padding-right:24px}
.tl-item:last-child{margin-bottom:0}
.tl-dot{width:20px;height:20px;border-radius:50%;position:absolute;right:-20px;top:2px;display:flex;align-items:center;justify-content:center;font-size:9px;color:#fff;border:2px solid #fff;box-shadow:0 1px 4px rgba(0,0,0,.12);z-index:1}
.tl-card{background:#fafcfc;border-radius:10px;border:.5px solid rgba(14,111,115,.09);padding:10px 12px}
.tl-title{font-size:.86rem;font-weight:600;color:#15363a}
.tl-sub{font-size:.74rem;color:#6b7d80;margin-top:2px}

.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.info-item{padding:8px 10px;background:#f8fbfb;border-radius:8px}
.info-label{font-size:.7rem;color:#6b7d80;font-weight:600}
.info-val{font-size:.85rem;color:#15363a;font-weight:600;margin-top:2px}

.contact-item{display:flex;gap:10px;align-items:flex-start;padding:10px 0;border-bottom:.5px dashed rgba(14,111,115,.08)}
.contact-item:last-child{border-bottom:none}
.contact-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.followup-badge{padding:2px 7px;border-radius:5px;font-size:.65rem;font-weight:700;background:rgba(241,180,76,.2);color:#8a5f00}

.tab-btn{padding:8px 18px;border-radius:12px;border:.5px solid rgba(14,111,115,.2);background:#fff;font-size:.82rem;font-weight:600;cursor:pointer;color:#15363a;transition:.12s}
.tab-btn.active{background:#0e6f73;color:#fff;border-color:#0e6f73}
.tab-pane{display:none}
.tab-pane.active{display:block}
</style>

@* Hero *@
<div class="bc-hero">
  <div class="d-flex align-items-start gap-3 flex-wrap mb-3">
    <div class="bc-avatar">@ben.FullName[0]</div>
    <div class="flex-grow-1">
      <h4 class="mb-1 text-white fw-bold">@ben.FullName</h4>
      <div style="opacity:.75;font-size:.82rem">
        @ben.Code
        @if (ben.NationalId != null) { <span> · الرقم القومي: @ben.NationalId</span> }
        @if (age > 0) { <span> · العمر: @age سنة</span> }
        @if (ben.PhoneNumber != null) { <span> · 📞 @ben.PhoneNumber</span> }
      </div>
      <div class="mt-2">
        @if (ben.Status != null)
        {
          <span class="badge bg-white text-dark" style="font-size:.75rem">@ben.Status.NameAr</span>
        }
        @if (!ben.IsActive)
        {
          <span class="badge bg-danger ms-1" style="font-size:.72rem">غير نشط</span>
        }
        @if (Model.PendingFollowUps > 0)
        {
          <span class="badge ms-1" style="background:#f1b44c;font-size:.72rem">⏰ @Model.PendingFollowUps متابعة مستحقة</span>
        }
      </div>
    </div>
    @* Priority score *@
    <div class="bc-score-ring" style="border-color:@ScoreColor(Model.PriorityScore);background:rgba(255,255,255,.1)">
      <span style="font-size:1.1rem;font-weight:800">@Model.PriorityScore</span>
      <span style="font-size:.55rem;opacity:.85;text-align:center">أولوية</span>
    </div>
  </div>

  <div class="d-flex gap-3 flex-wrap">
    <div class="bc-stat">
      <div class="n">@ben.AidDisbursements.Count</div>
      <div class="l">مرات الصرف</div>
    </div>
    <div class="bc-stat" style="background:rgba(52,195,143,.22)">
      <div class="n" style="color:#a7f3d0">@Model.TotalDisbursed.ToString("N0")</div>
      <div class="l">إجمالي المساعدات</div>
    </div>
    <div class="bc-stat">
      <div class="n">@ben.AidRequests.Count</div>
      <div class="l">طلبات مساعدة</div>
    </div>
    <div class="bc-stat" style="background:rgba(52,195,143,.20)">
      <div class="n" style="color:#a7f3d0">@Model.Kafalas.Count</div>
      <div class="l">كفالات</div>
    </div>
    <div class="bc-stat">
      <div class="n">@Model.ContactLogs.Count</div>
      <div class="l">سجلات التواصل</div>
    </div>
    @if (Model.DaysSinceLastAid >= 0)
    {
      <div class="bc-stat" style="background:@(Model.DaysSinceLastAid > 180 ? "rgba(244,106,106,.22)" : "rgba(255,255,255,.13)")">
        <div class="n" style="color:@(Model.DaysSinceLastAid > 180 ? "#fca5a5" : "#fff")">@Model.DaysSinceLastAid</div>
        <div class="l">يوم منذ آخر صرف</div>
      </div>
    }
  </div>
</div>

@* Action buttons + Quick links *@
<div class="d-flex gap-2 flex-wrap mb-3">
  <a asp-controller="Beneficiaries" asp-action="Edit" asp-route-id="@ben.Id"
     class="btn btn-primary btn-sm fw-bold" style="border-radius:10px">
    <i class="bx bx-edit me-1"></i>تعديل
  </a>
  <a asp-controller="BeneficiaryAidRequests" asp-action="Create" asp-route-beneficiaryId="@ben.Id"
     class="btn btn-success btn-sm fw-bold" style="border-radius:10px">
    <i class="bx bx-plus me-1"></i>طلب مساعدة
  </a>
  <a asp-controller="BeneficiaryAssessments" asp-action="Create" asp-route-beneficiaryId="@ben.Id"
     class="btn btn-info btn-sm fw-bold text-white" style="border-radius:10px">
    <i class="bx bx-clipboard me-1"></i>تقييم جديد
  </a>
  <a asp-controller="BeneficiaryCard" asp-action="EarlyWarning"
     class="btn btn-outline-warning btn-sm fw-bold" style="border-radius:10px">
    <i class="bx bx-error-circle me-1"></i>لوحة الإنذار
  </a>
</div>

@if (TempData["ContactSuccess"] != null)
{
  <div class="alert alert-success alert-dismissible fade show">
    <i class="bx bx-check-circle me-2"></i>@TempData["ContactSuccess"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

<div class="row g-3">

  @* Col 1 — البيانات الأساسية *@
  <div class="col-xl-4">
    <div class="bc-card">
      <div class="bc-card-head"><span><i class="bx bx-user me-2"></i>البيانات الأساسية</span></div>
      <div class="bc-card-body">
        <div class="info-grid">
          <div class="info-item"><div class="info-label">الجنس</div><div class="info-val">@(ben.Gender?.NameAr ?? "—")</div></div>
          <div class="info-item"><div class="info-label">الحالة الاجتماعية</div><div class="info-val">@(ben.MaritalStatus?.NameAr ?? "—")</div></div>
          <div class="info-item"><div class="info-label">المحافظة</div><div class="info-val">@(ben.Governorate?.NameAr ?? "—")</div></div>
          <div class="info-item"><div class="info-label">المدينة</div><div class="info-val">@(ben.City?.NameAr ?? "—")</div></div>
          <div class="info-item"><div class="info-label">أفراد الأسرة</div><div class="info-val">@ben.FamilyMembersCount</div></div>
          <div class="info-item"><div class="info-label">الدخل الشهري</div><div class="info-val">@(ben.MonthlyIncome?.ToString("N0") ?? "—")</div></div>
          <div class="info-item"><div class="info-label">الحالة الصحية</div><div class="info-val">@(ben.HealthStatus ?? "—")</div></div>
          <div class="info-item"><div class="info-label">السكن</div><div class="info-val">@(ben.HousingStatus ?? "—")</div></div>
          <div class="info-item"><div class="info-label">التعليم</div><div class="info-val">@(ben.EducationStatus ?? "—")</div></div>
          <div class="info-item"><div class="info-label">العمل</div><div class="info-val">@(ben.WorkStatus ?? "—")</div></div>
        </div>
        @if (ben.FamilyMembers.Any())
        {
          <div class="mt-3">
            <div class="fw-bold mb-2" style="font-size:.82rem;color:#0a5f63">أفراد الأسرة</div>
            @foreach (var fm in ben.FamilyMembers.Take(5))
            {
              <div style="padding:5px 0;border-bottom:.5px dashed rgba(14,111,115,.08);font-size:.8rem">
                <span class="fw-semibold">@fm.FullName</span>
                @if (fm.Relationship != null) { <span class="text-muted"> — @fm.Relationship</span> }
              </div>
            }
          </div>
        }
      </div>
    </div>

    @* مؤشر الأولوية *@
    <div class="bc-card">
      <div class="bc-card-head"><span><i class="bx bx-trophy me-2"></i>مؤشر الأولوية</span></div>
      <div class="bc-card-body">
        <div class="d-flex align-items-center gap-3 mb-2">
          <div style="font-size:2rem;font-weight:800;color:@ScoreColor(Model.PriorityScore)">@Model.PriorityScore</div>
          <div>
            <div class="fw-bold" style="color:@ScoreColor(Model.PriorityScore)">@ScoreLabel(Model.PriorityScore)</div>
            <div style="font-size:.75rem;color:#6b7d80">من 100 نقطة</div>
          </div>
        </div>
        <div style="height:8px;border-radius:999px;background:#eef4f3;overflow:hidden">
          <div style="height:100%;border-radius:999px;background:@ScoreColor(Model.PriorityScore);width:@Model.PriorityScore%"></div>
        </div>
        <div style="font-size:.73rem;color:#6b7d80;margin-top:8px">
          يحتسب بناءً على: الدخل · عدد الأسرة · الحالة الصحية · السكن · العمل
        </div>
      </div>
    </div>
  </div>

  @* Col 2 — Timeline التاريخ *@
  <div class="col-xl-4">
    <div class="bc-card" style="max-height:700px;overflow:hidden;display:flex;flex-direction:column">
      <div class="bc-card-head">
        <span><i class="bx bx-time-five me-2"></i>التاريخ الكامل</span>
      </div>
      <div class="bc-card-body" style="overflow-y:auto;flex:1">
        <div class="timeline">
          @{
            // بناء timeline مجمع من كل المصادر
            var events = new List<(DateTime Date, string Color, string Icon, string Title, string Sub)>();

            events.Add((ben.RegistrationDate, "#0e6f73", "bx-user-plus",
                "تسجيل المستفيد", $"كود: {ben.Code}"));

            foreach (var a in ben.Assessments.OrderByDescending(x => x.VisitDate))
                events.Add((a.VisitDate, "#556ee6", "bx-clipboard",
                    "تقييم ميداني",
                    $"النتيجة: {a.AssessmentScore?.ToString("N0") ?? "—"} | {a.RecommendedAidType?.NameAr ?? ""}"));

            foreach (var d in ben.CommitteeDecisions.OrderByDescending(x => x.DecisionDate))
                events.Add((d.DecisionDate, d.ApprovedStatus ? "#34c38f" : "#f46a6a", "bx-check-shield",
                    $"قرار لجنة: {d.DecisionType}",
                    $"{d.ApprovedAidType?.NameAr ?? ""} {d.ApprovedAmount?.ToString("N0") ?? ""}"));

            foreach (var r in ben.AidRequests.OrderByDescending(x => x.RequestDate))
                events.Add((r.RequestDate, "#f1b44c", "bx-file",
                    $"طلب {r.AidType?.NameAr ?? "مساعدة"}",
                    $"{r.RequestedAmount?.ToString("N0") ?? ""} — {StatusAr(r.Status)}"));

            foreach (var dis in ben.AidDisbursements.OrderByDescending(x => x.DisbursementDate))
                events.Add((dis.DisbursementDate, "#34c38f", "bx-money",
                    $"صرف {dis.AidType?.NameAr ?? "مساعدة"}",
                    dis.Amount?.ToString("N0") + " ريال"));

            foreach (var k in Model.Kafalas)
                events.Add((k.StartDate, "#dba44a", "bx-heart",
                    $"كفالة {k.CaseNumber}",
                    $"الكفيل: {k.Sponsor?.FullName ?? "—"} — {StatusAr(k.Status)}"));

            foreach (var cl in Model.ContactLogs.Take(5))
                events.Add((cl.ContactDate, "#50a5f1", ContactIcon(cl.ContactType),
                    ContactAr(cl.ContactType),
                    $"{OutcomeAr(cl.Outcome)}{(cl.Subject != null ? " — " + cl.Subject : "")}"));
          }

          @foreach (var ev in events.OrderByDescending(x => x.Date))
          {
            <div class="tl-item">
              <div class="tl-dot" style="background:@ev.Color">
                <i class="bx @ev.Icon" style="font-size:9px"></i>
              </div>
              <div class="tl-card">
                <div class="tl-title">@ev.Title</div>
                <div class="tl-sub">@ev.Date.ToString("d/M/yyyy") · @ev.Sub</div>
              </div>
            </div>
          }
        </div>
      </div>
    </div>
  </div>

  @* Col 3 — التواصل + الكفالات *@
  <div class="col-xl-4">

    @* سجل التواصل *@
    <div class="bc-card mb-3">
      <div class="bc-card-head">
        <span><i class="bx bx-phone me-2"></i>سجل التواصل</span>
        <button class="btn btn-primary btn-sm fw-bold" style="border-radius:9px;font-size:.75rem"
                data-bs-toggle="modal" data-bs-target="#addContactModal">
          <i class="bx bx-plus me-1"></i>تسجيل
        </button>
      </div>
      <div class="bc-card-body">
        @if (!Model.ContactLogs.Any())
        {
          <div class="text-center text-muted py-3" style="font-size:.82rem">
            <i class="bx bx-phone-off" style="font-size:2rem;display:block;margin-bottom:6px"></i>
            لا سجلات تواصل بعد
          </div>
        }
        else
        {
          @foreach (var cl in Model.ContactLogs.Take(5))
          {
            <div class="contact-item">
              <div class="contact-icon"
                   style="background:rgba(14,111,115,.08);color:@OutcomeColor(cl.Outcome)">
                <i class="bx @ContactIcon(cl.ContactType)"></i>
              </div>
              <div class="flex-grow-1 min-w-0">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <span style="font-size:.86rem;font-weight:600;color:#15363a">@ContactAr(cl.ContactType)</span>
                  <span style="font-size:.7rem;font-weight:700;color:@OutcomeColor(cl.Outcome)">
                    @OutcomeAr(cl.Outcome)
                  </span>
                </div>
                @if (cl.Subject != null)
                { <div style="font-size:.78rem;color:#15363a;margin-top:2px">@cl.Subject</div> }
                <div style="font-size:.72rem;color:#6b7d80;margin-top:2px">
                  @cl.ContactDate.ToString("d/M/yyyy")
                  @if (cl.FollowUpDate.HasValue)
                  {
                    <span class="followup-badge ms-1">⏰ متابعة: @cl.FollowUpDate.Value.ToString("d/M")</span>
                  }
                </div>
                @if (cl.Notes != null)
                { <div style="font-size:.75rem;color:#6b7d80;margin-top:2px">@cl.Notes</div> }
              </div>
            </div>
          }
        }
      </div>
    </div>

    @* الكفالات *@
    @if (Model.Kafalas.Any())
    {
      <div class="bc-card">
        <div class="bc-card-head"><span><i class="bx bx-heart me-2"></i>الكفالات</span></div>
        <div class="bc-card-body">
          @foreach (var k in Model.Kafalas)
          {
            <div class="tl-card mb-2">
              <div class="d-flex justify-content-between align-items-center">
                <span style="font-size:.86rem;font-weight:600">@k.CaseNumber</span>
                <span class="badge bg-@(k.Status=="Active"?"success":"secondary")" style="font-size:.68rem">
                  @StatusAr(k.Status)
                </span>
              </div>
              <div style="font-size:.75rem;color:#6b7d80;margin-top:3px">
                الكفيل: @(k.Sponsor?.FullName ?? "—") ·
                @k.MonthlyAmount.ToString("N0") شهرياً
                @if (k.NextDueDate.HasValue)
                { <span> · الاستحقاق: @k.NextDueDate.Value.ToString("d/M/yyyy")</span> }
              </div>
            </div>
          }
        </div>
      </div>
    }

  </div>
</div>

@* Add Contact Modal *@
<div class="modal fade" id="addContactModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:18px">
      <div class="modal-header" style="background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px 18px 0 0;color:#fff;border:none">
        <h5 class="modal-title fw-bold"><i class="bx bx-phone me-2"></i>تسجيل تواصل جديد</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <form asp-action="AddContact" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" name="beneficiaryId" value="@ben.Id"/>
          <div class="row g-3">
            <div class="col-6">
              <label class="form-label fw-semibold">نوع التواصل</label>
              <select name="contactType" class="form-select" style="border-radius:10px">
                <option value="PhoneCall">📞 مكالمة هاتفية</option>
                <option value="Visit">🏠 زيارة ميدانية</option>
                <option value="WhatsApp">💬 واتساب</option>
                <option value="Email">📧 بريد إلكتروني</option>
                <option value="Other">أخرى</option>
              </select>
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">النتيجة</label>
              <select name="outcome" class="form-select" style="border-radius:10px">
                <option value="Reached">✅ تم التواصل</option>
                <option value="NotReached">❌ لم يرد</option>
                <option value="FollowUp">⏰ يحتاج متابعة</option>
                <option value="Pending">⏳ في الانتظار</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">الموضوع</label>
              <input name="subject" class="form-control" placeholder="موضوع التواصل..." style="border-radius:10px"/>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">الملاحظات</label>
              <textarea name="notes" class="form-control" rows="3" style="border-radius:10px"
                        placeholder="تفاصيل المحادثة أو الزيارة..."></textarea>
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">تاريخ متابعة (اختياري)</label>
              <input name="followUpDate" type="date" class="form-control" style="border-radius:10px"/>
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">ملاحظة المتابعة</label>
              <input name="followUpNote" class="form-control" style="border-radius:10px" placeholder="ماذا تحتاج؟"/>
            </div>
          </div>
          <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary flex-fill fw-bold" style="border-radius:12px">
              <i class="bx bx-save me-1"></i>حفظ
            </button>
            <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal" style="border-radius:12px">إلغاء</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

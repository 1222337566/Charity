@model IEnumerable<InfrastrfuctureManagmentCore.Domains.Charity.Beneficiaries.BeneficiaryCategory>

@{
    ViewData["Title"] = "تصنيفات المستفيدين";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">تصنيفات المستفيدين</h4>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bx bx-plus"></i>
                    إنشاء تصنيف
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead>
                            <tr>
                                <th>الترتيب</th>
                                <th>اسم التصنيف</th>
                                <th>الكود</th>
                                <th>قائمة انتظار</th>
                                <th>يتطلب نوع الإعاقة</th>
                                <th>مرتبط بمشروع</th>
                                <th>مرتبط بنشاط</th>
                                <th>الحالة</th>
                                <th style="width:120px">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.SortOrder</td>
                                    <td>@item.NameAr</td>
                                    <td>@item.Code</td>
                                    <td>@(item.IsWaitingListCategory ? "نعم" : "لا")</td>
                                    <td>@(item.RequiresDisabilityType ? "نعم" : "لا")</td>
                                    <td>@(item.IsProjectRelated ? "نعم" : "لا")</td>
                                    <td>@(item.IsActivityRelated ? "نعم" : "لا")</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">مفعل</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">غير مفعل</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            تعديل
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.Any())
                {
                    <div class="alert alert-info mb-0">
                        لا توجد تصنيفات حتى الآن.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

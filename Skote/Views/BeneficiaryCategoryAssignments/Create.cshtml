@model Skote.ViewModels.Charity.Beneficiaries.CreateBeneficiaryCategoryAssignmentVm

@{
    ViewData["Title"] = "إضافة تصنيف / مشاركة للمستفيد";
}

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="BeneficiaryId" />

            <div class="card">
                <div class="card-header">
                    <h4 class="card-title mb-0">إضافة تصنيف / مشاركة للمستفيد</h4>
                </div>

                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">التصنيف</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
                            <option value="">-- اختر التصنيف --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label">الحالة</label>
                        <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AssignedAtUtc" class="form-label">تاريخ الإضافة</label>
                        <input asp-for="AssignedAtUtc" type="datetime-local" class="form-control" />
                    </div>

                    <div class="alert alert-warning">
                        الربط بالمشروع والنشاط في هذه المرحلة اختياري كـ Guid فقط لتجنب كسر أسماء كيانات المشروع الحالية.
                        بعد تثبيت أسماء كيانات Project و ProjectActivity نضيف Dropdown كامل.
                    </div>

                    <div class="mb-3">
                        <label asp-for="ProjectId" class="form-label">ProjectId - اختياري</label>
                        <input asp-for="ProjectId" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="ProjectActivityId" class="form-label">ProjectActivityId - اختياري</label>
                        <input asp-for="ProjectActivityId" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">ملاحظات</label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-between">
                    <a asp-controller="Beneficiaries" asp-action="Details" asp-route-id="@Model.BeneficiaryId" class="btn btn-secondary">
                        رجوع
                    </a>
                    <button type="submit" class="btn btn-primary">حفظ</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

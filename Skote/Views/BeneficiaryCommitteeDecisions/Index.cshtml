@using Skote.Helpers
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.CommitteeDecisions
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Shared
@model List<BeneficiaryCommitteeDecisionListItemVm>
@{ 
    ViewData["Title"] = "قرارات اللجنة";
    var canManageCommittee = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.CommitteeDecisionManage);
    var beneficiaryId = ViewBag.BeneficiaryId as Guid?;
    var hasBeneficiaryContext = (bool?)ViewBag.HasBeneficiaryContext ?? false;

    var beneficiaryName = ViewBag.BeneficiaryName as string;
    var beneficiaryCode = ViewBag.BeneficiaryCode as string;
    var beneficiaryNationalId = ViewBag.BeneficiaryNationalId as string;
    var beneficiaryPhone = ViewBag.BeneficiaryPhoneNumber as string;
    var beneficiaryStatus = ViewBag.BeneficiaryStatusName as string;
}
@if (beneficiaryId.HasValue)
{
    var beneficiaryHeader = new BeneficiaryHeaderVm
                {
                    Id = beneficiaryId.Value,
                    Code = beneficiaryCode ?? string.Empty,
                    FullName = beneficiaryName ?? string.Empty,
                    NationalId = beneficiaryNationalId ?? string.Empty,
                    PhoneNumber = beneficiaryPhone ?? string.Empty,
                    StatusName = beneficiaryStatus ?? string.Empty
                };

    <partial name="~/Views/Shared/Beneficiaries/_BeneficiaryHeader.cshtml" model="beneficiaryHeader" />
}
<div class="container-fluid">
    
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">قرارات اللجنة</h5>
            @if (canManageCommittee)
            {
                <a asp-action="Create" asp-route-beneficiaryId="@ViewBag.BeneficiaryId" class="btn btn-primary btn-sm">إضافة قرار</a>
            }
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light"><tr><th>التاريخ</th><th>نوع القرار</th><th>المساعدة</th><th>القيمة</th><th>المدة</th><th>الاعتماد</th><th style="width:120px">إجراءات</th></tr></thead>
                    <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.DecisionDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.DecisionType</td>
                                <td>@(item.ApprovedAidType ?? "-")</td>
                                <td>@(item.ApprovedAmount?.ToString("N2") ?? "-")</td>
                                <td>@(item.DurationInMonths?.ToString() ?? "-")</td>
                                <td>
                                    @if (item.ApprovedStatus)
                                    {
                                        <span class="badge bg-success">معتمد</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">غير معتمد</span>
                                    }
                                </td>
                                <td>
                                    @if (canManageCommittee)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-soft-primary">تعديل</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">عرض فقط</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center text-muted">لا توجد قرارات</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@using Skote.Helpers
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.CommitteeDecisions
@model CreateBeneficiaryCommitteeDecisionVm
<input type="hidden" asp-for="BeneficiaryId" />
<input type="hidden" asp-for="ApprovedStatus" />
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="alert alert-info py-2">قرار اللجنة يصدر من الأدمن فقط، وسيتم حفظه بحالة <strong>معتمد</strong>.</div>
<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="DecisionDate" class="form-label"></label>
        <input asp-for="DecisionDate" type="date" class="form-control" />
        <span asp-validation-for="DecisionDate" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="DecisionType" class="form-label"></label>
        <input asp-for="DecisionType" class="form-control" />
        <span asp-validation-for="DecisionType" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ApprovedAidTypeId" class="form-label"></label>
        <select asp-for="ApprovedAidTypeId" asp-items="Model.AidTypes" class="form-select">
            <option value="">-- اختر --</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="ApprovedAmount" class="form-label"></label>
        <input asp-for="ApprovedAmount" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="DurationInMonths" class="form-label"></label>
        <input asp-for="DurationInMonths" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="CommitteeNotes" class="form-label"></label>
        <textarea asp-for="CommitteeNotes" class="form-control"></textarea>
    </div>
</div>

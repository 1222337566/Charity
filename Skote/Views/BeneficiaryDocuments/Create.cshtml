@model Skote.ViewModels.BeneficiaryDocuments.BeneficiaryDocumentCreateVm
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Shared
@{
    ViewData["Title"] = "رفع مستند";
    var beneficiaryId = ViewBag.BeneficiaryId as Guid?;
    var hasBeneficiaryContext = (bool?)ViewBag.HasBeneficiaryContext ?? false;

    var beneficiaryName = ViewBag.BeneficiaryName as string;
    var beneficiaryCode = ViewBag.BeneficiaryCode as string;
    var beneficiaryNationalId = ViewBag.BeneficiaryNationalId as string;
    var beneficiaryPhone = ViewBag.BeneficiaryPhoneNumber as string;
    var beneficiaryStatus = ViewBag.BeneficiaryStatusName as string;
}
@if (beneficiaryId.HasValue)
{
    var beneficiaryHeader = new BeneficiaryHeaderVm
                {
                    Id = beneficiaryId.Value,
                    Code = beneficiaryCode ?? string.Empty,
                    FullName = beneficiaryName ?? string.Empty,
                    NationalId = beneficiaryNationalId ?? string.Empty,
                    PhoneNumber = beneficiaryPhone ?? string.Empty,
                    StatusName = beneficiaryStatus ?? string.Empty
                };

    <partial name="~/Views/Shared/Beneficiaries/_BeneficiaryHeader.cshtml" model="beneficiaryHeader" />
}
<div class="card">
    <div class="card-header">
        <h4 class="mb-0">رفع مستند للمستفيد</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            @if (Model.BeneficiaryId.HasValue)
            {
                <input type="hidden" asp-for="BeneficiaryId" />
            }
            else
            {
                <div class="mb-3">
                    <label asp-for="BeneficiaryId" class="form-label">المستفيد</label>
                    <select asp-for="BeneficiaryId" asp-items="Model.Beneficiaries" class="form-select">
                        <option value="">-- اختر --</option>
                    </select>
                    <span asp-validation-for="BeneficiaryId" class="text-danger"></span>
                </div>
            }

            <div class="mb-3">
                <label asp-for="DocumentType" class="form-label">نوع المستند</label>
                <input asp-for="DocumentType" class="form-control" />
                <span asp-validation-for="DocumentType" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">الملف</label>
                <input type="file" name="uploadFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                <div class="form-text">المسموح: PDF / JPG / JPEG / PNG</div>
            </div>

            <div class="mb-3">
                <label asp-for="Notes" class="form-label">ملاحظات</label>
                <textarea asp-for="Notes" class="form-control"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">حفظ</button>
                <a class="btn btn-secondary" asp-action="Index" asp-route-beneficiaryId="@Model.BeneficiaryId">عودة</a>
            </div>
        </form>
    </div>
</div>

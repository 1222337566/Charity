@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Shared
@model IEnumerable<Skote.ViewModels.BeneficiaryDocuments.BeneficiaryDocumentListItemVm>
@{
    ViewData["Title"] = "مستندات المستفيد";
    var beneficiaryId = ViewBag.BeneficiaryId as Guid?;
    var hasBeneficiaryContext = (bool?)ViewBag.HasBeneficiaryContext ?? false;
    
    var beneficiaryName = ViewBag.BeneficiaryName as string;
    var beneficiaryCode = ViewBag.BeneficiaryCode as string;
    var beneficiaryNationalId = ViewBag.BeneficiaryNationalId as string;
    var beneficiaryPhone = ViewBag.BeneficiaryPhoneNumber as string;
    var beneficiaryStatus = ViewBag.BeneficiaryStatusName as string;
}
@if (beneficiaryId.HasValue)
{
    var beneficiaryHeader = new BeneficiaryHeaderVm
                {
                    Id = beneficiaryId.Value,
                    Code = beneficiaryCode ?? string.Empty,
                    FullName = beneficiaryName ?? string.Empty,
                    NationalId = beneficiaryNationalId ?? string.Empty,
                    PhoneNumber = beneficiaryPhone ?? string.Empty,
                    StatusName = beneficiaryStatus ?? string.Empty
                };

    <partial name="~/Views/Shared/Beneficiaries/_BeneficiaryHeader.cshtml" model="beneficiaryHeader" />
}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">مستندات المستفيد</h4>
        <a class="btn btn-primary" asp-action="Create" asp-route-beneficiaryId="@beneficiaryId">رفع مستند جديد</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>المستفيد</th>
                    <th>النوع</th>
                    <th>اسم الملف</th>
                    <th>الحجم</th>
                    <th>تاريخ الرفع</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.BeneficiaryName (@item.BeneficiaryCode)</td>
                    <td>@item.DocumentType</td>
                    <td>@item.OriginalFileName</td>
                    <td>@String.Format("{0:N0} KB", Math.Ceiling(item.FileSizeBytes / 1024.0))</td>
                    <td>@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="d-flex gap-2">
                        <a class="btn btn-sm btn-success" asp-action="Download" asp-route-id="@item.Id">تحميل</a>
                        <form asp-action="Delete" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="beneficiaryId" value="@item.BeneficiaryId" />
                            <button type="submit" class="btn btn-sm btn-danger">حذف</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Documents
@model CreateBeneficiaryDocumentVm
<input type="hidden" asp-for="BeneficiaryId" />
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="DocumentType" class="form-label"></label>
        <input asp-for="DocumentType" class="form-control" />
        <span asp-validation-for="DocumentType" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DocumentNumber" class="form-label"></label>
        <input asp-for="DocumentNumber" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="IssueDate" class="form-label"></label>
        <input asp-for="IssueDate" type="date" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="ExpiryDate" class="form-label"></label>
        <input asp-for="ExpiryDate" type="date" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="FilePath" class="form-label"></label>
        <input asp-for="FilePath" class="form-control" />
    </div>
    <div class="col-md-9">
        <label asp-for="Notes" class="form-label"></label>
        <input asp-for="Notes" class="form-control" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <div class="form-check mb-2">
            <input asp-for="IsVerified" class="form-check-input" />
            <label asp-for="IsVerified" class="form-check-label"></label>
        </div>
    </div>
</div>

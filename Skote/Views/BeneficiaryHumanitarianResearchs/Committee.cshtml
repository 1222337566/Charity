@model InfrastructureManagmentWebFramework.Models.Charity.HumanitarianResearch.CommitteeBeneficiaryHumanitarianResearchVm
@{ ViewData["Title"] = "قرار اللجنة"; }

<style>
.cm-hero{background:linear-gradient(135deg,#2d4a8a,#3d5fa0);border-radius:16px;padding:18px 24px;color:#fff;margin-bottom:18px}
.cm-card{background:#fff;border-radius:16px;border:.5px solid rgba(45,74,138,.12);box-shadow:0 2px 10px rgba(45,74,138,.05);margin-bottom:16px}
.cm-head{padding:14px 18px 12px;border-bottom:.5px solid rgba(45,74,138,.08);font-size:.92rem;font-weight:700;color:#2d4a8a}
.cm-body{padding:18px}
.dec-btn{padding:12px 16px;border-radius:12px;border:1.5px solid;cursor:pointer;transition:.15s;width:100%;text-align:center;font-weight:700;font-size:.88rem;background:#fff}
.dec-btn.approve{border-color:#34c38f;color:#0d7a5a}
.dec-btn.approve.sel,.dec-btn.approve:hover{background:#34c38f;color:#fff}
.dec-btn.partial{border-color:#f1b44c;color:#8a5f00}
.dec-btn.partial.sel,.dec-btn.partial:hover{background:#f1b44c;color:#fff}
.dec-btn.reject{border-color:#f46a6a;color:#ab2b2b}
.dec-btn.reject.sel,.dec-btn.reject:hover{background:#f46a6a;color:#fff}
.amount-section{background:rgba(52,195,143,.06);border-radius:12px;padding:14px 16px;border:.5px solid rgba(52,195,143,.2)}
.note-box{background:rgba(241,180,76,.08);border-radius:12px;padding:12px 16px;font-size:.82rem;color:#8a5f00;border:.5px solid rgba(241,180,76,.2)}
</style>

<div class="cm-hero">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h5 class="fw-bold mb-1 text-white"><i class="bx bx-group me-2"></i>قرار اللجنة</h5>
      <div style="opacity:.75;font-size:.8rem">
        قرار اللجنة سيُنشئ تلقائياً طلب مساعدة معتمد وسجل صرف عند الموافقة
      </div>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light btn-sm fw-bold">
      <i class="bx bx-arrow-back me-1"></i>رجوع
    </a>
  </div>
</div>

@* تنبيه الربط التلقائي *@
<div class="note-box mb-3">
  <i class="bx bx-info-circle me-2"></i>
  <strong>تنبيه:</strong> عند تسجيل قرار "موافقة" أو "موافقة جزئية" — يُنشئ النظام تلقائياً
  <strong>قرار لجنة</strong> + <strong>طلب مساعدة معتمد</strong> + <strong>سجل صرف معتمد متاح للتنفيذ</strong>.
</div>

<form asp-action="Committee" method="post">
  @Html.AntiForgeryToken()
  <input asp-for="Id" type="hidden"/>
  <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="border-radius:12px"></div>

  @* تاريخ الاجتماع + القرار *@
  <div class="cm-card">
    <div class="cm-head"><i class="bx bx-calendar-check me-2"></i>اجتماع اللجنة</div>
    <div class="cm-body">
      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <label asp-for="CommitteeMeetingDate" class="form-label fw-semibold"></label>
          <input asp-for="CommitteeMeetingDate" type="date" class="form-control" style="border-radius:10px"/>
          <span asp-validation-for="CommitteeMeetingDate" class="text-danger small"></span>
        </div>
      </div>

      @* بطاقات القرار *@
      <input type="hidden" asp-for="Decision" id="dec-hidden"/>
      <div class="row g-3 mb-2">
        <div class="col-md-4">
          <div class="dec-btn approve" data-decision="Approve" onclick="pickDec('Approve', this)">
            <i class="bx bx-check-circle" style="font-size:1.3rem;display:block;margin-bottom:5px"></i>
            موافقة ✓
          </div>
        </div>
        <div class="col-md-4">
          <div class="dec-btn partial" data-decision="PartialApprove" onclick="pickDec('PartialApprove', this)">
            <i class="bx bx-check-square" style="font-size:1.3rem;display:block;margin-bottom:5px"></i>
            موافقة جزئية
          </div>
        </div>
        <div class="col-md-4">
          <div class="dec-btn reject" data-decision="Reject" onclick="pickDec('Reject', this)">
            <i class="bx bx-x-circle" style="font-size:1.3rem;display:block;margin-bottom:5px"></i>
            رفض ✗
          </div>
        </div>
      </div>
      <span asp-validation-for="Decision" class="text-danger small"></span>
    </div>
  </div>

  @* تفاصيل الموافقة — تظهر فقط عند موافقة/جزئية *@
  <div id="approval-section" style="display:none">
    <div class="cm-card">
      <div class="cm-head"><i class="bx bx-money me-2"></i>تفاصيل المساعدة المعتمدة</div>
      <div class="cm-body">
        <div class="amount-section mb-3">
          <div class="row g-3">
            <div class="col-md-4">
              <label asp-for="ApprovedAidTypeId" class="form-label fw-semibold"></label>
              <select asp-for="ApprovedAidTypeId" asp-items="Model.AidTypes" class="form-select" style="border-radius:10px"></select>
              <span asp-validation-for="ApprovedAidTypeId" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label asp-for="ApprovedAmount" class="form-label fw-semibold"></label>
              <div class="input-group">
                <input asp-for="ApprovedAmount" class="form-control" style="border-radius:10px 0 0 10px"
                       placeholder="0.00"/>
                <span class="input-group-text" style="border-radius:0 10px 10px 0">جنيه</span>
              </div>
              <span asp-validation-for="ApprovedAmount" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label asp-for="DurationMonths" class="form-label fw-semibold"></label>
              <div class="input-group">
                <input asp-for="DurationMonths" class="form-control" style="border-radius:10px 0 0 10px"
                       placeholder="0"/>
                <span class="input-group-text" style="border-radius:0 10px 10px 0">شهر</span>
              </div>
              <span asp-validation-for="DurationMonths" class="text-danger small"></span>
            </div>
          </div>
        </div>

        @* ما سيُنشأ تلقائياً *@
        <div id="auto-create-info" class="alert alert-success" style="border-radius:12px;font-size:.82rem">
          <i class="bx bx-magic me-2"></i>
          <strong>سيُنشئ النظام تلقائياً:</strong>
          قرار لجنة في سجل المستفيد + طلب مساعدة معتمد بنفس النوع والمبلغ + سجل صرف معتمد متاح للتنفيذ من الخزينة
        </div>
      </div>
    </div>
  </div>

  @* ملاحظات اللجنة *@
  <div class="cm-card">
    <div class="cm-head"><i class="bx bx-note me-2"></i>ملاحظات اللجنة</div>
    <div class="cm-body">
      <textarea asp-for="Notes" class="form-control" rows="3" style="border-radius:10px"
                placeholder="ملاحظات وتوصيات اللجنة..."></textarea>
    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary fw-bold" style="border-radius:12px">
      <i class="bx bx-save me-1"></i>حفظ قرار اللجنة
    </button>
    <a asp-action="Details" asp-route-id="@Model.Id"
       class="btn btn-light fw-bold" style="border-radius:12px">إلغاء</a>
  </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial"/>
<script>
function pickDec(val, btn) {
    document.getElementById('dec-hidden').value = val;
    document.querySelectorAll('.dec-btn').forEach(b => b.classList.remove('sel'));
    if (btn) btn.classList.add('sel');
    var sec = document.getElementById('approval-section');
    sec.style.display = (val === 'Approve' || val === 'PartialApprove' || val === 'ApproveAid') ? '' : 'none';
}

document.addEventListener('DOMContentLoaded', function () {
    var current = document.getElementById('dec-hidden').value;
    if (!current) return;
    var btn = document.querySelector('.dec-btn[data-decision="' + current + '"]');
    pickDec(current, btn);
});
</script>
}

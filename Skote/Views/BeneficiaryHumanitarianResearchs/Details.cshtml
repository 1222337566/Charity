@using Skote.Helpers
@model InfrastrfuctureManagmentCore.Domains.Charity.HumanitarianResearch.BeneficiaryHumanitarianResearch
@{
    ViewData["Title"] = "تفاصيل استمارة البحث الإنساني";
    var canSubmitResearch = User.HasCharityPermission(CharityPermissions.BeneficiariesManage);
    var canReviewResearch = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.ResearchReview);
    var canIssueCommittee = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.CommitteeDecisionManage);
    var hasCommitteeEvaluation = Model.CommitteeEvaluations != null && Model.CommitteeEvaluations.Any();
    var readyForCommitteeDecision = Model.Status == "SentToCommittee" || (Model.Status == "CommitteeDecided" && !hasCommitteeEvaluation);
}

<div class="page-title-box d-sm-flex align-items-center justify-content-between">
    <h4 class="mb-sm-0">تفاصيل استمارة البحث الإنساني</h4>
    <div class="page-title-right d-flex gap-2">
        <a asp-action="Index" class="btn btn-secondary">رجوع</a>
    </div>
</div>

<div class="row">
    <div class="col-xl-8">
        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">البيانات الأساسية</h5></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4"><strong>رقم الاستمارة:</strong> @Model.ResearchNumber</div>
                    <div class="col-md-4"><strong>الحالة:</strong> @Model.Status</div>
                    <div class="col-md-4"><strong>الأولوية:</strong> @Model.PriorityLevel</div>
                    <div class="col-md-4"><strong>اسم الحالة:</strong> @Model.FullName</div>
                    <div class="col-md-4"><strong>مقدم الطلب:</strong> @Model.ApplicantName</div>
                    <div class="col-md-4"><strong>نوع المساعدة:</strong> @Model.AidTypeName</div>
                    <div class="col-md-4"><strong>تاريخ الطلب:</strong> @Model.RequestDate.ToString("yyyy-MM-dd")</div>
                    <div class="col-md-4"><strong>تاريخ البحث:</strong> @(Model.ResearchDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="col-md-4"><strong>الرقم القومي:</strong> @Model.NationalId</div>
                    <div class="col-md-6"><strong>العنوان:</strong> @Model.AddressLine</div>
                    <div class="col-md-3"><strong>العمر:</strong> @Model.Age</div>
                    <div class="col-md-3"><strong>الحالة الاجتماعية:</strong> @Model.MaritalStatus</div>
                    <div class="col-md-4"><strong>إجمالي الأسرة:</strong> @Model.FamilyMembersCount</div>
                    <div class="col-md-4"><strong>إجمالي الدخل:</strong> @Model.TotalIncome</div>
                    <div class="col-md-4"><strong>إجمالي المصروفات:</strong> @Model.TotalExpenses</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">الاحتياجات والسكن</h5></div>
            <div class="card-body">
                <p><strong>الاحتياجات المطلوبة:</strong><br />@Model.RequiredNeedsPrimary</p>
                <p><strong>احتياجات أخرى:</strong><br />@Model.RequiredNeedsSecondary</p>
                <p><strong>وصف السكن:</strong><br />@Model.HousingDescription</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">تقرير الباحث ورأي مسؤول البحوث</h5></div>
            <div class="card-body">
                <p><strong>تقرير الباحث:</strong><br />@Model.ResearcherReport</p>
                <hr />
                <p><strong>رأي مسؤول البحوث:</strong><br />@Model.ResearchManagerOpinion</p>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">إجراءات الـ Workflow</h5></div>
            <div class="card-body">
                <div class="alert alert-light border mb-3">
                    <div><strong>المراجع:</strong> يراجع الاستمارة ويُحيلها للجنة بعد الاعتماد.</div>
                    <div><strong>الأدمن:</strong> هو الوحيد الذي يستطيع تسجيل قرار اللجنة.</div>
                </div>
                <div class="d-grid gap-2">
                    @if (canSubmitResearch && (Model.Status == "Draft" || Model.Status == "ReturnedForRevision"))
                    {
                        <form asp-action="SubmitForReview" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary">إرسال للمراجع</button>
                        </form>
                    }
                    @if (canReviewResearch && (Model.Status == "SubmittedForReview" || Model.Status == "ReviewedRejected" || Model.Status == "ReturnedForRevision"))
                    {
                        <a asp-action="Review" asp-route-id="@Model.Id" class="btn btn-warning">فتح شاشة المراجعة</a>
                    }
                    @if (canReviewResearch && Model.Status == "ReviewedApproved")
                    {
                        <form asp-action="SendToCommittee" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-info">إحالة للجنة</button>
                        </form>
                    }
                    @if (readyForCommitteeDecision)
                    {
                        if (canIssueCommittee)
                        {
                            <a asp-action="Committee" asp-route-id="@Model.Id" class="btn btn-success">قرار اللجنة</a>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-success" disabled>قرار اللجنة - تحتاج صلاحية</button>
                            <div class="small text-muted">الاستمارة جاهزة لقرار اللجنة، لكن حسابك لا يملك صلاحية CommitteeDecisionManage.</div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">المراجعات</h5></div>
            <div class="card-body">
                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    foreach (var review in Model.Reviews.OrderByDescending(x => x.ReviewDateUtc))
                    {
                        <div class="border rounded p-2 mb-2">
                            <div><strong>القرار:</strong> @review.Decision</div>
                            <div><strong>السبب:</strong> @review.Reason</div>
                            <div><strong>ملاحظات:</strong> @review.Notes</div>
                            <small class="text-muted">@review.ReviewDateUtc.ToString("yyyy-MM-dd HH:mm")</small>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted">لا توجد مراجعات.</div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h5 class="card-title mb-0">قرارات اللجنة</h5></div>
            <div class="card-body">
                @if (Model.CommitteeEvaluations != null && Model.CommitteeEvaluations.Any())
                {
                    foreach (var item in Model.CommitteeEvaluations.OrderByDescending(x => x.CommitteeMeetingDate))
                    {
                        <div class="border rounded p-2 mb-2">
                            <div><strong>القرار:</strong> @item.Decision</div>
                            <div><strong>نوع المساعدة:</strong> @item.ApprovedAidType</div>
                            <div><strong>القيمة:</strong> @item.ApprovedAmount</div>
                            <div><strong>المدة:</strong> @item.DurationMonths</div>
                            <div><strong>ملاحظات:</strong> @item.Notes</div>
                            <small class="text-muted">@item.CommitteeMeetingDate.ToString("yyyy-MM-dd")</small>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted">لا توجد قرارات لجنة.</div>
                }
            </div>
        </div>
    </div>
</div>

@using Skote.Helpers
@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Shared
@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.HumanitarianResearch.BeneficiaryHumanitarianResearchListItemVm>
@{
    ViewData["Title"] = "استمارات البحث الإنساني";
    var canCreateResearch = User.HasCharityPermission(CharityPermissions.BeneficiariesManage);
    var canReviewResearch = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.ResearchReview);
    var canIssueCommittee = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.CommitteeDecisionManage);
    var beneficiaryId = ViewBag.BeneficiaryId as Guid?;
    var beneficiaryName = ViewBag.BeneficiaryName as string;
    
    var beneficiaryCode = ViewBag.BeneficiaryCode as string;
    var beneficiaryNationalId = ViewBag.BeneficiaryNationalId as string;
    var beneficiaryPhone = ViewBag.BeneficiaryPhoneNumber as string;
    var beneficiaryStatus = ViewBag.BeneficiaryStatusName as string;
}
@if (beneficiaryId.HasValue)
{
    var beneficiaryHeader = new BeneficiaryHeaderVm
                {
                    Id = beneficiaryId.Value,
                    Code = beneficiaryCode ?? string.Empty,
                    FullName = beneficiaryName ?? string.Empty,
                    NationalId = beneficiaryNationalId ?? string.Empty,
                    PhoneNumber = beneficiaryPhone ?? string.Empty,
                    StatusName = beneficiaryStatus ?? string.Empty
                };

    <partial name="~/Views/Shared/Beneficiaries/_BeneficiaryHeader.cshtml" model="beneficiaryHeader" />
}
<div class="page-title-box d-sm-flex align-items-center justify-content-between">
    <h4 class="mb-sm-0">استمارات البحث الإنساني</h4>
    <div class="page-title-right d-flex gap-2">
        @if (canCreateResearch)
        {
            if (beneficiaryId.HasValue)
            {
                <a asp-action="Create" asp-route-beneficiaryId="@beneficiaryId" class="btn btn-primary">إنشاء استمارة جديدة</a>
            }
            else
            {
                <a asp-action="Create" class="btn btn-primary">إنشاء استمارة جديدة</a>
            }
        }
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(beneficiaryName))
{
    <div class="alert alert-info">
        عرض الاستمارات الخاصة بالمستفيد: <strong>@beneficiaryName</strong>
    </div>
}

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead>
                    <tr>
                        <th>رقم الاستمارة</th>
                        <th>كود المستفيد</th>
                        <th>اسم الحالة</th>
                        <th>مقدم الطلب</th>
                        <th>تاريخ الطلب</th>
                        <th>الحالة</th>
                        <th>قرار المراجع</th>
                        <th>قرار اللجنة</th>
                        <th style="width:220px;">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ResearchNumber</td>
                        <td>@item.BeneficiaryCode</td>
                        <td>@item.FullName</td>
                        <td>@item.ApplicantName</td>
                        <td>@item.RequestDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.Status</td>
                        <td>@item.ReviewDecision</td>
                        <td>@item.CommitteeDecision</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">عرض</a>
                                    @{
                                        var status = (item.Status ?? "").Trim();

                                        var canReview =
                                        status == "Draft" ||
                                        status == "UnderReview" ||
                                        status == "ReturnedForReview" ||
                                        status == "PendingReview" ||
                                        status == "WorkflowPending";

                                        var canCommittee =
                                        status == "SentToCommittee";
                                    }

                                    @if (canReview)
                                    {
                                        <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                            مراجعة
                                        </a>
                                    }
                                    @if (item.Status == "SentToCommittee" || item.Status == "CommitteeDecided")
                                    {
                                        <span class="badge bg-success">تمت المراجعة</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">لم تتم</span>
                                    }
                                    @if (canCommittee)
                                    {
                                        <a asp-action="Committee" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                                            اللجنة
                                        </a>
                                    }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

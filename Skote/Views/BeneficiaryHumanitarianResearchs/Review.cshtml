@model InfrastructureManagmentWebFramework.Models.Charity.HumanitarianResearch.ReviewBeneficiaryHumanitarianResearchVm
@{ ViewData["Title"] = "مراجعة استمارة البحث الإنساني"; }

<style>
.rv-hero{background:linear-gradient(135deg,#2d4a8a,#3d5fa0);border-radius:16px;padding:18px 24px;color:#fff;margin-bottom:18px}
.rv-card{background:#fff;border-radius:16px;border:.5px solid rgba(45,74,138,.12);box-shadow:0 2px 10px rgba(45,74,138,.05);margin-bottom:16px}
.rv-head{padding:14px 18px 12px;border-bottom:.5px solid rgba(45,74,138,.08);font-size:.92rem;font-weight:700;color:#2d4a8a}
.rv-body{padding:18px}
.decision-btn{padding:14px 20px;border-radius:14px;border:1.5px solid;cursor:pointer;transition:.15s;width:100%;text-align:center;font-weight:700;background:#fff}
.decision-btn:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.1)}
.decision-btn.approve{border-color:#34c38f;color:#0d7a5a}
.decision-btn.approve.selected,.decision-btn.approve:hover{background:#34c38f;color:#fff}
.decision-btn.reject{border-color:#f46a6a;color:#ab2b2b}
.decision-btn.reject.selected,.decision-btn.reject:hover{background:#f46a6a;color:#fff}
.decision-btn.return{border-color:#f1b44c;color:#8a5f00}
.decision-btn.return.selected,.decision-btn.return:hover{background:#f1b44c;color:#fff}
.status-pill{padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:700}
</style>

<div class="rv-hero">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h5 class="fw-bold mb-1 text-white"><i class="bx bx-search-alt-2 me-2"></i>مراجعة استمارة البحث الإنساني</h5>
      <div style="opacity:.75;font-size:.8rem">يتم توثيق قرار المراجعة ويُرسل تلقائياً للخطوة التالية</div>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light btn-sm fw-bold">
      <i class="bx bx-arrow-back me-1"></i>رجوع
    </a>
  </div>
</div>

<form asp-action="Review" method="post">
  @Html.AntiForgeryToken()
  <input asp-for="Id" type="hidden"/>
  <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="border-radius:12px"></div>

  @* اختيار القرار — بطاقات مرئية *@
  <div class="rv-card">
    <div class="rv-head"><i class="bx bx-git-branch me-2"></i>قرار المراجعة</div>
    <div class="rv-body">
      <input type="hidden" asp-for="Decision" id="decision-hidden"/>
      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <div class="decision-btn approve" onclick="selectDecision('Approve', this)">
            <i class="bx bx-check-circle" style="font-size:1.5rem;display:block;margin-bottom:6px"></i>
            اعتماد ✓
            <div style="font-size:.72rem;opacity:.75;margin-top:4px">الاستمارة مكتملة ومقبولة</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="decision-btn return" onclick="selectDecision('ReturnForRevision', this)">
            <i class="bx bx-revision" style="font-size:1.5rem;display:block;margin-bottom:6px"></i>
            إرجاع للتعديل ↩
            <div style="font-size:.72rem;opacity:.75;margin-top:4px">تحتاج تعديل قبل الإحالة</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="decision-btn reject" onclick="selectDecision('Reject', this)">
            <i class="bx bx-x-circle" style="font-size:1.5rem;display:block;margin-bottom:6px"></i>
            رفض ✗
            <div style="font-size:.72rem;opacity:.75;margin-top:4px">الاستمارة غير مقبولة</div>
          </div>
        </div>
      </div>
      <span asp-validation-for="Decision" class="text-danger small"></span>
    </div>
  </div>

  @* السبب والملاحظات *@
  <div class="rv-card">
    <div class="rv-head"><i class="bx bx-note me-2"></i>تفاصيل القرار</div>
    <div class="rv-body">
      <div class="mb-3">
        <label asp-for="Reason" class="form-label fw-semibold">
          سبب القرار <span class="text-danger">*</span>
        </label>
        <textarea asp-for="Reason" class="form-control" rows="3"
                  style="border-radius:10px"
                  placeholder="اكتب سبب القرار بوضوح..."></textarea>
        <span asp-validation-for="Reason" class="text-danger small"></span>
      </div>
      <div class="mb-3">
        <label asp-for="Notes" class="form-label fw-semibold">ملاحظات إضافية</label>
        <textarea asp-for="Notes" class="form-control" rows="2"
                  style="border-radius:10px"
                  placeholder="ملاحظات اختيارية..."></textarea>
      </div>
    </div>
  </div>

  @* ما سيحدث بعد القرار *@
  <div id="decision-info" style="display:none" class="alert mb-3" style="border-radius:12px"></div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary fw-bold" style="border-radius:12px">
      <i class="bx bx-save me-1"></i>حفظ قرار المراجعة
    </button>
    <a asp-action="Details" asp-route-id="@Model.Id"
       class="btn btn-light fw-bold" style="border-radius:12px">إلغاء</a>
  </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial"/>
<script>
var infoMap = {
    'Approve':           { cls:'alert-success', icon:'bx-check-circle', text:'✓ ستُحال الاستمارة تلقائياً للمدير لإرسالها إلى اللجنة' },
    'ReturnForRevision': { cls:'alert-warning',  icon:'bx-revision',     text:'↩ ستُعاد الاستمارة للباحث لإجراء التعديلات المطلوبة' },
    'Reject':            { cls:'alert-danger',   icon:'bx-x-circle',     text:'✗ ستُغلق الاستمارة ولن تُحال للجنة' }
};

function selectDecision(val, btn) {
    document.getElementById('decision-hidden').value = val;
    document.querySelectorAll('.decision-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    var info = document.getElementById('decision-info');
    var d = infoMap[val];
    if (d) {
        info.className = 'alert mb-3 ' + d.cls;
        info.innerHTML = '<i class="bx ' + d.icon + ' me-2"></i>' + d.text;
        info.style.display = '';
        info.style.borderRadius = '12px';
    }
}
</script>
}

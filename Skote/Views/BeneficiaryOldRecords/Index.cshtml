@using InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.OldRecords
@model List<BeneficiaryOldRecordListItemVm>
@{ ViewData["Title"] = "السجلات السابقة"; }
<div class="container-fluid">
    <partial name="~/Views/Shared/Beneficiaries/_BeneficiaryHeader.cshtml" />
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">السجلات السابقة</h5>
            <a asp-action="Create" asp-route-beneficiaryId="@ViewBag.BeneficiaryId" class="btn btn-primary btn-sm">إضافة سجل</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light"><tr><th>التاريخ</th><th>العنوان</th><th>التفاصيل</th><th>نشط</th><th style="width:120px">إجراءات</th></tr></thead>
                    <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RecordDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.Title</td>
                                <td>@(item.Details ?? "-")</td>
                                <td>@(item.IsActive ? "نعم" : "لا")</td>
                                <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-soft-primary">تعديل</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center text-muted">لا توجد سجلات سابقة</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@using InfrastrfuctureManagmentCore.Domains.Charity.MinutesAndDecisions;
@model IEnumerable<BoardDecisionAttachment>
@{
    ViewData["Title"] = "ملفات القرار";
    var decision = ViewBag.Decision as InfrastrfuctureManagmentCore.Domains.Charity.MinutesAndDecisions.BoardDecision;
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h4 class="mb-1">ملفات القرار</h4>
            <div class="text-muted">@decision?.Title - @decision?.DecisionNumber</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Create" asp-route-boardDecisionId="@decision?.Id" class="btn btn-primary">رفع ملف</a>
            <a asp-controller="BoardDecisions" asp-action="Details" asp-route-id="@decision?.Id" class="btn btn-light">العودة للقرار</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th>اسم الملف</th>
                                <th>النوع</th>
                                <th>الحجم</th>
                                <th>تاريخ الرفع</th>
                                <th>ملاحظات</th>
                                <th style="width:180px;">إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.OriginalFileName</td>
                                <td>@item.ContentType</td>
                                <td>@String.Format("{0:N0}", item.FileSizeBytes  / 1024.0) KB</td>
                                <td>@item.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@item.Notes</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Download" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تحميل</a>
                                        <form asp-action="Delete" method="post" onsubmit="return confirm('حذف الملف؟');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-muted">لا توجد ملفات مرفوعة لهذا القرار.</div>
            }
        </div>
    </div>
</div>

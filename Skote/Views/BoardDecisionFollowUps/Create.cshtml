@model Skote.Models.Charity.MinutesAndDecisions.BoardDecisionFollowUpVm
@{
    var decision = ViewBag.Decision as InfrastrfuctureManagmentCore.Domains.Charity.MinutesAndDecisions.BoardDecision;
    ViewData["Title"] = "إضافة متابعة";
}
<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">إضافة متابعة قرار</h4>
            <small class="text-muted">@decision?.DecisionNumber - @decision?.Title</small>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <input type="hidden" asp-for="BoardDecisionId" />
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">تاريخ المتابعة</label>
                        <input asp-for="FollowUpDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">الحالة</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Open">مفتوح</option>
                            <option value="InProgress">قيد التنفيذ</option>
                            <option value="Completed">مكتمل</option>
                            <option value="Deferred">مؤجل</option>
                            <option value="Blocked">متوقف</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">نسبة الإنجاز</label>
                        <input asp-for="ProgressPercent" type="number" min="0" max="100" class="form-control" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">تفاصيل المتابعة</label>
                        <textarea asp-for="Details" class="form-control" rows="5"></textarea>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">الإجراء التالي</label>
                        <textarea asp-for="NextAction" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">حفظ</button>
                    <a asp-action="Index" asp-route-boardDecisionId="@decision?.Id" class="btn btn-light">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>

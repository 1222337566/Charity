@model Skote.Models.Charity.MinutesAndDecisions.BoardDecisionVm
@{
    var meeting = ViewBag.Meeting as InfrastrfuctureManagmentCore.Domains.Charity.MinutesAndDecisions.BoardMeeting;
    ViewData["Title"] = "إضافة قرار";
}
<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">إضافة قرار / توصية</h4>
            <small class="text-muted">@meeting?.Title</small>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @await Html.PartialAsync("_Form", Model)
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">حفظ</button>
                    <a asp-action="Index" asp-route-meetingId="@meeting?.Id" class="btn btn-light">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>

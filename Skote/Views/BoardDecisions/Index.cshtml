@model IEnumerable<InfrastrfuctureManagmentCore.Domains.Charity.MinutesAndDecisions.BoardDecision>
@{
    var meeting = ViewBag.Meeting as InfrastrfuctureManagmentCore.Domains.Charity.MinutesAndDecisions.BoardMeeting;
    ViewData["Title"] = "قرارات الاجتماع";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h4 class="mb-1">قرارات الاجتماع</h4>
            <div class="text-muted">@meeting?.Title</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="BoardMeetings" asp-action="Details" asp-route-id="@meeting?.Id" class="btn btn-light">الرجوع للاجتماع</a>
            <a asp-action="Create" asp-route-boardMeetingId="@meeting?.Id" class="btn btn-primary">إضافة قرار</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>رقم القرار</th>
                        <th>العنوان</th>
                        <th>النوع</th>
                        <th>المسؤول</th>
                        <th>الاستحقاق</th>
                        <th>الحالة</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DecisionNumber</td>
                        <td>@item.Title</td>
                        <td>@item.DecisionKind</td>
                        <td>@item.ResponsibleParty</td>
                        <td>@item.DueDate?.ToString("yyyy-MM-dd")</td>
                        <td>@item.Status</td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تفاصيل</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a>
                                <a asp-controller="BoardDecisionFollowUps" asp-action="Index" asp-route-boardDecisionId="@item.Id" class="btn btn-sm btn-outline-success">متابعات</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

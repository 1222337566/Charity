@model InfrastrfuctureManagmentCore.Domains.Charity.MinutesAndDecisions.BoardMeeting
@{
    ViewData["Title"] = "تفاصيل الاجتماع";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h4 class="mb-1">@Model.Title</h4>
            <div class="text-muted">رقم الاجتماع: @Model.MeetingNumber | التاريخ: @Model.MeetingDate.ToString("yyyy-MM-dd") | الحالة: @Model.Status</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">تعديل</a>
            <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-outline-success">طباعة</a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><h5 class="mb-0">البيانات الأساسية</h5></div>
                <div class="card-body">
                    <p><strong>المكان:</strong> @Model.Location</p>
                    <p><strong>نوع الاجتماع:</strong> @Model.MeetingType</p>
                    <p><strong>وقت البدء:</strong> @Model.StartTime</p>
                    <p><strong>وقت الانتهاء:</strong> @Model.EndTime</p>
                    <p><strong>جدول الأعمال:</strong></p>
                    <div class="border rounded p-3 bg-light">@Html.Raw((Model.Agenda ?? "").Replace("\n","<br />"))</div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">القرارات والتوصيات</h5>
                    <a asp-controller="BoardDecisions" asp-action="Create" asp-route-boardMeetingId="@Model.Id" class="btn btn-sm btn-primary">إضافة قرار</a>
                </div>
                <div class="card-body">
                    @if (Model.Decisions.Any())
                    {
                        <div class="list-group">
                            @foreach (var decision in Model.Decisions.OrderBy(x => x.DecisionNumber))
                            {
                                <a asp-controller="BoardDecisions" asp-action="Details" asp-route-id="@decision.Id" class="list-group-item list-group-item-action">
                                    <div class="d-flex justify-content-between">
                                        <strong>@decision.DecisionNumber - @decision.Title</strong>
                                        <span class="badge bg-secondary">@decision.Status</span>
                                    </div>
                                    <small class="text-muted">@decision.DecisionKind | المسؤول: @decision.ResponsibleParty</small>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">لا توجد قرارات مسجلة حتى الآن.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-12">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">الحضور</h5></div>
                <div class="card-body table-responsive">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>الاسم</th>
                                <th>الصفة</th>
                                <th>الحالة</th>
                                <th>ملاحظات</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var attendee in Model.Attendees)
                        {
                            <tr>
                                <td>@attendee.FullName</td>
                                <td>@attendee.PositionTitle</td>
                                <td>@attendee.AttendanceStatus</td>
                                <td>@attendee.Notes</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-12">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">المحضر</h5></div>
                <div class="card-body">
                    <h6>الافتتاح</h6>
                    <div class="border rounded p-3 mb-3 bg-light">@Html.Raw((Model.Minute?.LegalOpeningText ?? "").Replace("\n","<br />"))</div>

                    <h6>ملخص المناقشات</h6>
                    <div class="border rounded p-3 mb-3 bg-light">@Html.Raw((Model.Minute?.DiscussionSummary ?? "").Replace("\n","<br />"))</div>

                    <h6>التوصيات</h6>
                    <div class="border rounded p-3 mb-3 bg-light">@Html.Raw((Model.Minute?.RecommendationsSummary ?? "").Replace("\n","<br />"))</div>

                    <h6>المحضر الكامل</h6>
                    <div class="border rounded p-3 bg-light">@Html.Raw((Model.Minute?.FullMinuteText ?? "").Replace("\n","<br />"))</div>
                </div>
            </div>
        </div>
    </div>
</div>

@model Skote.Models.Charity.MinutesAndDecisions.BoardMeetingVm
@{
    ViewData["Title"] = "تعديل اجتماع";
}
<div class="container-fluid">
    <div class="card">
        <div class="card-header"><h4 class="mb-0">تعديل اجتماع ومحضر</h4></div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                @await Html.PartialAsync("_Form", Model)
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>

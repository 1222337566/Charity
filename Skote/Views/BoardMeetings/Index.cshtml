@model IEnumerable<InfrastrfuctureManagmentCore.Domains.Charity.MinutesAndDecisions.BoardMeeting>
@{
    ViewData["Title"] = "المحاضر والاجتماعات";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-1">المحاضر والاجتماعات</h4>
            <p class="text-muted mb-0">إدارة اجتماعات مجلس الإدارة واللجان ومحاضرها وقراراتها.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">إضافة اجتماع</a>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>رقم الاجتماع</th>
                        <th>العنوان</th>
                        <th>التاريخ</th>
                        <th>المكان</th>
                        <th>الحالة</th>
                        <th style="width:260px"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MeetingNumber</td>
                        <td>@item.Title</td>
                        <td>@item.MeetingDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.Location</td>
                        <td>@item.Status</td>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تفاصيل</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a>
                                <a asp-controller="BoardDecisions" asp-action="Index" asp-route-meetingId="@item.Id" class="btn btn-sm btn-outline-dark">القرارات</a>
                                <a asp-action="Print" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">طباعة</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

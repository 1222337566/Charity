@model Skote.Controllers.BulkMessageFilterVm
@{ ViewData["Title"] = "الرسائل الجماعية"; }
@{ var m = Model ?? new Skote.Controllers.BulkMessageFilterVm(); }

<style>
.msg-hero{background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px;padding:20px 26px;color:#fff;margin-bottom:20px}
.msg-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 2px 10px rgba(14,111,115,.05);margin-bottom:16px}
.msg-head{padding:14px 18px 12px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.92rem;font-weight:700;color:#0a5f63}
.msg-body{padding:18px}
.group-btn{padding:10px 18px;border-radius:12px;border:1.5px solid rgba(14,111,115,.2);background:#fff;font-size:.85rem;font-weight:600;cursor:pointer;transition:.12s;color:#15363a;display:flex;align-items:center;gap:8px;flex:1}
.group-btn.active{background:#0e6f73;color:#fff;border-color:#0e6f73}
.group-btn:hover:not(.active){background:#f5faf9;border-color:#0e6f73}
.var-chip{padding:3px 9px;border-radius:6px;background:rgba(14,111,115,.1);color:#0e6f73;font-size:.78rem;font-weight:700;cursor:pointer;font-family:monospace}
.var-chip:hover{background:rgba(14,111,115,.2)}
.recipient-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:.5px dashed rgba(14,111,115,.07)}
.recipient-row:last-child{border-bottom:none}
.rec-badge{padding:2px 8px;border-radius:5px;font-size:.68rem;font-weight:700}
</style>

<div class="msg-hero">
  <h4 class="fw-bold mb-1 text-white"><i class="bx bx-broadcast me-2"></i>الرسائل الجماعية</h4>
  <div style="opacity:.75;font-size:.82rem">إرسال رسائل مجمّعة للمستفيدين أو الكفلاء أو المتبرعين</div>
</div>

@if (TempData["BulkResult"] != null)
{
  <div class="alert alert-success alert-dismissible fade show fw-semibold">
    <i class="bx bx-check-circle me-2"></i>@TempData["BulkResult"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

<div class="row g-3">
  <div class="col-xl-5">
    <form id="msg-form" method="post" asp-action="Preview">
      @Html.AntiForgeryToken()

      <div class="msg-card">
        <div class="msg-head"><i class="bx bx-group me-2"></i>المجموعة المستهدفة</div>
        <div class="msg-body">
          <div class="d-flex gap-2 flex-wrap mb-3">
            @{
              var groups = new[] {
                ("Beneficiaries", "👤", "المستفيدون"),
                ("KafalaOverdue", "🤝", "كفلاء متأخرون"),
                ("Donors",        "💰", "متبرعون صامتون")
              };
            }
            @foreach (var g in groups)
            {
              <button type="button" class="group-btn @(m.TargetGroup == g.Item1 ? "active" : "")"
                      onclick="setGroup('@g.Item1', this)">
                @g.Item2 @g.Item3
              </button>
            }
            <input type="hidden" id="target-group" name="TargetGroup" value="@m.TargetGroup"/>
          </div>

          <div id="filter-months" style="@(m.TargetGroup == "KafalaOverdue" ? "display:none" : "")">
            <label class="form-label fw-semibold" style="font-size:.82rem">
              فلتر: لم يُصرف / يتبرع منذ
            </label>
            <div class="input-group">
              <input type="number" name="FilterNoAidMonths" value="@m.FilterNoAidMonths"
                     min="0" max="24" class="form-control" style="border-radius:10px 0 0 10px"/>
              <span class="input-group-text" style="border-radius:0 10px 10px 0">شهر (0 = الكل)</span>
            </div>
          </div>
        </div>
      </div>

      <div class="msg-card">
        <div class="msg-head"><i class="bx bx-message-edit me-2"></i>نص الرسالة</div>
        <div class="msg-body">
          <div class="mb-2">
            <label class="form-label fw-semibold" style="font-size:.82rem">الموضوع</label>
            <input name="Subject" value="@m.Subject" class="form-control"
                   placeholder="موضوع الرسالة..." style="border-radius:10px"/>
          </div>
          <div class="mb-2">
            <label class="form-label fw-semibold" style="font-size:.82rem">نص الرسالة</label>
            <textarea name="MessageText" id="msg-text" class="form-control" rows="5"
                      placeholder="اكتب رسالتك هنا..." style="border-radius:10px;font-size:.9rem">@m.MessageText</textarea>
          </div>
          <div class="d-flex gap-2 flex-wrap mb-1">
            <span style="font-size:.75rem;color:#6b7d80;align-self:center">متغيرات:</span>
            <span class="var-chip" onclick="insertVar('{الاسم}')">{الاسم}</span>
            <span class="var-chip" onclick="insertVar('{الكود}')">{الكود}</span>
            <span class="var-chip" onclick="insertVar('{التفاصيل}')">{التفاصيل}</span>
          </div>
          <div style="font-size:.72rem;color:#adb5bd">
            مثال: «السيد {الاسم}، نذكركم بالكفالة {الكود} المستحقة — {التفاصيل}»
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" formaction="@Url.Action("Preview")"
                class="btn btn-outline-primary flex-fill fw-bold" style="border-radius:12px">
          <i class="bx bx-show me-1"></i>معاينة المستلمين
        </button>
        <button type="submit" formaction="@Url.Action("Send")"
                class="btn btn-success flex-fill fw-bold" style="border-radius:12px"
                onclick="return confirm('إرسال لـ ' + document.getElementById('rec-count').textContent + ' شخص؟')">
          <i class="bx bx-send me-1"></i>إرسال الآن
        </button>
      </div>
    </form>
  </div>

  <div class="col-xl-7">
    <div class="msg-card">
      <div class="msg-head d-flex justify-content-between">
        <span><i class="bx bx-list-ul me-2"></i>المستلمون</span>
        <span class="badge" style="background:rgba(14,111,115,.12);color:#0e6f73;font-size:.8rem">
          <span id="rec-count">@m.Recipients.Count</span> شخص
        </span>
      </div>
      <div class="msg-body" style="max-height:520px;overflow-y:auto">
        @if (!m.Recipients.Any())
        {
          <div class="text-center text-muted py-5">
            <i class="bx bx-group" style="font-size:2.5rem;display:block;margin-bottom:10px"></i>
            <p style="font-size:.85rem">اضغط "معاينة المستلمين" لعرض القائمة</p>
          </div>
        }
        else
        {
          @foreach (var r in m.Recipients)
          {
            <div class="recipient-row">
              <div class="flex-grow-1 min-w-0">
                <div class="fw-semibold" style="font-size:.87rem">@r.Name</div>
                <div style="font-size:.75rem;color:#6b7d80">
                  @(r.Phone ?? "بدون هاتف")
                  @if (r.Code != null) { <span> · @r.Code</span> }
                  @if (r.Extra != null) { <span class="text-danger"> · @r.Extra</span> }
                </div>
                @if (r.ResolvedText != null)
                {
                  <div style="font-size:.75rem;color:#0e6f73;margin-top:3px;background:rgba(14,111,115,.05);border-radius:6px;padding:4px 8px">
                    @r.ResolvedText
                  </div>
                }
              </div>
              @if (string.IsNullOrWhiteSpace(r.Phone))
              {
                <span class="rec-badge" style="background:rgba(244,106,106,.15);color:#ab2b2b">بدون هاتف</span>
              }
              else
              {
                <span class="rec-badge" style="background:rgba(52,195,143,.15);color:#0d7a5a">✓</span>
              }
            </div>
          }
        }
      </div>
    </div>
  </div>
</div>

@section scripts {
<script>
function setGroup(val, btn) {
  document.getElementById('target-group').value = val;
  document.querySelectorAll('.group-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('filter-months').style.display = val === 'KafalaOverdue' ? 'none' : '';
}
function insertVar(v) {
  var ta = document.getElementById('msg-text');
  var pos = ta.selectionStart;
  ta.value = ta.value.substring(0, pos) + v + ta.value.substring(ta.selectionEnd);
  ta.selectionStart = ta.selectionEnd = pos + v.length;
  ta.focus();
}
</script>
}

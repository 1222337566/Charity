@{
    ViewData["Title"] = "Calendar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h4 class="card-title mb-0">Calendar</h4>
                    <div>
                        <button id="btn-today" class="btn btn-sm btn-light me-2">اليوم</button>
                        <button id="btn-new" class="btn btn-sm btn-primary">+ حدث جديد</button>
                    </div>
                </div>
                <div id="fc-wrapper">
                    <div id="fc-calendar"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: create/update event -->
<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog">
        <form id="eventForm" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">حدث</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="evt-id">
                <div class="mb-3">
                    <label class="form-label">العنوان</label>
                    <input type="text" class="form-control" id="evt-title" required>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">البداية</label>
                        <input type="datetime-local" class="form-control" id="evt-start" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">النهاية</label>
                        <input type="datetime-local" class="form-control" id="evt-end">
                    </div>
                </div>
                <!-- اختياري: اختيار مدعوين -->
                <!-- <div class="mb-3">
                  <label class="form-label">المدعوون (UserIds مفصولة بفواصل)</label>
                  <input type="text" class="form-control" id="evt-attendees" placeholder="userId1,userId2">
                </div> -->
            </div>
            <div class="modal-footer">
                <button type="button" id="evt-delete" class="btn btn-outline-danger me-auto" style="display:none">حذف</button>
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">إلغاء</button>
                <button type="submit" class="btn btn-primary">حفظ</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/calendar.skote.js?v=1"></script>
}




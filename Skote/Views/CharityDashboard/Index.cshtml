@model InfrastructureManagmentWebFramework.Models.Reports.Dashboard.CharityDashboardVm
@using Skote.Helpers
@{
    ViewData["Title"] = "لوحة تحكم الجمعية";
}

@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")

<div class="row">
    <authz any-policy="BeneficiariesView,BeneficiariesManage"><div class="col-md-3"><div class="card mini-stats-wid"><div class="card-body"><p class="text-muted">المستفيدون</p><h4>@Model.BeneficiariesCount</h4></div></div></div></authz>
    <authz any-policy="DonorsView,DonorsManage"><div class="col-md-3"><div class="card mini-stats-wid"><div class="card-body"><p class="text-muted">المتبرعون</p><h4>@Model.DonorsCount</h4></div></div></div></authz>
    <authz any-policy="FundersView,FundersManage"><div class="col-md-3"><div class="card mini-stats-wid"><div class="card-body"><p class="text-muted">الممولون</p><h4>@Model.FundersCount</h4></div></div></div></authz>
    <authz any-policy="ProjectsView,ProjectsManage"><div class="col-md-3"><div class="card mini-stats-wid"><div class="card-body"><p class="text-muted">المشروعات</p><h4>@Model.ProjectsCount</h4></div></div></div></authz>
</div>

<div class="row">
    <authz any-policy="DonorsView,DonorsManage"><div class="col-md-3"><div class="card"><div class="card-body"><p class="text-muted mb-1">إجمالي التبرعات</p><h5>@Model.TotalDonations.ToString("N2")</h5></div></div></div></authz>
    <authz any-policy="FundersView,FundersManage"><div class="col-md-3"><div class="card"><div class="card-body"><p class="text-muted mb-1">إجمالي المنح المستلمة</p><h5>@Model.TotalReceivedGrants.ToString("N2")</h5></div></div></div></authz>
    <authz any-policy="BeneficiariesView,BeneficiariesManage"><div class="col-md-3"><div class="card"><div class="card-body"><p class="text-muted mb-1">إجمالي الصرف للمستفيدين</p><h5>@Model.TotalAidDisbursed.ToString("N2")</h5></div></div></div></authz>
    <authz any-policy="PayrollView,PayrollManage"><div class="col-md-3"><div class="card"><div class="card-body"><p class="text-muted mb-1">إجمالي صافي المرتبات</p><h5>@Model.TotalPayrollNet.ToString("N2")</h5></div></div></div></authz>
</div>

<div class="row">
    <authz any-policy="BeneficiariesView,BeneficiariesManage">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title mb-3">حالات المستفيدين</h4>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead><tr><th>الحالة</th><th>العدد</th></tr></thead>
                            <tbody>
                            @foreach (var row in Model.BeneficiaryStatuses)
                            {
                                <tr>
                                    <td>@row.Name</td>
                                    <td>@row.Count</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </authz>
    <authz any-policy="DonorsView,DonorsManage">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title mb-3">التبرعات آخر الشهور</h4>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped align-middle">
                            <thead><tr><th>الشهر</th><th>القيمة</th></tr></thead>
                            <tbody>
                            @foreach (var row in Model.MonthlyDonations)
                            {
                                <tr>
                                    <td>@row.Label</td>
                                    <td>@row.Amount.ToString("N2")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </authz>
</div>

<div class="row">
    <authz any-policy="ProjectsView,ProjectsManage">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title mb-3">المشروعات</h4>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>الكود</th>
                                    <th>الاسم</th>
                                    <th>الحالة</th>
                                    <th>الموازنة</th>
                                    <th>المستفيدون</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var row in Model.TopProjects)
                            {
                                <tr>
                                    <td>@row.Code</td>
                                    <td>@row.Name</td>
                                    <td>@row.Status</td>
                                    <td>@row.Budget.ToString("N2")</td>
                                    <td>@row.BeneficiariesCount</td>
                                    <td>
                                        <a asp-controller="CharityProjects" asp-action="Details" asp-route-id="@row.ProjectId" class="btn btn-sm btn-outline-primary">فتح</a>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </authz>
    <authz any-policy="PayrollView,PayrollManage">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title mb-3">آخر شهور المرتبات</h4>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead><tr><th>الشهر</th><th>الحالة</th><th>الصافي</th></tr></thead>
                            <tbody>
                            @foreach (var row in Model.RecentPayrollMonths)
                            {
                                <tr>
                                    <td>@($"{row.Month:00}/{row.Year}")</td>
                                    <td>@row.Status</td>
                                    <td>@row.TotalNet.ToString("N2")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </authz>
</div>

<authz any-policy="StoresView,StoresManage">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title mb-3">حركة المخازن</h4>
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>المخزن</th>
                            <th>عدد أذون الإضافة</th>
                            <th>كمية الإضافة</th>
                            <th>عدد أذون الصرف</th>
                            <th>كمية الصرف</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.StoreMovements)
                    {
                        <tr>
                            <td>@row.WarehouseName</td>
                            <td>@row.ReceiptsCount</td>
                            <td>@row.ReceiptQuantity.ToString("N2")</td>
                            <td>@row.IssuesCount</td>
                            <td>@row.IssueQuantity.ToString("N2")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</authz>

@model InfrastructureManagmentWebFramework.Models.Charity.Projects.ProjectDetailsVm
@using InfrastructureManagmentWebFramework.Models.Charity.Projects
@using Skote.Helpers
<partial name="~/Views/Shared/Projects/_ProjectHeader.cshtml" />
@{
    string StatusColor(string s)=>s switch{"Active"or"InProgress"=>"#556ee6","Planned"=>"#f1b44c","Completed"=>"#34c38f","Cancelled"=>"#f46a6a",_=>"#adb5bd"};
    string StatusAr(string s)=>s switch{"Active"=>"نشط","InProgress"=>"جارٍ","Planned"=>"مخطط","Completed"=>"مكتمل","Cancelled"=>"ملغى",_=>s};
    var budgetUsed  = Model.PlannedBudgetLinesTotal > 0 ? (double)Model.ActualBudgetLinesTotal/(double)Model.PlannedBudgetLinesTotal*100 : 0;
    var budgetPct   = Math.Min(100, Math.Round(budgetUsed));
    var daysLeft    = Model.EndDate.HasValue ? (Model.EndDate.Value-DateTime.Today).Days : (int?)null;
}
<style>
:root{--teal:#0e6f73;--teal-l:#e1f5f5;--ink:#1e3a5f;--muted:#6b7d80}
.dtl-stat{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 10px rgba(14,111,115,.05);padding:16px 20px;text-align:center}
.dtl-stat .n{font-size:1.8rem;font-weight:800;color:var(--teal);line-height:1}
.dtl-stat .l{font-size:.72rem;color:var(--muted);margin-top:4px}
.info-card{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 10px rgba(14,111,115,.05);overflow:hidden;margin-bottom:16px}
.info-card-hdr{padding:12px 18px;background:#f4f9f9;border-bottom:.5px solid rgba(14,111,115,.08);display:flex;align-items:center;gap:8px}
.info-card-hdr .ic-title{font-weight:700;font-size:.88rem;color:var(--ink)}
.info-card-body{padding:16px 18px}
.info-row{display:flex;gap:8px;padding:7px 0;border-bottom:.5px solid rgba(14,111,115,.04)}
.info-row:last-child{border-bottom:none}
.info-label{font-size:.75rem;font-weight:700;color:var(--muted);min-width:110px;flex-shrink:0}
.info-val{font-size:.84rem;color:var(--ink);flex:1}
.budget-bar-wrap{margin-top:8px}
.budget-bar{height:10px;border-radius:999px;background:#e2e8f0;overflow:hidden}
.budget-fill{height:100%;border-radius:999px;background:var(--teal);transition:width .5s}
.budget-numbers{display:flex;justify-content:space-between;font-size:.73rem;color:var(--muted);margin-top:4px}
.nav-links{display:flex;flex-wrap:wrap;gap:8px;padding:14px 18px;background:#f4f9f9;border-radius:0 0 14px 14px;border-top:.5px solid rgba(14,111,115,.08)}
.nl-btn{padding:6px 14px;border-radius:20px;font-size:.78rem;font-weight:600;text-decoration:none;background:#fff;color:var(--ink);border:.5px solid rgba(14,111,115,.18);transition:all .18s;white-space:nowrap}
.nl-btn:hover{background:var(--teal);color:#fff;border-color:var(--teal)}
.text-block{white-space:pre-wrap;font-size:.84rem;color:var(--muted);line-height:1.7;padding:10px;background:#f8fbfb;border-radius:8px;border:.5px solid rgba(14,111,115,.06)}
.badge-status{padding:4px 12px;border-radius:20px;font-size:.72rem;font-weight:700;color:#fff}
</style>
<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="dtl-stat"><div class="n">@Model.BudgetLinesCount</div><div class="l">بنود الموازنة</div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dtl-stat"><div class="n">@Model.ActivitiesCount</div><div class="l">الأنشطة</div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dtl-stat"><div class="n">@Model.BeneficiariesCount</div><div class="l">المستفيدون</div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="dtl-stat"><div class="n">@Model.GrantsCount</div><div class="l">التمويلات</div></div>
    </div>
</div>
<div class="row g-3">
    <div class="col-lg-7">
        <div class="info-card">
            <div class="info-card-hdr">
                <i class="bx bx-info-circle" style="color:var(--teal);font-size:1.1rem"></i>
                <span class="ic-title">بيانات المشروع</span>
                <authz policy="ProjectsManage">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-light ms-auto" style="border-radius:8px;font-size:.76rem">تعديل</a>
                </authz>
            </div>
            <div class="info-card-body">
                <div class="info-row"><span class="info-label">الكود</span><span class="info-val fw-bold" style="color:var(--teal)">@Model.Code</span></div>
                <div class="info-row"><span class="info-label">الاسم</span><span class="info-val fw-semibold">@Model.Name</span></div>
                <div class="info-row">
                    <span class="info-label">الحالة</span>
                    <span class="info-val"><span class="badge-status" style="background:@StatusColor(Model.Status)">@StatusAr(Model.Status)</span></span>
                </div>
                <div class="info-row"><span class="info-label">تاريخ البداية</span><span class="info-val">@Model.StartDate.ToString("yyyy/MM/dd")</span></div>
                <div class="info-row">
                    <span class="info-label">تاريخ الانتهاء</span>
                    <span class="info-val">
                        @(Model.EndDate?.ToString("yyyy/MM/dd")??"—")
                        @if(daysLeft.HasValue){
                            var cls=daysLeft<0?"text-danger":daysLeft<30?"text-warning":"text-success";
                            <span class="ms-2 small @cls">(@(daysLeft<0?$"تأخر {Math.Abs(daysLeft.Value)} يوم":$"يتبقى {daysLeft} يوم"))</span>
                        }
                    </span>
                </div>
                <div class="info-row"><span class="info-label">الموقع</span><span class="info-val">@(Model.Location??"—")</span></div>
                <div class="info-row"><span class="info-label">المستهدف</span><span class="info-val">@(Model.TargetBeneficiariesCount?.ToString("N0")??"—") مستفيد</span></div>
                <div class="info-row"><span class="info-label">نشط</span><span class="info-val">@(Model.IsActive?"<span class='badge bg-success'>نشط</span>":"<span class='badge bg-secondary'>غير نشط</span>")</span></div>
            </div>
        </div>
        @if(!string.IsNullOrWhiteSpace(Model.Description)){
        <div class="info-card">
            <div class="info-card-hdr"><i class="bx bx-detail" style="color:var(--teal);font-size:1.1rem"></i><span class="ic-title">الوصف</span></div>
            <div class="info-card-body"><div class="text-block">@Model.Description</div></div>
        </div>
        }
    </div>
    <div class="col-lg-5">
        <div class="info-card">
            <div class="info-card-hdr"><i class="bx bx-money" style="color:#f1b44c;font-size:1.1rem"></i><span class="ic-title">الموازنة</span></div>
            <div class="info-card-body">
                <div class="d-flex justify-content-between mb-1">
                    <span style="font-size:.78rem;color:var(--muted)">إجمالي الموازنة</span>
                    <span style="font-weight:800;color:var(--ink)">@Model.Budget.ToString("N0")</span>
                </div>
                <div class="budget-bar-wrap">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:.72rem;color:var(--muted)">المخطط vs الفعلي</span>
                        <span style="font-size:.72rem;font-weight:700;color:var(--teal)">@budgetPct%</span>
                    </div>
                    <div class="budget-bar"><div class="budget-fill" style="width:@budgetPct%"></div></div>
                    <div class="budget-numbers">
                        <span>مخطط: @Model.PlannedBudgetLinesTotal.ToString("N0")</span>
                        <span>فعلي: @Model.ActualBudgetLinesTotal.ToString("N0")</span>
                    </div>
                </div>
            </div>
        </div>
        @if(!string.IsNullOrWhiteSpace(Model.Objectives)){
        <div class="info-card">
            <div class="info-card-hdr"><i class="bx bx-target-lock" style="color:#556ee6;font-size:1.1rem"></i><span class="ic-title">الأهداف</span></div>
            <div class="info-card-body"><div class="text-block">@Model.Objectives</div></div>
        </div>
        }
        @if(!string.IsNullOrWhiteSpace(Model.Kpis)){
        <div class="info-card">
            <div class="info-card-hdr"><i class="bx bx-bar-chart-alt-2" style="color:#34c38f;font-size:1.1rem"></i><span class="ic-title">المؤشرات</span></div>
            <div class="info-card-body"><div class="text-block">@Model.Kpis</div></div>
        </div>
        }
        @if(!string.IsNullOrWhiteSpace(Model.Notes)){
        <div class="info-card">
            <div class="info-card-hdr"><i class="bx bx-note" style="color:#f1b44c;font-size:1.1rem"></i><span class="ic-title">ملاحظات</span></div>
            <div class="info-card-body"><div class="text-block">@Model.Notes</div></div>
        </div>
        }
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.Charity.Projects.EditCharityProjectVm
<div class="card">
    <div class="card-body">
        <h4 class="mb-3">تعديل مشروع</h4>
        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />
            <partial name="_Form" model="Model" />
            <div class="mt-3">
                <button class="btn btn-primary">حفظ</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">رجوع</a>
            </div>
        </form>
    </div>
</div>

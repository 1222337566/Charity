@model InfrastructureManagmentWebFramework.Models.Charity.Projects.ProjectListPageVm
@using Microsoft.AspNetCore.Mvc.Rendering
@using Skote.Helpers
@{
    ViewData["Title"] = "المشروعات";
    string StatusColor(string s) => s switch {
        "Active" or "InProgress" => "#556ee6","Planned" => "#f1b44c",
        "Completed" => "#34c38f","OnHold" => "#74788d","Cancelled" => "#f46a6a",_ => "#adb5bd"};
    string StatusAr(string s) => s switch {
        "Active"=>"نشط","InProgress"=>"جارٍ","Planned"=>"مخطط",
        "Completed"=>"مكتمل","OnHold"=>"موقوف","Cancelled"=>"ملغى",_=>s};
    var totalBudget = Model.Items.Sum(x=>x.Budget);
    var activeCount = Model.Items.Count(x=>x.IsActive);
    var doneCount   = Model.Items.Count(x=>x.Status=="Completed");
}
<style>
:root{--teal:#0e6f73;--teal-l:#e1f5f5;--ink:#1e3a5f;--muted:#6b7d80}
.pj-hero{background:linear-gradient(135deg,#1a3c5e,#0e6f73);border-radius:20px;padding:22px 28px;color:#fff;margin-bottom:20px;position:relative;overflow:hidden}
.pj-hero::after{content:'';position:absolute;top:-60px;left:-60px;width:220px;height:220px;background:rgba(255,255,255,.04);border-radius:50%;pointer-events:none}
.pj-stat{background:rgba(255,255,255,.13);border-radius:14px;padding:12px 18px;text-align:center;flex:1;min-width:90px}
.pj-stat .n{font-size:1.4rem;font-weight:800;line-height:1}
.pj-stat .l{font-size:.67rem;opacity:.8;margin-top:3px}
.filter-strip{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.12);padding:14px 18px;margin-bottom:16px}
.view-btn{width:32px;height:32px;border:1px solid rgba(14,111,115,.18);background:#fff;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all .2s}
.view-btn.active{background:var(--teal);color:#fff;border-color:var(--teal)}
.pj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px}
.pj-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 12px rgba(14,111,115,.06);overflow:hidden;transition:box-shadow .2s,transform .15s;display:flex;flex-direction:column}
.pj-card:hover{box-shadow:0 6px 28px rgba(14,111,115,.14);transform:translateY(-2px)}
.pj-card-top{padding:16px 18px;flex:1}
.pj-card-foot{padding:12px 18px;background:#f8fbfb;border-top:.5px solid rgba(14,111,115,.07);display:flex;align-items:center;justify-content:space-between;gap:8px}
.pj-code{font-size:.68rem;font-weight:700;color:var(--teal);background:var(--teal-l);padding:2px 8px;border-radius:6px}
.pj-name{font-weight:700;font-size:.95rem;color:var(--ink);margin:.4rem 0 .2rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.pj-meta{font-size:.76rem;color:var(--muted);display:flex;gap:.8rem;flex-wrap:wrap}
.pj-badge{padding:3px 10px;border-radius:20px;font-size:.68rem;font-weight:700;color:#fff;white-space:nowrap}
.prog-bar{height:5px;border-radius:999px;background:#e2e8f0;overflow:hidden;margin-top:10px}
.prog-fill{height:100%;border-radius:999px;background:var(--teal)}
.pj-table{width:100%;border-collapse:collapse;font-size:.84rem}
.pj-table th{padding:10px 14px;font-size:.73rem;font-weight:700;color:var(--muted);background:#f4f9f9;text-align:right;border-bottom:.5px solid rgba(14,111,115,.12);white-space:nowrap}
.pj-table td{padding:11px 14px;border-bottom:.5px solid rgba(14,111,115,.05);vertical-align:middle}
.pj-table tr:hover td{background:rgba(14,111,115,.02)}
.empty-state{padding:60px 20px;text-align:center;color:var(--muted)}
.empty-state i{font-size:3rem;opacity:.3;display:block;margin-bottom:12px}
</style>
<div class="pj-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h4 class="mb-1 fw-bold">المشروعات</h4>
            <p class="mb-0" style="opacity:.8;font-size:.88rem">إدارة المشروعات وربطها بالمستفيدين والتمويل</p>
        </div>
        <authz policy="ProjectsManage">
            <a asp-action="Create" class="btn btn-light fw-semibold" style="border-radius:10px">
                <i class="bx bx-plus me-1"></i>مشروع جديد
            </a>
        </authz>
    </div>
    <div class="d-flex flex-wrap gap-3 mt-4">
        <div class="pj-stat"><div class="n">@Model.Items.Count</div><div class="l">إجمالي</div></div>
        <div class="pj-stat"><div class="n">@activeCount</div><div class="l">نشطة</div></div>
        <div class="pj-stat"><div class="n">@doneCount</div><div class="l">مكتملة</div></div>
        <div class="pj-stat"><div class="n">@totalBudget.ToString("N0")</div><div class="l">إجمالي الموازنة</div></div>
    </div>
</div>
<div class="filter-strip">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-4 col-sm-6">
            <label class="form-label small text-muted mb-1">بحث</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text" style="background:#f4f9f9;border-color:rgba(14,111,115,.18)"><i class="bx bx-search text-muted"></i></span>
                <input asp-for="Filter.Q" class="form-control form-control-sm" placeholder="اسم المشروع أو الكود" style="border-color:rgba(14,111,115,.18)"/>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <label class="form-label small text-muted mb-1">الحالة</label>
            <select asp-for="Filter.Status" asp-items="Model.Filter.Statuses" class="form-select form-select-sm" style="border-color:rgba(14,111,115,.18)"></select>
        </div>
        <div class="col-md-2 col-sm-4">
            <label class="form-label small text-muted mb-1">النشاط</label>
            <select asp-for="Filter.IsActive" class="form-select form-select-sm" style="border-color:rgba(14,111,115,.18)">
                <option value="">الكل</option><option value="true">النشطة</option><option value="false">غير النشطة</option>
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button class="btn btn-sm fw-semibold flex-fill" style="background:var(--teal);color:#fff;border-radius:8px">بحث</button>
            <a asp-action="Index" class="btn btn-sm btn-light" style="border-radius:8px"><i class="bx bx-reset"></i></a>
        </div>
        <div class="col-md-1 d-flex justify-content-end gap-1">
            <button type="button" class="view-btn active" id="btnGrid" title="بطاقات"><i class="bx bx-grid-alt"></i></button>
            <button type="button" class="view-btn" id="btnTable" title="جدول"><i class="bx bx-list-ul"></i></button>
        </div>
    </form>
</div>
<div id="viewGrid">
@if (!Model.Items.Any()){
    <div class="empty-state"><i class="bx bx-folder-open"></i><p>لا توجد مشروعات</p><authz policy="ProjectsManage"><a asp-action="Create" class="btn btn-sm btn-primary mt-2">إنشاء أول مشروع</a></authz></div>
}else{
    <div class="pj-grid">
    @foreach(var item in Model.Items){
        var sc=StatusColor(item.Status);
        var daysLeft=item.EndDate.HasValue?(item.EndDate.Value-DateTime.Today).Days:(int?)null;
        <div class="pj-card">
            <div class="pj-card-top">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <span class="pj-code">@item.Code</span>
                    <span class="pj-badge" style="background:@sc">@StatusAr(item.Status)</span>
                </div>
                <div class="pj-name">@item.Name</div>
                <div class="pj-meta">
                    <span><i class="bx bx-calendar me-1"></i>@item.StartDate.ToString("yyyy/MM/dd")</span>
                    @if(item.EndDate.HasValue){<span><i class="bx bx-calendar-check me-1"></i>@item.EndDate.Value.ToString("yyyy/MM/dd")</span>}
                    @if(daysLeft.HasValue){
                        var cls=daysLeft<0?"text-danger":daysLeft<30?"text-warning":"text-muted";
                        <span class="@cls">@(daysLeft<0?$"تأخر {Math.Abs(daysLeft.Value)} يوم":$"يتبقى {daysLeft} يوم")</span>
                    }
                </div>
                <div class="prog-bar"><div class="prog-fill" style="width:60%"></div></div>
            </div>
            <div class="pj-card-foot">
                <div>
                    <div style="font-size:.67rem;color:var(--muted)">الموازنة</div>
                    <div style="font-weight:700;font-size:.88rem">@item.Budget.ToString("N0")</div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    @if(!item.IsActive){<span class="badge bg-secondary" style="font-size:.62rem">غير نشط</span>}
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm fw-semibold" style="background:var(--teal-l);color:var(--teal);border-radius:8px"><i class="bx bx-show me-1"></i>عرض</a>
                    <authz policy="ProjectsManage"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light" style="border-radius:8px"><i class="bx bx-edit-alt"></i></a></authz>
                </div>
            </div>
        </div>
    }
    </div>
}
</div>
<div id="viewTable" style="display:none">
    <div class="card" style="border-radius:14px;border:.5px solid rgba(14,111,115,.1);overflow:hidden">
        <div class="table-responsive">
            <table class="pj-table">
                <thead><tr><th style="width:100px">الكود</th><th>الاسم</th><th>البداية</th><th>النهاية</th><th>الموازنة</th><th>الحالة</th><th style="width:120px"></th></tr></thead>
                <tbody>
                @foreach(var item in Model.Items){
                    <tr>
                        <td><span class="pj-code">@item.Code</span></td>
                        <td><div class="fw-semibold" style="color:var(--ink)">@item.Name</div>@if(!item.IsActive){<span class="badge bg-secondary" style="font-size:.62rem">غير نشط</span>}</td>
                        <td class="text-muted">@item.StartDate.ToString("yyyy/MM/dd")</td>
                        <td class="text-muted">@(item.EndDate?.ToString("yyyy/MM/dd")??"—")</td>
                        <td class="fw-semibold">@item.Budget.ToString("N0")</td>
                        <td><span class="pj-badge" style="background:@StatusColor(item.Status)">@StatusAr(item.Status)</span></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm" style="background:var(--teal-l);color:var(--teal);border-radius:7px">عرض</a>
                            <authz policy="ProjectsManage"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light" style="border-radius:7px"><i class="bx bx-edit-alt"></i></a></authz>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
<script>
const g=document.getElementById('viewGrid'),t=document.getElementById('viewTable');
document.getElementById('btnGrid').addEventListener('click',function(){g.style.display='';t.style.display='none';this.classList.add('active');document.getElementById('btnTable').classList.remove('active');localStorage.setItem('pj_view','grid');});
document.getElementById('btnTable').addEventListener('click',function(){t.style.display='';g.style.display='none';this.classList.add('active');document.getElementById('btnGrid').classList.remove('active');localStorage.setItem('pj_view','table');});
if(localStorage.getItem('pj_view')==='table')document.getElementById('btnTable').click();
</script>
}

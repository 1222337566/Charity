@model InfrastructureManagmentWebFramework.Models.Charity.Projects.CreateCharityProjectVm
<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="Code" class="form-label"></label>
        <input asp-for="Code" class="form-control" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Budget" class="form-label"></label>
        <input asp-for="Budget" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Model.Statuses" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="TargetBeneficiariesCount" class="form-label"></label>
        <input asp-for="TargetBeneficiariesCount" class="form-control" />
    </div>
    <div class="col-md-8">
        <label asp-for="Location" class="form-label"></label>
        <input asp-for="Location" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-md-6">
        <label asp-for="Objectives" class="form-label"></label>
        <textarea asp-for="Objectives" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-md-6">
        <label asp-for="Kpis" class="form-label"></label>
        <textarea asp-for="Kpis" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
    </div>
    <div class="col-12 form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
</div>

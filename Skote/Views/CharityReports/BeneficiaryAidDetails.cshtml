@model InfrastructureManagmentWebFramework.Models.Reports.BeneficiaryAidDetailReportVm
@{
    ViewData["Title"] = "التقرير التفصيلي للمستفيدين";
}
@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")
<div class="card mb-3"><div class="card-body"><form method="get" class="row g-3 align-items-end"><div class="col-md-3"><label asp-for="FromDate" class="form-label"></label><input asp-for="FromDate" class="form-control" /></div><div class="col-md-3"><label asp-for="ToDate" class="form-label"></label><input asp-for="ToDate" class="form-control" /></div><div class="col-md-6 d-flex gap-2 flex-wrap"><button type="submit" class="btn btn-primary">عرض</button><a asp-action="BeneficiaryAidDetails" class="btn btn-light">إعادة ضبط</a><a asp-action="PrintBeneficiaryAidDetails" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" target="_blank" class="btn btn-outline-secondary">طباعة</a></div></form></div></div>
<div class="row mb-3"><div class="col-md-6"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الطلبات</div><h5>@Model.TotalRequested.ToString("N2")</h5></div></div></div><div class="col-md-6"><div class="card"><div class="card-body"><div class="text-muted">إجمالي المنصرف</div><h5>@Model.TotalDisbursed.ToString("N2")</h5></div></div></div></div>
<div class="card"><div class="card-body"><h4 class="card-title mb-3">التقرير التفصيلي للمستفيدين</h4><div class="table-responsive"><table class="table table-bordered table-striped align-middle"><thead><tr><th>الكود</th><th>المستفيد</th><th>الحالة</th><th>نوع المساعدة</th><th>تاريخ الطلب</th><th>المطلوب</th><th>الحالة الحالية</th><th>المنصرف</th><th>آخر صرف</th></tr></thead><tbody>@foreach (var row in Model.Rows){<tr><td>@row.BeneficiaryCode</td><td>@row.BeneficiaryName</td><td>@row.BeneficiaryStatus</td><td>@row.AidTypeName</td><td>@row.RequestDate.ToString("yyyy-MM-dd")</td><td>@row.RequestedAmount.ToString("N2")</td><td>@row.RequestStatus</td><td>@row.DisbursedAmount.ToString("N2")</td><td>@(row.LastDisbursementDate?.ToString("yyyy-MM-dd") ?? "-")</td></tr>}</tbody></table></div></div></div>

@model InfrastructureManagmentWebFramework.Models.Reports.BeneficiaryStatusReportVm
@{
    ViewData["Title"] = "تقرير حالات المستفيدين";
}

@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h4 class="card-title mb-0">تقرير حالات المستفيدين</h4>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="BeneficiaryAidDetails" class="btn btn-light btn-sm">التقرير التفصيلي</a>
                <a asp-action="PrintBeneficiaryStatuses" target="_blank" class="btn btn-outline-secondary btn-sm">طباعة</a>
                <a asp-action="ExportBeneficiaryStatusesExcel" class="btn btn-success btn-sm">Excel</a>
                <a asp-action="ExportBeneficiaryStatusesPdf" class="btn btn-danger btn-sm">PDF</a>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead>
                    <tr>
                        <th>الحالة</th>
                        <th>عدد المستفيدين</th>
                        <th>طلبات المساعدة</th>
                        <th>مرات الصرف</th>
                        <th>إجمالي الصرف</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.StatusName</td>
                        <td>@row.BeneficiariesCount</td>
                        <td>@row.AidRequestsCount</td>
                        <td>@row.DisbursementsCount</td>
                        <td>@row.TotalDisbursedAmount.ToString("N2")</td>
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr class="fw-bold">
                        <td>الإجمالي</td>
                        <td>@Model.Rows.Sum(x => x.BeneficiariesCount)</td>
                        <td>@Model.Rows.Sum(x => x.AidRequestsCount)</td>
                        <td>@Model.Rows.Sum(x => x.DisbursementsCount)</td>
                        <td>@Model.Rows.Sum(x => x.TotalDisbursedAmount).ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

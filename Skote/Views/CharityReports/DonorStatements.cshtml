@model InfrastructureManagmentWebFramework.Models.Reports.DonorStatementReportVm
@{
    ViewData["Title"] = "كشف حساب المتبرعين";
}
@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")
<div class="card mb-3"><div class="card-body"><form method="get" class="row g-3 align-items-end"><div class="col-md-4"><label class="form-label">المتبرع</label><select asp-for="DonorId" asp-items="Model.Donors" class="form-select"><option value="">الكل</option></select></div><div class="col-md-2"><label asp-for="FromDate" class="form-label"></label><input asp-for="FromDate" class="form-control" /></div><div class="col-md-2"><label asp-for="ToDate" class="form-label"></label><input asp-for="ToDate" class="form-control" /></div><div class="col-md-4 d-flex gap-2 flex-wrap"><button type="submit" class="btn btn-primary">عرض</button><a asp-action="DonorStatements" class="btn btn-light">إعادة ضبط</a><a asp-action="PrintDonorStatements" asp-route-donorId="@Model.DonorId" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" target="_blank" class="btn btn-outline-secondary">طباعة</a></div></form></div></div>
<div class="row mb-3"><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">إجمالي التبرعات</div><h5>@Model.TotalDonations.ToString("N2")</h5></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">إجمالي المخصص</div><h5>@Model.TotalAllocated.ToString("N2")</h5></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">المتبقي</div><h5>@Model.TotalRemaining.ToString("N2")</h5></div></div></div></div>
<div class="card"><div class="card-body"><h4 class="card-title mb-3">كشف حساب المتبرعين</h4><div class="table-responsive"><table class="table table-bordered table-hover align-middle"><thead><tr><th>المتبرع</th><th>التاريخ</th><th>رقم التبرع</th><th>النوع</th><th>القيمة</th><th>المخصص</th><th>المتبقي</th><th>مقيد؟</th><th>الحملة</th></tr></thead><tbody>@foreach (var row in Model.Rows){<tr><td>@row.DonorName</td><td>@row.DonationDate.ToString("yyyy-MM-dd")</td><td>@row.DonationNumber</td><td>@row.DonationType</td><td>@row.DonationAmount.ToString("N2")</td><td>@row.AllocatedAmount.ToString("N2")</td><td>@row.RemainingAmount.ToString("N2")</td><td>@(row.IsRestricted ? "نعم" : "لا")</td><td>@(row.CampaignName ?? "-")</td></tr>}</tbody></table></div></div></div>

@model InfrastructureManagmentWebFramework.Models.Reports.InKindBeneficiaryIssueReportVm
@{
    ViewData["Title"] = "تقرير الصرف العيني للمستحقين";
}

@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3"><label asp-for="FromDate" class="form-label"></label><input asp-for="FromDate" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="ToDate" class="form-label"></label><input asp-for="ToDate" class="form-control" /></div>
            <div class="col-md-6 d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-primary">عرض</button>
                <a asp-action="InKindBeneficiaryIssues" class="btn btn-light">إعادة ضبط</a>
                <a asp-action="InKindReceiptStatus" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" class="btn btn-outline-primary">حالة الإدخال</a>
                <a asp-action="InKindDonationBalances" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" class="btn btn-outline-primary">الأرصدة المتبقية</a>
            </div>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-6"><div class="card"><div class="card-body"><div class="text-muted">عدد أذون الصرف</div><h5>@Model.TotalIssues</h5></div></div></div>
    <div class="col-md-6"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الكميات المصروفة</div><h5>@Model.TotalIssuedQuantity.ToString("N2")</h5></div></div></div>
</div>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h4 class="card-title mb-0">تقرير الصرف العيني للمستحقين</h4>
            <a asp-action="PrintInKindBeneficiaryIssues" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" target="_blank" class="btn btn-outline-secondary btn-sm">طباعة</a>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead>
                    <tr>
                        <th>التاريخ</th><th>إذن الصرف</th><th>رقم التبرع</th><th>المستفيد</th><th>نوع المساعدة</th><th>الصنف</th><th>المخزن</th><th>الكمية</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.DisbursementDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (row.StoreIssueId.HasValue)
                            {
                                <a asp-controller="CharityStoreIssues" asp-action="Details" asp-route-id="@row.StoreIssueId">@row.StoreIssueNumber</a>
                            }
                            else
                            {
                                @row.StoreIssueNumber
                            }
                        </td>
                        <td>@row.DonationNumber</td>
                        <td>@row.BeneficiaryName</td>
                        <td>@row.AidTypeName</td>
                        <td>@row.ItemName</td>
                        <td>@row.WarehouseName</td>
                        <td>@row.Quantity.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

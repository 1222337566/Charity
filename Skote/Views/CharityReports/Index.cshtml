@{
    ViewData["Title"] = "تقارير الجمعية";
}

@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")

<div class="row g-3">
    <div class="col-md-6 col-xl-4">
        <div class="card h-100"><div class="card-body"><h5>المستفيدون</h5><p class="text-muted">ملخص الحالات والتفاصيل وطلبات المساعدة والصرف.</p><div class="d-flex gap-2 flex-wrap"><a asp-action="BeneficiaryStatuses" class="btn btn-primary btn-sm">الملخص</a><a asp-action="BeneficiaryAidDetails" class="btn btn-light btn-sm">التفصيلي</a></div></div></div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card h-100"><div class="card-body"><h5>التبرعات</h5><p class="text-muted">ملخص التبرعات وكشف حساب المتبرعين.</p><div class="d-flex gap-2 flex-wrap"><a asp-action="Donations" class="btn btn-primary btn-sm">الملخص</a><a asp-action="DonorStatements" class="btn btn-light btn-sm">كشف حساب</a></div></div></div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card h-100"><div class="card-body"><h5>المشروعات</h5><p class="text-muted">ملخص المشروعات وتقرير تفصيلي للتنفيذ.</p><div class="d-flex gap-2 flex-wrap"><a asp-action="Projects" class="btn btn-primary btn-sm">الملخص</a><a asp-action="ProjectDetails" class="btn btn-light btn-sm">التفصيلي</a></div></div></div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card h-100"><div class="card-body"><h5>المرتبات</h5><p class="text-muted">ملخص الأشهر وتفاصيل الموظفين داخل كل شهر.</p><div class="d-flex gap-2 flex-wrap"><a asp-action="Payroll" class="btn btn-primary btn-sm">الملخص</a><a asp-action="PayrollEmployees" class="btn btn-light btn-sm">تفاصيل الموظفين</a></div></div></div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card h-100"><div class="card-body"><h5>المخازن</h5><p class="text-muted">ملخص حركة المخزن وتفاصيل حركة الأصناف.</p><div class="d-flex gap-2 flex-wrap"><a asp-action="StoreMovements" class="btn btn-primary btn-sm">الملخص</a><a asp-action="StoreItemMovements" class="btn btn-light btn-sm">حركة الأصناف</a></div></div></div>
    </div>
    <div class="col-md-6 col-xl-4">
        <div class="card h-100"><div class="card-body"><h5>التبرعات العينية التشغيلية</h5><p class="text-muted">متابعة الإدخال للمخزن والصرف للمستحقين والأرصدة المتبقية.</p><div class="d-flex gap-2 flex-wrap"><a asp-action="InKindReceiptStatus" class="btn btn-primary btn-sm">الإدخال للمخزن</a><a asp-action="InKindBeneficiaryIssues" class="btn btn-light btn-sm">الصرف للمستحقين</a><a asp-action="InKindDonationBalances" class="btn btn-light btn-sm">الأرصدة</a></div></div></div>
    </div>

</div>

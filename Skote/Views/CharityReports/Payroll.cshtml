@model InfrastructureManagmentWebFramework.Models.Reports.PayrollMonthReportVm
@{
    ViewData["Title"] = "تقرير المرتبات";
}

@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h4 class="card-title mb-0">تقرير المرتبات</h4>
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <div class="fw-bold">إجمالي الصافي: @Model.TotalNet.ToString("N2")</div>
                <a asp-action="PayrollEmployees" class="btn btn-light btn-sm">تفاصيل الموظفين</a>
                <a asp-action="PrintPayroll" target="_blank" class="btn btn-outline-secondary btn-sm">طباعة</a>
                <a asp-action="ExportPayrollExcel" class="btn btn-success btn-sm">Excel</a>
                <a asp-action="ExportPayrollPdf" class="btn btn-danger btn-sm">PDF</a>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead><tr><th>الشهر</th><th>الحالة</th><th>عدد الموظفين</th><th>الأساسي</th><th>الإضافات</th><th>الخصومات</th><th>الصافي</th></tr></thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr><td>@($"{row.Month:00}/{row.Year}")</td><td>@row.Status</td><td>@row.EmployeesCount</td><td>@row.TotalBasic.ToString("N2")</td><td>@row.TotalAdditions.ToString("N2")</td><td>@row.TotalDeductions.ToString("N2")</td><td>@row.TotalNet.ToString("N2")</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.Reports.PayrollEmployeeDetailReportVm
@{
    ViewData["Title"] = "تفاصيل مرتبات الموظفين";
}
@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")
<div class="card mb-3"><div class="card-body"><form method="get" class="row g-3 align-items-end"><div class="col-md-6"><label class="form-label">شهر المرتبات</label><select asp-for="PayrollMonthId" asp-items="Model.PayrollMonths" class="form-select"><option value="">الكل</option></select></div><div class="col-md-6 d-flex gap-2 flex-wrap"><button type="submit" class="btn btn-primary">عرض</button><a asp-action="PayrollEmployees" class="btn btn-light">إعادة ضبط</a><a asp-action="PrintPayrollEmployees" asp-route-payrollMonthId="@Model.PayrollMonthId" target="_blank" class="btn btn-outline-secondary">طباعة</a></div></form></div></div>
<div class="row mb-3"><div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">الأساسي</div><h5>@Model.TotalBasic.ToString("N2")</h5></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">الإضافات</div><h5>@Model.TotalAdditions.ToString("N2")</h5></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">الخصومات</div><h5>@Model.TotalDeductions.ToString("N2")</h5></div></div></div><div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">الصافي</div><h5>@Model.TotalNet.ToString("N2")</h5></div></div></div></div>
<div class="card"><div class="card-body"><h4 class="card-title mb-3">تفاصيل مرتبات الموظفين</h4><div class="table-responsive"><table class="table table-bordered table-hover align-middle"><thead><tr><th>الكود</th><th>الاسم</th><th>القسم</th><th>الأساسي</th><th>الإضافات</th><th>خصم الحضور</th><th>خصومات أخرى</th><th>إجمالي الخصومات</th><th>الصافي</th></tr></thead><tbody>@foreach (var row in Model.Rows){<tr><td>@row.EmployeeCode</td><td>@row.EmployeeName</td><td>@(row.DepartmentName ?? "-")</td><td>@row.BasicSalary.ToString("N2")</td><td>@row.Additions.ToString("N2")</td><td>@row.AttendanceDeduction.ToString("N2")</td><td>@row.OtherDeductions.ToString("N2")</td><td>@row.TotalDeductions.ToString("N2")</td><td>@row.NetAmount.ToString("N2")</td></tr>}</tbody></table></div></div></div>

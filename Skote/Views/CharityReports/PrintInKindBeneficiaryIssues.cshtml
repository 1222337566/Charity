@model InfrastructureManagmentWebFramework.Models.Reports.InKindBeneficiaryIssueReportVm
@{ Layout = "~/Views/Shared/Reports/_PrintLayout.cshtml"; ViewData["Title"] = "طباعة تقرير الصرف العيني للمستحقين"; }
<h3>تقرير الصرف العيني للمستحقين</h3>
<div class="meta">الفترة: @(Model.FromDate?.ToString("yyyy-MM-dd") ?? "الكل") - @(Model.ToDate?.ToString("yyyy-MM-dd") ?? "الكل")</div>
<table class="table">
    <thead><tr><th>التاريخ</th><th>إذن الصرف</th><th>رقم التبرع</th><th>المستفيد</th><th>نوع المساعدة</th><th>الصنف</th><th>المخزن</th><th>الكمية</th></tr></thead>
    <tbody>@foreach (var row in Model.Rows){<tr><td>@row.DisbursementDate.ToString("yyyy-MM-dd")</td><td>@row.StoreIssueNumber</td><td>@row.DonationNumber</td><td>@row.BeneficiaryName</td><td>@row.AidTypeName</td><td>@row.ItemName</td><td>@row.WarehouseName</td><td>@row.Quantity.ToString("N2")</td></tr>}</tbody>
</table>

@model InfrastructureManagmentWebFramework.Models.Reports.ProjectDetailsReportVm
@{
    ViewData["Title"] = "التقرير التفصيلي للمشروعات";
}
@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")
<div class="card mb-3"><div class="card-body"><form method="get" class="row g-3 align-items-end"><div class="col-md-6"><label class="form-label">المشروع</label><select asp-for="ProjectId" asp-items="Model.Projects" class="form-select"><option value="">الكل</option></select></div><div class="col-md-6 d-flex gap-2 flex-wrap"><button type="submit" class="btn btn-primary">عرض</button><a asp-action="ProjectDetails" class="btn btn-light">إعادة ضبط</a><a asp-action="PrintProjectDetails" asp-route-projectId="@Model.ProjectId" target="_blank" class="btn btn-outline-secondary">طباعة</a></div></form></div></div>
<div class="row mb-3"><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الموازنات</div><h5>@Model.TotalBudget.ToString("N2")</h5></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">إجمالي التمويل</div><h5>@Model.TotalAllocated.ToString("N2")</h5></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">إجمالي المنفذ</div><h5>@Model.TotalActual.ToString("N2")</h5></div></div></div></div>
<div class="card"><div class="card-body"><h4 class="card-title mb-3">التقرير التفصيلي للمشروعات</h4><div class="table-responsive"><table class="table table-bordered table-striped align-middle"><thead><tr><th>الكود</th><th>المشروع</th><th>الفترة</th><th>الموقع</th><th>الحالة</th><th>الموازنة</th><th>المنفذ</th><th>التمويل</th><th>المستفيدون</th><th>الأنشطة</th><th>نسبة التنفيذ</th></tr></thead><tbody>@foreach (var row in Model.Rows){<tr><td>@row.ProjectCode</td><td>@row.ProjectName</td><td>@row.StartDate.ToString("yyyy-MM-dd") - @(row.EndDate?.ToString("yyyy-MM-dd") ?? "-")</td><td>@(row.Location ?? "-")</td><td>@row.Status</td><td>@row.Budget.ToString("N2")</td><td>@row.ActualBudgetLines.ToString("N2")</td><td>@row.AllocatedGrants.ToString("N2")</td><td>@row.BeneficiariesCount</td><td>@row.ActivitiesCount</td><td>@row.ExecutionPercentage.ToString("N2")%</td></tr>}</tbody></table></div></div></div>

@model InfrastructureManagmentWebFramework.Models.Reports.StoreItemMovementDetailReportVm
@{
    ViewData["Title"] = "حركة الأصناف بالمخازن";
}
@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")
<div class="card mb-3"><div class="card-body"><form method="get" class="row g-3 align-items-end"><div class="col-md-4"><label class="form-label">المخزن</label><select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select"><option value="">الكل</option></select></div><div class="col-md-2"><label asp-for="FromDate" class="form-label"></label><input asp-for="FromDate" class="form-control" /></div><div class="col-md-2"><label asp-for="ToDate" class="form-label"></label><input asp-for="ToDate" class="form-control" /></div><div class="col-md-4 d-flex gap-2 flex-wrap"><button type="submit" class="btn btn-primary">عرض</button><a asp-action="StoreItemMovements" class="btn btn-light">إعادة ضبط</a><a asp-action="PrintStoreItemMovements" asp-route-warehouseId="@Model.WarehouseId" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" target="_blank" class="btn btn-outline-secondary">طباعة</a></div></form></div></div>
<div class="row mb-3"><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">الوارد</div><h5>@Model.TotalReceived.ToString("N2")</h5></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">المنصرف</div><h5>@Model.TotalIssued.ToString("N2")</h5></div></div></div><div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">الصافي</div><h5>@Model.TotalNet.ToString("N2")</h5></div></div></div></div>
<div class="card"><div class="card-body"><h4 class="card-title mb-3">حركة الأصناف بالمخازن</h4><div class="table-responsive"><table class="table table-bordered table-striped align-middle"><thead><tr><th>المخزن</th><th>كود الصنف</th><th>الصنف</th><th>الوارد</th><th>المنصرف</th><th>الصافي</th></tr></thead><tbody>@foreach (var row in Model.Rows){<tr><td>@row.WarehouseName</td><td>@row.ItemCode</td><td>@row.ItemName</td><td>@row.ReceivedQuantity.ToString("N2")</td><td>@row.IssuedQuantity.ToString("N2")</td><td>@row.NetQuantity.ToString("N2")</td></tr>}</tbody></table></div></div></div>

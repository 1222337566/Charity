@model InfrastructureManagmentWebFramework.Models.Reports.StoreMovementReportVm
@{
    ViewData["Title"] = "تقرير حركة المخازن";
}

@await Html.PartialAsync("~/Views/Shared/Reports/_ReportsNav.cshtml")

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3"><label asp-for="FromDate" class="form-label"></label><input asp-for="FromDate" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="ToDate" class="form-label"></label><input asp-for="ToDate" class="form-control" /></div>
            <div class="col-md-6 d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-primary">عرض</button>
                <a asp-action="StoreMovements" class="btn btn-light">إعادة ضبط</a>
                <a asp-action="StoreItemMovements" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" class="btn btn-outline-primary">حركة الأصناف</a>
            </div>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-6"><div class="card"><div class="card-body"><div class="text-muted">إجمالي كميات الإضافة</div><h5>@Model.TotalReceivedQty.ToString("N2")</h5></div></div></div>
    <div class="col-md-6"><div class="card"><div class="card-body"><div class="text-muted">إجمالي كميات الصرف</div><h5>@Model.TotalIssuedQty.ToString("N2")</h5></div></div></div>
</div>

<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h4 class="card-title mb-0">تقرير حركة المخازن</h4>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="PrintStoreMovements" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" target="_blank" class="btn btn-outline-secondary btn-sm">طباعة</a>
                <a asp-action="ExportStoreMovementsExcel" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" class="btn btn-success btn-sm">Excel</a>
                <a asp-action="ExportStoreMovementsPdf" asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")" class="btn btn-danger btn-sm">PDF</a>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead><tr><th>المخزن</th><th>عدد أذون الإضافة</th><th>كمية الإضافة</th><th>عدد أذون الصرف</th><th>كمية الصرف</th></tr></thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr><td>@row.WarehouseName</td><td>@row.ReceiptsCount</td><td>@row.ReceiptQuantity.ToString("N2")</td><td>@row.IssuesCount</td><td>@row.IssueQuantity.ToString("N2")</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.Charity.Stores.Receipts.CreateStoreReceiptVm
@await Html.PartialAsync("~/Views/Shared/Stores/_StoresNav.cshtml")
<h4 class="mb-3">إضافة إذن إضافة مخزني</h4>
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    @await Html.PartialAsync("_Form", Model)
    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">حفظ</button>
        <a asp-action="Index" class="btn btn-light">عودة</a>
    </div>
</form>

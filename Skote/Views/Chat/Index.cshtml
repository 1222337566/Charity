@{
    ViewData["Title"] = "Chat";
    Layout = "_Layout"; // Skote layout
}

<div class="row">
    <!-- left -->
    <div class="col-xl-3 col-lg-4">
        <div class="card">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div>
                        <h5 class="mb-0">Rooms</h5>
                        <small class="text-muted">اختر غرفة</small>
                    </div>
                    <button id="btn-add-room" class="btn btn-sm btn-primary ms-auto">+ Room</button>
                </div>

                <div id="rooms" class="list-group">
                    <a href="javascript:void(0)" data-room="general" class="list-group-item list-group-item-action active"># general</a>
                    <a href="javascript:void(0)" data-room="it" class="list-group-item list-group-item-action"># it</a>
                    <a href="javascript:void(0)" data-room="security" class="list-group-item list-group-item-action"># security</a>
                </div>

                <hr class="my-3" />

                <div class="d-flex align-items-center mb-2">
                    <h6 class="mb-0">Users online</h6>
                    <span id="online-count" class="badge bg-success ms-2">0</span>
                </div>
                <ul id="users" class="list-unstyled mb-0" style="max-height: 220px; overflow:auto;"></ul>
            </div>
        </div>
    </div>

    <!-- right -->
    <div class="col-xl-9 col-lg-8">
        <div class="card">
            <div class="card-body d-flex flex-column" style="height: 70vh;">
                <div class="d-flex align-items-center border-bottom pb-2 mb-2">
                    <div>
                        <h5 class="mb-0">Room: <span id="roomName" class="badge bg-info">general</span></h5>
                        <small id="typing" class="text-muted" style="display:none">someone is typing…</small>
                    </div>
                    <div class="ms-auto input-group" style="width: 260px;">
                        <span class="input-group-text"><i class="mdi mdi-account"></i></span>
                        <input id="me" class="form-control" placeholder="Your name (optional)">
                    </div>
                </div>

                <div id="log" class="flex-grow-1 p-2" style="overflow:auto; background:#fafafa; border-radius:.5rem; border:1px solid #eee;"></div>

                <div class="mt-2">
                    <div class="input-group">
                        <input id="msg" class="form-control" placeholder="اكتب رسالتك…" />
                        <button id="btn-send" class="btn btn-primary"><i class="mdi mdi-send"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ~/assets/js/chat.skote.js
        (function () {
          "use strict";

          // عناصر الواجهة
          const ui = {
            rooms: document.getElementById("rooms"),
            roomName: document.getElementById("roomName"),
            users: document.getElementById("users"),
            onlineCount: document.getElementById("online-count"),
            log: document.getElementById("log"),
            typing: document.getElementById("typing"),
            msg: document.getElementById("msg"),
            send: document.getElementById("btn-send"),
          };

          // حالة العميل
          let chat = null;
          let currentRoom = "general";
          let usersInRoom = []; // [{userId, userName}]

          // Utils
          const esc = (s) => String(s ?? "").replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
          const append = (html) => {
            const d = document.createElement("div");
            d.innerHTML = html;
            ui.log?.appendChild(d);
            if (ui.log) ui.log.scrollTop = ui.log.scrollHeight;
          };

          function setRoomBadge(name) {
            if (ui.roomName) ui.roomName.textContent = name;
          }

          function renderUsers(list) {
            usersInRoom = Array.from(list || []);
            if (ui.users) ui.users.innerHTML = "";
            if (ui.onlineCount) ui.onlineCount.textContent = usersInRoom.length;

            usersInRoom.forEach(u => {
              const li = document.createElement("li");
              li.className = "d-flex align-items-center mb-2";
              li.innerHTML = `
                <div class="avatar-xs me-2">
                  <span class="avatar-title rounded-circle bg-soft-success text-success">
                    ${esc((u.userName || "?")[0])}
                  </span>
                </div>
                <div class="flex-grow-1">
                  <div class="fw-semibold">${esc(u.userName)}</div>
                  <small class="text-muted">${esc(u.userId)}</small>
                </div>
                <button class="btn btn-sm btn-outline-primary ms-2" type="button">DM</button>
              `;
              li.querySelector("button").onclick = async () => {
                const txt = prompt("رسالة خاصة إلى: " + u.userName);
                if (txt) {
                  try {
                    // hub: SendPrivate(string toUserId, string message)
                    await chat.invoke("SendPrivate", u.userId, txt);
                    append(`<span class="badge bg-primary me-1">Private</span> <b>You → ${esc(u.userName)}</b>: ${esc(txt)}`);
                  } catch (e) {
                    console.error(e);
                    append(`<div class="text-danger">Private send failed: ${esc(e?.message||e)}</div>`);
                  }
                }
              };
              ui.users?.appendChild(li);
            });
          }

          // أحداث SignalR (تتطابق مع ChatHub claims-based)
          function wireEvents() {
            // ReceiveMessage({ room, fromName, message, at })
            chat.on("ReceiveMessage", ({ room, fromName, message, at }) => {
              if (room !== currentRoom) return;
              append(
                `<small class="text-muted">${new Date(at).toLocaleTimeString()}</small>
                 <b class="ms-2">[${esc(room)}] ${esc(fromName)}</b>: ${esc(message)}`
              );
            });

            // ReceivePrivate({ fromName, message, at })
            chat.on("ReceivePrivate", ({ fromName, message, at }) => {
              append(
                `<span class="badge bg-info me-1">Private</span>
                 <small class="text-muted">${new Date(at).toLocaleTimeString()}</small>
                 <b class="ms-2">${esc(fromName)}</b>: ${esc(message)}`
              );
            });

            // UserTyping({ room, userName, isTyping })
            chat.on("UserTyping", ({ room, userName, isTyping }) => {
              if (room !== currentRoom || !ui.typing) return;
              ui.typing.style.display = isTyping ? "inline" : "none";
              ui.typing.textContent = isTyping ? `${userName} is typing…` : "";
            });

            // Presence (لو مفعل في الهَب)
            chat.on("OnlineUsers", renderUsers);
            chat.on("UserOnline", (u) => { // {userId, userName}
              if (!usersInRoom.find(x => x.userId === u.userId)) {
                usersInRoom.push(u);
                renderUsers(usersInRoom);
              }
            });
            chat.on("UserOffline", (u) => {
              usersInRoom = usersInRoom.filter(x => x.userId !== u.userId);
              renderUsers(usersInRoom);
            });
          }

          async function join(room) {
            // hub: JoinRoom(string room)
            await chat.invoke("JoinRoom", room);
            setRoomBadge(room);
            append(`<i class="text-success">Joined room: ${esc(room)}</i>`);
          }
          async function leave(room) {
            try { await chat.invoke("LeaveRoom", room); } catch {}
          }

          function wireUI() {
            // إرسال رسالة: SendToRoom(string room, string message)
            ui.send?.addEventListener("click", async () => {
              const txt = (ui.msg?.value || "").trim();
              if (!txt) return;
              try {
                await chat.invoke("SendToRoom", currentRoom, txt);
                if (ui.msg) ui.msg.value = "";
                try { await chat.invoke("Typing", currentRoom, false); } catch {}
              } catch (e) {
                console.error(e);
                append(`<div class="text-danger">Send failed: ${esc(e?.message||e)}</div>`);
              }
            });

            // Enter للإرسال + Typing(room, bool)
            ui.msg?.addEventListener("keydown", async (e) => {
              if (e.key === "Enter") { ui.send?.click(); return; }
              try {
                await chat.invoke("Typing", currentRoom, true);
                clearTimeout(window.__typingTimer);
                window.__typingTimer = setTimeout(() => chat.invoke("Typing", currentRoom, false), 1200);
              } catch {}
            });

            // تبديل الغرف (لو عندك قائمة rooms بعناصر data-room)
            ui.rooms?.addEventListener("click", async (e) => {
              const a = e.target.closest("[data-room]");
              if (!a) return;
              const next = a.getAttribute("data-room");
              if (!next || next === currentRoom) return;
              try {
                await leave(currentRoom);
                currentRoom = next;
                await join(currentRoom);
              } catch (err) {
                console.error(err);
                append(`<div class="text-danger">Switch failed: ${esc(err?.message||err)}</div>`);
              }
            });
          }

          async function init() {
            // 1) احصل على عميل hub باسم 'chat' — الـ Manager هيقرأ URL من window.__SIGNALR_HUBS__
            chat = await SignalR.get('chat'); // TokenProvider يُستخدم تلقائيًا

            // 2) اربط الأحداث
            wireEvents();

            // 3) انضم للغرفة الافتراضية
            await join(currentRoom);

            // 4) هيّئ واجهة المستخدم
            wireUI();
          }

          // ابدأ
          init().catch(err => {
            console.error(err);
            append(`<div class="alert alert-danger">Failed to init chat: ${esc(err?.message||err)}</div>`);
          });
        })();
    </script>

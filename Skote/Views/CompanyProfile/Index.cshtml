@using InfrastructureManagmentWebFramework.Models.Company;
@model CompanyProfileVm

@{
    ViewData["Title"] = "بيانات الشركة";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">بيانات الشركة</h4>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                    <div class="alert alert-success">@TempData["Success"]</div>
            }

            <form asp-action="Index" method="post">
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CompanyNameAr" class="form-label"></label>
                        <input asp-for="CompanyNameAr" class="form-control" />
                        <span asp-validation-for="CompanyNameAr" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CompanyNameEn" class="form-label"></label>
                        <input asp-for="CompanyNameEn" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="TaxNumber" class="form-label"></label>
                        <input asp-for="TaxNumber" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ReceiptHeaderText" class="form-label"></label>
                        <input asp-for="ReceiptHeaderText" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ReceiptFooterText" class="form-label"></label>
                        <input asp-for="ReceiptFooterText" class="form-control" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">حفظ</button>
            </form>
        </div>
    </div>
</div>
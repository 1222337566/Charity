@model List<InfrastructureManagmentWebFramework.Models.Accounting.CostCenterListItemVm>
@{
    ViewData["Title"] = "مراكز التكلفة";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">مراكز التكلفة</h4>
            <a asp-action="Create" class="btn btn-primary btn-sm">إضافة مركز تكلفة</a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>المستوى</th>
                        <th>مرتبط بالمشروعات</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    var indent = (item.Level - 1) * 25;
                    <tr>
                        <td>@item.CostCenterCode</td>
                        <td><div style="padding-right:@(indent)px">@item.CostCenterNameAr</div></td>
                        <td>@item.Level</td>
                        <td>@(item.IsProjectRelated ? "نعم" : "لا")</td>
                        <td>@(item.IsActive ? "نشط" : "غير نشط")</td>
                        <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">تعديل</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

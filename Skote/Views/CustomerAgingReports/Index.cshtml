@model InfrastructureManagmentWebFramework.Models.AgingReports.CustomerAgingReportPageVm
@{
    ViewData["Title"] = "أعمار ديون العملاء";
}

<style>
.ag-hero{background:linear-gradient(135deg,#1f2937,#2563eb);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.ag-card{background:#fff;border-radius:16px;border:.5px solid rgba(37,99,235,.12);box-shadow:0 2px 8px rgba(37,99,235,.05);overflow:hidden;margin-bottom:16px}
.ag-head{padding:12px 18px;border-bottom:.5px solid rgba(37,99,235,.08);font-size:.9rem;font-weight:700;color:#1d4ed8;background:rgba(37,99,235,.03)}
.ag-table{width:100%;border-collapse:collapse;font-size:.82rem}
.ag-table th{background:#f8fafc;color:#64748b;font-size:.75rem;font-weight:700;padding:9px;border-bottom:1px solid #e5e7eb}
.ag-table td{padding:9px;border-bottom:1px solid #f1f5f9;vertical-align:middle}
.ag-table tr:hover td{background:#f8fafc}
.ag-stat{background:rgba(255,255,255,.14);border-radius:12px;padding:10px 14px;text-align:center;flex:1;min-width:120px}
.ag-stat .n{font-size:1.2rem;font-weight:800;line-height:1}
.ag-stat .l{font-size:.7rem;opacity:.85;margin-top:2px}
.bucket-0{color:#059669;font-weight:800}
.bucket-1{color:#ca8a04;font-weight:800}
.bucket-2{color:#ea580c;font-weight:800}
.bucket-3{color:#dc2626;font-weight:800}
</style>

<div class="ag-hero">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h4 class="fw-bold mb-1 text-white"><i class="bx bx-time-five me-2"></i>أعمار ديون العملاء</h4>
            <div style="opacity:.78;font-size:.82rem">توزيع مستحقات العملاء حسب عمر الفواتير غير المسددة</div>
        </div>
        <a asp-controller="CustomerStatements" asp-action="Index" class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">كشف حساب عميل</a>
    </div>
    <div class="d-flex gap-3 flex-wrap">
        <div class="ag-stat"><div class="n">@Model.Totals.TotalOutstanding.ToString("N0")</div><div class="l">إجمالي المستحق</div></div>
        <div class="ag-stat"><div class="n">@Model.Totals.Current0To30.ToString("N0")</div><div class="l">0 - 30 يوم</div></div>
        <div class="ag-stat"><div class="n">@Model.Totals.Days31To60.ToString("N0")</div><div class="l">31 - 60 يوم</div></div>
        <div class="ag-stat"><div class="n">@Model.Totals.Days61To90.ToString("N0")</div><div class="l">61 - 90 يوم</div></div>
        <div class="ag-stat" style="background:rgba(220,38,38,.2)"><div class="n" style="color:#fecaca">@Model.Totals.Over90.ToString("N0")</div><div class="l">أكثر من 90 يوم</div></div>
    </div>
</div>

<div class="ag-card">
    <div class="ag-head">فلاتر التقرير</div>
    <div class="p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <label asp-for="CustomerId" class="form-label"></label>
                <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select"><option value="">كل العملاء</option></select>
            </div>
            <div class="col-md-3">
                <label asp-for="AsOfDate" class="form-label"></label>
                <input asp-for="AsOfDate" type="date" class="form-control" />
            </div>
            <div class="col-md-3"><button class="btn btn-primary w-100 fw-bold">عرض التقرير</button></div>
        </form>
    </div>
</div>

<div class="ag-card">
    <div class="ag-head">ملخص أعمار الديون</div>
    <div class="table-responsive">
        <table class="ag-table">
            <thead>
                <tr>
                    <th>العميل</th><th>إجمالي الفواتير</th><th>إجمالي المقبوض</th><th>0-30</th><th>31-60</th><th>61-90</th><th>90+</th><th>الإجمالي المستحق</th><th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Rows)
            {
                <tr>
                    <td><div class="fw-bold">@r.PartyName</div><div style="font-size:.72rem;color:#94a3b8">@r.PartyNumber</div></td>
                    <td>@r.TotalInvoiced.ToString("N2")</td>
                    <td>@r.TotalPaidOrReceived.ToString("N2")</td>
                    <td class="bucket-0">@r.Current0To30.ToString("N2")</td>
                    <td class="bucket-1">@r.Days31To60.ToString("N2")</td>
                    <td class="bucket-2">@r.Days61To90.ToString("N2")</td>
                    <td class="bucket-3">@r.Over90.ToString("N2")</td>
                    <td class="fw-bold text-danger">@r.TotalOutstanding.ToString("N2")</td>
                    <td><a asp-controller="CustomerStatements" asp-action="Index" asp-route-customerId="@r.PartyId" class="btn btn-sm btn-outline-primary">كشف</a></td>
                </tr>
                @if (Model.CustomerId == r.PartyId && r.OpenInvoices.Any())
                {
                    <tr>
                        <td colspan="9" style="background:#f8fafc">
                            <strong>الفواتير المفتوحة:</strong>
                            <div class="table-responsive mt-2">
                                <table class="table table-sm table-bordered mb-0">
                                    <thead><tr><th>الفاتورة</th><th>التاريخ</th><th>العمر</th><th>إجمالي الفاتورة</th><th>المحصل المخصص</th><th>المتبقي</th><th>الشريحة</th></tr></thead>
                                    <tbody>
                                    @foreach (var inv in r.OpenInvoices)
                                    {
                                        <tr>
                                            <td>@inv.InvoiceNumber</td>
                                            <td>@inv.InvoiceDateUtc.ToLocalTime().ToString("yyyy/MM/dd")</td>
                                            <td>@inv.AgeDays يوم</td>
                                            <td>@inv.InvoiceAmount.ToString("N2")</td>
                                            <td>@inv.AllocatedPayment.ToString("N2")</td>
                                            <td class="text-danger fw-bold">@inv.RemainingAmount.ToString("N2")</td>
                                            <td>@inv.Bucket</td>
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
    @if (!Model.Rows.Any())
    {
        <div class="p-4 text-center text-muted">لا توجد مستحقات حسب الفلاتر الحالية.</div>
    }
</div>

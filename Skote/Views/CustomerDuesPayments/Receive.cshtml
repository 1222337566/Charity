@model InfrastructureManagmentWebFramework.Models.CustomerDuesPayments.CustomerReceiveVm

@{
    ViewData["Title"] = "تحصيل من عميل";
}

<div style="background:linear-gradient(135deg,#064e3b,#0f766e);border-radius:16px;padding:16px 22px;color:#fff;margin-bottom:18px">
    <h5 class="fw-bold mb-1 text-white"><i class="bx bx-money me-2"></i>تحصيل من عميل</h5>
    <div style="opacity:.75;font-size:.8rem">
        العميل: <strong>@Model.CustomerName</strong> — الرصيد المستحق:
        <strong>@Model.CurrentDue.ToString("N2")</strong>
    </div>
</div>

<div class="card" style="border-radius:16px;border:.5px solid rgba(6,78,59,.1)">
    <div class="card-body p-4">
        <form asp-action="Receive" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="CustomerId" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="ReceiptNumber" class="form-label fw-semibold" style="font-size:.83rem"></label>
                    <input asp-for="ReceiptNumber" class="form-control" style="border-radius:10px" />
                    <span asp-validation-for="ReceiptNumber" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="ReceiptDateUtc" class="form-label fw-semibold" style="font-size:.83rem"></label>
                    <input asp-for="ReceiptDateUtc" type="datetime-local" class="form-control" style="border-radius:10px"
                           value="@Model.ReceiptDateUtc.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="ReceiptDateUtc" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold" style="font-size:.83rem">رقم العميل</label>
                    <input class="form-control" value="@Model.CustomerNumber" readonly style="border-radius:10px" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold" style="font-size:.83rem">اسم العميل</label>
                    <input class="form-control" value="@Model.CustomerName" readonly style="border-radius:10px" />
                </div>

                <div class="col-md-4">
                    <label asp-for="SalesInvoiceId" class="form-label fw-semibold" style="font-size:.83rem"></label>
                    <select asp-for="SalesInvoiceId" asp-items="Model.Invoices" class="form-select" style="border-radius:10px">
                        <option value="">-- بدون ربط فاتورة --</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label asp-for="Amount" class="form-label fw-semibold" style="font-size:.83rem"></label>
                    <input asp-for="Amount" type="number" step="0.01" class="form-control" style="border-radius:10px" />
                    <small class="text-muted">المقترح: @Model.SuggestedAmount.ToString("N2")</small>
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="PaymentMethodId" class="form-label fw-semibold" style="font-size:.83rem"></label>
                    <select asp-for="PaymentMethodId" asp-items="Model.PaymentMethods" class="form-select" style="border-radius:10px">
                        <option value="">-- اختر طريقة الدفع --</option>
                    </select>
                </div>

                <div class="col-12">
                    <label asp-for="Notes" class="form-label fw-semibold" style="font-size:.83rem"></label>
                    <textarea asp-for="Notes" class="form-control" rows="2" style="border-radius:10px"></textarea>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success fw-bold" style="border-radius:12px">
                    <i class="bx bx-save me-1"></i>حفظ التحصيل
                </button>
                <a asp-action="Index" asp-route-customerId="@Model.CustomerId" class="btn btn-light fw-bold" style="border-radius:12px">إلغاء</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

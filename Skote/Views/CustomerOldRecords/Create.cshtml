@model CreateOldRecordVm
@using InfrastructureManagmentWebFramework.Models.Optics

@{
    ViewData["Title"] = "إضافة سجل قديم";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">إضافة سجل قديم</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <input asp-for="CustomerId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label">رقم العميل</label>
                        <input class="form-control" value="@Model.CustomerNumber" readonly />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">اسم العميل</label>
                        <input class="form-control" value="@Model.CustomerName" readonly />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="RecordDateUtc" class="form-label"></label>
                        <input asp-for="RecordDateUtc" type="datetime-local" class="form-control"
                               value="@(Model.RecordDateUtc.ToString("yyyy-MM-ddTHH:mm"))" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Details" class="form-label"></label>
                    <textarea asp-for="Details" class="form-control" rows="6"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">حفظ</button>
                <a asp-action="Index" asp-route-customerId="@Model.CustomerId" class="btn btn-secondary">رجوع</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
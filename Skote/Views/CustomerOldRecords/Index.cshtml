@model List<OldRecordListItemVm>
@using InfrastructureManagmentWebFramework.Models.Optics


@{
    ViewData["Title"] = "Old Records";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0">Old Records</h4>
                <small class="text-muted">
                    العميل: @ViewBag.CustomerName - @ViewBag.CustomerNumber
                </small>
            </div>

            <div class="d-flex gap-2">
                <a asp-controller="Customers" asp-action="Details" asp-route-id="@ViewBag.CustomerId" class="btn btn-secondary btn-sm">
                    ملف العميل
                </a>
                <a asp-action="Create" asp-route-customerId="@ViewBag.CustomerId" class="btn btn-primary btn-sm">
                    إضافة سجل
                </a>
            </div>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>التاريخ</th>
                            <th>العنوان</th>
                            <th>التفاصيل</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RecordDateUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@item.Title</td>
                                <td>@(item.Details ?? "-")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">غير نشط</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        تعديل
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
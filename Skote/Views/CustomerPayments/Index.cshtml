@model InfrastructureManagmentWebFramework.Models.CustomerPayments.CustomerPaymentPageVm

@{
    ViewData["Title"] = "مستحقات العملاء";
}

<style>
.cp-hero{background:linear-gradient(135deg,#064e3b,#0f766e);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.cp-stat{background:rgba(255,255,255,.12);border-radius:12px;padding:10px 14px;text-align:center;flex:1;min-width:90px}
.cp-stat .n{font-size:1.2rem;font-weight:800;line-height:1}
.cp-stat .l{font-size:.67rem;opacity:.8;margin-top:2px}
.cp-card{background:#fff;border-radius:16px;border:.5px solid rgba(6,78,59,.1);box-shadow:0 2px 8px rgba(6,78,59,.05);overflow:hidden;margin-bottom:16px}
.cp-head{padding:12px 18px;border-bottom:.5px solid rgba(6,78,59,.07);font-size:.9rem;font-weight:700;color:#064e3b;background:rgba(6,78,59,.02)}
.cp-row{display:grid;grid-template-columns:1fr 1fr 1fr 1fr 90px;gap:0;padding:10px 16px;border-bottom:.5px solid rgba(6,78,59,.04);font-size:.84rem;align-items:center}
.cp-row:hover{background:rgba(6,78,59,.02)}
.cp-row:last-child{border-bottom:none}
.balance-red{color:#f46a6a;font-weight:700}
.balance-green{color:#34c38f;font-weight:700}
.receive-btn{background:#064e3b;color:#fff;border:none;border-radius:8px;padding:4px 12px;font-size:.75rem;font-weight:600;cursor:pointer;text-decoration:none;white-space:nowrap}
.receive-btn:hover{background:#0f766e;color:#fff}
</style>

<div class="cp-hero">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-1 text-white">
                <i class="bx bx-wallet me-2"></i>مستحقات العملاء
            </h4>
            <div style="opacity:.72;font-size:.8rem">
                إدارة التحصيل والأرصدة لكل عميل
            </div>
        </div>
        <a asp-controller="Customers" asp-action="Create"
           class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">
            <i class="bx bx-plus me-1"></i>عميل جديد
        </a>
    </div>

    <div class="d-flex gap-3 flex-wrap">
        <div class="cp-stat">
            <div class="n">@Model.Rows.Count</div>
            <div class="l">العملاء</div>
        </div>
        <div class="cp-stat" style="background:rgba(244,106,106,.2)">
            <div class="n" style="color:#fca5a5">@Model.TotalReceivable.ToString("N0")</div>
            <div class="l">إجمالي المستحقات</div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="cp-card">
    <div class="cp-head">العملاء وأرصدتهم</div>
    <div style="padding:8px 16px;background:#f8fbfb;border-bottom:.5px solid rgba(6,78,59,.08);display:grid;grid-template-columns:1fr 1fr 1fr 1fr 90px;font-size:.76rem;font-weight:700;color:#6b7d80">
        <div>العميل</div>
        <div style="text-align:center">إجمالي الفواتير</div>
        <div style="text-align:center">المقبوض</div>
        <div style="text-align:center">المستحق</div>
        <div></div>
    </div>

    @foreach (var r in Model.Rows)
    {
        var bal = r.Balance;
        <a asp-action="Index" asp-route-customerId="@r.CustomerId"
           style="text-decoration:none;color:inherit">
            <div class="cp-row"
                 style="@(Model.CustomerId == r.CustomerId ? "background:rgba(6,78,59,.05);border-right:3px solid #064e3b" : "")">
                <div>
                    <div class="fw-semibold" style="color:#064e3b">@r.CustomerName</div>
                    <div style="font-size:.72rem;color:#adb5bd">
                        @r.CustomerNumber
                        @if (!string.IsNullOrWhiteSpace(r.MobileNo))
                        {
                            <span> · @r.MobileNo</span>
                        }
                    </div>
                </div>
                <div style="text-align:center">@r.Invoiced.ToString("N2")</div>
                <div style="text-align:center;color:#34c38f">@r.Received.ToString("N2")</div>
                <div style="text-align:center" class="@(bal > 0 ? "balance-red" : "balance-green")">
                    @bal.ToString("N2")
                </div>
                <div>
                    @if (bal > 0)
                    {
                        <a asp-action="Receive" asp-route-customerId="@r.CustomerId" class="receive-btn"
                           onclick="event.stopPropagation()">تحصيل</a>
                    }
                </div>
            </div>
        </a>
    }
</div>

@if (Model.SelectedCustomer != null)
{
    <div class="row g-3 mt-1">
        <div class="col-md-6">
            <div class="cp-card">
                <div class="cp-head d-flex justify-content-between align-items-center">
                    <span><i class="bx bx-file me-2"></i>فواتير @Model.SelectedCustomer.CustomerName</span>
                    <a asp-controller="SalesInvoice" asp-action="Create"
                       class="btn btn-sm btn-outline-primary fw-bold" style="border-radius:8px;font-size:.75rem">
                        فاتورة جديدة
                    </a>
                </div>
                <div style="padding:0">
                    @if (Model.Invoices.Any())
                    {
                        @foreach (var inv in Model.Invoices)
                        {
                            <div style="padding:9px 16px;border-bottom:.5px solid rgba(6,78,59,.04);font-size:.83rem;display:flex;justify-content:space-between;align-items:center">
                                <div>
                                    <div class="fw-semibold">@inv.InvoiceNumber</div>
                                    <div style="font-size:.72rem;color:#adb5bd">
                                        @inv.InvoiceDateUtc.ToLocalTime().ToString("d/M/yyyy")
                                        · مقبوض @inv.Received.ToString("N2")
                                    </div>
                                </div>
                                <div>
                                    <div class="fw-bold">@inv.NetAmount.ToString("N2")</div>
                                    <div style="font-size:.72rem;color:@(inv.Balance > 0 ? "#f46a6a" : "#34c38f")">
                                        متبقي @inv.Balance.ToString("N2")
                                    </div>
                                </div>
                                @if (inv.Balance > 0)
                                {
                                    <a asp-action="Receive"
                                       asp-route-customerId="@Model.SelectedCustomer.CustomerId"
                                       asp-route-invoiceId="@inv.Id"
                                       class="btn btn-sm"
                                       style="border-radius:7px;background:rgba(6,78,59,.08);color:#064e3b;border:none;font-size:.72rem">
                                        تحصيل
                                    </a>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div style="padding:20px;text-align:center;color:#adb5bd">لا توجد فواتير</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="cp-card">
                <div class="cp-head d-flex justify-content-between align-items-center">
                    <span><i class="bx bx-money me-2"></i>سندات القبض</span>
                    <a asp-action="Receive" asp-route-customerId="@Model.SelectedCustomer.CustomerId"
                       class="btn btn-sm btn-success fw-bold" style="border-radius:8px;font-size:.75rem">
                        + تحصيل جديد
                    </a>
                </div>
                <div style="padding:0">
                    @if (Model.Receipts.Any())
                    {
                        @foreach (var p in Model.Receipts)
                        {
                            <div style="padding:9px 16px;border-bottom:.5px solid rgba(6,78,59,.04);font-size:.83rem">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <div class="fw-semibold">@p.ReceiptNumber</div>
                                        <div style="font-size:.72rem;color:#adb5bd">
                                            @p.ReceiptDateUtc.ToLocalTime().ToString("d/M/yyyy")
                                            @if (!string.IsNullOrWhiteSpace(p.PaymentMethodName))
                                            {
                                                <span> · @p.PaymentMethodName</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(p.InvoiceNumber))
                                            {
                                                <span> · فاتورة @p.InvoiceNumber</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="fw-bold" style="color:#34c38f">@p.Amount.ToString("N2")</div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(p.Notes))
                                {
                                    <div style="font-size:.72rem;color:#adb5bd;margin-top:2px">@p.Notes</div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div style="padding:20px;text-align:center;color:#adb5bd">لا توجد سندات قبض</div>
                    }
                </div>
            </div>
        </div>
    </div>
}

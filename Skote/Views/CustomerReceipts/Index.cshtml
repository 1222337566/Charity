@model List<CustomerReceiptListItemVm>
@using InfrastructureManagmentWebFramework.Models.Optics;

@{
    ViewData["Title"] = "سندات القبض";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">سندات القبض</h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>رقم السند</th>
                            <th>التاريخ</th>
                            <th>العميل</th>
                            <th>طريقة الدفع</th>
                            <th>المبلغ</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ReceiptNumber</td>
                                <td>@item.ReceiptDateUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@item.CustomerName</td>
                                <td>@(item.PaymentMethodName ?? "-")</td>
                                <td>@item.Amount</td>
                                <td>@item.StatusText</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
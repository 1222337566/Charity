@model CustomerReportPageVm
@using InfrastructureManagmentWebFramework.Models.Optics.Reports

@{
    ViewData["Title"] = "Customer Report";
}

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-header">
            <h4 class="mb-0">Customer Report</h4>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">العميل</label>
                    <select asp-for="Filter.CustomerId" asp-items="Model.Filter.Customers" class="form-select">
                        <option value="">-- اختر العميل --</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">من تاريخ</label>
                    <input asp-for="Filter.DateFrom" type="date" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">إلى تاريخ</label>
                    <input asp-for="Filter.DateTo" type="date" class="form-control" />
                </div>

                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Report != null)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h4 class="mb-0">تقرير العميل</h4>

                <div class="d-flex gap-2">
                    <a asp-controller="Customers" asp-action="Details" asp-route-id="@Model.Report.CustomerId" class="btn btn-secondary btn-sm">
                        ملف العميل
                    </a>
                    <button type="button" class="btn btn-dark btn-sm" onclick="window.print()">
                        طباعة
                    </button>
                </div>
            </div>

            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-3">
                        <label class="form-label">رقم العميل</label>
                        <input class="form-control" value="@Model.Report.CustomerNumber" readonly />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">الاسم</label>
                        <input class="form-control" value="@Model.Report.CustomerName" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">النوع</label>
                        <input class="form-control" value="@Model.Report.GenderText" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">السن</label>
                        <input class="form-control" value="@(Model.Report.Age?.ToString() ?? "-")" readonly />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">الرصيد</label>
                        <input class="form-control fw-bold" value="@Model.Report.AccountBalance" readonly />
                    </div>

                    <div class="col-md-3 mt-3">
                        <label class="form-label">تليفون</label>
                        <input class="form-control" value="@Model.Report.Tel" readonly />
                    </div>
                    <div class="col-md-3 mt-3">
                        <label class="form-label">موبايل</label>
                        <input class="form-control" value="@Model.Report.MobileNo" readonly />
                    </div>
                    <div class="col-md-6 mt-3">
                        <label class="form-label">الفترة</label>
                        <input class="form-control" value="@($"{Model.Report.DateFrom:yyyy-MM-dd} -> {Model.Report.DateTo:yyyy-MM-dd}")" readonly />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-xl-2 col-md-4">
                        <div class="border rounded p-3 bg-light">
                            <div class="text-muted">Prescriptions</div>
                            <div class="fs-4 fw-bold">@Model.Report.PrescriptionsCount</div>
                        </div>
                    </div>
                    <div class="col-xl-2 col-md-4">
                        <div class="border rounded p-3 bg-light">
                            <div class="text-muted">Sold items</div>
                            <div class="fs-4 fw-bold">@Model.Report.SoldItemsCount</div>
                        </div>
                    </div>
                    <div class="col-xl-2 col-md-4">
                        <div class="border rounded p-3 bg-light">
                            <div class="text-muted">Old Records</div>
                            <div class="fs-4 fw-bold">@Model.Report.OldRecordsCount</div>
                        </div>
                    </div>
                    <div class="col-xl-2 col-md-4">
                        <div class="border rounded p-3 bg-light">
                            <div class="text-muted">Work Orders</div>
                            <div class="fs-4 fw-bold">@Model.Report.WorkOrdersCount</div>
                        </div>
                    </div>
                </div>

                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#rep-prescriptions">Prescription</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#rep-sales">Sold items</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#rep-account">Account</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#rep-old">Old Records</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#rep-workorders">Work Orders</a></li>
                </ul>

                <div class="tab-content border border-top-0 p-3">
                    <div class="tab-pane active" id="rep-prescriptions">
                        @await Html.PartialAsync("_CustomerReportTable", Model.Report.Prescriptions)
                    </div>

                    <div class="tab-pane" id="rep-sales">
                        @await Html.PartialAsync("_CustomerReportTable", Model.Report.Sales)
                    </div>

                    <div class="tab-pane" id="rep-account">
                        @await Html.PartialAsync("_CustomerReportTable", Model.Report.AccountEntries)
                    </div>

                    <div class="tab-pane" id="rep-old">
                        @await Html.PartialAsync("_CustomerReportTable", Model.Report.OldRecords)
                    </div>

                    <div class="tab-pane" id="rep-workorders">
                        @await Html.PartialAsync("_CustomerReportTable", Model.Report.WorkOrders)
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    @@media print {
        .btn, .card-header form, .nav-tabs {
            display: none !important;
        }

        .tab-pane {
            display: block !important;
            opacity: 1 !important;
        }

        .tab-content {
            border: none !important;
            padding: 0 !important;
        }

        body {
            background: #fff !important;
        }
    }
</style>
@model CustomerOpticalSaleVm
@using InfrastructureManagmentWebFramework.Models.Optics

@{
    ViewData["Title"] = "Customer Sale";
}

<link rel="stylesheet" href="~/assets/css/Customer-Sale.css" />

<div class="container-fluid">
    <form asp-action="Create" method="post" id="customer-sale-form">
        <input asp-for="CustomerId" type="hidden" />

        <div class="row">
            <div class="col-lg-4">
                <div class="card sticky-sale-card">
                    <div class="card-header">
                        <h4 class="mb-0">بيانات البيع</h4>
                    </div>
                    <div class="card-body">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label">رقم العميل</label>
                            <input class="form-control" value="@Model.CustomerNumber" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">اسم العميل</label>
                            <input class="form-control" value="@Model.CustomerName" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="InvoiceNumber" class="form-label"></label>
                            <input asp-for="InvoiceNumber" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="InvoiceDateUtc" class="form-label"></label>
                            <input asp-for="InvoiceDateUtc" type="datetime-local" class="form-control"
                                   value="@(Model.InvoiceDateUtc.ToString("yyyy-MM-ddTHH:mm"))" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="WarehouseId" class="form-label"></label>
                            <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select">
                                <option value="">-- اختر المخزن --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PrescriptionId" class="form-label"></label>
                            <select asp-for="PrescriptionId" asp-items="Model.Prescriptions" class="form-select" id="prescription-select">
                                <option value="">-- اختر الروشتة --</option>
                            </select>
                        </div>

                        <div class="prescription-box mb-3" id="prescription-box">
                            <div class="text-muted">اختر الروشتة لعرض التفاصيل</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        </div>

                        <hr />
                        <h5 class="mb-3">طرق الدفع</h5>

                        <div class="table-responsive">
                            <table class="table table-bordered align-middle" id="payments-table">
                                <thead class="table-light">
                                    <tr>
                                        <th>طريقة الدفع</th>
                                        <th style="width:140px;">المبلغ</th>
                                        <th style="width:80px;">حذف</th>
                                    </tr>
                                </thead>
                                <tbody id="payments-body">
                                    @for (int i = 0; i < Model.Payments.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <select asp-for="Payments[@i].PaymentMethodId" asp-items="Model.Payments[i].PaymentMethods" class="form-select payment-method">
                                                    <option value="">-- اختر --</option>
                                                </select>
                                            </td>
                                            <td>
                                                <input asp-for="Payments[@i].Amount" class="form-control payment-amount" />
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-danger btn-remove-payment">حذف</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <button type="button" class="btn btn-outline-primary btn-sm mb-3" id="btn-add-payment">
                            إضافة طريقة دفع
                        </button>

                        <div class="row">
                            <div class="col-6">
                                <label class="form-label">إجمالي البيع</label>
                                <input type="text" class="form-control fw-bold" id="sale-total" readonly />
                            </div>
                            <div class="col-6">
                                <label class="form-label">المتبقي</label>
                                <input type="text" class="form-control fw-bold" id="sale-remaining" readonly />
                            </div>
                        </div>

                        <div class="mt-3 d-flex gap-2">
                            <button type="submit" class="btn btn-success">حفظ البيع</button>
                            <a asp-controller="Customers" asp-action="Details" asp-route-id="@Model.CustomerId" class="btn btn-secondary">رجوع</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h4 class="mb-0">تفاصيل النظارة</h4>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <div class="sale-section">
                                    <h5>Frame</h5>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="form-label">الصنف</label>
                                            <select asp-for="FrameItemId" class="form-select optical-item-select" data-price-target="FrameUnitPrice">
                                                <option value="">-- اختر Frame --</option>
                                                @foreach (var item in Model.Frames)
                                                {
                                                    <option value="@item.Id" data-price="@item.SalePrice">@item.DisplayName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">الكمية</label>
                                            <input asp-for="FrameQty" class="form-control line-qty" data-price-input="FrameUnitPrice" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">السعر</label>
                                            <input asp-for="FrameUnitPrice" class="form-control line-price" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="sale-section">
                                    <h5>Lens</h5>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="form-label">الصنف</label>
                                            <select asp-for="LensItemId" class="form-select optical-item-select" data-price-target="LensUnitPrice">
                                                <option value="">-- اختر Lens --</option>
                                                @foreach (var item in Model.Lenses)
                                                {
                                                    <option value="@item.Id" data-price="@item.SalePrice">@item.DisplayName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">الكمية</label>
                                            <input asp-for="LensQty" class="form-control line-qty" data-price-input="LensUnitPrice" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">السعر</label>
                                            <input asp-for="LensUnitPrice" class="form-control line-price" />
                                        </div>
                                    </div>
                                    <small class="text-muted">الافتراضي عدستين = 2</small>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="sale-section">
                                    <h5>Contact Lens</h5>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="form-label">الصنف</label>
                                            <select asp-for="ContactLensItemId" class="form-select optical-item-select" data-price-target="ContactLensUnitPrice">
                                                <option value="">-- اختر Contact Lens --</option>
                                                @foreach (var item in Model.ContactLenses)
                                                {
                                                    <option value="@item.Id" data-price="@item.SalePrice">@item.DisplayName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">الكمية</label>
                                            <input asp-for="ContactLensQty" class="form-control line-qty" data-price-input="ContactLensUnitPrice" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">السعر</label>
                                            <input asp-for="ContactLensUnitPrice" class="form-control line-price" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-12">
                                <div class="sale-section">
                                    <h5>Accessory</h5>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <label class="form-label">الصنف</label>
                                            <select asp-for="AccessoryItemId" class="form-select optical-item-select" data-price-target="AccessoryUnitPrice">
                                                <option value="">-- اختر Accessory --</option>
                                                @foreach (var item in Model.Accessories)
                                                {
                                                    <option value="@item.Id" data-price="@item.SalePrice">@item.DisplayName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">الكمية</label>
                                            <input asp-for="AccessoryQty" class="form-control line-qty" data-price-input="AccessoryUnitPrice" />
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">السعر</label>
                                            <input asp-for="AccessoryUnitPrice" class="form-control line-price" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 mb-0">
                            الشاشة دي نسخة أولى مخصصة للنظارات. الخطوة اللي بعدها نقدر نخليها أذكى:
                            Frame + Right Lens + Left Lens + أمر شغل / Delivery.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<table class="d-none">
    <tbody>
        <tr id="payment-line-template">
            <td>
                <select class="form-select payment-method">
                    <option value="">-- اختر --</option>
                    @foreach (var method in Model.Payments.First().PaymentMethods)
                    {
                        <option value="@method.Value">@method.Text</option>
                    }
                </select>
            </td>
            <td>
                <input type="number" min="0.01" step="0.01" class="form-control payment-amount" value="0" />
            </td>
            <td>
                <button type="button" class="btn btn-sm btn-danger btn-remove-payment">حذف</button>
            </td>
        </tr>
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/assets/js/Customer-Sale.js"></script>
}
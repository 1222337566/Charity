@model OpticsDashboardVm
@using InfrastructureManagmentWebFramework.Models.Optics.Dashboard

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-xl-3 col-md-6">
            <div class="card mini-stats-wid">
                <div class="card-body">
                    <p class="text-muted">مبيعات اليوم</p>
                    <h4>@Model.SalesTodayTotal</h4>
                    <small>@Model.SalesTodayCount فاتورة</small>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card mini-stats-wid">
                <div class="card-body">
                    <p class="text-muted">مشتريات اليوم</p>
                    <h4>@Model.PurchasesTodayTotal</h4>
                    <small>@Model.PurchasesTodayCount فاتورة</small>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card mini-stats-wid">
                <div class="card-body">
                    <p class="text-muted">قبض اليوم</p>
                    <h4>@Model.ReceiptsTodayTotal</h4>
                    <small>@Model.ReceiptsTodayCount سند</small>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card mini-stats-wid">
                <div class="card-body">
                    <p class="text-muted">مصروفات اليوم</p>
                    <h4>@Model.ExpensesTodayTotal</h4>
                    <small>@Model.ExpensesTodayCount حركة</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-xl-3 col-md-6">
            <div class="card border-warning">
                <div class="card-body">
                    <p class="text-muted">New Orders</p>
                    <h4>@Model.WorkOrdersNewCount</h4>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-info">
                <div class="card-body">
                    <p class="text-muted">In Lab</p>
                    <h4>@Model.WorkOrdersInLabCount</h4>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-success">
                <div class="card-body">
                    <p class="text-muted">Ready</p>
                    <h4>@Model.WorkOrdersReadyCount</h4>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-danger">
                <div class="card-body">
                    <p class="text-danger">Overdue</p>
                    <h4 class="text-danger">@Model.WorkOrdersOverdueCount</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-xl-4 col-md-6">
            <div class="card">
                <div class="card-body">
                    <p class="text-muted">العملاء</p>
                    <h5>الإجمالي: @Model.CustomersCount</h5>
                    <h6>النشط: @Model.ActiveCustomersCount</h6>
                    <h6>برصيد: @Model.CustomersWithBalanceCount</h6>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="card">
                <div class="card-body">
                    <h5 class="mb-3">اختصارات سريعة</h5>
                    <div class="d-flex gap-2 flex-wrap">
                        <a href="@Url.Action("Index", "Customers")" class="btn btn-primary btn-sm">Customer list</a>
                        <a href="@Url.Action("ReadyForDelivery", "OpticalWorkOrders")" class="btn btn-success btn-sm">جاهز للتسليم</a>
                        <a href="@Url.Action("Index", "FindSales")" class="btn btn-info btn-sm">Find Sales</a>
                        <a href="@Url.Action("Index", "FindPurchases")" class="btn btn-warning btn-sm">Find Purchase</a>
                        <a href="@Url.Action("Index", "Expenses")" class="btn btn-dark btn-sm">Expenses</a>
                        <a href="@Url.Action("Dashboard", "OpticalWorkOrders")" class="btn btn-secondary btn-sm">متابعة أوامر الشغل</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-4">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">جاهز للتسليم</h5></div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>الأمر</th>
                                    <th>العميل</th>
                                    <th>التسليم</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ReadyOrders.Any())
                                {
                                    foreach (var item in Model.ReadyOrders)
                                    {
                                        <tr>
                                            <td>@item.WorkOrderNumber</td>
                                            <td>@item.CustomerName</td>
                                            <td>@(item.ExpectedDeliveryDateUtc?.ToLocalTime().ToString("yyyy-MM-dd") ?? "-")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted">لا توجد طلبات جاهزة</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">آخر المبيعات</h5></div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>الفاتورة</th>
                                    <th>العميل</th>
                                    <th>الصافي</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.LatestSales.Any())
                                {
                                    foreach (var item in Model.LatestSales)
                                    {
                                        <tr>
                                            <td>@item.InvoiceNumber</td>
                                            <td>@item.CustomerName</td>
                                            <td>@item.NetAmount</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted">لا توجد مبيعات</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">آخر سندات القبض</h5></div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>السند</th>
                                    <th>العميل</th>
                                    <th>المبلغ</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.LatestReceipts.Any())
                                {
                                    foreach (var item in Model.LatestReceipts)
                                    {
                                        <tr>
                                            <td>@item.ReceiptNumber</td>
                                            <td>@item.CustomerName</td>
                                            <td>@item.Amount</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted">لا توجد سندات</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
          <h4 class="card-title joud-card-title mb-0">التبرعات خلال الأشهر الأخيرة</h4>
          <span class="joud-mini-chip">Bar</span>
        </div>
        <div class="chart-wrap"><canvas id="monthlyDonationsChart"></canvas></div>

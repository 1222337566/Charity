  </div>
  <div class="col-md-6 col-xl-3">
    <div class="card joud-kpi-card h-100">
      <div class="card-body d-flex align-items-center">
        <div class="flex-grow-1">
          <p class="text-muted mb-1">المشروعات</p>
          <h2 class="mb-1">@(Model?.ProjectsCount ?? 0)</h2>
          <span class="text-muted small">جارية ومسجلة</span>
        </div>
        <div class="joud-stat-icon"><i class="bx bx-briefcase-alt-2"></i></div>

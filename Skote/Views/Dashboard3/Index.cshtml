      </div>
    </div>
  </div>
  <div class="col-md-6 col-xl-3">
    <div class="card joud-kpi-card h-100">
      <div class="card-body d-flex align-items-center">
        <div class="flex-grow-1">
          <p class="text-muted mb-1">إجمالي التبرعات</p>
          <h2 class="mb-1 joud-money">@((Model?.TotalDonations ?? 0).ToString("N0"))</h2>

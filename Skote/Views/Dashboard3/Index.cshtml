@model InfrastructureManagmentWebFramework.Models.Reports.Dashboard.CharityDashboardVm
@using System.Text.Json
@{
    ViewBag.Title = "لوحة التحكم";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var beneficiaryStatuses   = Model?.BeneficiaryStatuses    ?? new();
    var monthlyDonations      = Model?.MonthlyDonations        ?? new();
    var recentPayrollMonths   = Model?.RecentPayrollMonths     ?? new();
    var topProjects           = Model?.TopProjects             ?? new();
    var kafalaBySponType      = Model?.KafalaBySponsorshipType ?? new();
    var kafalaByFreq          = Model?.KafalaByFrequency        ?? new();
    var kafalaCollected       = Model?.KafalaMonthlyCollected   ?? new();
    var kafalaDisbursed       = Model?.KafalaMonthlyDisbursed   ?? new();

    // Arabic label helpers
    string SponLabel(string k) => k switch {
        "Orphan"    => "يتيم",   "Monthly"    => "شهري",
        "Health"    => "صحي",    "Education"  => "تعليمي",
        "Family"    => "أسري",   _ => k };
    string FreqLabel(string k) => k switch {
        "Monthly"    => "شهري",  "Quarterly"   => "ربع سنوي",
        "SemiAnnual" => "نصف سنوي", "Annual"  => "سنوي", _ => k };
    string GrantStatusLabel(string k) => k switch {
        "Active"=>"نشطة","Draft"=>"مسودة","Signed"=>"موقّعة",
        "Closed"=>"مغلقة","Completed"=>"مكتملة", _ => k };
    string AccCatLabel(string k) => k switch {
        "Asset"=>"أصول","Liability"=>"خصوم","Equity"=>"حقوق ملكية",
        "Revenue"=>"إيرادات","Expense"=>"مصروفات", _ => k };

    // ── pre-compute ALL JSON here (safe server-side) ──
    var jsn = new JsonSerializerOptions();

    // Existing charts
    var j_sLabels  = JsonSerializer.Serialize(beneficiaryStatuses.Select(x => x.Name));
    var j_sValues  = JsonSerializer.Serialize(beneficiaryStatuses.Select(x => x.Count));
    var j_mLabels  = JsonSerializer.Serialize(monthlyDonations.Select(x => x.Label));
    var j_mValues  = JsonSerializer.Serialize(monthlyDonations.Select(x => x.Amount));
    var j_pLabels  = JsonSerializer.Serialize(recentPayrollMonths.Select(x => $"{x.Month:00}/{x.Year}"));
    var j_pValues  = JsonSerializer.Serialize(recentPayrollMonths.Select(x => x.TotalNet));

    // Kafala
    var j_kTypeLabels = JsonSerializer.Serialize(kafalaBySponType.Select(x => SponLabel(x.Name)));
    var j_kTypeValues = JsonSerializer.Serialize(kafalaBySponType.Select(x => x.Count));
    var j_kFreqLabels = JsonSerializer.Serialize(kafalaByFreq.Select(x => FreqLabel(x.Name)));
    var j_kFreqValues = JsonSerializer.Serialize(kafalaByFreq.Select(x => x.Count));
    var j_kMonLabels  = JsonSerializer.Serialize(kafalaCollected.Select(x => x.Label));
    var j_kColValues  = JsonSerializer.Serialize(kafalaCollected.Select(x => x.Amount));
    var j_kDisValues  = JsonSerializer.Serialize(kafalaDisbursed.Select(x => x.Amount));

    // Accounting
    var j_accCatLabels = JsonSerializer.Serialize((Model?.AccountsByCategory ?? new()).Select(x => AccCatLabel(x.Name)));
    var j_accCatValues = JsonSerializer.Serialize((Model?.AccountsByCategory ?? new()).Select(x => x.Count));
    var j_revLabels    = JsonSerializer.Serialize((Model?.MonthlyRevenue     ?? new()).Select(x => x.Label));
    var j_revValues    = JsonSerializer.Serialize((Model?.MonthlyRevenue     ?? new()).Select(x => x.Amount));
    var j_expValues    = JsonSerializer.Serialize((Model?.MonthlyExpenses    ?? new()).Select(x => x.Amount));

    // Historical — Beneficiaries
    var j_hBenLabels    = JsonSerializer.Serialize((Model?.MonthlyNewBeneficiaries ?? new()).Select(x => x.Label));
    var j_hBenValues    = JsonSerializer.Serialize((Model?.MonthlyNewBeneficiaries ?? new()).Select(x => x.Amount));
    var j_hReqLabels    = JsonSerializer.Serialize((Model?.MonthlyAidRequests      ?? new()).Select(x => x.Label));
    var j_hReqValues    = JsonSerializer.Serialize((Model?.MonthlyAidRequests      ?? new()).Select(x => x.Amount));
    var j_hDisAmtLabels = JsonSerializer.Serialize((Model?.MonthlyAidDisbursedAmount ?? new()).Select(x => x.Label));
    var j_hDisAmtValues = JsonSerializer.Serialize((Model?.MonthlyAidDisbursedAmount ?? new()).Select(x => x.Amount));

    // Historical — Donors
    var j_hNewDonLabels = JsonSerializer.Serialize((Model?.MonthlyNewDonors  ?? new()).Select(x => x.Label));
    var j_hNewDonValues = JsonSerializer.Serialize((Model?.MonthlyNewDonors  ?? new()).Select(x => x.Amount));

    // Historical — Funders
    var j_hGrantLabels     = JsonSerializer.Serialize((Model?.MonthlyGrantsReceived   ?? new()).Select(x => x.Label));
    var j_hGrantValues     = JsonSerializer.Serialize((Model?.MonthlyGrantsReceived   ?? new()).Select(x => x.Amount));
    var j_grantStatLabels  = JsonSerializer.Serialize((Model?.GrantAgreementsByStatus ?? new()).Select(x => GrantStatusLabel(x.Name)));
    var j_grantStatValues  = JsonSerializer.Serialize((Model?.GrantAgreementsByStatus ?? new()).Select(x => x.Count));

    // Historical — Projects
    var j_hProjLabels     = JsonSerializer.Serialize((Model?.MonthlyNewProjects  ?? new()).Select(x => x.Label));
    var j_hProjValues     = JsonSerializer.Serialize((Model?.MonthlyNewProjects  ?? new()).Select(x => x.Amount));
    var j_projStatLabels  = JsonSerializer.Serialize((Model?.ProjectsByStatus    ?? new()).Select(x => x.Name));
    var j_projStatValues  = JsonSerializer.Serialize((Model?.ProjectsByStatus    ?? new()).Select(x => x.Count));
    var j_hBudgetLabels   = JsonSerializer.Serialize((Model?.MonthlyProjectBudget ?? new()).Select(x => x.Label));
    var j_hBudgetValues   = JsonSerializer.Serialize((Model?.MonthlyProjectBudget ?? new()).Select(x => x.Amount));

    // Scalars
    var j_assets   = (Model?.TotalAssets      ?? 0).ToString();
    var j_liabs    = (Model?.TotalLiabilities ?? 0).ToString();
    var j_equity   = (Model?.TotalEquity      ?? 0).ToString();
    var j_revenue  = (Model?.TotalRevenue     ?? 0).ToString();
    var j_expenses = (Model?.TotalExpenses    ?? 0).ToString();

    var kafalaBalance = (Model?.KafalaTotalCollected ?? 0) - (Model?.KafalaTotalDisbursed ?? 0);
    var kActiveRatio  = (Model?.KafalaCasesTotal ?? 0) > 0
        ? Math.Round((decimal)(Model!.KafalaCasesActive) / Model.KafalaCasesTotal * 100, 0) : 0m;
}

@section styles{
<style>
.joud-stat-icon{width:56px;height:56px;border-radius:18px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(18,118,121,.12),rgba(219,164,74,.18));color:#0b666a;font-size:28px}
.joud-hero-card{background:linear-gradient(135deg,#0d6f74 0%,#0a5d62 55%,#8cc56a 140%);border:none;border-radius:22px;color:#fff;overflow:hidden;position:relative}
.joud-hero-card:after{content:"";position:absolute;inset:auto -60px -70px auto;width:220px;height:220px;background:radial-gradient(circle,rgba(255,255,255,.18),transparent 70%)}
.joud-hero-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.45rem .9rem;border-radius:999px;background:rgba(255,255,255,.14);font-size:.85rem}
.joud-kpi-card{border:1px solid rgba(13,111,116,.10);border-radius:20px;box-shadow:0 10px 30px rgba(13,111,116,.07)}
.joud-chart-card,.joud-panel-card{border-radius:22px;border:1px solid rgba(13,111,116,.08);box-shadow:0 10px 30px rgba(16,78,80,.06)}
.joud-card-title{color:#0a5f63;font-weight:700}
.joud-progress{height:14px;border-radius:999px;background:#eef4f3}
.joud-progress .progress-bar{border-radius:999px;font-size:.75rem;font-weight:700}
.joud-list li{padding:.8rem 0;border-bottom:1px dashed rgba(13,111,116,.15)}
.joud-list li:last-child{border-bottom:none}
.joud-dot{width:10px;height:10px;border-radius:50%;display:inline-block}
.joud-mini-chip{display:inline-flex;align-items:center;padding:.3rem .7rem;border-radius:999px;background:rgba(13,111,116,.08);color:#0b666a;font-size:.8rem;font-weight:600}
.joud-actions .btn{border-radius:14px;padding:.8rem 1rem;font-weight:700}
.joud-money{font-variant-numeric:tabular-nums}

/* Kafala section */
.kafala-section-title{font-size:1.25rem;font-weight:800;color:#0a5f63;border-right:4px solid #dba44a;padding-right:14px;margin-bottom:1.5rem}
.kafala-kpi{border-radius:18px;padding:20px;border:1px solid rgba(13,111,116,.10);box-shadow:0 6px 20px rgba(13,111,116,.06);background:#fff}
.kafala-kpi-icon{width:50px;height:50px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px}
.kafala-kpi-num{font-size:1.8rem;font-weight:800;line-height:1}
.kafala-status-bar{height:10px;border-radius:999px;overflow:hidden;background:#eef4f3;display:flex;gap:2px}
.kafala-status-seg{height:100%;border-radius:999px;transition:width .5s}
canvas{min-height:240px;max-height:300px}
.chart-wrap{position:relative;height:260px;width:100%}
</style>
}

@* ════════ HERO ════════ *@
<div class="row mb-4">
  <div class="col-12">
    <div class="card joud-hero-card">
      <div class="card-body p-4 p-lg-5">
        <div class="row align-items-center">
          <div class="col-lg-8">
            <span class="joud-hero-badge mb-3"><i class="bx bx-pulse me-1"></i>بيانات حية من قاعدة البيانات</span>
            <h2 class="mb-3 text-white">لوحة تحكم جود الخيري</h2>
            <p class="mb-4 text-white-50">متابعة شاملة للمستفيدين، الكفالات، المشروعات، التمويل، والمرتبات.</p>
            <div class="d-flex flex-wrap gap-2 joud-actions">
              <a class="btn btn-light" href="/Beneficiaries">المستفيدون</a>
              <a class="btn btn-outline-light" href="/KafalaCases">الكفالات</a>
              <a class="btn btn-outline-light" href="/CharityProjects">المشروعات</a>
              <a class="btn btn-outline-light" href="/AidCycles">دورات الصرف</a>
            </div>
          </div>
          <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="bg-white bg-opacity-10 rounded-4 p-4">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 text-white">مؤشرات سريعة</h5>
                <span class="joud-mini-chip bg-white text-dark">Live</span>
              </div>
              <div class="row g-3 text-center">
                <div class="col-4"><h3 class="mb-0 text-white">@(Model?.BeneficiariesCount ?? 0)</h3><small class="text-white-50">مستفيد</small></div>
                <div class="col-4"><h3 class="mb-0 text-white">@(Model?.KafalaCasesActive ?? 0)</h3><small class="text-white-50">كفالة</small></div>
                <div class="col-4"><h3 class="mb-0 text-white">@(Model?.ProjectsCount ?? 0)</h3><small class="text-white-50">مشروع</small></div>
              </div>
              <hr class="border-light opacity-25"/>
              <div class="small text-white-50">المنح المستلمة: <strong class="text-white joud-money">@((Model?.TotalReceivedGrants ?? 0).ToString("N0"))</strong></div>
              <div class="small text-white-50">الصرف للمستفيدين: <strong class="text-white joud-money">@((Model?.TotalAidDisbursed ?? 0).ToString("N0"))</strong></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@* ════════ KPIs العامة ════════ *@

        <div class="p-3 rounded-3 @(netP>=0?"bg-success":"bg-danger") bg-opacity-10">
          <div class="small text-muted">صافي النتيجة</div>
          <div class="fw-bold fs-5 @(netP>=0?"text-success":"text-danger") joud-money">@netP.ToString("N0")</div>

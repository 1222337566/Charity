</div>

@* ════════════════════════════════
     قسم كفالة الأيتام
════════════════════════════════ *@
<div class="kafala-section-title">
  <i class="bx bx-heart me-2 text-warning"></i>كفالة الأيتام والرعاية
</div>

@* KPIs الكفالة *@
<div class="row g-3 mb-4">
  <div class="col-6 col-md-4 col-xl-2">
    <div class="kafala-kpi text-center">
      <div class="kafala-kpi-icon mx-auto mb-2" style="background:rgba(13,111,116,.10);color:#0d6f74"><i class="bx bx-heart"></i></div>
      <div class="kafala-kpi-num text-primary">@(Model?.KafalaCasesTotal ?? 0)</div>
      <div class="text-muted small mt-1">إجمالي الكفالات</div>
    </div>
  </div>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="kafala-kpi text-center">
      <div class="kafala-kpi-icon mx-auto mb-2" style="background:rgba(52,195,143,.12);color:#34c38f"><i class="bx bx-check-circle"></i></div>
      <div class="kafala-kpi-num text-success">@(Model?.KafalaCasesActive ?? 0)</div>
      <div class="text-muted small mt-1">كفالات نشطة</div>
    </div>
  </div>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="kafala-kpi text-center">
      <div class="kafala-kpi-icon mx-auto mb-2" style="background:rgba(241,180,76,.12);color:#f1b44c"><i class="bx bx-pause-circle"></i></div>
      <div class="kafala-kpi-num text-warning">@(Model?.KafalaCasesSuspended ?? 0)</div>
      <div class="text-muted small mt-1">معلّقة</div>
    </div>
  </div>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="kafala-kpi text-center">
      <div class="kafala-kpi-icon mx-auto mb-2" style="background:rgba(80,165,241,.12);color:#50a5f1"><i class="bx bx-user-check"></i></div>
      <div class="kafala-kpi-num" style="color:#50a5f1">@(Model?.KafalaSponsorsCount ?? 0)</div>
      <div class="text-muted small mt-1">كفلاء نشطون</div>
    </div>
  </div>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="kafala-kpi text-center">
      <div class="kafala-kpi-icon mx-auto mb-2" style="background:rgba(52,195,143,.12);color:#34c38f"><i class="bx bx-down-arrow-circle"></i></div>
      <div class="kafala-kpi-num text-success joud-money" style="font-size:1.3rem">@((Model?.KafalaTotalCollected ?? 0).ToString("N0"))</div>
      <div class="text-muted small mt-1">إجمالي التحصيل</div>
    </div>
  </div>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="kafala-kpi text-center">
      <div class="kafala-kpi-icon mx-auto mb-2" style="background:rgba(85,110,230,.12);color:#556ee6"><i class="bx bx-up-arrow-circle"></i></div>
      <div class="kafala-kpi-num joud-money" style="color:#556ee6;font-size:1.3rem">@((Model?.KafalaTotalDisbursed ?? 0).ToString("N0"))</div>
      <div class="text-muted small mt-1">إجمالي الصرف</div>
    </div>
  </div>
</div>

@* شريط الحالة + رصيد *@
<div class="row g-4 mb-4">
  <div class="col-xl-8">
    <div class="card joud-chart-card h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <h4 class="card-title joud-card-title mb-0">تحصيل وصرف الكفالات — آخر 6 أشهر</h4>
          <span class="joud-mini-chip">Bar</span>
        </div>
        <div class="chart-wrap"><canvas id="kafalaMonthlyChart"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-xl-4">
    <div class="card joud-chart-card h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <h4 class="card-title joud-card-title mb-0">توزيع الكفالات حسب النوع</h4>
          <span class="joud-mini-chip">Pie</span>
        </div>
        <div class="chart-wrap"><canvas id="kTypeChart"></canvas></div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-5">
  <div class="col-xl-4">
    <div class="card joud-chart-card h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <h4 class="card-title joud-card-title mb-0">توزيع الكفالات حسب الدورية</h4>
          <span class="joud-mini-chip">Doughnut</span>
        </div>
        <div class="chart-wrap"><canvas id="kFreqChart"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-xl-4">
    <div class="card joud-chart-card h-100">
      <div class="card-body">
        <h4 class="card-title joud-card-title mb-3">حالة الكفالات</h4>
        @{
          var total = Model?.KafalaCasesTotal ?? 1;
          var aW = total > 0 ? Math.Round((decimal)(Model!.KafalaCasesActive)    / total * 100, 0) : 0m;
          var sW = total > 0 ? Math.Round((decimal)(Model!.KafalaCasesSuspended) / total * 100, 0) : 0m;
          var cW = total > 0 ? Math.Round((decimal)(Model!.KafalaCasesClosed)    / total * 100, 0) : 0m;
        }
        <div class="kafala-status-bar mb-3">
          <div class="kafala-status-seg bg-success" style="width:@aW%"></div>
          <div class="kafala-status-seg bg-warning" style="width:@sW%"></div>
          <div class="kafala-status-seg bg-secondary" style="width:@cW%"></div>
        </div>
        <ul class="list-unstyled joud-list">
          <li><div class="d-flex justify-content-between"><span><span class="joud-dot bg-success me-2"></span>نشطة</span><strong>@(Model?.KafalaCasesActive ?? 0) (@aW%)</strong></div></li>
          <li><div class="d-flex justify-content-between"><span><span class="joud-dot bg-warning me-2"></span>معلّقة</span><strong>@(Model?.KafalaCasesSuspended ?? 0) (@sW%)</strong></div></li>
          <li><div class="d-flex justify-content-between"><span><span class="joud-dot bg-secondary me-2"></span>مغلقة</span><strong>@(Model?.KafalaCasesClosed ?? 0) (@cW%)</strong></div></li>
        </ul>
        <div class="mt-3 p-3 rounded-3" style="background:rgba(13,111,116,.06)">
          <div class="text-muted small">صافي رصيد الكفالات</div>
          <div class="joud-money fw-bold fs-5 @(kafalaBalance >= 0 ? "text-success" : "text-danger")">
            @kafalaBalance.ToString("N0")
          </div>
          <div class="text-muted" style="font-size:.75rem">تحصيل - صرف</div>
        </div>
        <div class="mt-3 d-grid">
          <a class="btn btn-outline-primary btn-sm" href="/KafalaCases">إدارة الكفالات ←</a>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xl-4">
    <div class="card joud-chart-card h-100">
      <div class="card-body">
        <h4 class="card-title joud-card-title mb-3">ملخصات سريعة</h4>
        <ul class="list-unstyled joud-list mb-0">

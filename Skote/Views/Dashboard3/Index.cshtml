@section scripts{
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
(function () {
var C=['#0d6f74','#dba44a','#8cc56a','#6bc4c7','#5d8f52','#f2c572','#e07b5a','#7b9ed1'];
var TEAL='#0d6f74',GOLD='#dba44a',GREEN='#34c38f',BLUE='#556ee6',RED='#f46a6a',YLW='#f1b44c',CYAN='#50a5f1';
Chart.defaults.font.family='inherit';

function mk(id,cfg){var el=document.getElementById(id);if(el)new Chart(el,cfg);}
function bar(labels,data,color){return{type:'bar',data:{labels:labels,datasets:[{data:data,backgroundColor:color,borderRadius:8,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false}}}}};}
function line(labels,data,color,fill){return{type:'line',data:{labels:labels,datasets:[{data:data,borderColor:color,backgroundColor:fill?color+'22':color+'11',fill:!!fill,tension:.35,pointBackgroundColor:color,pointRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(0,0,0,.04)'}}}}};}

// 1 Beneficiary statuses donut
mk('beneficiaryStatusesChart',{type:'doughnut',data:{labels:@Html.Raw(j_sLabels),datasets:[{data:@Html.Raw(j_sValues),backgroundColor:C,borderWidth:0,hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false,cutout:'65%'}});

// 2 Monthly donations bar
mk('monthlyDonationsChart',bar(@Html.Raw(j_mLabels),@Html.Raw(j_mValues),TEAL));

// 3 Payroll line
mk('payrollTrendChart',line(@Html.Raw(j_pLabels),@Html.Raw(j_pValues),GOLD,true));

// 4 Kafala monthly grouped bar
mk('kafalaMonthlyChart',{type:'bar',data:{labels:@Html.Raw(j_kMonLabels),datasets:[{label:'تحصيل',data:@Html.Raw(j_kColValues),backgroundColor:GREEN,borderRadius:7,borderSkipped:false},{label:'صرف',data:@Html.Raw(j_kDisValues),backgroundColor:BLUE,borderRadius:7,borderSkipped:false}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top'}},scales:{x:{grid:{display:false}}}}});

// 5 Kafala type pie
mk('kTypeChart',{type:'pie',data:{labels:@Html.Raw(j_kTypeLabels),datasets:[{data:@Html.Raw(j_kTypeValues),backgroundColor:C,borderWidth:2,borderColor:'#fff',hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false}});

// 6 Kafala frequency donut
mk('kFreqChart',{type:'doughnut',data:{labels:@Html.Raw(j_kFreqLabels),datasets:[{data:@Html.Raw(j_kFreqValues),backgroundColor:[TEAL,GOLD,GREEN,BLUE],borderWidth:0,hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false,cutout:'60%'}});

// 7 Balance sheet horizontal bar
mk('balanceSheetChart',{type:'bar',data:{labels:['الأصول','الخصوم','حقوق الملكية','الإيرادات','المصروفات'],datasets:[{data:[@Html.Raw(j_assets),@Html.Raw(j_liabs),@Html.Raw(j_equity),@Html.Raw(j_revenue),@Html.Raw(j_expenses)],backgroundColor:[CYAN,RED,BLUE,GREEN,YLW],borderRadius:8,borderSkipped:false}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(0,0,0,.05)'}},y:{grid:{display:false}}}}});

// 8 Accounts by category donut
mk('accountsByCategoryChart',{type:'doughnut',data:{labels:@Html.Raw(j_accCatLabels),datasets:[{data:@Html.Raw(j_accCatValues),backgroundColor:[CYAN,RED,BLUE,GREEN,YLW],borderWidth:2,borderColor:'#fff',hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false,cutout:'55%'}});

// 9 Revenue vs expenses line
mk('revExpLineChart',{type:'line',data:{labels:@Html.Raw(j_revLabels),datasets:[{label:'الإيرادات',data:@Html.Raw(j_revValues),borderColor:GREEN,backgroundColor:'rgba(52,195,143,.10)',fill:true,tension:.35,pointRadius:4},{label:'المصروفات',data:@Html.Raw(j_expValues),borderColor:YLW,backgroundColor:'rgba(241,180,76,.10)',fill:true,tension:.35,pointRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top'}},scales:{x:{grid:{color:'rgba(0,0,0,.04)'}},y:{grid:{color:'rgba(0,0,0,.04)'}}}}});

// 10 Monthly new beneficiaries
mk('monthlyBeneficiariesChart',bar(@Html.Raw(j_hBenLabels),@Html.Raw(j_hBenValues),TEAL));

// 11 Monthly aid requests
mk('monthlyAidRequestsChart',line(@Html.Raw(j_hReqLabels),@Html.Raw(j_hReqValues),CYAN));

// 12 Monthly disbursed amount
mk('monthlyDisbursedAmountChart',line(@Html.Raw(j_hDisAmtLabels),@Html.Raw(j_hDisAmtValues),GREEN,true));

// 13 Donations history
mk('donationsHistoryChart',bar(@Html.Raw(j_mLabels),@Html.Raw(j_mValues),GOLD));

// 14 New donors
mk('newDonorsChart',line(@Html.Raw(j_hNewDonLabels),@Html.Raw(j_hNewDonValues),YLW));

// 15 Grants received
mk('grantsHistoryChart',bar(@Html.Raw(j_hGrantLabels),@Html.Raw(j_hGrantValues),CYAN));

// 16 Grant agreements by status
mk('grantAgreementsChart',{type:'doughnut',data:{labels:@Html.Raw(j_grantStatLabels),datasets:[{data:@Html.Raw(j_grantStatValues),backgroundColor:[GREEN,GOLD,BLUE,RED,'#8cc56a'],borderWidth:2,borderColor:'#fff',hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false,cutout:'55%'}});

// 17 New projects
mk('newProjectsChart',bar(@Html.Raw(j_hProjLabels),@Html.Raw(j_hProjValues),BLUE));

// 18 Projects by status
mk('projectsByStatusChart',{type:'pie',data:{labels:@Html.Raw(j_projStatLabels),datasets:[{data:@Html.Raw(j_projStatValues),backgroundColor:C,borderWidth:2,borderColor:'#fff',hoverOffset:6}]},options:{responsive:true,maintainAspectRatio:false}});

// 19 Project budget history
mk('projectBudgetChart',line(@Html.Raw(j_hBudgetLabels),@Html.Raw(j_hBudgetValues),BLUE,true));

})();
</script>
}
</div>

@* المشروعات *@
<div class="row g-4 mb-4">
  <div class="col-12">
    <div class="card joud-panel-card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h4 class="card-title joud-card-title mb-0">المشروعات الأعلى موازنةً</h4>
          <span class="joud-mini-chip">Live</span>
        </div>
        @if (topProjects.Any())
        {
          @foreach (var project in topProjects)
          {
            var ratio = project.PlannedBudgetLines > 0 ? Math.Round((project.ActualBudgetLines / project.PlannedBudgetLines) * 100m, 0) : 0m;
            var width = Math.Min(100m, Math.Max(0m, ratio));
            <div class="mb-4">
              <div class="d-flex justify-content-between mb-2">
                <div>
                  <strong>@project.Name</strong>
                  <div class="text-muted small">@project.Code — @project.Status — @project.BeneficiariesCount مستفيد</div>
                </div>
                <strong>@width%</strong>
              </div>
              <div class="progress joud-progress">
                <div class="progress-bar @(width >= 75 ? "bg-info" : width >= 50 ? "bg-warning text-dark" : "bg-success")"
                     style="width:@width%">@width%</div>
              </div>
            </div>
          }
        }
        else
        {
          <div class="alert alert-light mb-0">لا توجد بيانات مشروعات كافية.</div>
        }
      </div>
    </div>
  </div>
</div>


          <li><div class="d-flex justify-content-between"><span><span class="joud-dot bg-success me-2"></span>الإيرادات</span><strong class="joud-money text-success">@((Model?.TotalRevenue??0).ToString("N0"))</strong></div></li>
          <li><div class="d-flex justify-content-between"><span><span class="joud-dot bg-warning me-2"></span>المصروفات</span><strong class="joud-money text-warning">@((Model?.TotalExpenses??0).ToString("N0"))</strong></div></li>

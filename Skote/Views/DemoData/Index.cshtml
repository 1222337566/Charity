@model Skote.ViewModels.DemoData.DemoDataIndexVm
@{ ViewData["Title"] = "البيانات التجريبية"; }

<style>
.dd-hero{background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px;padding:20px 26px;color:#fff;margin-bottom:20px}
.dd-stat{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 10px rgba(14,111,115,.05);padding:14px 16px;text-align:center}
.dd-stat .n{font-size:1.6rem;font-weight:800;color:#0a5f63;line-height:1}
.dd-stat .l{font-size:.72rem;color:#6b7d80;margin-top:4px}
.dd-stat.highlight .n{color:#f1b44c}
.action-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 10px rgba(14,111,115,.05);margin-bottom:16px;overflow:hidden}
.action-head{padding:14px 20px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.92rem;font-weight:800;color:#0a5f63;background:rgba(14,111,115,.03);display:flex;align-items:center;gap:8px}
.action-body{padding:18px 20px}
.desc{font-size:.83rem;color:#6b7d80;margin-bottom:14px;line-height:1.6}
.ls-badge{padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700;background:#d1fae5;color:#065f46}
</style>

<div class="dd-hero">
  <h4 class="fw-bold mb-1 text-white"><i class="bx bx-data me-2"></i>البيانات التجريبية للنظام</h4>
  <div style="opacity:.75;font-size:.82rem">توليد وإدارة البيانات الديمو لاختبار جميع موديولات النظام</div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.LastResultMessage))
{
  <div class="alert alert-@(Model.LastResultMessage.StartsWith("❌") ? "danger" : "success") alert-dismissible fade show" style="border-radius:12px">
    @Model.LastResultMessage
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

@* ── إحصائيات ── *@
<div class="row g-3 mb-4">
  @{
    var stats = new[] {
        ("الموظفون",          Model.EmployeesCount,                  false),
        ("الإجازات",          Model.LeaveRequestsCount,              false),
        ("المستفيدون",        Model.BeneficiariesCount,              Model.BeneficiariesCount >= 10000),
        ("البحث الإنساني",    Model.HumanResearchCount,              false),
        ("المتبرعون",         Model.DonorsCount,                     false),
        ("التبرعات",          Model.DonationsCount,                  false),
        ("الكفالات",          Model.KafaCasesCount,                  false),
        ("المشروعات",         Model.ProjectsCount,                   false),
        ("مقترحات المشاريع",  Model.ProjectProposalsCount,           false),
        ("الممولون",          Model.FundersCount,                    false),
        ("اتفاقيات التمويل",  Model.GrantAgreementsCount,           false),
        ("دفعات المنح",       Model.GrantInstallmentsCount,          false),
        ("دورات الصرف",       Model.AidCyclesCount,                  false),
        ("المتطوعون",         Model.VolunteersCount,                  false),
        ("الاجتماعات",        Model.BoardMeetingsCount,              false),
        ("مسيرات الرواتب",    Model.PayrollMonthsCount,             false),
        ("القيود اليومية",    Model.JournalEntriesCount,             false),
        ("عقود الموظفين",     Model.EmployeeContractsCount,          false),
        ("المكافآت",          Model.EmployeeBonusesCount,            false),
        ("المخازن",           Model.WarehousesCount,                  false),
        ("الأصناف المخزنية",  Model.StockItemsCount,                 false),
        ("أذون الإضافة",      Model.StoreReceiptsCount,              false),
        ("أذون الصرف",        Model.StoreIssuesCount,                false),
        ("طلبات الاحتياج",    Model.StockNeedRequestsCount,          false),
        ("حركات المخزون",     Model.StockTransactionsCount,          false),
        ("مستخدمو المحاكاة",  Model.WorkflowUsersCount,              false),
    };
  }
  @foreach (var (label, count, hl) in stats)
  {
    <div class="col-6 col-md-3 col-xl-2">
      <div class="dd-stat @(hl ? "highlight" : "")">
        <div class="n">@count.ToString("N0")</div>
        <div class="l">@label</div>
        @if (hl) { <div class="ls-badge mt-1">✓ 10K</div> }
      </div>
    </div>
  }
</div>

@* ── قسم 1: Large Scale Seeder ── *@
<div class="action-card">
  <div class="action-head" style="background:rgba(14,111,115,.05)">
    <i class="bx bx-rocket" style="color:#0e6f73;font-size:1.1rem"></i>
    Large Scale Seeder — 10,000 مستفيد + كل الموديولات
    <span class="ls-badge ms-1">مقترح</span>
  </div>
  <div class="action-body">
    <div class="desc">
      يكمّل البيانات تلقائياً إلى الأهداف المحددة دون تكرار — Idempotent بالكامل.
      يُضيف الفرق فقط من الرقم الحالي للهدف.
    </div>
    <div class="row g-2 mb-3" style="font-size:.8rem">
      @foreach (var (m, t, c) in new[]{
          ("المستفيدون","10,000","#0e6f73"),("الموظفون","50","#556ee6"),
          ("الكفالات","1,500","#34c38f"),("المتبرعون","500","#f1b44c"),
          ("التبرعات","2,000","#f46a6a"),("الاجتماعات","60","#8b5cf6"),
          ("المقترحات","30","#0891b2"),("المتطوعون","300","#db2777")})
      {
        <div class="col-6 col-md-3">
          <div style="background:rgba(0,0,0,.04);border-radius:10px;padding:8px 12px">
            <div style="font-size:.7rem;color:#6b7d80">@m</div>
            <div style="font-size:.95rem;font-weight:800;color:@c">@t</div>
          </div>
        </div>
      }
    </div>
    <form asp-action="SeedLargeScale" method="post"
          onsubmit="return confirm('سيتم تشغيل LargeScaleSeeder — قد يستغرق عدة دقائق. هل تريد المتابعة؟')">
      @Html.AntiForgeryToken()
      <button type="submit" class="btn btn-primary fw-bold" style="border-radius:12px;min-width:200px">
        <i class="bx bx-rocket me-2"></i>تشغيل LargeScaleSeeder
      </button>
    </form>
  </div>
</div>

@* ── قسم 2: Seeder الأساسي ── *@
<div class="action-card">
  <div class="action-head">
    <i class="bx bx-data" style="color:#0e6f73"></i>
    Seeder الأساسي — بيانات تجريبية مترابطة
  </div>
  <div class="action-body">
    <div class="desc">
      يدخل بيانات ديمو مترابطة لجميع الموديولات (موظفين، مستفيدين، تبرعات، مشروعات، مخازن، محاسبة...).
      لا يُكرر البيانات إذا وُجدت مسبقاً.
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <form asp-action="SeedNow" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-success fw-bold" style="border-radius:12px">
          <i class="bx bx-plus me-1"></i>إدخال البيانات التجريبية
        </button>
      </form>
      <form asp-action="ResetAndSeedNow" method="post"
            onsubmit="return confirm('سيتم حذف بيانات الموديولات التشغيلية ثم إعادة تعبئتها. هل أنت متأكد؟')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger fw-bold" style="border-radius:12px">
          <i class="bx bx-trash me-1"></i>مسح وإعادة التعبئة
        </button>
      </form>
    </div>
  </div>
</div>

@* ── قسم 3: Seeder كبير مترابط ── *@
<div class="action-card">
  <div class="action-head">
    <i class="bx bx-expand" style="color:#556ee6"></i>
    Seeder كبير مترابط — مع إعدادات مخصصة
  </div>
  <div class="action-body">
    <div class="desc">
      يولّد كميات كبيرة مع ربط كامل بين الموديولات: بحوث إنسانية، طلبات مساعدة، تبرعات، تخصيصات، صرف، مخازن، محاسبة.
    </div>
    <div class="row g-3 mb-3">
      <div class="col-md-2">
        <label class="form-label fw-semibold" style="font-size:.82rem">عدد المستفيدين</label>
        <input form="largeSeedForm" name="beneficiaryCount" type="number" min="1" max="50000" value="8000" class="form-control" style="border-radius:10px"/>
      </div>
      <div class="col-md-2">
        <label class="form-label fw-semibold" style="font-size:.82rem">حجم الدفعة</label>
        <input form="largeSeedForm" name="batchSize" type="number" min="100" max="2000" value="500" class="form-control" style="border-radius:10px"/>
      </div>
      <div class="col-md-2">
        <label class="form-label fw-semibold" style="font-size:.82rem">المتبرعون</label>
        <input form="largeSeedForm" name="donorCount" type="number" min="50" max="5000" value="800" class="form-control" style="border-radius:10px"/>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold" style="font-size:.82rem">التبرعات النقدية</label>
        <input form="largeSeedForm" name="cashDonationCount" type="number" min="100" max="10000" value="1200" class="form-control" style="border-radius:10px"/>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold" style="font-size:.82rem">التبرعات العينية</label>
        <input form="largeSeedForm" name="inKindDonationCount" type="number" min="20" max="3000" value="240" class="form-control" style="border-radius:10px"/>
      </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <form id="largeSeedForm" asp-action="SeedLargeDemo" method="post"
            onsubmit="return confirm('سيتم تشغيل Seeder كبير — قد يستغرق عدة دقائق. المتابعة؟')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-success fw-bold" style="border-radius:12px">
          <i class="bx bx-expand me-1"></i>توليد بيانات كبيرة مترابطة
        </button>
      </form>
      <form asp-action="ResetAndSeedLargeDemo" method="post"
            onsubmit="return copyLargeSeedInputs(this) && confirm('مسح ديمو كبير وإعادة توليده؟')">
        @Html.AntiForgeryToken()
        <input type="hidden" name="beneficiaryCount" value="8000"/>
        <input type="hidden" name="batchSize" value="500"/>
        <input type="hidden" name="donorCount" value="800"/>
        <input type="hidden" name="cashDonationCount" value="1200"/>
        <input type="hidden" name="inKindDonationCount" value="240"/>
        <button type="submit" class="btn btn-outline-danger fw-bold" style="border-radius:12px">
          <i class="bx bx-trash me-1"></i>مسح وإعادة التوليد
        </button>
      </form>
    </div>
  </div>
</div>
@* ── قسم 3.5: إصلاح حسابات التبرعات ── *@
<div class="action-card">
    <div class="action-head" style="background:rgba(244,106,106,.04)">
        <i class="bx bx-wrench" style="color:#f46a6a;font-size:1.1rem"></i>
        إصلاح ربط التبرعات بالحسابات المالية
    </div>
    <div class="action-body">
        <div class="desc">
            إذا كانت قائمة "الحساب المالي المصدر" في شاشة التخصيص فارغة —
            اضغط هذا الزر لربط التبرعات النقدية بالحساب المالي تلقائياً وضبط نطاق التوجيه.
        </div>
        <form asp-action="FixDonationAccounts" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning fw-bold" style="border-radius:12px">
                <i class="bx bx-link me-1"></i>ربط التبرعات بالحسابات المالية
            </button>
        </form>
    </div>
</div>
@* ── قسم 4: مستخدمو المحاكاة ── *@
<div class="action-card">
  <div class="action-head">
    <i class="bx bx-user-check" style="color:#0e6f73"></i>
    مستخدمو المحاكاة — اختبار صلاحيات سير العمل
  </div>
  <div class="action-body">
    <div class="desc">
      ينشئ حسابات محاكاة بصلاحيات مختلفة لاختبار دورة الموافقات.
      كلمة المرور الافتراضية: <code style="background:#f1f5f9;padding:2px 6px;border-radius:5px">Demo@12345</code>
      · أمثلة: <code>demo.charity.admin01</code> · <code>demo.charity.research01</code>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <form asp-action="SeedWorkflowUsers" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-primary fw-bold" style="border-radius:12px">
          <i class="bx bx-user-plus me-1"></i>إنشاء / تحديث المستخدمين
        </button>
      </form>
      <form asp-action="ResetWorkflowUsers" method="post"
            onsubmit="return confirm('حذف وإعادة إنشاء مستخدمي المحاكاة؟')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger fw-bold" style="border-radius:12px">
          <i class="bx bx-refresh me-1"></i>إعادة إنشاء المستخدمين
        </button>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
function copyLargeSeedInputs(target) {
    var src = document.getElementById('largeSeedForm');
    ['beneficiaryCount','batchSize','donorCount','cashDonationCount','inKindDonationCount'].forEach(function(n) {
        var s = src?.querySelector('[name="'+n+'"]');
        var t = target.querySelector('[name="'+n+'"]');
        if (s && t) t.value = s.value;
    });
    return true;
}
</script>
}

@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile
@model InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.BulkDonationAllocationVm
@{
    ViewData["Title"] = "توزيع جماعي للتبرع";
    var donorHeader = ViewBag.DonorHeader as DonorHeaderVm;
    var donation    = ViewBag.Donation as InfrastrfuctureManagmentCore.Domains.Charity.Donors.Donation;
    bool isCash     = string.Equals(Model.DonationType, "نقدي", StringComparison.OrdinalIgnoreCase);
    bool hasRows    = Model.Rows != null && Model.Rows.Any();
    bool canAllocate = Model.CanAllocateToRequests;
    bool isZero     = Model.DonationRemainingAmount <= 0;
    bool canDistrib = isCash && canAllocate && hasRows && !isZero;
    var  totalNeed  = Model.Rows?.Sum(r => r.RemainingNeedAmount) ?? 0m;
    var  allocatedPct = Model.DonationAmount > 0
        ? (Model.DonationAmount - Model.DonationRemainingAmount) / Model.DonationAmount * 100m
        : 0m;
}

<style>
.bk-hero{background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px;padding:20px 26px;color:#fff;margin-bottom:18px}
.bk-stat{background:rgba(255,255,255,.15);border-radius:12px;padding:10px 16px;text-align:center;flex:1;min-width:80px}
.bk-stat .n{font-size:1.15rem;font-weight:800;line-height:1}
.bk-stat .l{font-size:.67rem;opacity:.8;margin-top:2px}
.budget-track{height:14px;border-radius:999px;background:rgba(255,255,255,.2);overflow:hidden;margin-top:10px;position:relative}
.budget-fill{height:100%;border-radius:999px;background:#34c38f;transition:width .3s}

/* ── Warning banner ── */
.warn-banner{border-radius:12px;padding:12px 18px;font-size:.87rem;font-weight:600;display:flex;align-items:center;gap:10px;margin-bottom:14px;transition:background .3s,color .3s}
.warn-safe{background:rgba(52,195,143,.1);color:#0d7a5a;border:.5px solid rgba(52,195,143,.3)}
.warn-low {background:rgba(241,180,76,.1);color:#8a5f00;border:.5px solid rgba(241,180,76,.3)}
.warn-done{background:rgba(14,111,115,.08);color:#0a5659;border:.5px solid rgba(14,111,115,.2)}
.warn-over{background:rgba(244,106,106,.1);color:#ab2b2b;border:.5px solid rgba(244,106,106,.3)}

.dist-toolbar{background:#f8fbfb;border-radius:12px;padding:12px 16px;margin-bottom:14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;border:.5px solid rgba(14,111,115,.1)}
.tool-btn{padding:6px 14px;border-radius:9px;border:.5px solid rgba(14,111,115,.25);background:#fff;font-size:.8rem;font-weight:600;cursor:pointer;color:#0e6f73;transition:.12s;display:flex;align-items:center;gap:5px}
.tool-btn:hover{background:#0e6f73;color:#fff;border-color:#0e6f73}
.tool-btn.danger:hover{background:#f46a6a;border-color:#f46a6a}

.bk-table{width:100%;border-collapse:collapse}
.bk-table thead th{padding:10px 12px;font-size:.77rem;font-weight:700;color:#6b7d80;background:#f8fbfb;text-align:right;white-space:nowrap;border-bottom:.5px solid rgba(14,111,115,.1)}
.bk-table tbody td{padding:10px 12px;font-size:.83rem;border-top:.5px solid rgba(14,111,115,.06);vertical-align:middle}
.bk-table tfoot td{padding:10px 12px;font-weight:700;background:#f8fbfb;border-top:.5px solid rgba(14,111,115,.15)}

.pri-first{background:rgba(52,195,143,.15);color:#0d7a5a;padding:2px 8px;border-radius:5px;font-size:.68rem;font-weight:700}
.pri-other{background:rgba(173,181,189,.15);color:#6b7d80;padding:2px 8px;border-radius:5px;font-size:.68rem;font-weight:700}

.amt-wrap{position:relative}
.amt-input{border-radius:10px;border:.5px solid rgba(14,111,115,.25);padding:7px 40px 7px 10px;width:100%;font-size:.88rem;font-weight:600;transition:.15s}
.amt-input:focus{outline:none;border-color:#0e6f73;box-shadow:0 0 0 3px rgba(14,111,115,.1)}
.amt-input.over{border-color:#f46a6a;background:rgba(244,106,106,.05)}
.amt-max-btn{position:absolute;left:6px;top:50%;transform:translateY(-50%);font-size:.65rem;background:rgba(14,111,115,.1);color:#0e6f73;border:none;border-radius:5px;padding:2px 5px;cursor:pointer}
.amt-max-btn:hover{background:#0e6f73;color:#fff}
.row-prog{height:4px;border-radius:999px;background:#e2e8f0;margin-top:5px;overflow:hidden}
.row-prog-fill{height:100%;border-radius:999px;background:#34c38f;transition:width .2s}
.summary-box{border-radius:14px;padding:14px 18px;border:.5px solid rgba(14,111,115,.15);background:#f8fbfb}
</style>

@if (donorHeader != null)
{
    @await Html.PartialAsync("~/Views/Shared/Donors/_DonorHeader.cshtml", donorHeader)
}

@* ── Hero ── *@
<div class="bk-hero mb-3">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
    <div>
      <div class="fw-bold" style="font-size:1rem">
        <i class="bx bx-transfer-alt me-2"></i>توزيع جماعي — @donation?.DonationNumber
      </div>
      <div style="opacity:.75;font-size:.8rem;margin-top:3px">
        النوع: <strong>@Model.DonationType</strong> ·
        نطاق التوجيه: <strong>@(Model.TargetingScopeName ?? "عام")</strong> ·
        المساعدة المستهدفة: <strong>@(Model.AidTypeName ?? "غير محددة")</strong>
        @if (!string.IsNullOrWhiteSpace(Model.GeneralPurposeName))
        {
            <text> · الغرض العام: <strong>@Model.GeneralPurposeName</strong></text>
        }
      </div>
    </div>
    <a asp-action="Index" asp-route-donationId="@Model.DonationId"
       class="btn btn-light btn-sm fw-bold" style="border-radius:10px">
      <i class="bx bx-list-ul me-1"></i>التخصيصات السابقة
    </a>
  </div>
  <div class="d-flex gap-3 flex-wrap mb-3">
    <div class="bk-stat">
      <div class="n">@Model.DonationAmount.ToString("N0")</div>
      <div class="l">إجمالي التبرع</div>
    </div>
    <div class="bk-stat" style="background:rgba(244,106,106,.2)">
      <div class="n" style="color:#fca5a5">@((Model.DonationAmount - Model.DonationRemainingAmount).ToString("N0"))</div>
      <div class="l">مُخصَّص مسبقاً</div>
    </div>
    <div class="bk-stat" style="background:rgba(52,195,143,.2)">
      <div class="n" style="color:#a7f3d0" id="hero-remaining">@Model.DonationRemainingAmount.ToString("N0")</div>
      <div class="l">المتبقي للتوزيع</div>
    </div>
    <div class="bk-stat">
      <div class="n" id="hero-entered">0</div>
      <div class="l">المُدخَل الآن</div>
    </div>
    @if (hasRows)
    {
      <div class="bk-stat" style="background:rgba(241,180,76,.15)">
        <div class="n" style="color:#fde68a">@Model.Rows!.Count(r => !r.HasPreviousDisbursement)</div>
        <div class="l">لم يتلق مساعدة</div>
      </div>
    }
  </div>
  <div class="budget-track">
    <div class="budget-fill" id="budget-fill" style="width:@allocatedPct%"></div>
  </div>
  <div class="d-flex justify-content-between mt-1" style="font-size:.7rem;opacity:.7">
    <span>0</span>
    <span id="budget-label">مُخصَّص: @((Model.DonationAmount - Model.DonationRemainingAmount).ToString("N0"))</span>
    <span>@Model.DonationAmount.ToString("N0")</span>
  </div>
</div>

@* ── Form ── *@
<form asp-action="BulkCreate" method="post" id="bulk-form">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="DonationId"/>

  <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"
       style="border-radius:12px;font-size:.85rem"></div>

  <div class="row g-3 mb-3">
    <div class="col-md-3">
      <label asp-for="AllocatedDate" class="form-label fw-semibold"></label>
      <input asp-for="AllocatedDate" type="date" class="form-control" style="border-radius:10px"/>
      <span asp-validation-for="AllocatedDate" class="text-danger small"></span>
    </div>
    <div class="col-md-9">
      <label asp-for="Notes" class="form-label fw-semibold"></label>
      <input asp-for="Notes" class="form-control" placeholder="ملاحظة تظهر على كل التخصيصات..."
             style="border-radius:10px"/>
    </div>
  </div>

  @* حالات الإيقاف *@
  @if (!isCash)
  {
    <div class="alert alert-warning" style="border-radius:12px">
      <i class="bx bx-error me-2"></i>التوزيع الجماعي مخصص للتبرعات النقدية فقط.
    </div>
  }
  @if (isCash && !canAllocate)
  {
    <div class="alert alert-warning" style="border-radius:12px">
      <i class="bx bx-error me-2"></i>@(Model.AllocationPolicyMessage ?? "هذا التبرع غير جاهز للتوزيع على طلبات المساعدة.")
    </div>
  }
  @if (isCash && canAllocate && !hasRows)
  {
    <div class="alert alert-info" style="border-radius:12px">
      <i class="bx bx-info-circle me-2"></i>@(Model.AllocationPolicyMessage ?? "لا توجد طلبات معتمدة مفتوحة مؤهلة لهذا التبرع حاليًا.")
    </div>
  }

  @* ── حارس المتبقي = صفر ── *@
  @if (isCash && canAllocate && hasRows && isZero)
  {
    <div class="warn-banner warn-done">
      <i class="bx bx-check-circle" style="font-size:1.4rem"></i>
      <div>
        <div>هذا التبرع <strong>مكتمل التخصيص</strong> — لا يوجد رصيد متبقٍ للتوزيع.</div>
        <div style="font-size:.78rem;margin-top:2px;opacity:.8">
          الإجمالي @Model.DonationAmount.ToString("N0") — مُخصَّص بالكامل
        </div>
      </div>
      <a asp-action="Index" asp-route-donationId="@Model.DonationId"
         class="btn btn-sm fw-bold ms-auto"
         style="border-radius:10px;background:rgba(14,111,115,.15);color:#0a5659;border:none">
        عرض التخصيصات
      </a>
    </div>
  }

  @* ── الجدول الرئيسي — يظهر فقط لو canDistrib ── *@
  @if (canDistrib)
  {
    @* بانر الإنذار الحي *@
    <div class="warn-banner warn-safe" id="live-warn">
      <i class="bx bx-wallet" id="warn-icon" style="font-size:1.3rem"></i>
      <div>
        <span id="warn-text">المتبقي للتوزيع: </span>
        <strong id="warn-amount">@Model.DonationRemainingAmount.ToString("N0")</strong>
        <span id="warn-suffix"> — يمكنك المتابعة</span>
      </div>
      <div style="margin-right:auto;font-size:.78rem;opacity:.8">
        <span id="warn-pct">0</span>% مُستخدَم
      </div>
    </div>

    @* Toolbar *@
    <div class="dist-toolbar">
      <span style="font-size:.8rem;font-weight:700;color:#0a5f63">توزيع سريع:</span>
      <button type="button" class="tool-btn" onclick="autoDistribute('equal')">
        <i class="bx bx-equalizer"></i> متساوٍ
      </button>
      <button type="button" class="tool-btn" onclick="autoDistribute('proportional')">
        <i class="bx bx-pie-chart-alt-2"></i> نسبي
      </button>
      <button type="button" class="tool-btn" onclick="autoDistribute('priority')">
        <i class="bx bx-sort-down"></i> بالأولوية
      </button>
      <button type="button" class="tool-btn" onclick="autoDistribute('full')">
        <i class="bx bx-check-double"></i> اكتمال الكل
      </button>
      <button type="button" class="tool-btn danger" onclick="clearAll()">
        <i class="bx bx-trash"></i> مسح الكل
      </button>
      <div style="margin-right:auto;font-size:.8rem;color:#6b7d80">
        متبقي: <strong id="toolbar-remaining" style="color:#0e6f73">@Model.DonationRemainingAmount.ToString("N0")</strong>
      </div>
    </div>

    @* Table *@
    <div style="overflow-x:auto;border-radius:14px;border:.5px solid rgba(14,111,115,.1)">
      <table class="bk-table">
        <thead>
          <tr>
            <th>المستفيد / الطلب</th>
            <th>الأولوية</th>
            <th>المطلوب</th>
            <th>المصروف</th>
            <th>المتبقي</th>
            <th style="min-width:200px">المبلغ الموزع الآن</th>
          </tr>
        </thead>
        <tbody>
          @for (var i = 0; i < Model.Rows!.Count; i++)
          {
            var row  = Model.Rows[i];
            bool isFirst = !row.HasPreviousDisbursement;
            <tr class="bk-row" data-max="@row.RemainingNeedAmount.ToString("F2").Replace(",","")">
              <td>
                <div class="fw-semibold" style="font-size:.87rem">@row.BeneficiaryName</div>
                <div style="font-size:.73rem;color:#6b7d80">
                  طلب @row.RequestNumberOrDate · @row.AidTypeName
                  @if (!string.IsNullOrWhiteSpace(row.UrgencyLevel))
                  {
                    <span> · @row.UrgencyLevel</span>
                  }
                </div>
                <input type="hidden" asp-for="Rows[i].AidRequestId"/>
                <input type="hidden" asp-for="Rows[i].BeneficiaryId"/>
                <input type="hidden" asp-for="Rows[i].BeneficiaryName"/>
                <input type="hidden" asp-for="Rows[i].RequestNumberOrDate"/>
                <input type="hidden" asp-for="Rows[i].AidTypeName"/>
                <input type="hidden" asp-for="Rows[i].UrgencyLevel"/>
                <input type="hidden" asp-for="Rows[i].HasPreviousDisbursement"/>
                <input type="hidden" asp-for="Rows[i].RequestedAmount"/>
                <input type="hidden" asp-for="Rows[i].FundedAmount"/>
                <input type="hidden" asp-for="Rows[i].DisbursedAmount"/>
                <input type="hidden" asp-for="Rows[i].RemainingNeedAmount"/>
              </td>
              <td>
                @if (isFirst)
                {
                  <span class="pri-first">⭐ أولوية أولى</span>
                }
                else
                {
                  <span class="pri-other">له صرف سابق</span>
                }
              </td>
              <td class="fw-semibold">@row.RequestedAmount.ToString("N0")</td>
              <td style="color:#f46a6a">@row.DisbursedAmount.ToString("N0")</td>
              <td style="color:#0e6f73;font-weight:600">@row.RemainingNeedAmount.ToString("N0")</td>
              <td>
                <div class="amt-wrap">
                  <input type="number" step="0.01" min="0"
                         name="Rows[@i].AllocateAmount"
                         value="@(row.AllocateAmount?.ToString("F2") ?? "")"
                         class="amt-input js-amt"
                         placeholder="0"
                         data-max="@row.RemainingNeedAmount.ToString("F2").Replace(",","")"/>
                  <button type="button" class="amt-max-btn" onclick="setMax(this)">اكتمال</button>
                </div>
                <div class="row-prog">
                  <div class="row-prog-fill js-row-prog" style="width:0%"></div>
                </div>
                <div style="font-size:.7rem;color:#adb5bd;margin-top:2px">
                  الحد الأقصى: @row.RemainingNeedAmount.ToString("N0")
                </div>
                <span class="text-danger small js-row-err" style="display:none"></span>
              </td>
            </tr>
          }
        </tbody>
        <tfoot>
          <tr>
            <td colspan="4" style="font-size:.85rem">إجمالي ما سيُوزَّع الآن</td>
            <td>@totalNeed.ToString("N0")</td>
            <td>
              <span id="foot-total" style="font-size:1rem;color:#0e6f73">0</span>
              <span id="foot-warning" style="display:none;font-size:.75rem;color:#f46a6a;margin-right:8px">
                <i class="bx bx-error me-1"></i>يتجاوز المتبقي
              </span>
            </td>
          </tr>
        </tfoot>
      </table>
    </div>

    @* Summary *@
    <div class="summary-box mt-3 mb-3">
      <div class="row g-3">
        <div class="col-md-4">
          <div style="font-size:.75rem;color:#6b7d80">سيُوزَّع على</div>
          <div class="fw-bold" id="sum-count" style="font-size:1.1rem;color:#0a5f63">0 مستفيد</div>
        </div>
        <div class="col-md-4">
          <div style="font-size:.75rem;color:#6b7d80">إجمالي التوزيع</div>
          <div class="fw-bold" id="sum-total" style="font-size:1.1rem;color:#34c38f">0</div>
        </div>
        <div class="col-md-4">
          <div style="font-size:.75rem;color:#6b7d80">سيتبقى بعد التوزيع</div>
          <div class="fw-bold" id="sum-after" style="font-size:1.1rem">@Model.DonationRemainingAmount.ToString("N0")</div>
        </div>
      </div>
    </div>
  }

  <div class="d-flex gap-2 mt-3">
    @if (canDistrib)
    {
      <button type="submit" class="btn btn-primary fw-bold" style="border-radius:12px">
        <i class="bx bx-save me-1"></i>حفظ التوزيع الجماعي
      </button>
    }
    <a asp-action="Index" asp-route-donationId="@Model.DonationId"
       class="btn btn-light fw-bold" style="border-radius:12px">رجوع</a>
  </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial"/>
@if (canDistrib)
{
<script>
var REMAINING         = @Model.DonationRemainingAmount.ToString("F2").Replace(",","");
var TOTAL_DONATION    = @Model.DonationAmount.ToString("F2").Replace(",","");
var ALREADY_ALLOCATED = TOTAL_DONATION - REMAINING;

function getAmt(inp) {
    var v = parseFloat(inp.value || '0');
    return isNaN(v) ? 0 : Math.max(0, v);
}
function fmt(n) {
    return n.toLocaleString('ar-EG', {minimumFractionDigits:0, maximumFractionDigits:0});
}
function el(id) { return document.getElementById(id); }

function refreshAll() {
    var inputs = document.querySelectorAll('.js-amt');
    var total = 0, count = 0;

    inputs.forEach(function(inp) {
        var val = getAmt(inp);
        var max = parseFloat(inp.dataset.max || '0');
        total  += val;
        if (val > 0) count++;

        var prog = inp.closest('tr').querySelector('.js-row-prog');
        var err  = inp.closest('tr').querySelector('.js-row-err');
        if (prog) prog.style.width = (max > 0 ? Math.min(val/max*100,100) : 0) + '%';
        if (val > max && max > 0) {
            inp.classList.add('over');
            if (err) { err.textContent = 'يتجاوز الاحتياج (' + max.toLocaleString() + ')'; err.style.display=''; }
        } else {
            inp.classList.remove('over');
            if (err) err.style.display = 'none';
        }
    });

    var afterDist = REMAINING - total;
    var pct = TOTAL_DONATION > 0
        ? Math.min((ALREADY_ALLOCATED + total) / TOTAL_DONATION * 100, 100)
        : 0;
    var usedPct = REMAINING > 0 ? Math.round(total / REMAINING * 100) : 0;

    el('hero-entered').textContent      = fmt(total);
    el('toolbar-remaining').textContent = fmt(Math.max(afterDist, 0));
    el('budget-fill').style.width       = pct + '%';
    el('budget-label').textContent      = 'مُخصَّص: ' + fmt(ALREADY_ALLOCATED + total);
    el('foot-total').textContent        = fmt(total);
    el('foot-warning').style.display    = total > REMAINING ? '' : 'none';

    // ── بانر الإنذار ──
    var warn = el('live-warn');
    if (warn) {
        warn.classList.remove('warn-safe','warn-low','warn-done','warn-over');
        el('warn-amount').textContent = fmt(Math.max(afterDist, 0));
        el('warn-pct').textContent    = usedPct;

        if (afterDist < 0) {
            warn.classList.add('warn-over');
            el('warn-icon').className  = 'bx bx-error-circle';
            el('warn-text').textContent  = '⚠ تجاوزت الميزانية! المتبقي: ';
            el('warn-suffix').textContent = ' — قلّل المبالغ المدخلة';
            el('warn-amount').style.color = '#f46a6a';
        } else if (afterDist === 0) {
            warn.classList.add('warn-done');
            el('warn-icon').className  = 'bx bx-check-circle';
            el('warn-text').textContent  = 'تم استنفاد التبرع بالكامل — المتبقي: ';
            el('warn-suffix').textContent = ' ✓';
            el('warn-amount').style.color = '#0a5659';
        } else if (usedPct >= 80) {
            warn.classList.add('warn-low');
            el('warn-icon').className  = 'bx bx-alarm';
            el('warn-text').textContent  = '⚡ تنبيه: المتبقي أقل من 20% — المتبقي: ';
            el('warn-suffix').textContent = ' — تحقق من المبالغ';
            el('warn-amount').style.color = '#8a5f00';
        } else {
            warn.classList.add('warn-safe');
            el('warn-icon').className  = 'bx bx-wallet';
            el('warn-text').textContent  = 'المتبقي للتوزيع: ';
            el('warn-suffix').textContent = ' — يمكنك المتابعة';
            el('warn-amount').style.color = '#0d7a5a';
        }
    }

    // تعطيل الحقول الفارغة لو انتهى الرصيد
    inputs.forEach(function(inp) {
        if (afterDist <= 0 && getAmt(inp) === 0) {
            inp.disabled    = true;
            inp.style.background = '#f5f5f5';
            inp.placeholder = 'لا رصيد';
        } else {
            inp.disabled    = false;
            inp.style.background = '';
            inp.placeholder = '0';
        }
    });

    var sc = el('sum-count'), st = el('sum-total'), sa = el('sum-after');
    if (sc) sc.textContent = count + ' مستفيد';
    if (st) { st.textContent = fmt(total); st.style.color = total > REMAINING ? '#f46a6a' : '#34c38f'; }
    if (sa) { sa.textContent = fmt(afterDist); sa.style.color = afterDist < 0 ? '#f46a6a' : '#15363a'; }
}

function setMax(btn) {
    var inp    = btn.closest('.amt-wrap').querySelector('.js-amt');
    var max    = parseFloat(inp.dataset.max || '0');
    var others = Array.from(document.querySelectorAll('.js-amt')).filter(x => x !== inp);
    var other  = others.reduce(function(s,x) { return s + getAmt(x); }, 0);
    inp.value  = Math.max(Math.min(max, REMAINING - other), 0).toFixed(2);
    refreshAll();
}

function clearAll() {
    document.querySelectorAll('.js-amt').forEach(function(inp) { inp.value = ''; });
    refreshAll();
}

function autoDistribute(mode) {
    var inputs = Array.from(document.querySelectorAll('.js-amt'));
    var maxArr = inputs.map(function(inp) { return parseFloat(inp.dataset.max||'0'); });
    var totalMax = maxArr.reduce(function(s,v){return s+v;},0);
    var budget = REMAINING;
    inputs.forEach(function(inp){inp.value='';});

    if (mode === 'equal') {
        var per = inputs.length > 0 ? budget / inputs.length : 0;
        inputs.forEach(function(inp,i){ var v=Math.min(per,maxArr[i]); if(v>0) inp.value=v.toFixed(2); });
    } else if (mode === 'proportional') {
        if (totalMax > 0)
            inputs.forEach(function(inp,i){ var v=Math.min((maxArr[i]/totalMax)*budget,maxArr[i]); if(v>0) inp.value=v.toFixed(2); });
    } else if (mode === 'priority') {
        var first=[], other=[];
        inputs.forEach(function(inp,i){
            inp.closest('tr').querySelector('.pri-first') ? first.push({inp,max:maxArr[i]}) : other.push({inp,max:maxArr[i]});
        });
        var rem = budget;
        first.concat(other).forEach(function(item){
            if(rem<=0) return;
            var v=Math.min(item.max,rem); if(v>0){item.inp.value=v.toFixed(2);rem-=v;}
        });
    } else if (mode === 'full') {
        var rem = budget;
        inputs.forEach(function(inp,i){
            if(rem<=0) return;
            var v=Math.min(maxArr[i],rem); if(v>0){inp.value=v.toFixed(2);rem-=v;}
        });
    }
    refreshAll();
}

document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.js-amt').forEach(function(inp){
        inp.addEventListener('input', refreshAll);
    });
    refreshAll();
});
</script>
}
}

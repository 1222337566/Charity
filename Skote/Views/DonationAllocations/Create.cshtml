@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile
@model InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.CreateDonationAllocationVm
@{
    ViewData["Title"] = "تخصيص تبرع";
    var donorHeader = ViewBag.DonorHeader as DonorHeaderVm;
    var donation = ViewBag.Donation as InfrastrfuctureManagmentCore.Domains.Charity.Donors.Donation;
}
<div class="page-content">
    <div class="container-fluid">
        @if (donorHeader != null)
        {
            @await Html.PartialAsync("~/Views/Shared/Donors/_DonorHeader.cshtml", donorHeader)
        }

        <div class="card mb-3">
            <div class="card-body">
                <div class="fw-semibold">رقم التبرع: @(donation?.DonationNumber)</div>
                <div class="text-muted">النوع: @(donation?.DonationType) | القيمة: @(donation?.Amount?.ToString("N2"))</div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h4 class="card-title mb-0">تخصيص تبرع لطلب مساعدة</h4></div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    @await Html.PartialAsync("_Form", Model)
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">حفظ</button>
                        <a asp-action="Index" asp-route-donationId="@Model.DonationId" class="btn btn-light">رجوع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

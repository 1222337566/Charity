@model InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.GeneralFundingAllocationVm
@{
    ViewData["Title"] = "التخصيص العام من الرصيد";

    var sourceScopeName = Model.SourceScopes?.FirstOrDefault(x => string.Equals(x.Value, Model.SourceScopeCode, StringComparison.OrdinalIgnoreCase))?.Text ?? Model.SourceScopeCode;
    var hasFinancialAccount = Model.FinancialAccountId.HasValue && Model.FinancialAccountId.Value != Guid.Empty;
    var hasAidType = Model.AidTypeId.HasValue && Model.AidTypeId.Value != Guid.Empty;
    var hasRequiredFilters = hasFinancialAccount && hasAidType;
    var hasSources = Model.SourceDonations != null && Model.SourceDonations.Any();
    var hasRows = Model.Rows != null && Model.Rows.Any();
    var canDistribute = hasRequiredFilters && hasSources && hasRows && Model.AvailablePoolAmount > 0m;

    var totalPoolAmount = Model.SourceDonations?.Sum(x => x.DonationAmount) ?? 0m;
    var allocatedPoolAmount = Model.SourceDonations?.Sum(x => x.AllocatedAmount) ?? 0m;
    var availablePoolAmount = Model.AvailablePoolAmount;
    var totalNeed = Model.Rows?.Sum(x => x.RemainingNeedAmount) ?? 0m;
    var firstPriorityCount = Model.Rows?.Count(x => !x.HasPreviousDisbursement) ?? 0;
    var allocatedPct = totalPoolAmount > 0m ? Math.Min(allocatedPoolAmount / totalPoolAmount * 100m, 100m) : 0m;
    var selectedTotal = Model.SelectedTotalAmount;
}

<style>
.gf-hero{background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px;padding:20px 26px;color:#fff;margin-bottom:18px}
.gf-stat{background:rgba(255,255,255,.15);border-radius:12px;padding:10px 16px;text-align:center;flex:1;min-width:105px}
.gf-stat .n{font-size:1.15rem;font-weight:800;line-height:1}
.gf-stat .l{font-size:.67rem;opacity:.82;margin-top:3px}
.gf-track{height:14px;border-radius:999px;background:rgba(255,255,255,.2);overflow:hidden;margin-top:10px;position:relative}
.gf-fill{height:100%;border-radius:999px;background:#34c38f;transition:width .3s}
.gf-panel{border-radius:16px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 6px 18px rgba(20,40,45,.04)}
.gf-panel .card-header{background:#f8fbfb;border-bottom:.5px solid rgba(14,111,115,.1)}
.gf-filter-card{border-radius:16px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 6px 18px rgba(20,40,45,.04)}
.gf-filter-card .form-control,.gf-filter-card .form-select{border-radius:10px}
.gf-badge{display:inline-flex;align-items:center;gap:4px;border-radius:999px;padding:4px 9px;font-size:.72rem;font-weight:700;background:rgba(14,111,115,.12);color:#0a5659}
.warn-banner{border-radius:12px;padding:12px 18px;font-size:.87rem;font-weight:600;display:flex;align-items:center;gap:10px;margin-bottom:14px;transition:background .3s,color .3s}
.warn-safe{background:rgba(52,195,143,.1);color:#0d7a5a;border:.5px solid rgba(52,195,143,.3)}
.warn-low{background:rgba(241,180,76,.1);color:#8a5f00;border:.5px solid rgba(241,180,76,.3)}
.warn-done{background:rgba(14,111,115,.08);color:#0a5659;border:.5px solid rgba(14,111,115,.2)}
.warn-over{background:rgba(244,106,106,.1);color:#ab2b2b;border:.5px solid rgba(244,106,106,.3)}
.dist-toolbar{background:#f8fbfb;border-radius:12px;padding:12px 16px;margin-bottom:14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;border:.5px solid rgba(14,111,115,.1)}
.tool-btn{padding:6px 14px;border-radius:9px;border:.5px solid rgba(14,111,115,.25);background:#fff;font-size:.8rem;font-weight:600;cursor:pointer;color:#0e6f73;transition:.12s;display:flex;align-items:center;gap:5px}
.tool-btn:hover{background:#0e6f73;color:#fff;border-color:#0e6f73}
.tool-btn.danger:hover{background:#f46a6a;border-color:#f46a6a}
.gf-search{border-radius:9px;border:.5px solid rgba(14,111,115,.18);padding:6px 10px;font-size:.8rem;min-width:220px}
.gf-table{width:100%;border-collapse:collapse}
.gf-table thead th{padding:10px 12px;font-size:.77rem;font-weight:700;color:#6b7d80;background:#f8fbfb;text-align:right;white-space:nowrap;border-bottom:.5px solid rgba(14,111,115,.1)}
.gf-table tbody td{padding:10px 12px;font-size:.83rem;border-top:.5px solid rgba(14,111,115,.06);vertical-align:middle}
.gf-table tfoot td{padding:10px 12px;font-weight:700;background:#f8fbfb;border-top:.5px solid rgba(14,111,115,.15)}
.pri-first{background:rgba(52,195,143,.15);color:#0d7a5a;padding:2px 8px;border-radius:5px;font-size:.68rem;font-weight:700;white-space:nowrap}
.pri-other{background:rgba(173,181,189,.15);color:#6b7d80;padding:2px 8px;border-radius:5px;font-size:.68rem;font-weight:700;white-space:nowrap}
.amt-wrap{position:relative}
.amt-input{border-radius:10px;border:.5px solid rgba(14,111,115,.25);padding:7px 40px 7px 10px;width:100%;font-size:.88rem;font-weight:600;transition:.15s}
.amt-input:focus{outline:none;border-color:#0e6f73;box-shadow:0 0 0 3px rgba(14,111,115,.1)}
.amt-input.over{border-color:#f46a6a;background:rgba(244,106,106,.05)}
.amt-max-btn{position:absolute;left:6px;top:50%;transform:translateY(-50%);font-size:.65rem;background:rgba(14,111,115,.1);color:#0e6f73;border:none;border-radius:5px;padding:2px 5px;cursor:pointer}
.amt-max-btn:hover{background:#0e6f73;color:#fff}
.row-prog{height:4px;border-radius:999px;background:#e2e8f0;margin-top:5px;overflow:hidden}
.row-prog-fill{height:100%;border-radius:999px;background:#34c38f;transition:width .2s}
.source-prog{height:5px;border-radius:999px;background:#e9ecef;overflow:hidden;margin-top:5px}
.source-prog-fill{height:100%;border-radius:999px;background:#0e6f73}
.summary-box{border-radius:14px;padding:14px 18px;border:.5px solid rgba(14,111,115,.15);background:#f8fbfb}
.empty-state{border:1px dashed rgba(14,111,115,.24);background:#fbfdfd;border-radius:14px;padding:18px;text-align:center;color:#6b7d80}
</style>

<div class="page-content">
    <div class="container-fluid">
        <div class="gf-hero mb-3">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                <div>
                    <div class="fw-bold" style="font-size:1.05rem">
                        <i class="bx bx-transfer-alt me-2"></i>التخصيص العام من الرصيد
                    </div>
                    <div style="opacity:.78;font-size:.8rem;margin-top:4px">
                        النطاق: <strong>@sourceScopeName</strong> ·
                        الحساب المصدر: <strong>@(Model.FinancialAccountName ?? "غير محدد")</strong> ·
                        نوع المساعدة: <strong>@(Model.AidTypeName ?? "غير محدد")</strong>
                        @if (!string.IsNullOrWhiteSpace(Model.PurposeName))
                        {
                            <text> · الغرض: <strong>@Model.PurposeName</strong></text>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Donations" asp-action="Index" class="btn btn-light btn-sm fw-bold" style="border-radius:10px">
                        <i class="bx bx-list-ul me-1"></i>رجوع للتبرعات
                    </a>
                    <button type="submit" form="general-filter-form" class="btn btn-success btn-sm fw-bold" style="border-radius:10px">
                        <i class="bx bx-refresh me-1"></i>تحديث الرصيد
                    </button>
                </div>
            </div>

            <div class="d-flex gap-3 flex-wrap mb-3">
                <div class="gf-stat">
                    <div class="n">@totalPoolAmount.ToString("N0")</div>
                    <div class="l">إجمالي مصادر الرصيد</div>
                </div>
                <div class="gf-stat" style="background:rgba(244,106,106,.2)">
                    <div class="n" style="color:#fca5a5">@allocatedPoolAmount.ToString("N0")</div>
                    <div class="l">مُخصَّص سابقًا</div>
                </div>
                <div class="gf-stat" style="background:rgba(52,195,143,.2)">
                    <div class="n" style="color:#a7f3d0" id="hero-remaining">@availablePoolAmount.ToString("N0")</div>
                    <div class="l">المتاح للتخصيص</div>
                </div>
                <div class="gf-stat">
                    <div class="n" id="hero-entered">@selectedTotal.ToString("N0")</div>
                    <div class="l">المُدخَل الآن</div>
                </div>
                <div class="gf-stat" style="background:rgba(241,180,76,.15)">
                    <div class="n" style="color:#fde68a">@firstPriorityCount</div>
                    <div class="l">أولوية أولى</div>
                </div>
            </div>
            <div class="gf-track">
                <div class="gf-fill" id="budget-fill" style="width:@allocatedPct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"></div>
            </div>
            <div class="d-flex justify-content-between mt-1" style="font-size:.7rem;opacity:.75">
                <span>0</span>
                <span id="budget-label">مُخصَّص: @allocatedPoolAmount.ToString("N0")</span>
                <span>@totalPoolAmount.ToString("N0")</span>
            </div>
        </div>

        <form asp-action="GeneralCreate" method="get" id="general-filter-form" class="card gf-filter-card mb-3">
            <div class="card-body row g-3 align-items-end">
                <div class="col-md-3">
                    <label asp-for="SourceScopeCode" class="form-label fw-semibold"></label>
                    <select asp-for="SourceScopeCode" asp-items="Model.SourceScopes" class="form-select" id="SourceScopeCode"></select>
                    <small class="text-muted">يعتمد على TargetingScopeCode فقط بدون fallback.</small>
                </div>
                <div class="col-md-3">
                    <label asp-for="FinancialAccountId" class="form-label fw-semibold"></label>
                    <select asp-for="FinancialAccountId" asp-items="Model.FinancialAccounts" class="form-select">
                        <option value="">-- اختر الحساب --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="AidTypeId" class="form-label fw-semibold"></label>
                    <select asp-for="AidTypeId" asp-items="Model.AidTypes" class="form-select">
                        <option value="">-- اختر نوع المساعدة --</option>
                    </select>
                </div>
                <div class="col-md-3" id="purpose-box">
                    <label asp-for="PurposeName" class="form-label fw-semibold"></label>
                    <input asp-for="PurposeName" class="form-control" placeholder="مثل: زكاة الفطر أو شنطة رمضان" />
                    <small class="text-muted">يظهر مع رصيد غرض / باب عام.</small>
                </div>
                <div class="col-12 d-flex justify-content-end gap-2 flex-wrap">
                    <a asp-action="GeneralCreate" class="btn btn-light fw-bold" style="border-radius:10px">
                        <i class="bx bx-x me-1"></i>مسح الفلاتر
                    </a>
                    <button type="submit" class="btn btn-primary fw-bold" style="border-radius:10px">
                        <i class="bx bx-search me-1"></i>تحميل الرصيد والطلبات
                    </button>
                </div>
            </div>
        </form>

        @if (!hasRequiredFilters)
        {
            <div class="alert alert-info" style="border-radius:12px">
                <i class="bx bx-info-circle me-2"></i>اختر الحساب المالي ونوع المساعدة ثم اضغط تحميل الرصيد حتى تظهر مصادر التبرع والطلبات المؤهلة.
            </div>
        }

        <div class="card gf-panel mb-3">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h5 class="card-title mb-0"><i class="bx bx-wallet me-1"></i>مصادر الرصيد المتاحة</h5>
                    <small class="text-muted">التبرعات العامة أو تبرعات الغرض العام التي ما زال لها رصيد متبقٍ.</small>
                </div>
                <span class="gf-badge">@((Model.SourceDonations?.Count ?? 0).ToString("N0")) مصدر</span>
            </div>
            <div class="card-body">
                @if (!hasSources)
                {
                    <div class="empty-state">
                        <i class="bx bx-search-alt" style="font-size:1.7rem"></i>
                        <div class="fw-semibold mt-1">لا توجد مصادر رصيد مطابقة للفلاتر الحالية.</div>
                        <div class="small mt-1">تأكد أن التبرعات لها TargetingScopeCode مناسب وأن لها رصيد متبقٍ.</div>
                    </div>
                }
                else
                {
                    <div class="table-responsive" style="border-radius:14px;border:.5px solid rgba(14,111,115,.1)">
                        <table class="gf-table mb-0">
                            <thead>
                                <tr>
                                    <th>رقم التبرع</th>
                                    <th>التاريخ</th>
                                    <th>المتبرع</th>
                                    <th>الغرض / النوع</th>
                                    <th>القيمة</th>
                                    <th>المخصص</th>
                                    <th>المتبقي</th>
                                    <th>الحالة</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var source in Model.SourceDonations)
                                {
                                    var sourcePct = source.DonationAmount > 0m ? Math.Min(source.AllocatedAmount / source.DonationAmount * 100m, 100m) : 0m;
                                    <tr>
                                        <td>
                                            <a asp-action="Index" asp-route-donationId="@source.DonationId" class="fw-semibold">@source.DonationNumber</a>
                                        </td>
                                        <td>@source.DonationDate.ToString("yyyy-MM-dd")</td>
                                        <td>@(source.DonorName ?? "-")</td>
                                        <td>@(source.PurposeName ?? source.AidTypeName ?? "-")</td>
                                        <td class="fw-semibold">@source.DonationAmount.ToString("N2")</td>
                                        <td style="color:#f46a6a">@source.AllocatedAmount.ToString("N2")</td>
                                        <td style="color:#0e6f73;font-weight:700">@source.RemainingAmount.ToString("N2")</td>
                                        <td style="min-width:120px">
                                            <div class="source-prog"><div class="source-prog-fill" style="width:@sourcePct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"></div></div>
                                            <small class="text-muted">@sourcePct.ToString("N0")% مستخدم</small>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <form asp-action="GeneralCreate" method="post" id="general-allocation-form" class="card gf-panel">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SourceScopeCode" />
            <input type="hidden" asp-for="FinancialAccountId" />
            <input type="hidden" asp-for="AidTypeId" />
            <input type="hidden" asp-for="PurposeName" />

            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h5 class="card-title mb-0"><i class="bx bx-user-check me-1"></i>طلبات المساعدة المؤهلة</h5>
                    <small class="text-muted">الأولوية تلقائيًا للمستفيدين الذين لم يتلقوا صرف مساعدة سابقًا، ثم حسب درجة الاستعجال وتاريخ الطلب.</small>
                </div>
                <div class="text-muted small">الاحتياج المفتوح: <strong>@totalNeed.ToString("N2")</strong></div>
            </div>

            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="border-radius:12px;font-size:.85rem"></div>

                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <label asp-for="AllocatedDate" class="form-label fw-semibold"></label>
                        <input asp-for="AllocatedDate" type="date" class="form-control" style="border-radius:10px" />
                        <span asp-validation-for="AllocatedDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-9">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <input asp-for="Notes" class="form-control" placeholder="ملاحظة تظهر على كل سطور التخصيص العام..." style="border-radius:10px" />
                    </div>
                </div>

                @if (hasRequiredFilters && hasSources && !hasRows)
                {
                    <div class="alert alert-info" style="border-radius:12px">
                        <i class="bx bx-info-circle me-2"></i>يوجد رصيد متاح، لكن لا توجد طلبات معتمدة ومفتوحة مؤهلة لنوع المساعدة المحدد.
                    </div>
                }
                @if (hasRequiredFilters && hasSources && hasRows && availablePoolAmount <= 0m)
                {
                    <div class="warn-banner warn-done">
                        <i class="bx bx-check-circle" style="font-size:1.4rem"></i>
                        <div>
                            <div>الرصيد المحدد <strong>مكتمل التخصيص</strong> — لا يوجد مبلغ متاح للتوزيع.</div>
                            <div style="font-size:.78rem;margin-top:2px;opacity:.8">راجع مصادر الرصيد أو اختر حسابًا آخر.</div>
                        </div>
                    </div>
                }

                @if (canDistribute)
                {
                    <div class="warn-banner warn-safe" id="live-warn">
                        <i class="bx bx-wallet" id="warn-icon" style="font-size:1.3rem"></i>
                        <div>
                            <span id="warn-text">المتبقي للتخصيص: </span>
                            <strong id="warn-amount">@availablePoolAmount.ToString("N0")</strong>
                            <span id="warn-suffix"> — يمكنك المتابعة</span>
                        </div>
                        <div style="margin-right:auto;font-size:.78rem;opacity:.8">
                            <span id="warn-pct">0</span>% مستخدم من الرصيد المتاح
                        </div>
                    </div>

                    <div class="dist-toolbar">
                        <span style="font-size:.8rem;font-weight:700;color:#0a5f63">توزيع سريع:</span>
                        <button type="button" class="tool-btn" onclick="autoDistribute('equal')">
                            <i class="bx bx-equalizer"></i> متساوٍ
                        </button>
                        <button type="button" class="tool-btn" onclick="autoDistribute('proportional')">
                            <i class="bx bx-pie-chart-alt-2"></i> نسبي
                        </button>
                        <button type="button" class="tool-btn" onclick="autoDistribute('priority')">
                            <i class="bx bx-sort-down"></i> بالأولوية
                        </button>
                        <button type="button" class="tool-btn" onclick="autoDistribute('full')">
                            <i class="bx bx-check-double"></i> اكتمال الكل
                        </button>
                        <button type="button" class="tool-btn danger" onclick="clearAll()">
                            <i class="bx bx-trash"></i> مسح الكل
                        </button>
                        <input type="search" class="gf-search" id="request-search" placeholder="بحث باسم المستفيد أو الطلب..." />
                        <div style="margin-right:auto;font-size:.8rem;color:#6b7d80">
                            متبقي: <strong id="toolbar-remaining" style="color:#0e6f73">@availablePoolAmount.ToString("N0")</strong>
                        </div>
                    </div>

                    <div style="overflow-x:auto;border-radius:14px;border:.5px solid rgba(14,111,115,.1)">
                        <table class="gf-table" id="requests-table">
                            <thead>
                                <tr>
                                    <th>المستفيد / الطلب</th>
                                    <th>الأولوية</th>
                                    <th>المطلوب</th>
                                    <th>الممول</th>
                                    <th>المصروف</th>
                                    <th>المتبقي</th>
                                    <th style="min-width:210px">المبلغ المخصص الآن</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < Model.Rows.Count; i++)
                                {
                                    var row = Model.Rows[i];
                                    var isFirst = !row.HasPreviousDisbursement;
                                    <tr class="gf-row" data-max="@row.RemainingNeedAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" data-search="@($"{row.BeneficiaryName} {row.RequestNumberOrDate} {row.AidTypeName} {row.UrgencyLevel}")">
                                        <td>
                                            <div class="fw-semibold" style="font-size:.87rem">@row.BeneficiaryName</div>
                                            <div style="font-size:.73rem;color:#6b7d80">
                                                طلب @row.RequestNumberOrDate · @row.AidTypeName
                                                @if (!string.IsNullOrWhiteSpace(row.UrgencyLevel))
                                                {
                                                    <span> · @row.UrgencyLevel</span>
                                                }
                                            </div>
                                            <input type="hidden" asp-for="Rows[i].AidRequestId" />
                                            <input type="hidden" asp-for="Rows[i].BeneficiaryId" />
                                        </td>
                                        <td>
                                            @if (isFirst)
                                            {
                                                <span class="pri-first">⭐ أولوية أولى</span>
                                            }
                                            else
                                            {
                                                <span class="pri-other">له صرف سابق</span>
                                            }
                                        </td>
                                        <td class="fw-semibold">@row.RequestedAmount.ToString("N0")</td>
                                        <td>@row.FundedAmount.ToString("N0")</td>
                                        <td style="color:#f46a6a">@row.DisbursedAmount.ToString("N0")</td>
                                        <td style="color:#0e6f73;font-weight:700">@row.RemainingNeedAmount.ToString("N0")</td>
                                        <td>
                                            <div class="amt-wrap">
                                                <input asp-for="Rows[i].AllocateAmount"
                                                       type="number"
                                                       step="0.01"
                                                       min="0"
                                                       class="amt-input js-amt"
                                                       placeholder="0"
                                                       data-max="@row.RemainingNeedAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" />
                                                <button type="button" class="amt-max-btn" onclick="setMax(this)">اكتمال</button>
                                            </div>
                                            <div class="row-prog">
                                                <div class="row-prog-fill js-row-prog" style="width:0%"></div>
                                            </div>
                                            <div style="font-size:.7rem;color:#adb5bd;margin-top:2px">
                                                الحد الأقصى: @row.RemainingNeedAmount.ToString("N0")
                                            </div>
                                            <span asp-validation-for="Rows[i].AllocateAmount" class="text-danger small"></span>
                                            <span class="text-danger small js-row-err" style="display:none"></span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="4" style="font-size:.85rem">إجمالي ما سيُخصَّص الآن</td>
                                    <td colspan="2">@totalNeed.ToString("N0")</td>
                                    <td>
                                        <span id="foot-total" style="font-size:1rem;color:#0e6f73">0</span>
                                        <span id="foot-warning" style="display:none;font-size:.75rem;color:#f46a6a;margin-right:8px">
                                            <i class="bx bx-error me-1"></i>يتجاوز الرصيد المتاح
                                        </span>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="summary-box mt-3 mb-3">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div style="font-size:.75rem;color:#6b7d80">سيُخصَّص على</div>
                                <div class="fw-bold" id="sum-count" style="font-size:1.1rem;color:#0a5f63">0 مستفيد</div>
                            </div>
                            <div class="col-md-4">
                                <div style="font-size:.75rem;color:#6b7d80">إجمالي التخصيص</div>
                                <div class="fw-bold" id="sum-total" style="font-size:1.1rem;color:#34c38f">0</div>
                            </div>
                            <div class="col-md-4">
                                <div style="font-size:.75rem;color:#6b7d80">سيتبقى بعد التخصيص</div>
                                <div class="fw-bold" id="sum-after" style="font-size:1.1rem">@availablePoolAmount.ToString("N0")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="card-footer d-flex justify-content-end gap-2 flex-wrap">
                <a asp-controller="Donations" asp-action="Index" class="btn btn-light fw-bold" style="border-radius:12px">رجوع</a>
                @if (canDistribute)
                {
                    <button type="submit" class="btn btn-primary fw-bold" id="save-btn" style="border-radius:12px">
                        <i class="bx bx-save me-1"></i>حفظ التخصيص العام
                    </button>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
(function () {
    var scopeSelect = document.getElementById('SourceScopeCode');
    var purposeBox = document.getElementById('purpose-box');
    function togglePurposeBox() {
        if (!scopeSelect || !purposeBox) return;
        var show = (scopeSelect.value || '').toLowerCase() === 'generalpurpose';
        purposeBox.style.display = show ? '' : 'none';
    }
    if (scopeSelect) {
        scopeSelect.addEventListener('change', togglePurposeBox);
        togglePurposeBox();
    }
})();
</script>
@if (canDistribute)
{
<script>
var AVAILABLE       = @availablePoolAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
var TOTAL_POOL      = @totalPoolAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
var ALREADY_USED    = @allocatedPoolAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);

function getAmt(inp) {
    var v = parseFloat(inp.value || '0');
    return isNaN(v) ? 0 : Math.max(0, v);
}
function fmt(n) {
    return n.toLocaleString('ar-EG', {minimumFractionDigits:0, maximumFractionDigits:0});
}
function el(id) { return document.getElementById(id); }

function refreshAll() {
    var inputs = document.querySelectorAll('.js-amt');
    var total = 0, count = 0;

    inputs.forEach(function(inp) {
        var row = inp.closest('tr');
        if (row && row.style.display === 'none') return;

        var val = getAmt(inp);
        var max = parseFloat(inp.dataset.max || '0');
        total += val;
        if (val > 0) count++;

        var prog = row ? row.querySelector('.js-row-prog') : null;
        var err = row ? row.querySelector('.js-row-err') : null;
        if (prog) prog.style.width = (max > 0 ? Math.min(val / max * 100, 100) : 0) + '%';
        if (val > max && max > 0) {
            inp.classList.add('over');
            if (err) { err.textContent = 'يتجاوز احتياج الطلب (' + fmt(max) + ')'; err.style.display = ''; }
        } else {
            inp.classList.remove('over');
            if (err) err.style.display = 'none';
        }
    });

    var afterDist = AVAILABLE - total;
    var pct = TOTAL_POOL > 0 ? Math.min((ALREADY_USED + total) / TOTAL_POOL * 100, 100) : 0;
    var usedPct = AVAILABLE > 0 ? Math.round(total / AVAILABLE * 100) : 0;

    if (el('hero-entered')) el('hero-entered').textContent = fmt(total);
    if (el('hero-remaining')) el('hero-remaining').textContent = fmt(Math.max(afterDist, 0));
    if (el('toolbar-remaining')) el('toolbar-remaining').textContent = fmt(Math.max(afterDist, 0));
    if (el('budget-fill')) el('budget-fill').style.width = pct + '%';
    if (el('budget-label')) el('budget-label').textContent = 'مُخصَّص: ' + fmt(ALREADY_USED + total);
    if (el('foot-total')) el('foot-total').textContent = fmt(total);
    if (el('foot-warning')) el('foot-warning').style.display = total > AVAILABLE ? '' : 'none';

    var warn = el('live-warn');
    if (warn) {
        warn.classList.remove('warn-safe','warn-low','warn-done','warn-over');
        if (el('warn-amount')) el('warn-amount').textContent = fmt(Math.max(afterDist, 0));
        if (el('warn-pct')) el('warn-pct').textContent = usedPct;

        if (afterDist < 0) {
            warn.classList.add('warn-over');
            el('warn-icon').className = 'bx bx-error-circle';
            el('warn-text').textContent = '⚠ تجاوزت الرصيد المتاح! المتبقي: ';
            el('warn-suffix').textContent = ' — قلّل المبالغ المدخلة';
            el('warn-amount').style.color = '#f46a6a';
        } else if (afterDist === 0) {
            warn.classList.add('warn-done');
            el('warn-icon').className = 'bx bx-check-circle';
            el('warn-text').textContent = 'تم استنفاد الرصيد بالكامل — المتبقي: ';
            el('warn-suffix').textContent = ' ✓';
            el('warn-amount').style.color = '#0a5659';
        } else if (usedPct >= 80) {
            warn.classList.add('warn-low');
            el('warn-icon').className = 'bx bx-alarm';
            el('warn-text').textContent = '⚡ تنبيه: المتبقي أقل من 20% — المتبقي: ';
            el('warn-suffix').textContent = ' — تحقق من المبالغ';
            el('warn-amount').style.color = '#8a5f00';
        } else {
            warn.classList.add('warn-safe');
            el('warn-icon').className = 'bx bx-wallet';
            el('warn-text').textContent = 'المتبقي للتخصيص: ';
            el('warn-suffix').textContent = ' — يمكنك المتابعة';
            el('warn-amount').style.color = '#0d7a5a';
        }
    }

    inputs.forEach(function(inp) {
        var val = getAmt(inp);
        if (afterDist <= 0 && val === 0) {
            inp.disabled = true;
            inp.style.background = '#f5f5f5';
            inp.placeholder = 'لا رصيد';
        } else {
            inp.disabled = false;
            inp.style.background = '';
            inp.placeholder = '0';
        }
    });

    if (el('sum-count')) el('sum-count').textContent = count + ' مستفيد';
    if (el('sum-total')) { el('sum-total').textContent = fmt(total); el('sum-total').style.color = total > AVAILABLE ? '#f46a6a' : '#34c38f'; }
    if (el('sum-after')) { el('sum-after').textContent = fmt(afterDist); el('sum-after').style.color = afterDist < 0 ? '#f46a6a' : '#15363a'; }
    if (el('save-btn')) el('save-btn').disabled = total <= 0 || total > AVAILABLE;
}

function setMax(btn) {
    var inp = btn.closest('.amt-wrap').querySelector('.js-amt');
    var max = parseFloat(inp.dataset.max || '0');
    var others = Array.from(document.querySelectorAll('.js-amt')).filter(function(x) { return x !== inp; });
    var other = others.reduce(function(s, x) { return s + getAmt(x); }, 0);
    inp.value = Math.max(Math.min(max, AVAILABLE - other), 0).toFixed(2);
    refreshAll();
}

function clearAll() {
    document.querySelectorAll('.js-amt').forEach(function(inp) { inp.value = ''; });
    refreshAll();
}

function autoDistribute(mode) {
    var inputs = Array.from(document.querySelectorAll('.js-amt')).filter(function(inp) {
        var row = inp.closest('tr');
        return !row || row.style.display !== 'none';
    });
    var maxArr = inputs.map(function(inp) { return parseFloat(inp.dataset.max || '0'); });
    var totalMax = maxArr.reduce(function(s, v) { return s + v; }, 0);
    var budget = AVAILABLE;
    inputs.forEach(function(inp) { inp.value = ''; });

    if (mode === 'equal') {
        var per = inputs.length > 0 ? budget / inputs.length : 0;
        inputs.forEach(function(inp, i) { var v = Math.min(per, maxArr[i]); if (v > 0) inp.value = v.toFixed(2); });
    } else if (mode === 'proportional') {
        if (totalMax > 0) inputs.forEach(function(inp, i) { var v = Math.min((maxArr[i] / totalMax) * budget, maxArr[i]); if (v > 0) inp.value = v.toFixed(2); });
    } else if (mode === 'priority') {
        var first = [], other = [];
        inputs.forEach(function(inp, i) {
            inp.closest('tr').querySelector('.pri-first') ? first.push({ inp: inp, max: maxArr[i] }) : other.push({ inp: inp, max: maxArr[i] });
        });
        var rem = budget;
        first.concat(other).forEach(function(item) {
            if (rem <= 0) return;
            var v = Math.min(item.max, rem);
            if (v > 0) { item.inp.value = v.toFixed(2); rem -= v; }
        });
    } else if (mode === 'full') {
        var remFull = budget;
        inputs.forEach(function(inp, i) {
            if (remFull <= 0) return;
            var v = Math.min(maxArr[i], remFull);
            if (v > 0) { inp.value = v.toFixed(2); remFull -= v; }
        });
    }
    refreshAll();
}

document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.js-amt').forEach(function(inp) { inp.addEventListener('input', refreshAll); });

    var search = document.getElementById('request-search');
    if (search) {
        search.addEventListener('input', function() {
            var q = (search.value || '').toLowerCase().trim();
            document.querySelectorAll('#requests-table tbody tr').forEach(function(row) {
                var text = (row.getAttribute('data-search') || '').toLowerCase();
                row.style.display = !q || text.indexOf(q) >= 0 ? '' : 'none';
            });
            refreshAll();
        });
    }

    var form = document.getElementById('general-allocation-form');
    if (form) {
        form.addEventListener('submit', function(e) {
            var total = Array.from(document.querySelectorAll('.js-amt')).reduce(function(s, x) { return s + getAmt(x); }, 0);
            if (total <= 0 || total > AVAILABLE) {
                e.preventDefault();
                refreshAll();
            }
        });
    }

    refreshAll();
});
</script>
}
}

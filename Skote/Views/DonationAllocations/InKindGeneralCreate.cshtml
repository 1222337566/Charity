@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations
@model InKindGeneralAllocationVm
@{
    ViewData["Title"] = "التخصيص العام للعيني";
    var hasItems   = Model.SourceItems != null && Model.SourceItems.Any();
    var hasRows    = Model.Rows != null && Model.Rows.Any();
    var canSubmit  = hasItems && hasRows;
    var totalAvail = Model.SourceItems?.Sum(x=>x.RemainingQuantity) ?? 0;
}
<style>
:root{--teal:#0e6f73;--teal-l:#e1f5f5;--ink:#1e3a5f;--muted:#6b7d80;--accent:#556ee6}
.ik-hero{background:linear-gradient(135deg,#1e3c5e,#556ee6);border-radius:20px;padding:20px 26px;color:#fff;margin-bottom:18px;position:relative;overflow:hidden}
.ik-hero::after{content:'';position:absolute;top:-50px;left:-50px;width:200px;height:200px;background:rgba(255,255,255,.04);border-radius:50%}
.ik-stat{background:rgba(255,255,255,.14);border-radius:13px;padding:11px 16px;text-align:center;flex:1;min-width:90px}
.ik-stat .n{font-size:1.25rem;font-weight:800;line-height:1}
.ik-stat .l{font-size:.67rem;opacity:.82;margin-top:3px}
.filter-card{background:#fff;border-radius:14px;border:.5px solid rgba(85,110,230,.12);padding:16px 18px;margin-bottom:16px;box-shadow:0 2px 8px rgba(85,110,230,.05)}
.source-card{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 8px rgba(14,111,115,.05);overflow:hidden;margin-bottom:12px}
.source-card-hdr{padding:12px 18px;background:#f4f9f9;border-bottom:.5px solid rgba(14,111,115,.08);display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap}
.source-table{width:100%;border-collapse:collapse;font-size:.82rem}
.source-table th{padding:9px 12px;font-size:.71rem;font-weight:700;color:var(--muted);background:#f8fbfb;text-align:right;border-bottom:.5px solid rgba(14,111,115,.1);white-space:nowrap}
.source-table td{padding:10px 12px;border-bottom:.5px solid rgba(14,111,115,.05);vertical-align:middle}
.source-table tr:hover td{background:rgba(14,111,115,.02)}
.alloc-table{width:100%;border-collapse:collapse;font-size:.82rem}
.alloc-table th{padding:9px 12px;font-size:.71rem;font-weight:700;color:var(--muted);background:#f8f9fc;text-align:right;border-bottom:.5px solid rgba(85,110,230,.1);white-space:nowrap}
.alloc-table td{padding:10px 12px;border-bottom:.5px solid rgba(85,110,230,.04);vertical-align:middle}
.alloc-table tr:hover td{background:rgba(85,110,230,.02)}
.qty-input{border-radius:9px;border:.5px solid rgba(85,110,230,.25);padding:6px 36px 6px 10px;width:100%;font-size:.87rem;font-weight:600;transition:.15s;position:relative}
.qty-input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(85,110,230,.1)}
.qty-input.over{border-color:#f46a6a;background:rgba(244,106,106,.05)}
.qty-wrap{position:relative}
.qty-max-btn{position:absolute;left:5px;top:50%;transform:translateY(-50%);font-size:.62rem;background:rgba(85,110,230,.1);color:var(--accent);border:none;border-radius:4px;padding:2px 5px;cursor:pointer;white-space:nowrap}
.qty-max-btn:hover{background:var(--accent);color:#fff}
.source-select{border-radius:9px;border:.5px solid rgba(85,110,230,.2);padding:5px 8px;font-size:.8rem;width:100%}
.pri-badge{padding:2px 8px;border-radius:5px;font-size:.67rem;font-weight:700;background:rgba(52,195,143,.15);color:#0d7a5a;white-space:nowrap}
.pri-other{background:#f0f4f8;color:#6b7d80}
.live-banner{border-radius:12px;padding:12px 18px;font-size:.85rem;font-weight:600;display:flex;align-items:center;gap:10px;margin-bottom:12px;transition:background .25s}
.banner-ok{background:rgba(52,195,143,.1);color:#0d7a5a;border:.5px solid rgba(52,195,143,.25)}
.banner-warn{background:rgba(241,180,76,.1);color:#7a5500;border:.5px solid rgba(241,180,76,.25)}
.banner-over{background:rgba(244,106,106,.1);color:#c0392b;border:.5px solid rgba(244,106,106,.25)}
.toolbar{background:#f8f9fc;border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;border:.5px solid rgba(85,110,230,.1);margin-bottom:12px}
.tool-btn{padding:5px 12px;border-radius:8px;border:.5px solid rgba(85,110,230,.2);background:#fff;font-size:.78rem;font-weight:600;cursor:pointer;color:var(--accent);transition:.12s;display:inline-flex;align-items:center;gap:5px}
.tool-btn:hover{background:var(--accent);color:#fff;border-color:var(--accent)}
.empty-info{border:1px dashed rgba(85,110,230,.2);background:#f8f9fc;border-radius:12px;padding:18px;text-align:center;color:var(--muted);font-size:.85rem}
.summary-box{background:#f8f9fc;border-radius:12px;padding:14px 18px;border:.5px solid rgba(85,110,230,.12);margin-top:12px}
.row-prog{height:4px;border-radius:999px;background:#e2e8f0;margin-top:4px;overflow:hidden}
.row-prog-fill{height:100%;border-radius:999px;background:var(--accent);transition:width .2s}
</style>

<div class="ik-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h4 class="mb-1 fw-bold"><i class="bx bx-transfer-alt me-2"></i>التخصيص العام للتبرعات العينية</h4>
            <p class="mb-0" style="opacity:.8;font-size:.87rem">توزيع أصناف التبرعات العينية المتاحة على طلبات المساعدة المؤهلة</p>
        </div>
        <a asp-controller="Donations" asp-action="Index" class="btn btn-sm" style="background:rgba(255,255,255,.2);color:#fff;border-radius:9px">
            <i class="bx bx-arrow-back me-1"></i>رجوع للتبرعات
        </a>
    </div>
    <div class="d-flex flex-wrap gap-3 mt-3">
        <div class="ik-stat"><div class="n">@(Model.SourceItems?.Count??0)</div><div class="l">أصناف متاحة</div></div>
        <div class="ik-stat"><div class="n" id="hero-avail">@totalAvail.ToString("N0")</div><div class="l">إجمالي الكمية</div></div>
        <div class="ik-stat"><div class="n">@(Model.Rows?.Count??0)</div><div class="l">طلبات مؤهلة</div></div>
        <div class="ik-stat"><div class="n" id="hero-entered">0</div><div class="l">مدخل الآن</div></div>
    </div>
</div>

<!-- ── Filter Form ── -->
<form asp-action="InKindGeneralCreate" method="get" class="filter-card">
    <h6 class="fw-bold mb-3" style="color:var(--ink)"><i class="bx bx-filter-alt me-2 text-primary"></i>فلاتر البحث</h6>
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="AidTypeId" class="form-label small fw-bold text-muted"></label>
            <select asp-for="AidTypeId" asp-items="Model.AidTypes" class="form-select form-select-sm" style="border-color:rgba(85,110,230,.2)">
                <option value="">-- نوع المساعدة --</option>
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="ItemId" class="form-label small fw-bold text-muted"></label>
            <select asp-for="ItemId" asp-items="Model.Items" class="form-select form-select-sm" style="border-color:rgba(85,110,230,.2)">
                <option value="">-- الصنف (اختياري) --</option>
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="WarehouseId" class="form-label small fw-bold text-muted"></label>
            <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select form-select-sm" style="border-color:rgba(85,110,230,.2)">
                <option value="">-- المخزن (اختياري) --</option>
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm fw-semibold flex-fill" style="background:var(--accent);color:#fff;border-radius:8px"><i class="bx bx-search me-1"></i>تحميل البيانات</button>
            <a asp-action="InKindGeneralCreate" class="btn btn-sm btn-light" style="border-radius:8px"><i class="bx bx-reset"></i></a>
        </div>
    </div>
</form>

<!-- ── Source Items Panel ── -->
<div class="source-card mb-3">
    <div class="source-card-hdr">
        <div>
            <h6 class="fw-bold mb-0" style="color:var(--ink)"><i class="bx bx-package me-2 text-primary"></i>أصناف التبرعات المتاحة</h6>
            <small class="text-muted">التبرعات العينية التي لا تزال لديها كميات متبقية للتخصيص</small>
        </div>
        <span style="background:var(--teal-l);color:var(--teal);padding:3px 12px;border-radius:20px;font-size:.72rem;font-weight:700">@(Model.SourceItems?.Count??0) صنف</span>
    </div>
    @if(!hasItems){
        <div class="p-4"><div class="empty-info"><i class="bx bx-search-alt" style="font-size:1.8rem;display:block;margin-bottom:8px"></i>اختر نوع المساعدة واضغط تحميل البيانات</div></div>
    }else{
        <div class="table-responsive">
            <table class="source-table">
                <thead><tr><th>#</th><th>رقم التبرع</th><th>المتبرع</th><th>الصنف</th><th>الكمية</th><th>مخصص</th><th>متبقي</th><th>المخزن</th><th>الصلاحية</th></tr></thead>
                <tbody>
                @for(var i=0;i<Model.SourceItems!.Count;i++){
                    var src=Model.SourceItems[i];
                    var usedPct=src.TotalQuantity>0?Math.Min((double)src.AllocatedQuantity/(double)src.TotalQuantity*100,100):0;
                    <tr>
                        <td class="text-muted" style="font-size:.72rem">@(i+1)</td>
                        <td class="fw-semibold" style="color:var(--teal)">@src.DonationNumber</td>
                        <td class="text-muted">@src.DonorName</td>
                        <td class="fw-semibold" style="color:var(--ink)">@src.ItemName</td>
                        <td>@src.TotalQuantity.ToString("N0")</td>
                        <td style="color:#f46a6a">@src.AllocatedQuantity.ToString("N0")</td>
                        <td style="color:var(--teal);font-weight:700" class="js-source-rem" data-id="@src.DonationInKindItemId">@src.RemainingQuantity.ToString("N0")</td>
                        <td class="text-muted">@(src.WarehouseName??"—")</td>
                        <td class="text-muted" style="font-size:.75rem">@(src.ExpiryDate?.ToString("yyyy/MM/dd")??"—")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- ── Allocation Form ── -->
@if(canSubmit){
<form asp-action="InKindGeneralCreate" method="post" id="inkind-alloc-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="AidTypeId"/>
    <input type="hidden" asp-for="ItemId"/>
    <input type="hidden" asp-for="WarehouseId"/>

    <div class="source-card">
        <div class="source-card-hdr" style="background:#f8f9fc;border-bottom:.5px solid rgba(85,110,230,.08)">
            <div>
                <h6 class="fw-bold mb-0" style="color:var(--ink)"><i class="bx bx-user-check me-2" style="color:var(--accent)"></i>طلبات المساعدة المؤهلة</h6>
                <small class="text-muted">الطلبات المعتمدة التي تحتاج أصنافًا عينية مطابقة</small>
            </div>
        </div>
        <div class="p-3">
            <div id="live-banner" class="live-banner banner-ok">
                <i class="bx bx-package" style="font-size:1.3rem"></i>
                <span>حدد الكميات المطلوبة لكل طلب واختر الصنف المصدر</span>
            </div>
            <div class="toolbar">
                <span style="font-size:.8rem;font-weight:700;color:var(--ink)">توزيع سريع:</span>
                <button type="button" class="tool-btn" onclick="autoAlloc('max')"><i class="bx bx-check-double"></i>اكتمال الكل</button>
                <button type="button" class="tool-btn" onclick="autoAlloc('equal')"><i class="bx bx-equalizer"></i>متساوٍ</button>
                <button type="button" class="tool-btn" onclick="clearAlloc()"><i class="bx bx-trash"></i>مسح الكل</button>
                <input type="text" id="rowSearch" class="form-control form-control-sm" style="max-width:220px;border-radius:8px;border-color:rgba(85,110,230,.2)" placeholder="بحث بالمستفيد..."/>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label asp-for="AllocatedDate" class="form-label small fw-bold text-muted"></label>
                    <input asp-for="AllocatedDate" type="date" class="form-control form-control-sm" style="border-radius:9px;border-color:rgba(85,110,230,.2)"/>
                </div>
                <div class="col-md-9">
                    <label asp-for="Notes" class="form-label small fw-bold text-muted"></label>
                    <input asp-for="Notes" class="form-control form-control-sm" placeholder="ملاحظة تُضاف لجميع التخصيصات..." style="border-radius:9px;border-color:rgba(85,110,230,.2)"/>
                </div>
            </div>
            <div class="table-responsive" style="border-radius:12px;border:.5px solid rgba(85,110,230,.1)">
                <table class="alloc-table" id="alloc-table">
                    <thead><tr><th>المستفيد</th><th>الصنف المطلوب</th><th>الأولوية</th><th>مطلوب</th><th>محدد</th><th>متبقي</th><th style="min-width:160px">مصدر التبرع</th><th style="min-width:120px">الكمية</th></tr></thead>
                    <tbody>
                    @for(var i=0;i<Model.Rows!.Count;i++){
                        var row=Model.Rows[i];
                        <tr data-search="@row.BeneficiaryName.ToLower() @row.ItemName.ToLower()" data-max="@row.RemainingNeedQuantity.ToString("F2",System.Globalization.CultureInfo.InvariantCulture)">
                            <td>
                                <div class="fw-semibold" style="font-size:.86rem;color:var(--ink)">@row.BeneficiaryName</div>
                                <div style="font-size:.72rem;color:var(--muted)">@row.RequestSummary</div>
                                <input type="hidden" asp-for="Rows[i].AidRequestId"/>
                                <input type="hidden" asp-for="Rows[i].BeneficiaryId"/>
                                <input type="hidden" asp-for="Rows[i].AidRequestLineId"/>
                            </td>
                            <td class="fw-semibold" style="color:var(--accent)">@row.ItemName</td>
                            <td>
                                @if(!row.HasPreviousDisbursement){<span class="pri-badge">⭐ أولوية</span>}
                                else{<span class="pri-badge pri-other">له صرف</span>}
                            </td>
                            <td class="fw-semibold">@row.RequestedQuantity.ToString("N0")</td>
                            <td style="color:#f46a6a">@row.AllocatedQuantity.ToString("N0")</td>
                            <td style="color:var(--teal);font-weight:700">@row.RemainingNeedQuantity.ToString("N0")</td>
                            <td>
                                <select asp-for="Rows[i].SelectedDonationInKindItemId" class="source-select js-source-sel" style="border-color:rgba(85,110,230,.2)">
                                    <option value="">-- اختر --</option>
                                    @foreach(var src in Model.SourceItems!){
                                        <option value="@src.DonationInKindItemId" data-rem="@src.RemainingQuantity.ToString("F2",System.Globalization.CultureInfo.InvariantCulture)">
                                            @src.DonationNumber — @src.ItemName (@src.RemainingQuantity.ToString("N0") متبقي)
                                        </option>
                                    }
                                </select>
                            </td>
                            <td>
                                <div class="qty-wrap">
                                    <input asp-for="Rows[i].AllocateQuantity" type="number" step="0.01" min="0" class="qty-input js-qty" placeholder="0"
                                           data-max="@row.RemainingNeedQuantity.ToString("F2",System.Globalization.CultureInfo.InvariantCulture)"/>
                                    <button type="button" class="qty-max-btn" onclick="setRowMax(this)">اكتمال</button>
                                </div>
                                <div class="row-prog"><div class="row-prog-fill" style="width:0%"></div></div>
                                <div style="font-size:.67rem;color:var(--muted);margin-top:2px">الحد: @row.RemainingNeedQuantity.ToString("N0")</div>
                                <span asp-validation-for="Rows[i].AllocateQuantity" class="text-danger small"></span>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="summary-box">
                <div class="row g-3">
                    <div class="col-md-4"><div style="font-size:.74rem;color:var(--muted)">سيُخصَّص على</div><div class="fw-bold" id="sum-count" style="font-size:1.1rem;color:var(--accent)">0 طلب</div></div>
                    <div class="col-md-4"><div style="font-size:.74rem;color:var(--muted)">إجمالي الكميات</div><div class="fw-bold" id="sum-qty" style="font-size:1.1rem;color:#34c38f">0</div></div>
                    <div class="col-md-4"><div style="font-size:.74rem;color:var(--muted)">حالة التخصيص</div><div class="fw-bold" id="sum-status" style="font-size:.9rem;color:var(--muted)">لم يبدأ</div></div>
                </div>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-end gap-2 p-3" style="background:#f8f9fc;border-top:.5px solid rgba(85,110,230,.08)">
            <a asp-controller="Donations" asp-action="Index" class="btn btn-light fw-semibold" style="border-radius:11px">رجوع</a>
            <button type="submit" class="btn fw-bold" id="save-btn" disabled style="background:var(--accent);color:#fff;border-radius:11px"><i class="bx bx-save me-1"></i>حفظ التخصيص العيني</button>
        </div>
    </div>
</form>
}else if(Model.AidTypeId.HasValue && !hasRows && hasItems){
    <div class="alert" style="background:rgba(241,180,76,.1);border:.5px solid rgba(241,180,76,.3);border-radius:12px;font-size:.87rem">
        <i class="bx bx-info-circle me-2" style="color:#f1b44c"></i>يوجد أصناف متاحة لكن لا توجد طلبات معتمدة مفتوحة لهذا النوع من المساعدة.
    </div>
}

@section Scripts {
<partial name="_ValidationScriptsPartial"/>
<script>
var SOURCE_DATA = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.SourceItems?.ToDictionary(x=>x.DonationInKindItemId.ToString(),
        x=>new{rem=x.RemainingQuantity,name=x.ItemName}) ?? new()
));

function getQty(inp){var v=parseFloat(inp.value||'0');return isNaN(v)?0:Math.max(0,v);}
function fmt(n){return n.toLocaleString('ar-EG',{minimumFractionDigits:0,maximumFractionDigits:2});}

function refresh(){
    var rows=document.querySelectorAll('#alloc-table tbody tr');
    var total=0,count=0;
    rows.forEach(function(row){
        if(row.style.display==='none')return;
        var inp=row.querySelector('.js-qty');
        var sel=row.querySelector('.js-source-sel');
        if(!inp||!sel)return;
        var val=getQty(inp);
        var needMax=parseFloat(row.dataset.max||'0');
        var srcOpt=sel.selectedOptions[0];
        var srcRem=srcOpt?parseFloat(srcOpt.dataset.rem||'999999'):999999;
        var over=val>needMax||val>srcRem;
        inp.classList.toggle('over',over&&val>0);
        var prog=row.querySelector('.row-prog-fill');
        if(prog)prog.style.width=(needMax>0?Math.min(val/needMax*100,100):0)+'%';
        total+=val;
        if(val>0)count++;
    });
    var el=id=>document.getElementById(id);
    if(el('hero-entered'))el('hero-entered').textContent=fmt(total);
    if(el('sum-count'))el('sum-count').textContent=count+' طلب';
    if(el('sum-qty')){el('sum-qty').textContent=fmt(total);el('sum-qty').style.color=total>0?'#34c38f':'var(--muted)';}
    if(el('sum-status'))el('sum-status').textContent=count>0?'جاهز للحفظ':'لم يبدأ';
    var btn=el('save-btn');
    if(btn)btn.disabled=total<=0;
    var banner=el('live-banner');
    if(banner){
        banner.className='live-banner '+(total>0?'banner-ok':'banner-warn');
        banner.innerHTML='<i class="bx bx-package" style="font-size:1.3rem"></i><span>'+
            (total>0?'إجمالي المخصص: <strong>'+fmt(total)+'</strong> وحدة على <strong>'+count+'</strong> طلب'
                    :'حدد الكميات من الطلبات أدناه')+'</span>';
    }
}
function setRowMax(btn){
    var row=btn.closest('tr');
    var inp=row.querySelector('.js-qty');
    var sel=row.querySelector('.js-source-sel');
    var needMax=parseFloat(row.dataset.max||'0');
    var srcOpt=sel?sel.selectedOptions[0]:null;
    var srcRem=srcOpt?parseFloat(srcOpt.dataset.rem||'0'):0;
    inp.value=Math.min(needMax,srcRem>0?srcRem:needMax).toFixed(2);
    refresh();
}
function autoAlloc(mode){
    var rows=Array.from(document.querySelectorAll('#alloc-table tbody tr')).filter(r=>r.style.display!=='none');
    if(mode==='max'){rows.forEach(function(row){var inp=row.querySelector('.js-qty');var max=parseFloat(row.dataset.max||'0');if(inp&&max>0)inp.value=max.toFixed(2);});}
    else if(mode==='equal'){var per=rows.length>0?1:0;rows.forEach(function(row){var inp=row.querySelector('.js-qty');var max=parseFloat(row.dataset.max||'0');if(inp&&max>0)inp.value=Math.min(per,max).toFixed(2);});}
    refresh();
}
function clearAlloc(){document.querySelectorAll('.js-qty').forEach(i=>i.value='');refresh();}
document.addEventListener('DOMContentLoaded',function(){
    document.querySelectorAll('.js-qty').forEach(i=>i.addEventListener('input',refresh));
    document.querySelectorAll('.js-source-sel').forEach(s=>s.addEventListener('change',refresh));
    var search=document.getElementById('rowSearch');
    if(search)search.addEventListener('input',function(){
        var q=this.value.toLowerCase();
        document.querySelectorAll('#alloc-table tbody tr').forEach(function(r){
            r.style.display=!q||(r.dataset.search||'').includes(q)?'':'none';
        });
        refresh();
    });
    refresh();
});
</script>
}

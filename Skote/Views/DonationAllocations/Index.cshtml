@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile
@model List<InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.DonationAllocationListItemVm>
@{
    ViewData["Title"] = "تخصيصات التبرع";
    var donorHeader = ViewBag.DonorHeader as DonorHeaderVm;
    var donation = ViewBag.Donation as InfrastrfuctureManagmentCore.Domains.Charity.Donors.Donation;
    decimal allocatedAmount = ViewBag.AllocatedAmount ?? 0m;
    bool supportsDirectAllocation = ViewBag.SupportsDirectAllocation is bool b && b;
    string scopeCode = ViewBag.TargetingScopeCode as string ?? string.Empty;
    string? purposeName = ViewBag.PurposeName as string;
}
<div class="page-content">
    <div class="container-fluid">
        @if (donorHeader != null)
        {
            @await Html.PartialAsync("~/Views/Shared/Donors/_DonorHeader.cshtml", donorHeader)
        }

        <div class="card mb-3">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <div class="fw-semibold">رقم التبرع: @(donation?.DonationNumber)</div>
                    <div class="text-muted">المبلغ الأصلي: @(donation?.Amount?.ToString("N2")) | المبلغ المخصص: @allocatedAmount.ToString("N2")</div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Donations" asp-action="Index" asp-route-donorId="@(donation?.DonorId)" class="btn btn-light">رجوع للتبرعات</a>
                    @if (supportsDirectAllocation)
                    {
                        <a asp-action="Create" asp-route-donationId="@(donation?.Id)" class="btn btn-success">إضافة تخصيص</a>
                        <a asp-action="BulkCreate" asp-route-donationId="@(donation?.Id)" class="btn btn-primary">توزيع جماعي</a>
                        <a asp-action="generalcreate"  class="btn btn-primary"> تخصيص عام</a>

                    }
                    else if (donation != null && string.Equals(donation.DonationType, "نقدي", System.StringComparison.OrdinalIgnoreCase))
                    {
                        <a asp-action="GeneralCreate"
                           asp-route-financialAccountId="@(donation?.FinancialAccountId)"
                           asp-route-aidTypeId="@(donation?.AidTypeId)"
                           asp-route-sourceScopeCode="@scopeCode"
                           asp-route-purposeName="@purposeName"
                           class="btn btn-primary">التخصيص العام من الرصيد</a>
                    }
                </div>
            </div>
            @if (!supportsDirectAllocation)
            {
                <div class="card-footer text-muted">
                    هذا التبرع لا يدعم التخصيص المباشر على الطلبات. استخدم شاشة <strong>التخصيص العام من الرصيد</strong>.
                </div>
            }
        </div>

        <div class="card">
            <div class="card-header"><h4 class="card-title mb-0">سجل التخصيصات</h4></div>
            <div class="card-body table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>المستفيد</th>
                            <th>طلب المساعدة</th>
                            <th>بند الطلب</th>
                            <th>الصنف العيني</th>
                            <th>الكمية</th>
                            <th>المبلغ</th>
                            <th>ملاحظات</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.AllocatedDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.BeneficiaryName</td>
                                <td>@item.AidRequestSummary</td>
                                
                                <td>@item.DonationItemName</td>
                                <td>@item.AllocatedQuantity?.ToString("N2")</td>
                                <td>@item.Amount?.ToString("N2")</td>
                                <td>@item.Notes</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">تعديل</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile
@model List<InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.DonationInKindItemListItemVm>
@{
    ViewData["Title"] = "التبرعات العينية";
    var donorHeader = ViewBag.DonorHeader as DonorHeaderVm;
    var donation = ViewBag.Donation as InfrastrfuctureManagmentCore.Domains.Charity.Donors.Donation;
}
<div class="page-content">
    <div class="container-fluid">
        @if (donorHeader != null)
        {
            @await Html.PartialAsync("~/Views/Shared/Donors/_DonorHeader.cshtml", donorHeader)
        }

        <div class="card mb-3">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <div class="fw-semibold">رقم التبرع: @(donation?.DonationNumber)</div>
                    <div class="text-muted">النوع: @(donation?.DonationType) | التاريخ: @(donation?.DonationDate.ToString("yyyy-MM-dd"))</div>
                </div>
                <div class="d-flex gap-2">
                    <a asp-controller="Donations" asp-action="Index" asp-route-donorId="@(donation?.DonorId)" class="btn btn-light">رجوع للتبرعات</a>
                    <a asp-controller="Donations" asp-action="PrintReceipt" asp-route-id="@(donation?.Id)" target="_blank" class="btn btn-outline-dark">طباعة الإيصال</a>
                    <a asp-controller="Donations" asp-action="PrintMovement" asp-route-id="@(donation?.Id)" target="_blank" class="btn btn-outline-info">كشف الحركة</a>
                    <a asp-action="Create" asp-route-donationId="@(donation?.Id)" class="btn btn-success">إضافة صنف عيني</a>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h4 class="card-title mb-0">تفاصيل التبرع العيني</h4></div>
            <div class="card-body table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>الصنف</th>
                            <th>الكمية</th>
                            <th>المخصص</th>
                            <th>المتبقي</th>
                            <th>القيمة التقديرية</th>
                            <th>الصلاحية</th>
                            <th>المخزن</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div>@item.ItemName</div>
                                    @if (!string.IsNullOrWhiteSpace(item.BatchNo))
                                    {
                                        <small class="text-muted">تشغيلة: @item.BatchNo</small>
                                    }
                                </td>
                                <td>@item.Quantity.ToString("N2")</td>
                                <td>@item.AllocatedQuantity.ToString("N2")</td>
                                <td>@item.RemainingQuantity.ToString("N2")</td>
                                <td>@item.EstimatedTotalValue?.ToString("N2")</td>
                                <td>@item.ExpiryDate?.ToString("yyyy-MM-dd")</td>
                                <td>@item.WarehouseName</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">تعديل</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

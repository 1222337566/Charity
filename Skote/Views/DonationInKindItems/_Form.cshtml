@model InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.CreateDonationInKindItemVm
<div class="alert alert-info mb-3">
    كل تبرع عيني يتم إدخاله هنا سيُنشئ تلقائيًا <strong>إذن إضافة مخزني</strong> ويزيد رصيد المخزن المختار، لذلك اختيار المخزن هنا إلزامي.
</div>
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="ItemId" class="form-label"></label>
        <select asp-for="ItemId" asp-items="Model.Items" class="form-select">
            <option value="">اختر الصنف</option>
        </select>
        <span asp-validation-for="ItemId" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Quantity" class="form-label"></label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="WarehouseId" class="form-label"></label>
        <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select">
            <option value="">اختر المخزن</option>
        </select>
        <span asp-validation-for="WarehouseId" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="EstimatedUnitValue" class="form-label"></label>
        <input asp-for="EstimatedUnitValue" class="form-control" />
        <span asp-validation-for="EstimatedUnitValue" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="EstimatedTotalValue" class="form-label"></label>
        <input asp-for="EstimatedTotalValue" class="form-control" />
        <span asp-validation-for="EstimatedTotalValue" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="ExpiryDate" class="form-label"></label>
        <input asp-for="ExpiryDate" class="form-control" />
        <span asp-validation-for="ExpiryDate" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="BatchNo" class="form-label"></label>
        <input asp-for="BatchNo" class="form-control" />
        <span asp-validation-for="BatchNo" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Notes" class="form-label"></label>
        <input asp-for="Notes" class="form-control" />
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>
</div>
<input type="hidden" asp-for="DonationId" />

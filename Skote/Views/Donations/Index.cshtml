@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile
@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations
@model List<InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.DonationListItemVm>
@{
    ViewData["Title"] = "التبرعات";
    var donorHeader = ViewBag.DonorHeader as DonorHeaderVm;
    string TypeColor(string t)=>t=="نقدي"?"#34c38f":"#556ee6";
    string TypeIcon(string t)=>t=="نقدي"?"bx-money":"bx-package";
    string ScopeAr(string? s)=>s switch{"GeneralFund"=>"عام","SpecificRequests"=>"مخصص لطلبات","GeneralPurpose"=>"غرض عام",_=>s??"—"};
    string ScopeColor(string? s)=>s switch{"GeneralFund"=>"#74788d","SpecificRequests"=>"#556ee6","GeneralPurpose"=>"#f1b44c",_=>"#adb5bd"};
    var cashTotal   = Model.Where(x=>x.DonationType=="نقدي").Sum(x=>x.Amount??0);
    var inKindCount = Model.Count(x=>x.DonationType=="عيني");
    var cashCount   = Model.Count(x=>x.DonationType=="نقدي");
}
<style>
:root{--teal:#0e6f73;--teal-l:#e1f5f5;--ink:#1e3a5f;--muted:#6b7d80}
.dn-hero{background:linear-gradient(135deg,#1a3c5e,#0e6f73);border-radius:20px;padding:20px 26px;color:#fff;margin-bottom:18px;position:relative;overflow:hidden}
.dn-hero::after{content:'';position:absolute;top:-50px;left:-50px;width:200px;height:200px;background:rgba(255,255,255,.04);border-radius:50%}
.dn-stat{background:rgba(255,255,255,.13);border-radius:13px;padding:11px 16px;text-align:center;flex:1;min-width:90px}
.dn-stat .n{font-size:1.35rem;font-weight:800;line-height:1}
.dn-stat .l{font-size:.67rem;opacity:.8;margin-top:3px}
.dn-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 12px rgba(14,111,115,.06);overflow:hidden;margin-bottom:12px;transition:box-shadow .2s}
.dn-card:hover{box-shadow:0 4px 22px rgba(14,111,115,.12)}
.dn-card-top{padding:14px 18px;display:flex;align-items:flex-start;gap:12px}
.dn-card-foot{padding:10px 18px;background:#f8fbfb;border-top:.5px solid rgba(14,111,115,.07);display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap}
.dn-type-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.dn-num{font-weight:800;font-size:.88rem;color:var(--teal)}
.dn-date{font-size:.75rem;color:var(--muted)}
.dn-amount{font-size:1.1rem;font-weight:800;color:var(--ink)}
.scope-badge{padding:2px 9px;border-radius:20px;font-size:.67rem;font-weight:700;color:#fff}
.act-btn{padding:4px 11px;border-radius:8px;font-size:.75rem;font-weight:600;text-decoration:none;transition:all .15s;white-space:nowrap}
.filter-strip{background:#fff;border-radius:13px;border:.5px solid rgba(14,111,115,.12);padding:12px 16px;margin-bottom:14px}
.empty-dn{padding:50px;text-align:center;color:var(--muted)}
.empty-dn i{font-size:2.8rem;opacity:.3;display:block;margin-bottom:10px}
.view-btn{width:30px;height:30px;border:1px solid rgba(14,111,115,.18);background:#fff;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all .2s}
.view-btn.active{background:var(--teal);color:#fff;border-color:var(--teal)}
.dn-table{width:100%;border-collapse:collapse;font-size:.83rem}
.dn-table th{padding:9px 12px;font-size:.72rem;font-weight:700;color:var(--muted);background:#f4f9f9;text-align:right;border-bottom:.5px solid rgba(14,111,115,.1);white-space:nowrap}
.dn-table td{padding:10px 12px;border-bottom:.5px solid rgba(14,111,115,.05);vertical-align:middle}
.dn-table tr:hover td{background:rgba(14,111,115,.02)}
</style>

@if(donorHeader!=null){
    @await Html.PartialAsync("~/Views/Shared/Donors/_DonorHeader.cshtml", donorHeader)
}

<div class="dn-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h4 class="mb-1 fw-bold"><i class="bx bx-gift me-2"></i>سجل التبرعات</h4>
            <p class="mb-0" style="opacity:.8;font-size:.87rem">@(ViewBag.PageSubtitle ?? "جميع التبرعات النقدية والعينية")</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if(donorHeader!=null){
                <a asp-action="Create" asp-route-donorId="@donorHeader.Id" class="btn btn-sm fw-semibold" style="background:#34c38f;color:#fff;border-radius:10px"><i class="bx bx-plus me-1"></i>تسجيل تبرع</a>
            }
            <a asp-controller="DonationAllocations" asp-action="GeneralCreate" class="btn btn-sm fw-semibold" style="background:rgba(255,255,255,.2);color:#fff;border-radius:10px"><i class="bx bx-transfer-alt me-1"></i>تخصيص عام نقدي</a>
            <a asp-controller="DonationAllocations" asp-action="InKindGeneralCreate" class="btn btn-sm fw-semibold" style="background:rgba(255,255,255,.2);color:#fff;border-radius:10px"><i class="bx bx-package me-1"></i>تخصيص عام عيني</a>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-3 mt-3">
        <div class="dn-stat"><div class="n">@Model.Count</div><div class="l">إجمالي التبرعات</div></div>
        <div class="dn-stat"><div class="n">@cashCount</div><div class="l">نقدية</div></div>
        <div class="dn-stat"><div class="n">@inKindCount</div><div class="l">عينية</div></div>
        <div class="dn-stat"><div class="n">@cashTotal.ToString("N0")</div><div class="l">إجمالي النقدي</div></div>
    </div>
</div>

<div class="filter-strip">
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <div class="input-group input-group-sm" style="max-width:260px">
            <span class="input-group-text" style="background:#f4f9f9;border-color:rgba(14,111,115,.18)"><i class="bx bx-search text-muted"></i></span>
            <input type="text" id="dnSearch" class="form-control form-control-sm" placeholder="بحث بالرقم أو المتبرع..." style="border-color:rgba(14,111,115,.18)"/>
        </div>
        <select id="dnType" class="form-select form-select-sm" style="max-width:130px;border-color:rgba(14,111,115,.18)">
            <option value="">الكل</option><option value="نقدي">نقدي</option><option value="عيني">عيني</option>
        </select>
        <div class="ms-auto d-flex gap-1">
            <button type="button" class="view-btn active" id="btnCards"><i class="bx bx-grid-alt"></i></button>
            <button type="button" class="view-btn" id="btnTable"><i class="bx bx-list-ul"></i></button>
        </div>
    </div>
</div>

@if(TempData["Success"]!=null){<div class="alert alert-success alert-dismissible fade show mb-3">@TempData["Success"]<button class="btn-close" data-bs-dismiss="alert"></button></div>}

@if(!Model.Any()){
    <div class="empty-dn"><i class="bx bx-gift"></i><p>لا توجد تبرعات</p></div>
}else{
<!-- CARDS VIEW -->
<div id="viewCards">
@foreach(var item in Model){
    var isInKind = item.DonationType=="عيني";
    var canAllocate = item.TargetingScopeCode==DonationTargetingScopeOption.SpecificRequests || isInKind;
    var tc=TypeColor(item.DonationType);
    <div class="dn-card" data-type="@item.DonationType" data-q="@(item.DonationNumber.ToLower()) @(item.DonorName?.ToLower())">
        <div class="dn-card-top">
            <div class="dn-type-icon" style="background:@tc+22;color:@tc">
                <i class="bx @TypeIcon(item.DonationType)"></i>
            </div>
            <div class="flex-1">
                <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                    <span class="dn-num">@item.DonationNumber</span>
                    <span class="scope-badge" style="background:@ScopeColor(item.TargetingScopeCode)">@ScopeAr(item.TargetingScopeCode)</span>
                    @if(!string.IsNullOrEmpty(item.GeneralPurposeName)){<span style="font-size:.67rem;color:var(--muted);background:#f0f4f8;padding:1px 7px;border-radius:4px">@item.GeneralPurposeName</span>}
                    @if(!string.IsNullOrEmpty(item.DonorName) && donorHeader==null){<span style="font-size:.74rem;color:var(--ink);font-weight:600">@item.DonorName</span>}
                </div>
                <div class="dn-date"><i class="bx bx-calendar me-1"></i>@item.DonationDate.ToString("yyyy/MM/dd")</div>
                @if(!string.IsNullOrEmpty(item.ReceiptNumber)){<div class="dn-date mt-1"><i class="bx bx-receipt me-1"></i>إيصال: @item.ReceiptNumber</div>}
            </div>
            <div class="text-end">
                @if(item.Amount.HasValue && item.DonationType=="نقدي"){<div class="dn-amount">@item.Amount.Value.ToString("N0")</div>}
                else if(isInKind){<div style="font-size:.78rem;color:#556ee6;font-weight:700">عيني</div>}
                @if(!string.IsNullOrEmpty(item.PaymentMethod)){<div class="dn-date">@item.PaymentMethod</div>}
            </div>
        </div>
        <div class="dn-card-foot">
            <div class="d-flex flex-wrap gap-1">
                <a asp-action="Edit" asp-route-id="@item.Id" class="act-btn" style="background:var(--teal-l);color:var(--teal)"><i class="bx bx-edit-alt me-1"></i>تعديل</a>
                <a asp-action="PrintReceipt" asp-route-id="@item.Id" target="_blank" class="act-btn" style="background:#f0f4f8;color:var(--ink)"><i class="bx bx-printer me-1"></i>إيصال</a>
                @if(canAllocate && !isInKind){
                    <a asp-controller="DonationAllocations" asp-action="Index" asp-route-donationId="@item.Id" class="act-btn" style="background:rgba(52,195,143,.1);color:#1a7a55"><i class="bx bx-transfer-alt me-1"></i>تخصيص</a>
                }
                @if(isInKind){
                    <a asp-controller="DonationInKindItems" asp-action="Index" asp-route-donationId="@item.Id" class="act-btn" style="background:rgba(85,110,230,.1);color:#3145a3"><i class="bx bx-package me-1"></i>الأصناف</a>
                    <a asp-action="Tracking" asp-route-id="@item.Id" class="act-btn" style="background:rgba(241,180,76,.1);color:#7a5500"><i class="bx bx-radar me-1"></i>تتبع</a>
                    <a asp-controller="DonationAllocations" asp-action="Index" asp-route-donationId="@item.Id" class="act-btn" style="background:rgba(52,195,143,.1);color:#1a7a55"><i class="bx bx-link me-1"></i>تخصيص</a>
                    <a asp-action="PrintMovement" asp-route-id="@item.Id" target="_blank" class="act-btn" style="background:#f0f4f8;color:var(--ink)"><i class="bx bx-file me-1"></i>كشف</a>
                }
            </div>
        </div>
    </div>
}
</div>

<!-- TABLE VIEW -->
<div id="viewTable" style="display:none">
    <div class="card" style="border-radius:14px;border:.5px solid rgba(14,111,115,.1);overflow:hidden">
        <div class="table-responsive">
            <table class="dn-table">
                <thead><tr>
                    @if(donorHeader==null){<th>المتبرع</th>}
                    <th>رقم التبرع</th><th>التاريخ</th><th>النوع</th><th>القيمة</th>
                    <th>طريقة الدفع</th><th>نطاق التوجيه</th><th>الغرض</th><th>الإيصال</th><th></th>
                </tr></thead>
                <tbody>
                @foreach(var item in Model){
                    var isInKind2=item.DonationType=="عيني";
                    var canAllocate2=item.TargetingScopeCode==DonationTargetingScopeOption.SpecificRequests||isInKind2;
                    <tr data-type="@item.DonationType" data-q="@(item.DonationNumber.ToLower()) @(item.DonorName?.ToLower())">
                        @if(donorHeader==null){<td class="fw-semibold">@(item.DonorName??"-")</td>}
                        <td class="fw-semibold" style="color:var(--teal)">@item.DonationNumber</td>
                        <td>@item.DonationDate.ToString("yyyy/MM/dd")</td>
                        <td><span class="scope-badge" style="background:@TypeColor(item.DonationType)">@item.DonationType</span></td>
                        <td class="fw-semibold">@(item.Amount?.ToString("N0")??"—")</td>
                        <td class="text-muted">@(item.PaymentMethod??"—")</td>
                        <td><span class="scope-badge" style="background:@ScopeColor(item.TargetingScopeCode)">@ScopeAr(item.TargetingScopeCode)</span></td>
                        <td class="text-muted" style="font-size:.78rem">@(item.GeneralPurposeName??"—")</td>
                        <td class="text-muted">@(item.ReceiptNumber??"—")</td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="act-btn" style="background:var(--teal-l);color:var(--teal)">تعديل</a>
                                @if(canAllocate2){<a asp-controller="DonationAllocations" asp-action="Index" asp-route-donationId="@item.Id" class="act-btn" style="background:rgba(52,195,143,.1);color:#1a7a55">تخصيص</a>}
                                @if(isInKind2){<a asp-controller="DonationInKindItems" asp-action="Index" asp-route-donationId="@item.Id" class="act-btn" style="background:rgba(85,110,230,.1);color:#3145a3">الأصناف</a>}
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
}
@section Scripts{
<script>
const g=document.getElementById('viewCards'),t=document.getElementById('viewTable');
document.getElementById('btnCards')?.addEventListener('click',function(){g.style.display='';t.style.display='none';this.classList.add('active');document.getElementById('btnTable').classList.remove('active');});
document.getElementById('btnTable')?.addEventListener('click',function(){t.style.display='';g.style.display='none';this.classList.add('active');document.getElementById('btnCards').classList.remove('active');});

function filterDonations(){
    const q=document.getElementById('dnSearch').value.toLowerCase();
    const type=document.getElementById('dnType').value;
    document.querySelectorAll('[data-type]').forEach(el=>{
        const matchQ=!q||(el.dataset.q||'').includes(q);
        const matchT=!type||el.dataset.type===type;
        el.style.display=matchQ&&matchT?'':'none';
    });
}
document.getElementById('dnSearch')?.addEventListener('input',filterDonations);
document.getElementById('dnType')?.addEventListener('change',filterDonations);
</script>
}

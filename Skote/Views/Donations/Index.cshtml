@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile
@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations
@model List<InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.DonationListItemVm>
@{
    ViewData["Title"] = "التبرعات";
    var donorHeader = ViewBag.DonorHeader as DonorHeaderVm;
}
<div class="page-content">
    <div class="container-fluid">
        @if (donorHeader != null)
        {
            @await Html.PartialAsync("~/Views/Shared/Donors/_DonorHeader.cshtml", donorHeader)
        }

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="card-title mb-0">سجل التبرعات</h4>
                    @if (donorHeader == null && ViewBag.PageSubtitle != null)
                    {
                        <small class="text-muted">@ViewBag.PageSubtitle</small>
                    }
                </div>
                @if (donorHeader != null)
                {
                    <a asp-action="Create" asp-route-donorId="@donorHeader.Id" class="btn btn-success">تسجيل تبرع</a>
                    <a asp-action="\DonationAllocations\generalcreate" class="btn btn-primary"> تخصيص عام</a>
                }
            </div>
            <div class="card-body table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            @if (donorHeader == null)
                            {
                                <th>المتبرع</th>
                            }
                            <th>رقم التبرع</th>
                            <th>التاريخ</th>
                            <th>النوع</th>
                            <th>القيمة</th>
                            <th>طريقة الدفع</th>
                            <th>الحساب المالي</th>
                            <th>نطاق التوجيه</th>
                            <th>الغرض العام</th>
                            <th>الإيصال</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                            var isSpecific = string.Equals(item.TargetingScopeCode, DonationTargetingScopeOption.SpecificRequests, StringComparison.OrdinalIgnoreCase);
                            var isInKind = string.Equals(item.DonationType, "عيني", StringComparison.OrdinalIgnoreCase);
                            var canAllocate = isSpecific || isInKind;
                        <tr>
                            @if (donorHeader == null)
                            {
                                <td>@(item.DonorName ?? "-")</td>
                            }
                            <td>@item.DonationNumber</td>
                            <td>@item.DonationDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.DonationType</td>
                            <td>@item.Amount?.ToString("N2")</td>
                            <td>@item.PaymentMethod</td>
                            <td>@item.FinancialAccount</td>
                            <td><span class="badge bg-info-subtle text-dark">@(item.TargetingScopeName ?? "-")</span></td>
                            <td>@(item.GeneralPurposeName ?? "-")</td>
                            <td>@item.ReceiptNumber</td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">تعديل</a>
                                    <a asp-action="PrintReceipt" asp-route-id="@item.Id" target="_blank" class="btn btn-sm btn-outline-dark">طباعة الإيصال</a>
                                        @if (canAllocate)
                                        {
                                            <a asp-controller="DonationAllocations" asp-action="Index" asp-route-donationId="@item.Id" class="btn btn-sm btn-outline-success">
                                                @(isInKind ? "تخصيص عيني" : "تخصيص")
                                            </a>
                                        }
                                    @if (item.DonationType == "عيني")
                                    {
                                        <a asp-controller="DonationInKindItems" asp-action="Index" asp-route-donationId="@item.Id" class="btn btn-sm btn-outline-secondary">أصناف عينية</a>
                                        <a asp-action="Tracking" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">تتبع عيني</a>
                                        <a asp-action="PrintMovement" asp-route-id="@item.Id" target="_blank" class="btn btn-sm btn-outline-warning">كشف حركة</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.DonationInKindMovementPrintVm
@{
    Layout = "~/Views/Shared/Reports/_PrintLayout.cshtml";
    ViewData["Title"] = "كشف حركة التبرع العيني";
}

<h2 class="text-center">كشف حركة التبرع</h2>
<div class="meta text-center">رقم التبرع: @Model.DonationNumber | التاريخ: @Model.DonationDate.ToString("yyyy-MM-dd")</div>

<table class="table">
    <tbody>
        <tr>
            <th style="width:20%">المتبرع</th>
            <td style="width:30%">@(string.IsNullOrWhiteSpace(Model.DonorName) ? "-" : Model.DonorName)</td>
            <th style="width:20%">رقم الإيصال</th>
            <td style="width:30%">@(string.IsNullOrWhiteSpace(Model.ReceiptNumber) ? "-" : Model.ReceiptNumber)</td>
        </tr>
        <tr>
            <th>كود المتبرع</th>
            <td>@(string.IsNullOrWhiteSpace(Model.DonorCode) ? "-" : Model.DonorCode)</td>
            <th>الهاتف</th>
            <td>@(string.IsNullOrWhiteSpace(Model.DonorPhone) ? "-" : Model.DonorPhone)</td>
        </tr>
        <tr>
            <th>نوع التبرع</th>
            <td>@Model.DonationType</td>
            <th>نوع المساعدة المستهدف</th>
            <td>@(string.IsNullOrWhiteSpace(Model.AidTypeName) ? "-" : Model.AidTypeName)</td>
        </tr>
        <tr>
            <th>ملاحظات</th>
            <td colspan="3">@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</td>
        </tr>
    </tbody>
</table>

@if (!Model.IsInKind)
{
    <div class="alert alert-warning">هذا التقرير مخصص للتبرعات العينية فقط.</div>
}
else
{
    <table class="table">
        <tbody>
            <tr>
                <th style="width:25%">عدد الأصناف</th>
                <td style="width:25%">@Model.Items.Count</td>
                <th style="width:25%">القيمة التقديرية</th>
                <td style="width:25%">@Model.EstimatedGrandTotal.ToString("N2")</td>
            </tr>
            <tr>
                <th>عدد أذون الإضافة</th>
                <td>@Model.StoreReceipts.Count</td>
                <th>عدد أذون الصرف المرتبطة</th>
                <td>@Model.StoreIssues.Count</td>
            </tr>
        </tbody>
    </table>

    <h4>الأصناف العينية</h4>
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>الكود</th>
                <th>الصنف</th>
                <th>المخزن</th>
                <th>الكمية</th>
                <th>الوارد للمخزن</th>
                <th>القيمة التقديرية</th>
                <th>الصلاحية</th>
                <th>التشغيلة</th>
            </tr>
        </thead>
        <tbody>
        @{ var idx = 1; }
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@idx</td>
                <td>@item.ItemCode</td>
                <td>@item.ItemName</td>
                <td>@(string.IsNullOrWhiteSpace(item.WarehouseName) ? "-" : item.WarehouseName)</td>
                <td>@item.Quantity.ToString("N2")</td>
                <td>@item.ReceivedQuantity.ToString("N2")</td>
                <td>@((item.EstimatedTotalValue ?? 0m).ToString("N2"))</td>
                <td>@(item.ExpiryDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                <td>@(string.IsNullOrWhiteSpace(item.BatchNo) ? "-" : item.BatchNo)</td>
            </tr>
            idx++;
        }
        </tbody>
    </table>

    <h4>أذون الإضافة المخزنية</h4>
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>رقم الإذن</th>
                <th>التاريخ</th>
                <th>المخزن</th>
                <th>المصدر</th>
                <th>عدد البنود</th>
                <th>الإجمالي</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.StoreReceipts.Count == 0)
        {
            <tr><td colspan="7" class="text-center">لا توجد أذون إضافة مرتبطة بهذا التبرع حتى الآن.</td></tr>
        }
        else
        {
            var idx2 = 1;
            foreach (var item in Model.StoreReceipts)
            {
                <tr>
                    <td>@idx2</td>
                    <td>@item.ReceiptNumber</td>
                    <td>@item.ReceiptDate.ToString("yyyy-MM-dd")</td>
                    <td>@(string.IsNullOrWhiteSpace(item.WarehouseName) ? "-" : item.WarehouseName)</td>
                    <td>@item.SourceType @(string.IsNullOrWhiteSpace(item.SourceName) ? string.Empty : $"- {item.SourceName}")</td>
                    <td>@item.LinesCount</td>
                    <td>@item.TotalAmount.ToString("N2")</td>
                </tr>
                idx2++;
            }
        }
        </tbody>
    </table>

    <h4>أذون الصرف المرتبطة</h4>
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>رقم الإذن</th>
                <th>التاريخ</th>
                <th>المخزن</th>
                <th>الجهة المصروف إليها</th>
                <th>عدد البنود</th>
                <th>الإجمالي</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.StoreIssues.Count == 0)
        {
            <tr><td colspan="7" class="text-center">لا توجد أذون صرف مرتبطة مباشرة بهذا التبرع حتى الآن.</td></tr>
        }
        else
        {
            var idx3 = 1;
            foreach (var item in Model.StoreIssues)
            {
                <tr>
                    <td>@idx3</td>
                    <td>@item.IssueNumber</td>
                    <td>@item.IssueDate.ToString("yyyy-MM-dd")</td>
                    <td>@(string.IsNullOrWhiteSpace(item.WarehouseName) ? "-" : item.WarehouseName)</td>
                    <td>@(string.IsNullOrWhiteSpace(item.DestinationName) ? "-" : item.DestinationName)</td>
                    <td>@item.LinesCount</td>
                    <td>@item.TotalAmount.ToString("N2")</td>
                </tr>
                idx3++;
            }
        }
        </tbody>
    </table>

    <table class="table mt-3">
        <tbody>
            <tr>
                <td class="text-center" style="height:80px; vertical-align:bottom;">إعداد</td>
                <td class="text-center" style="height:80px; vertical-align:bottom;">المراجعة</td>
                <td class="text-center" style="height:80px; vertical-align:bottom;">الاعتماد</td>
            </tr>
        </tbody>
    </table>
}

@model InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations.DonationReceiptPrintVm
@{
    Layout = null;
    var totalAmount = Model.IsInKind ? Model.EstimatedInKindTotal : (Model.Amount ?? 0m);
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>@Model.ReceiptTitle</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            padding: 0;
            background: #f5f5f5;
            color: #111827;
            font-family: Tahoma, Arial, sans-serif;
            line-height: 1.7;
        }
        .page {
            width: 210mm;
            min-height: 297mm;
            margin: 8mm auto;
            background: #fff;
            padding: 14mm;
            box-shadow: 0 0 10px rgba(0,0,0,.08);
        }
        .header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            border-bottom: 2px solid #0f172a;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }
        .header-title {
            font-size: 26px;
            font-weight: 700;
            margin: 0 0 4px 0;
        }
        .subtle { color: #475569; }
        .receipt-box {
            min-width: 210px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            padding: 10px 12px;
            background: #f8fafc;
        }
        .receipt-box h2 {
            margin: 0 0 8px 0;
            font-size: 20px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }
        .card {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px;
            background: #fff;
        }
        .card h3 {
            margin: 0 0 10px 0;
            font-size: 18px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 6px;
        }
        .meta { width: 100%; border-collapse: collapse; }
        .meta td {
            padding: 5px 0;
            vertical-align: top;
        }
        .meta td:first-child {
            width: 34%;
            color: #475569;
            font-weight: 700;
        }
        .summary {
            margin: 14px 0 18px;
            border: 2px dashed #94a3b8;
            border-radius: 10px;
            padding: 12px 16px;
            background: #f8fafc;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }
        .summary-title { font-size: 18px; font-weight: 700; }
        .summary-value { font-size: 28px; font-weight: 700; }
        table.items {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
        }
        .items th, .items td {
            border: 1px solid #cbd5e1;
            padding: 8px;
            text-align: right;
            vertical-align: top;
        }
        .items thead th {
            background: #e2e8f0;
            font-weight: 700;
        }
        .footer {
            margin-top: 28px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            align-items: end;
        }
        .signature {
            border-top: 1px solid #64748b;
            padding-top: 8px;
            text-align: center;
            min-height: 70px;
        }
        .no-print {
            position: fixed;
            left: 14px;
            bottom: 14px;
            display: flex;
            gap: 8px;
        }
        .no-print button {
            border: none;
            background: #0f172a;
            color: white;
            padding: 10px 16px;
            border-radius: 8px;
            cursor: pointer;
        }
        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 13px;
            background: #e2e8f0;
        }
        @@media print {
            body { background: #fff; }
            .page {
                width: 100%;
                min-height: auto;
                margin: 0;
                box-shadow: none;
                padding: 0;
            }
            .no-print { display: none; }
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="header">
            <div>
                <div class="header-title">@Model.CompanyNameAr</div>
                @if (!string.IsNullOrWhiteSpace(Model.ReceiptHeaderText))
                {
                    <div class="subtle">@Model.ReceiptHeaderText</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.CompanyAddress))
                {
                    <div class="subtle">العنوان: @Model.CompanyAddress</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.CompanyPhone))
                {
                    <div class="subtle">الهاتف: @Model.CompanyPhone</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.CompanyTaxNumber))
                {
                    <div class="subtle">الرقم الضريبي: @Model.CompanyTaxNumber</div>
                }
            </div>
            <div class="receipt-box">
                <h2>@Model.ReceiptTitle</h2>
                <div><strong>رقم الإيصال:</strong> @(string.IsNullOrWhiteSpace(Model.ReceiptNumber) ? "-" : Model.ReceiptNumber)</div>
                <div><strong>رقم التبرع:</strong> @Model.DonationNumber</div>
                <div><strong>التاريخ:</strong> @Model.DonationDate.ToString("yyyy-MM-dd")</div>
                <div><strong>النوع:</strong> @Model.DonationType</div>
            </div>
        </div>

        <div class="grid">
            <div class="card">
                <h3>بيانات المتبرع</h3>
                <table class="meta">
                    <tr><td>اسم المتبرع</td><td>@Model.DonorName</td></tr>
                    <tr><td>كود المتبرع</td><td>@(string.IsNullOrWhiteSpace(Model.DonorCode) ? "-" : Model.DonorCode)</td></tr>
                    <tr><td>نوع المتبرع</td><td>@(string.IsNullOrWhiteSpace(Model.DonorType) ? "-" : Model.DonorType)</td></tr>
                    <tr><td>جهة الاتصال</td><td>@(string.IsNullOrWhiteSpace(Model.ContactPerson) ? "-" : Model.ContactPerson)</td></tr>
                    <tr><td>رقم الهاتف</td><td>@(string.IsNullOrWhiteSpace(Model.DonorPhoneNumber) ? "-" : Model.DonorPhoneNumber)</td></tr>
                    <tr><td>العنوان</td><td>@(string.IsNullOrWhiteSpace(Model.DonorAddress) ? "-" : Model.DonorAddress)</td></tr>
                </table>
            </div>
            <div class="card">
                <h3>بيانات التبرع</h3>
                <table class="meta">
                    <tr><td>نوع المساعدة المستهدف</td><td>@(string.IsNullOrWhiteSpace(Model.AidTypeName) ? "-" : Model.AidTypeName)</td></tr>
                    <tr><td>طريقة الدفع</td><td>@(string.IsNullOrWhiteSpace(Model.PaymentMethodName) ? "-" : Model.PaymentMethodName)</td></tr>
                    <tr><td>الحساب المالي</td><td>@(string.IsNullOrWhiteSpace(Model.FinancialAccountName) ? "-" : Model.FinancialAccountName)</td></tr>
                    <tr><td>تبرع مخصص</td><td>@(Model.IsRestricted ? "نعم" : "لا")</td></tr>
                    <tr><td>اسم الحملة</td><td>@(string.IsNullOrWhiteSpace(Model.CampaignName) ? "-" : Model.CampaignName)</td></tr>
                    <tr><td>الرقم المرجعي</td><td>@(string.IsNullOrWhiteSpace(Model.ReferenceNumber) ? "-" : Model.ReferenceNumber)</td></tr>
                </table>
            </div>
        </div>

        <div class="summary">
            <div>
                <div class="summary-title">القيمة الإجمالية للتبرع</div>
                <div class="subtle">@(Model.IsInKind ? "إجمالي القيمة التقديرية للأصناف العينية" : "إجمالي المبلغ النقدي المستلم")</div>
            </div>
            <div class="summary-value">@totalAmount.ToString("N2")</div>
        </div>

        @if (Model.IsInKind)
        {
            <div class="card">
                <h3>الأصناف العينية</h3>
                <table class="items">
                    <thead>
                        <tr>
                            <th style="width:24%">الصنف</th>
                            <th style="width:10%">الكمية</th>
                            <th style="width:14%">القيمة التقديرية للوحدة</th>
                            <th style="width:14%">الإجمالي التقديري</th>
                            <th style="width:12%">المخزن</th>
                            <th style="width:10%">الصلاحية</th>
                            <th style="width:8%">التشغيلة</th>
                            <th>ملاحظات</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.InKindItems.Any())
                    {
                        foreach (var line in Model.InKindItems)
                        {
                            <tr>
                                <td>@line.ItemName</td>
                                <td>@line.Quantity.ToString("N2")</td>
                                <td>@(line.EstimatedUnitValue?.ToString("N2") ?? "-")</td>
                                <td>@(line.EstimatedTotalValue?.ToString("N2") ?? "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(line.WarehouseName) ? "-" : line.WarehouseName)</td>
                                <td>@(line.ExpiryDate.HasValue ? line.ExpiryDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(line.BatchNo) ? "-" : line.BatchNo)</td>
                                <td>@(string.IsNullOrWhiteSpace(line.Notes) ? "-" : line.Notes)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" style="text-align:center">لا توجد أصناف عينية مسجلة على هذا التبرع حتى الآن.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="card" style="margin-top:16px;">
                <h3>ملاحظات</h3>
                <div>@Model.Notes</div>
            </div>
        }

        <div class="footer">
            <div class="signature">توقيع المستلم / الموظف المختص</div>
            <div class="signature">توقيع المتبرع / الختم</div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ReceiptFooterText))
        {
            <div style="margin-top:18px; text-align:center; color:#475569;">@Model.ReceiptFooterText</div>
        }
    </div>

    <div class="no-print">
        <button type="button" onclick="window.print()">طباعة</button>
        <button type="button" onclick="window.close()">إغلاق</button>
    </div>

    <script>
        window.onload = function() {
            setTimeout(function() { window.print(); }, 400);
        };
    </script>
</body>
</html>

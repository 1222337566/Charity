@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile.Donations
@model CreateDonationVm
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isEdit = string.Equals(currentAction, "Edit", StringComparison.OrdinalIgnoreCase);
}
<input type="hidden" asp-for="DonorId" />
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-3">
        <label asp-for="DonationNumber" class="form-label"></label>
        <input asp-for="DonationNumber" class="form-control" />
        <span asp-validation-for="DonationNumber" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="DonationDate" class="form-label"></label>
        <input asp-for="DonationDate" type="date" class="form-control" />
        <span asp-validation-for="DonationDate" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="DonationType" class="form-label"></label>
        <select asp-for="DonationType" asp-items="Model.DonationTypes" class="form-select"></select>
        <span asp-validation-for="DonationType" class="text-danger"></span>
    </div>
    <div class="col-md-3 donation-cash-only">
        <label asp-for="TargetingScopeCode" class="form-label"></label>
        <select asp-for="TargetingScopeCode" asp-items="Model.TargetingScopes" class="form-select" id="targeting-scope"></select>
        <span asp-validation-for="TargetingScopeCode" class="text-danger"></span>
    </div>
    <div class="col-md-3 scope-specific">
        <label asp-for="AidTypeId" class="form-label"></label>
        <select asp-for="AidTypeId" asp-items="Model.AidTypes" class="form-select">
            <option value="">-- اختر نوع المساعدة --</option>
        </select>
        <span asp-validation-for="AidTypeId" class="text-danger"></span>
    </div>
    <div class="col-md-3 scope-general-purpose donation-cash-only">
        <label asp-for="GeneralPurposeName" class="form-label"></label>
        <input asp-for="GeneralPurposeName" class="form-control" placeholder="مثال: زكاة الفطر / شنطة رمضان" />
        <span asp-validation-for="GeneralPurposeName" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    <div class="col-md-4 donation-cash-only">
        <label asp-for="PaymentMethodId" class="form-label"></label>
        <select asp-for="PaymentMethodId" asp-items="Model.PaymentMethods" class="form-select">
            <option value="">-- اختر --</option>
        </select>
    </div>
    <div class="col-md-4 donation-cash-only">
        <label asp-for="FinancialAccountId" class="form-label"></label>
        <select asp-for="FinancialAccountId" asp-items="Model.FinancialAccounts" class="form-select">
            <option value="">-- اختر --</option>
        </select>
    </div>
    <div class="col-md-4 d-none">
        <div class="form-check">
            <input asp-for="IsRestricted" class="form-check-input" />
            <label asp-for="IsRestricted" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-md-4 d-none">
        <label asp-for="CampaignName" class="form-label"></label>
        <input asp-for="CampaignName" class="form-control" />
    </div>

    @if (!isEdit)
    {
        <div class="col-12 donation-inkind-only">
            <div class="border rounded p-3 bg-light-subtle">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">بيانات التبرع العيني</h5>
                    <span class="badge bg-info">الصنف والكمية والوصف إلزامية للتبرع العيني</span>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="InKindItemId" class="form-label"></label>
                        <select asp-for="InKindItemId" asp-items="Model.Items" class="form-select">
                            <option value="">-- اختر الصنف --</option>
                        </select>
                        <span asp-validation-for="InKindItemId" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="InKindQuantity" class="form-label"></label>
                        <input asp-for="InKindQuantity" class="form-control" />
                        <span asp-validation-for="InKindQuantity" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="InKindWarehouseId" class="form-label"></label>
                        <select asp-for="InKindWarehouseId" asp-items="Model.Warehouses" class="form-select">
                            <option value="">-- اختر المخزن --</option>
                        </select>
                        <span asp-validation-for="InKindWarehouseId" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="InKindEstimatedUnitValue" class="form-label"></label>
                        <input asp-for="InKindEstimatedUnitValue" class="form-control" />
                        <span asp-validation-for="InKindEstimatedUnitValue" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="InKindEstimatedTotalValue" class="form-label"></label>
                        <input asp-for="InKindEstimatedTotalValue" class="form-control" />
                        <span asp-validation-for="InKindEstimatedTotalValue" class="text-danger"></span>
                    </div>
                    <div class="col-md-9">
                        <label asp-for="InKindItemDescription" class="form-label"></label>
                        <input asp-for="InKindItemDescription" class="form-control" placeholder="مثال: بطاطين شتوية مقاس كبير / ملابس أطفال / شنط غذائية كاملة" />
                        <span asp-validation-for="InKindItemDescription" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="col-md-4">
        <label asp-for="ReceiptNumber" class="form-label"></label>
        <input asp-for="ReceiptNumber" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="ReferenceNumber" class="form-label"></label>
        <input asp-for="ReferenceNumber" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
    </div>
</div>

<script>
    (function () {
        const generalFundScope = 'GeneralFund';

        function isInKindDonation() {
            const type = document.getElementById('DonationType')?.value || '';
            return type.trim() === 'عيني';
        }

        function setDisplay(selector, visible) {
            document.querySelectorAll(selector).forEach(el => {
                el.style.display = visible ? '' : 'none';
            });
        }

        function updateScopeUi() {
            const inKind = isInKindDonation();
            const scopeElement = document.getElementById('targeting-scope');
            const scope = inKind ? generalFundScope : (scopeElement?.value || '');

            if (inKind && scopeElement) {
                scopeElement.value = generalFundScope;
            }

            setDisplay('.donation-cash-only', !inKind);
            setDisplay('.donation-inkind-only', inKind);
            setDisplay('.scope-specific', inKind || scope === 'SpecificRequests');
            setDisplay('.scope-general-purpose', !inKind && scope === 'GeneralPurpose');
        }

        function updateInKindTotals() {
            if (!isInKindDonation()) return;

            const quantity = parseFloat(document.getElementById('InKindQuantity')?.value || '0') || 0;
            const unitValue = parseFloat(document.getElementById('InKindEstimatedUnitValue')?.value || '0') || 0;
            const totalInput = document.getElementById('InKindEstimatedTotalValue');
            const amountInput = document.getElementById('Amount');
            const total = quantity * unitValue;

            if (total > 0 && totalInput && !totalInput.value) {
                totalInput.value = total.toFixed(2);
            }

            if (totalInput && amountInput) {
                amountInput.value = totalInput.value || (total > 0 ? total.toFixed(2) : amountInput.value);
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const donationType = document.getElementById('DonationType');
            const scope = document.getElementById('targeting-scope');
            const quantity = document.getElementById('InKindQuantity');
            const unitValue = document.getElementById('InKindEstimatedUnitValue');
            const total = document.getElementById('InKindEstimatedTotalValue');

            if (donationType) donationType.addEventListener('change', updateScopeUi);
            if (scope) scope.addEventListener('change', updateScopeUi);
            if (quantity) quantity.addEventListener('input', updateInKindTotals);
            if (unitValue) unitValue.addEventListener('input', updateInKindTotals);
            if (total) total.addEventListener('input', updateInKindTotals);

            updateScopeUi();
            updateInKindTotals();
        });
    })();
</script>

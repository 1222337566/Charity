@model InfrastructureManagmentWebFramework.Models.Charity.Donors.CreateDonorVm
@{
    ViewData["Title"] = "إضافة متبرع";
}
<div class="page-content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header"><h4 class="card-title mb-0">إضافة متبرع</h4></div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.Partial("_Form", Model)
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">حفظ</button>
                        <a asp-action="Index" class="btn btn-secondary">رجوع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model InfrastructureManagmentWebFramework.Models.Charity.Donors.DonorDetailsVm
@{
    ViewData["Title"] = "تفاصيل المتبرع";
}
<div class="page-content">
    <div class="container-fluid">
        <div class="card mb-3">
            <div class="card-body d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h4 class="mb-1">@Model.FullName</h4>
                    <div class="text-muted">@Model.DonorType - @Model.Code</div>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">تعديل</a>
                    <a asp-controller="Donations" asp-action="Index" asp-route-donorId="@Model.Id" class="btn btn-success">إدارة التبرعات</a>
                    <a asp-action="Index" class="btn btn-light">رجوع</a>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">عدد التبرعات</div><h4 class="mb-0">@Model.DonationsCount</h4></div></div></div>
            <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">إجمالي القيمة</div><h4 class="mb-0">@Model.TotalDonationsAmount.ToString("N2")</h4></div></div></div>
            <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">الحالة</div><h4 class="mb-0">@(Model.IsActive ? "نشط" : "غير نشط")</h4></div></div></div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header"><h5 class="mb-0">البيانات الأساسية</h5></div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tr><th style="width: 180px;">الكود</th><td>@Model.Code</td></tr>
                            <tr><th>نوع المتبرع</th><td>@Model.DonorType</td></tr>
                            <tr><th>مسؤول التواصل</th><td>@Model.ContactPerson</td></tr>
                            <tr><th>الرقم القومي / الضريبي</th><td>@Model.NationalIdOrTaxNo</td></tr>
                            <tr><th>الهاتف</th><td>@Model.PhoneNumber</td></tr>
                            <tr><th>البريد الإلكتروني</th><td>@Model.Email</td></tr>
                            <tr><th>وسيلة التواصل</th><td>@Model.PreferredCommunicationMethod</td></tr>
                            <tr><th>تاريخ الإنشاء</th><td>@Model.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td></tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header"><h5 class="mb-0">العنوان والملاحظات</h5></div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tr><th style="width: 180px;">المحافظة</th><td>@Model.GovernorateName</td></tr>
                            <tr><th>المدينة / المركز</th><td>@Model.CityName</td></tr>
                            <tr><th>المنطقة / القرية</th><td>@Model.AreaName</td></tr>
                            <tr><th>العنوان</th><td>@Model.AddressLine</td></tr>
                            <tr><th>ملاحظات</th><td>@Model.Notes</td></tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">آخر التبرعات</h5>
                <a asp-controller="Donations" asp-action="Create" asp-route-donorId="@Model.Id" class="btn btn-sm btn-success">تسجيل تبرع</a>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>رقم التبرع</th>
                            <th>التاريخ</th>
                            <th>النوع</th>
                            <th>القيمة</th>
                            <th>الإيصال</th>
                            <th>طريقة الدفع</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.RecentDonations)
                    {
                        <tr>
                            <td>@item.DonationNumber</td>
                            <td>@item.DonationDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.DonationType</td>
                            <td>@item.Amount?.ToString("N2")</td>
                            <td>@item.ReceiptNumber</td>
                            <td>@item.PaymentMethod</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

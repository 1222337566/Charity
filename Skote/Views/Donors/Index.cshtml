@model InfrastructureManagmentWebFramework.Models.Charity.Donors.DonorListPageVm
@using Skote.Helpers
@{
    ViewData["Title"] = "المتبرعون";
    string TypeColor(string t) => t switch {
        "شركة" => "#556ee6", "مؤسسة" => "#34c38f", "جهة مانحة" => "#f1b44c",
        "فاعل خير" => "#e83e8c", _ => "#0e6f73"};
    string TypeIcon(string t) => t switch {
        "شركة" => "bx-buildings", "مؤسسة" => "bx-building-house",
        "جهة مانحة" => "bx-dollar-circle", "فاعل خير" => "bx-heart",
        _ => "bx-user"};
}
<style>
:root{--teal:#0e6f73;--teal-l:#e1f5f5;--ink:#1e3a5f;--muted:#6b7d80}
.dn-hero{background:linear-gradient(135deg,#1a3c5e,#0e6f73);border-radius:20px;padding:22px 28px;color:#fff;margin-bottom:20px;position:relative;overflow:hidden}
.dn-hero::after{content:'';position:absolute;top:-50px;left:-50px;width:200px;height:200px;background:rgba(255,255,255,.04);border-radius:50%;pointer-events:none}
.dn-stat{background:rgba(255,255,255,.13);border-radius:14px;padding:12px 18px;text-align:center;flex:1;min-width:100px}
.dn-stat .n{font-size:1.4rem;font-weight:800;line-height:1}
.dn-stat .l{font-size:.68rem;opacity:.8;margin-top:3px}
.filter-strip{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.12);padding:14px 18px;margin-bottom:16px}
.dn-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px}
.dn-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 12px rgba(14,111,115,.06);overflow:hidden;transition:box-shadow .2s,transform .15s;display:flex;flex-direction:column}
.dn-card:hover{box-shadow:0 6px 24px rgba(14,111,115,.13);transform:translateY(-2px)}
.dn-card-top{padding:16px 18px;flex:1}
.dn-card-foot{padding:11px 18px;background:#f8fbfb;border-top:.5px solid rgba(14,111,115,.07);display:flex;align-items:center;justify-content:space-between;gap:8px}
.dn-avatar{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.dn-code{font-size:.68rem;font-weight:700;color:var(--teal);background:var(--teal-l);padding:2px 8px;border-radius:6px}
.dn-name{font-weight:700;font-size:.93rem;color:var(--ink);margin:.3rem 0 .15rem}
.dn-meta{font-size:.75rem;color:var(--muted)}
.dn-amount{font-size:.88rem;font-weight:800;color:var(--teal)}
.type-badge{padding:3px 10px;border-radius:20px;font-size:.68rem;font-weight:700;color:#fff}
.dn-table{width:100%;border-collapse:collapse;font-size:.84rem}
.dn-table th{padding:10px 14px;font-size:.73rem;font-weight:700;color:var(--muted);background:#f4f9f9;text-align:right;border-bottom:.5px solid rgba(14,111,115,.12);white-space:nowrap}
.dn-table td{padding:11px 14px;border-bottom:.5px solid rgba(14,111,115,.05);vertical-align:middle}
.dn-table tr:hover td{background:rgba(14,111,115,.02)}
.view-btn{width:32px;height:32px;border:1px solid rgba(14,111,115,.18);background:#fff;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all .2s}
.view-btn.active{background:var(--teal);color:#fff;border-color:var(--teal)}
.empty-dn{padding:56px;text-align:center;color:var(--muted)}
.empty-dn i{font-size:2.8rem;opacity:.3;display:block;margin-bottom:10px}
</style>
<div class="dn-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h4 class="mb-1 fw-bold">المتبرعون</h4>
            <p class="mb-0" style="opacity:.8;font-size:.88rem">قاعدة بيانات المتبرعين وتتبع إجمالي تبرعاتهم</p>
        </div>
        <authz policy="DonorsManage">
            <a asp-action="Create" class="btn btn-light fw-semibold" style="border-radius:10px">
                <i class="bx bx-plus me-1"></i>متبرع جديد
            </a>
        </authz>
    </div>
    <div class="d-flex flex-wrap gap-3 mt-4">
        <div class="dn-stat"><div class="n">@Model.TotalCount</div><div class="l">إجمالي المتبرعين</div></div>
        <div class="dn-stat"><div class="n">@Model.ActiveCount</div><div class="l">المتبرعون النشطون</div></div>
        <div class="dn-stat"><div class="n">@Model.TotalDonations.ToString("N0")</div><div class="l">إجمالي التبرعات</div></div>
        <div class="dn-stat"><div class="n">@Model.Rows.Count(x=>x.DonorType=="شركة")</div><div class="l">شركات</div></div>
    </div>
</div>
<div class="filter-strip">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label small text-muted mb-1">بحث</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text" style="background:#f4f9f9;border-color:rgba(14,111,115,.18)"><i class="bx bx-search text-muted"></i></span>
                <input asp-for="Filter.Q" name="q" class="form-control form-control-sm" placeholder="اسم، كود، هاتف..." style="border-color:rgba(14,111,115,.18)"/>
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">نوع المتبرع</label>
            <select asp-for="Filter.DonorType" name="donorType" asp-items="Model.Filter.DonorTypes" class="form-select form-select-sm" style="border-color:rgba(14,111,115,.18)">
                <option value="">الكل</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">الحالة</label>
            <select asp-for="Filter.IsActive" name="isActive" class="form-select form-select-sm" style="border-color:rgba(14,111,115,.18)">
                <option value="">الكل</option><option value="true">نشط</option><option value="false">غير نشط</option>
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button class="btn btn-sm fw-semibold flex-fill" style="background:var(--teal);color:#fff;border-radius:8px">بحث</button>
            <a asp-action="Index" class="btn btn-sm btn-light" style="border-radius:8px"><i class="bx bx-reset"></i></a>
        </div>
        <div class="col-md-1 d-flex justify-content-end gap-1">
            <button type="button" class="view-btn active" id="btnGrid"><i class="bx bx-grid-alt"></i></button>
            <button type="button" class="view-btn" id="btnTable"><i class="bx bx-list-ul"></i></button>
        </div>
    </form>
</div>
@if (TempData["Success"] != null){
    <div class="alert alert-success alert-dismissible fade show mb-3">@TempData["Success"]<button class="btn-close" data-bs-dismiss="alert"></button></div>
}
<div id="viewGrid">
@if (!Model.Rows.Any()){
    <div class="empty-dn"><i class="bx bx-heart"></i><p>لا يوجد متبرعون مطابقون للبحث</p></div>
}else{
    <div class="dn-grid">
    @foreach(var item in Model.Rows){
        var tc=TypeColor(item.DonorType);
        var ti=TypeIcon(item.DonorType);
        var initials=string.Join("",item.FullName.Split(' ').Take(2).Select(w=>w.Length>0?w[0].ToString():""));
        <div class="dn-card">
            <div class="dn-card-top">
                <div class="d-flex align-items-start gap-3">
                    <div class="dn-avatar" style="background:@tc+22;color:@tc">
                        <i class="bx @ti"></i>
                    </div>
                    <div class="flex-1">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="dn-code">@item.Code</span>
                            <span class="type-badge" style="background:@tc">@item.DonorType</span>
                            @if(!item.IsActive){<span class="badge bg-secondary" style="font-size:.62rem">غير نشط</span>}
                        </div>
                        <div class="dn-name">@item.FullName</div>
                        <div class="dn-meta">
                            @if(!string.IsNullOrEmpty(item.PhoneNumber)){<span><i class="bx bx-phone me-1"></i>@item.PhoneNumber</span>}
                            @if(!string.IsNullOrEmpty(item.GovernorateName)){<span class="ms-2"><i class="bx bx-map me-1"></i>@item.GovernorateName</span>}
                        </div>
                        @if(!string.IsNullOrEmpty(item.ContactPerson)){
                            <div class="dn-meta mt-1"><i class="bx bx-user-voice me-1"></i>@item.ContactPerson</div>
                        }
                    </div>
                </div>
            </div>
            <div class="dn-card-foot">
                <div>
                    <div style="font-size:.67rem;color:var(--muted)">إجمالي التبرعات</div>
                    <div class="dn-amount">@item.TotalDonations.ToString("N0")</div>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm fw-semibold" style="background:var(--teal-l);color:var(--teal);border-radius:8px"><i class="bx bx-show me-1"></i>عرض</a>
                    <a asp-controller="Donations" asp-action="Index" asp-route-donorId="@item.Id" class="btn btn-sm" style="background:rgba(52,195,143,.1);color:#1a7a55;border-radius:8px"><i class="bx bx-gift"></i></a>
                    <authz policy="DonorsManage"><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light" style="border-radius:8px"><i class="bx bx-edit-alt"></i></a></authz>
                </div>
            </div>
        </div>
    }
    </div>
}
</div>
<div id="viewTable" style="display:none">
    <div class="card" style="border-radius:14px;border:.5px solid rgba(14,111,115,.1);overflow:hidden">
        <div class="table-responsive">
            <table class="dn-table">
                <thead><tr><th>الكود</th><th>النوع</th><th>الاسم</th><th>مسؤول التواصل</th><th>الهاتف</th><th>المحافظة</th><th>إجمالي التبرعات</th><th>الحالة</th><th style="width:130px"></th></tr></thead>
                <tbody>
                @foreach(var item in Model.Rows){
                    <tr>
                        <td><span class="dn-code">@item.Code</span></td>
                        <td><span class="type-badge" style="background:@TypeColor(item.DonorType)">@item.DonorType</span></td>
                        <td class="fw-semibold" style="color:var(--ink)">@item.FullName</td>
                        <td class="text-muted">@(item.ContactPerson??"—")</td>
                        <td class="text-muted">@(item.PhoneNumber??"—")</td>
                        <td class="text-muted">@(item.GovernorateName??"—")</td>
                        <td class="fw-semibold" style="color:var(--teal)">@item.TotalDonations.ToString("N0")</td>
                        <td>@(item.IsActive?"<span class='badge bg-success-subtle text-success'>نشط</span>":"<span class='badge bg-secondary-subtle text-secondary'>غير نشط</span>")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm" style="background:var(--teal-l);color:var(--teal);border-radius:7px">عرض</a>
                            <a asp-controller="Donations" asp-action="Index" asp-route-donorId="@item.Id" class="btn btn-sm btn-light" style="border-radius:7px">التبرعات</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
<script>
const g=document.getElementById('viewGrid'),t=document.getElementById('viewTable');
document.getElementById('btnGrid').addEventListener('click',function(){g.style.display='';t.style.display='none';this.classList.add('active');document.getElementById('btnTable').classList.remove('active');localStorage.setItem('dn_view','grid');});
document.getElementById('btnTable').addEventListener('click',function(){t.style.display='';g.style.display='none';this.classList.add('active');document.getElementById('btnGrid').classList.remove('active');localStorage.setItem('dn_view','table');});
if(localStorage.getItem('dn_view')==='table')document.getElementById('btnTable').click();
</script>
}

@model InfrastructureManagmentWebFramework.Models.Payroll.EmployeeStructures.CreateEmployeeSalaryStructureVm
@using InfrastructureManagmentWebFramework.Models.HR.EmployeeProfile
@{ var header = ViewBag.EmployeeHeader as EmployeeHeaderVm; ViewData["Title"] = "إضافة بند للمرتب"; }
@if (header != null)
{
    <partial name="~/Views/Shared/HR/_EmployeeHeader.cshtml" model="header" />
}
<h4 class="mb-3">إضافة بند للمرتب</h4>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <partial name="_Form" model="Model" />
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">حفظ</button>
        <a asp-action="Index" asp-route-employeeId="@Model.EmployeeId" class="btn btn-light">رجوع</a>
    </div>
</form>

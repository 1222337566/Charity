@model List<InfrastructureManagmentWebFramework.Models.Payroll.EmployeeStructures.EmployeeSalaryStructureListItemVm>
@using InfrastructureManagmentWebFramework.Models.HR.EmployeeProfile
@{
    var header = ViewBag.EmployeeHeader as EmployeeHeaderVm;
    ViewData["Title"] = "هيكل مرتب الموظف";
}
@if (header != null)
{
    <partial name="~/Views/Shared/HR/_EmployeeHeader.cshtml" model="header" />
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">هيكل المرتب</h4>
    <a asp-action="Create" asp-route-employeeId="@header?.Id" class="btn btn-primary">إضافة بند</a>
</div>
<table class="table table-bordered table-striped align-middle">
    <thead><tr><th>البند</th><th>النوع</th><th>القيمة</th><th>من</th><th>إلى</th><th>نشط</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.SalaryItemName</td>
            <td>@item.ItemType</td>
            <td>@item.Value.ToString("N2")</td>
            <td>@item.FromDate.ToString("yyyy-MM-dd")</td>
            <td>@(item.ToDate?.ToString("yyyy-MM-dd") ?? "-")</td>
            <td>@(item.IsActive ? "نعم" : "لا")</td>
            <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">تعديل</a></td>
        </tr>
    }
    </tbody>
</table>

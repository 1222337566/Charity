@model CreateExpenseCategoryVm
@using InfrastructureManagmentWebFramework.Models.Expenses

@{
    ViewData["Title"] = "إضافة تصنيف مصروف";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header"><h4 class="mb-0">إضافة تصنيف مصروف</h4></div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="CategoryCode" class="form-label"></label>
                        <input asp-for="CategoryCode" class="form-control" />
                    </div>
                    <div class="col-md-8 mb-3">
                        <label asp-for="CategoryNameAr" class="form-label"></label>
                        <input asp-for="CategoryNameAr" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryNameEn" class="form-label"></label>
                        <input asp-for="CategoryNameEn" class="form-control" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">حفظ</button>
                <a asp-action="Index" class="btn btn-secondary">رجوع</a>
            </form>
        </div>
    </div>
</div>
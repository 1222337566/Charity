@model List<ExpenseCategoryListItemVm>
@using InfrastructureManagmentWebFramework.Models.Expenses

@{
    ViewData["Title"] = "تصنيفات المصروفات";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">تصنيفات المصروفات</h4>
            <a asp-action="Create" class="btn btn-primary btn-sm">إضافة تصنيف</a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                    <div class="alert alert-success">@TempData["Success"]</div>
            }

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>الحالة</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                            <tr>
                                <td>@item.CategoryCode</td>
                                <td>@item.CategoryNameAr</td>
                                <td>@(item.IsActive ? "نشط" : "غير نشط")</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">تعديل</a>
                                </td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
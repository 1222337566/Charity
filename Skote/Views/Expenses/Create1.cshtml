@model List<ExpenseListItemVm>
@using InfrastructureManagmentWebFramework.Models.Expenses

@{
    ViewData["Title"] = "المصروفات";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">المصروفات</h4>
            <a asp-action="Create" class="btn btn-primary btn-sm">تسجيل مصروف</a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>رقم المصروف</th>
                        <th>التاريخ</th>
                        <th>التصنيف</th>
                        <th>البيان</th>
                        <th>طريقة الدفع</th>
                        <th>المبلغ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ExpenseNumber</td>
                            <td>@item.ExpenseDateUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td>@item.CategoryName</td>
                            <td>@item.Description</td>
                            <td>@(item.PaymentMethodName ?? "-")</td>
                            <td>@item.Amount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@using InfrastructureManagmentWebFramework.Models.FinancialAccounting;
@model CreateAccountVm

@{
    ViewData["Title"] = "إضافة حساب جديد";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h4 class="mb-0">إضافة حساب جديد</h4>
            <a asp-action="Index" class="btn btn-outline-secondary">رجوع إلى دليل الحسابات</a>
        </div>
        <div class="card-body">
            <div class="alert alert-info">
                اترك الحساب الأب فارغًا إذا كنت تريد إنشاء <strong>حساب رئيسي</strong>، وفي هذه الحالة اختر فئة الحساب الرئيسية.
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="AccountCode" class="form-label"></label>
                        <input asp-for="AccountCode" class="form-control" />
                        <span asp-validation-for="AccountCode" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 mb-3">
                        <label asp-for="AccountNameAr" class="form-label"></label>
                        <input asp-for="AccountNameAr" class="form-control" />
                        <span asp-validation-for="AccountNameAr" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="AccountNameEn" class="form-label"></label>
                        <input asp-for="AccountNameEn" class="form-control" />
                        <span asp-validation-for="AccountNameEn" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ParentAccountId" class="form-label"></label>
                        <select asp-for="ParentAccountId" asp-items="Model.ParentAccounts" class="form-select">
                            <option value="">-- بدون حساب أب (حساب رئيسي) --</option>
                        </select>
                        <span asp-validation-for="ParentAccountId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Category" class="form-label"></label>
                        <select asp-for="Category" asp-items="Model.Categories" class="form-select">
                            <option value="">-- اختر الفئة عند إنشاء حساب رئيسي --</option>
                        </select>
                        <div class="form-text">هذه القيمة تُستخدم فقط إذا كان الحساب بدون أب. أما الحسابات الفرعية فترث الفئة من الحساب الأب.</div>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="IsPosting" class="form-check-input" />
                            <label asp-for="IsPosting" class="form-check-label"></label>
                            <div class="form-text">عند إنشاء حساب رئيسي سيبقى الحساب تجميعيًا حتى لو تم تحديد هذا الخيار.</div>
                        </div>
                    </div>

                    <div class="col-md-4 mb-3 form-check">
                        <input asp-for="RequiresProject" class="form-check-input" />
                        <label asp-for="RequiresProject" class="form-check-label"></label>
                    </div>

                    <div class="col-md-4 mb-3 form-check">
                        <input asp-for="RequiresCostCenter" class="form-check-input" />
                        <label asp-for="RequiresCostCenter" class="form-check-label"></label>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="CashKind" class="form-label"></label>
                        <select asp-for="CashKind" asp-items="Model.CashKinds" class="form-select"></select>
                        <div class="form-text">استخدمها فقط لحسابات الخزينة والبنوك الحركية.</div>
                        <span asp-validation-for="CashKind" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3 form-check">
                        <input asp-for="AllowNegativeCashBalance" class="form-check-input" />
                        <label asp-for="AllowNegativeCashBalance" class="form-check-label"></label>
                        <div class="form-text">يفضل تركها غير مفعلة لتطبيق رقابة الرصيد.</div>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">حفظ</button>
                    <a asp-action="Index" class="btn btn-secondary">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

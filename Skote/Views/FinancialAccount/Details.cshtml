@using InfrastructureManagmentWebFramework.Models.FinancialAccounting
@model AccountDetailsVm

@{
    ViewData["Title"] = "تفاصيل الحساب";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h4 class="mb-1">تفاصيل الحساب</h4>
            <div class="text-muted">@Model.AccountCode - @Model.AccountNameAr</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Index" class="btn btn-light">الرجوع للدليل</a>
            <a asp-controller="AccountingReports"
               asp-action="AccountStatement"
               asp-route-accountId="@Model.Id"
               asp-route-fiscalPeriodId="@Model.FiscalPeriodId"
               asp-route-fromDate="@(Model.FromDate?.ToString("yyyy-MM-dd"))"
               asp-route-toDate="@(Model.ToDate?.ToString("yyyy-MM-dd"))"
               class="btn btn-outline-primary">
                فتح كشف الحساب
            </a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-lg-3 col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">كود الحساب</div>
                    <div class="fw-bold">@Model.AccountCode</div>
                    <div class="text-muted small mt-3">الفئة</div>
                    <div>@Model.Category</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">نوع الحساب</div>
                    <div>
                        @if (Model.IsPosting)
                        {
                            <span class="badge bg-success">حركي</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">تجميعي</span>
                        }
                    </div>
                    <div class="text-muted small mt-3">الحالة</div>
                    <div>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-primary">نشط</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">معطل</span>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">المستوى</div>
                    <div class="fw-bold">@Model.Level</div>
                    <div class="text-muted small mt-3">الحساب الأب</div>
                    <div>@(string.IsNullOrWhiteSpace(Model.ParentAccountDisplay) ? "-" : Model.ParentAccountDisplay)</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">متطلبات الربط</div>
                    <div class="d-flex flex-column gap-2 mt-2">
                        <span class="badge @(Model.RequiresProject ? "bg-warning text-dark" : "bg-light text-dark")">
                            مشروع: @(Model.RequiresProject ? "مطلوب" : "غير مطلوب")
                        </span>
                        <span class="badge @(Model.RequiresCostCenter ? "bg-info text-dark" : "bg-light text-dark")">
                            مركز تكلفة: @(Model.RequiresCostCenter ? "مطلوب" : "غير مطلوب")
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><h5 class="mb-0">فلاتر الأرصدة والحركات</h5></div>
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="col-md-4">
                    <label class="form-label">الفترة المالية</label>
                    <select asp-for="FiscalPeriodId" asp-items="Model.FiscalPeriods" class="form-select">
                        <option value="">الكل</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">من تاريخ</label>
                    <input asp-for="FromDate" type="date" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">إلى تاريخ</label>
                    <input asp-for="ToDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.IsPosting)
    {
        <div class="alert alert-info">
            هذا الحساب <strong>تجميعي</strong>. تفاصيل الحركات المباشرة تظهر عادة للحسابات الحركية فقط، لكن يمكنك استخدامه كمرجع بنيوي داخل دليل الحسابات.
        </div>
    }

    @if (Model.Statement != null)
    {
        <div class="row g-3 mb-3">
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-start border-4 border-primary">
                    <div class="card-body">
                        <div class="text-muted small">الرصيد الافتتاحي</div>
                        <div class="fs-5 fw-bold">@Model.Statement.OpeningBalance.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-start border-4 border-success">
                    <div class="card-body">
                        <div class="text-muted small">إجمالي المدين</div>
                        <div class="fs-5 fw-bold">@Model.Statement.TotalDebit.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-start border-4 border-danger">
                    <div class="card-body">
                        <div class="text-muted small">إجمالي الدائن</div>
                        <div class="fs-5 fw-bold">@Model.Statement.TotalCredit.ToString("N2")</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-start border-4 border-dark">
                    <div class="card-body">
                        <div class="text-muted small">الرصيد الختامي</div>
                        <div class="fs-5 fw-bold">@Math.Abs(Model.Statement.ClosingBalance).ToString("N2")</div>
                        <div class="text-muted small">طبيعة الرصيد: @Model.ClosingBalanceNature</div>
                        <div class="text-muted small">عدد الحركات: @Model.MovementCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0">حركات الحساب</h5>
                <div class="text-muted small">
                    الفترة: @(Model.FromDate?.ToString("yyyy-MM-dd") ?? "بداية البيانات")
                    — @(Model.ToDate?.ToString("yyyy-MM-dd") ?? "حتى آخر البيانات")
                </div>
            </div>
            <div class="card-body">
                @if (Model.Statement.Rows.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>التاريخ</th>
                                    <th>رقم القيد</th>
                                    <th>الوصف</th>
                                    <th>المصدر</th>
                                    <th>مركز التكلفة</th>
                                    <th>مدين</th>
                                    <th>دائن</th>
                                    <th>الرصيد الجاري</th>
                                    <th>الإجراء</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.Statement.Rows)
                                {
                                    <tr>
                                        <td>@row.EntryDate.ToString("yyyy-MM-dd")</td>
                                        <td>@row.EntryNumber</td>
                                        <td>@row.Description</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.SourceType) ? "-" : row.SourceType)</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.CostCenterNameAr) ? "-" : row.CostCenterNameAr)</td>
                                        <td>@row.DebitAmount.ToString("N2")</td>
                                        <td>@row.CreditAmount.ToString("N2")</td>
                                        <td>@row.RunningBalance.ToString("N2")</td>
                                        <td>
                                            <a asp-controller="JournalEntries" asp-action="Details" asp-route-id="@row.JournalEntryId" class="btn btn-sm btn-outline-primary">
                                                عرض القيد
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td colspan="5">الإجمالي</td>
                                    <td>@Model.Statement.TotalDebit.ToString("N2")</td>
                                    <td>@Model.Statement.TotalCredit.ToString("N2")</td>
                                    <td>@Model.Statement.ClosingBalance.ToString("N2")</td>
                                    <td>-</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">لا توجد حركات للحساب ضمن الفلاتر الحالية.</div>
                }
            </div>
        </div>
    }
</div>

@using InfrastructureManagmentWebFramework.Models.FinancialAccounting
@using InfrastrfuctureManagmentCore.Domains.Financial
@model List<AccountListItemVm>
@{
    ViewData["Title"] = "دليل الحسابات";
    var tree = ViewBag.Tree as List<(AccountListItemVm Vm, int Depth, int ChildCount)>
            ?? new List<(AccountListItemVm, int, int)>();

    string CatColor(string cat) => cat switch {
        "Asset"=>"#2d5282","Liability"=>"#991b1b","Equity"=>"#065f46",
        "Revenue"=>"#0e6f73","Expense"=>"#92400e",_=>"#6b7d80"};
    string CatAr(string cat) => cat switch {
        "Asset"=>"أصول","Liability"=>"خصوم","Equity"=>"حقوق الملكية",
        "Revenue"=>"إيرادات","Expense"=>"مصروفات",_=>cat};
}

<style>
.coa-hero{background:linear-gradient(135deg,#0a4a3a,#1a6b5e);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.coa-stat{background:rgba(255,255,255,.13);border-radius:12px;padding:9px 14px;text-align:center;flex:1;min-width:70px}
.coa-stat .n{font-size:1.1rem;font-weight:800;line-height:1}
.coa-stat .l{font-size:.65rem;opacity:.8;margin-top:2px}
.cat-tab{padding:5px 14px;border-radius:20px;font-size:.8rem;font-weight:600;cursor:pointer;border:none;background:rgba(30,58,95,.07);color:#374151}
.cat-tab.active{color:#fff;background:#0a4a3a}
.tree-wrap{background:#fff;border-radius:16px;border:.5px solid rgba(10,74,58,.1);box-shadow:0 2px 8px rgba(10,74,58,.05);overflow:hidden}
.tree-col-head{display:flex;align-items:center;padding:8px 16px;background:#f8fdfb;border-bottom:.5px solid rgba(10,74,58,.08);font-size:.75rem;font-weight:700;color:#6b7d80}
.node-row{display:flex;align-items:center;padding:8px 16px;gap:6px;border-bottom:.5px solid rgba(10,74,58,.04);transition:background .1s}
.node-row:hover{background:rgba(10,74,58,.03)}
.node-row:hover .node-acts{opacity:1}
.node-acts{opacity:0;display:flex;gap:3px;transition:.15s}
.toggle-btn{width:18px;height:18px;border-radius:4px;border:none;background:rgba(10,74,58,.1);color:#0a4a3a;font-size:.65rem;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.acc-code{font-size:.74rem;font-weight:700;color:#6b7d80;font-family:monospace;min-width:72px}
.acc-name{flex:1;font-size:.85rem}
.acc-name.grp{font-weight:700;color:#0a4a3a}
.acc-name.pst{color:#374151}
.typ-badge{padding:1px 7px;border-radius:5px;font-size:.67rem;font-weight:700}
.act-btn{padding:2px 7px;border-radius:5px;font-size:.68rem;font-weight:600;border:none;cursor:pointer;text-decoration:none}
</style>

<div class="coa-hero">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h4 class="fw-bold mb-1 text-white"><i class="bx bx-list-ol me-2"></i>دليل الحسابات</h4>
      <div style="opacity:.72;font-size:.8rem">الهيكل المحاسبي الشجري متعدد المستويات</div>
    </div>
    <a href="@Url.Action("Create","FinancialAccount")" class="btn btn-warning fw-bold" style="border-radius:12px">
      <i class="bx bx-plus me-1"></i>حساب جديد
    </a>
  </div>
  <div class="d-flex gap-3 flex-wrap">
    <div class="coa-stat"><div class="n">@Model.Count</div><div class="l">إجمالي</div></div>
    @foreach (var grp in Model.GroupBy(x => x.Category).OrderBy(g => g.Key))
    {
      <div class="coa-stat" style="background:@(CatColor(grp.Key))44">
        <div class="n">@grp.Count()</div><div class="l">@CatAr(grp.Key)</div>
      </div>
    }
    <div class="coa-stat" style="background:rgba(52,195,143,.2)">
      <div class="n" style="color:#a7f3d0">@Model.Count(x=>x.IsPosting)</div><div class="l">حركية</div>
    </div>
    <div class="coa-stat" style="background:rgba(59,130,246,.18)">
      <div class="n">@Model.Count(x=>x.CashKind != InfrastrfuctureManagmentCore.Domains.Financial.FinancialAccountCashKind.None)</div><div class="l">خزينة/بنك</div>
    </div>
  </div>
</div>

@if (TempData["Success"] != null)
{<div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["Error"] != null)
{<div class="alert alert-danger alert-dismissible fade show" style="border-radius:12px">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div class="d-flex gap-2 flex-wrap">
    <button class="cat-tab active" onclick="filterCat('all',this)">الكل</button>
    @foreach(var cat in new[]{"Asset","Liability","Equity","Revenue","Expense"})
    {
      <button class="cat-tab" onclick="filterCat('@cat',this)"
              style="color:@CatColor(cat)">@CatAr(cat)</button>
    }
  </div>
  <div class="d-flex gap-2">
    <input id="coa-q" type="text" placeholder="🔍 بحث..." oninput="searchCoa()"
           class="form-control form-control-sm" style="border-radius:20px;width:170px"/>
    <button onclick="expandAll()" class="btn btn-sm" style="border-radius:9px;background:rgba(10,74,58,.08);color:#0a4a3a;border:none;font-size:.78rem">⊞ توسيع</button>
    <button onclick="collapseAll()" class="btn btn-sm" style="border-radius:9px;background:rgba(10,74,58,.08);color:#0a4a3a;border:none;font-size:.78rem">⊟ طي</button>
  </div>
</div>

<div class="tree-wrap">
  <div class="tree-col-head">
    <div style="width:18px"></div>
    <div style="width:72px;margin-right:6px">الكود</div>
    <div style="flex:1">اسم الحساب</div>
    <div style="width:70px;text-align:center">النوع</div>
    <div style="width:80px;text-align:center">النقدية</div>
    <div style="width:60px;text-align:center">المستوى</div>
    <div style="width:80px;text-align:center">الحالة</div>
    <div style="width:110px;text-align:center">إجراءات</div>
  </div>

  @foreach (var (vm, depth, kids) in tree)
  {
    var indent  = depth * 20;
    var catClr  = CatColor(vm.Category);
    var nodeKey = vm.Id.ToString("N");
    var pidKey  = vm.ParentAccountId?.ToString("N") ?? "";

    <div class="node-row"
         data-cat="@vm.Category"
         data-depth="@depth"
         data-key="@nodeKey"
         data-parent="@pidKey"
         id="nr-@nodeKey">
      @* مسافة + زر توسيع *@
      @if (indent > 0)
      { <div style="width:@(indent)px;flex-shrink:0"></div> }
      @if (kids > 0)
      {
        <button class="toggle-btn" id="tb-@nodeKey" onclick="toggle('@nodeKey')">
          <i class="bx bx-chevron-left" id="ic-@nodeKey"></i>
        </button>
      }
      else
      { <div style="width:18px;flex-shrink:0"></div> }

      @* نقطة ملونة *@
      <div style="width:7px;height:7px;border-radius:50%;background:@catClr;flex-shrink:0"></div>

      @* كود *@
      <span class="acc-code">@vm.AccountCode</span>

      @* الاسم *@
      <span class="acc-name @(vm.IsPosting?"pst":"grp")">
        @vm.AccountNameAr
        @if (kids > 0)
        { <span style="font-size:.68rem;color:#adb5bd">(@kids)</span> }
      </span>

      @* النوع *@
      <div style="width:70px;text-align:center">
        @if (vm.IsPosting)
        {<span class="typ-badge" style="background:rgba(14,111,115,.1);color:#0e6f73">حركي</span>}
        else
        {<span class="typ-badge" style="background:rgba(30,58,95,.08);color:#1e3a5f">تجميعي</span>}
      </div>

      @* طبيعة النقدية *@
      <div style="width:80px;text-align:center">
        @if (vm.CashKind == FinancialAccountCashKind.Treasury)
        {<span class="typ-badge" style="background:rgba(52,195,143,.1);color:#065f46">خزينة</span>}
        else if (vm.CashKind == FinancialAccountCashKind.Bank)
        {<span class="typ-badge" style="background:rgba(59,130,246,.1);color:#1d4ed8">بنك</span>}
        else
        {<span class="typ-badge" style="background:rgba(107,114,128,.08);color:#6b7280">—</span>}
      </div>

      @* المستوى *@
      <div style="width:60px;text-align:center;font-size:.75rem;color:#adb5bd">@vm.Level</div>

      @* الحالة *@
      <div style="width:80px;text-align:center">
        @if (vm.IsActive)
        {<span class="typ-badge" style="background:rgba(52,195,143,.1);color:#065f46">نشط</span>}
        else
        {<span class="typ-badge" style="background:rgba(244,106,106,.1);color:#991b1b">موقوف</span>}
      </div>

      @* إجراءات *@
      <div class="node-acts" style="width:110px;justify-content:center">
        <a href="@Url.Action("Create","FinancialAccount",new{parentId=vm.Id})"
           class="act-btn" style="background:rgba(14,111,115,.1);color:#0e6f73" title="حساب فرعي">
          <i class="bx bx-plus"></i>
        </a>
        <a href="@Url.Action("Edit","FinancialAccount",new{id=vm.Id})"
           class="act-btn" style="background:rgba(241,180,76,.12);color:#92400e">
          <i class="bx bx-edit"></i>
        </a>
        <a href="@Url.Action("Details","FinancialAccount",new{id=vm.Id})"
           class="act-btn" style="background:rgba(30,58,95,.08);color:#1e3a5f">
          <i class="bx bx-bar-chart-alt-2"></i>
        </a>
        <form action="@Url.Action("ToggleActive","FinancialAccount")" method="post" class="d-inline">
          @Html.AntiForgeryToken()
          <input type="hidden" name="id" value="@vm.Id"/>
          <button type="submit" class="act-btn"
                  style="background:@(vm.IsActive?"rgba(244,106,106,.1)":"rgba(52,195,143,.1)");color:@(vm.IsActive?"#991b1b":"#065f46")"
                  onclick="return confirm('@(vm.IsActive?"تعطيل؟":"تفعيل؟")')">
            <i class="bx bx-@(vm.IsActive?"block":"check")"></i>
          </button>
        </form>
      </div>
    </div>
  }
</div>

@section Scripts {
<script>
// ── State: which nodes are open ──
var openNodes = new Set();

// افتح المستوى الأول تلقائياً
document.addEventListener('DOMContentLoaded', function(){
    document.querySelectorAll('[data-depth="0"]').forEach(function(row){
        openNodes.add(row.dataset.key);
    });
    applyVisibility();
});

function toggle(key) {
    if (openNodes.has(key)) openNodes.delete(key);
    else openNodes.add(key);
    applyVisibility();
}

function applyVisibility() {
    document.querySelectorAll('.node-row[data-key]').forEach(function(row){
        var depth  = parseInt(row.dataset.depth);
        var parent = row.dataset.parent;

        if (depth === 0) { row.style.display = ''; return; }

        // مرئي لو كل أجداده مفتوحون
        var visible = isAncestorOpen(row);
        row.style.display = visible ? '' : 'none';

        // أيقونة الزر
        var key = row.dataset.key;
        var ic  = document.getElementById('ic-' + key);
        if (ic) ic.className = openNodes.has(key) ? 'bx bx-chevron-down' : 'bx bx-chevron-left';
    });
}

function isAncestorOpen(row) {
    var parent = row.dataset.parent;
    if (!parent) return true;
    if (!openNodes.has(parent)) return false;
    var parentRow = document.querySelector('[data-key="' + parent + '"]');
    return parentRow ? isAncestorOpen(parentRow) : true;
}

function expandAll() {
    document.querySelectorAll('.node-row[data-key]').forEach(function(r){ openNodes.add(r.dataset.key); });
    applyVisibility();
}
function collapseAll() {
    openNodes.clear();
    document.querySelectorAll('[data-depth="0"]').forEach(function(r){ openNodes.add(r.dataset.key); });
    applyVisibility();
}

function filterCat(cat, btn) {
    document.querySelectorAll('.cat-tab').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.node-row[data-cat]').forEach(function(r){
        r.style.display = (cat === 'all' || r.dataset.cat === cat) ? '' : 'none';
    });
    if (cat !== 'all') expandAll();
}

function searchCoa() {
    var q = document.getElementById('coa-q').value.toLowerCase().trim();
    if (!q) { expandAll(); return; }
    document.querySelectorAll('.node-row').forEach(function(r){
        var txt = r.textContent.toLowerCase();
        r.style.display = txt.includes(q) ? '' : 'none';
    });
}
</script>
}

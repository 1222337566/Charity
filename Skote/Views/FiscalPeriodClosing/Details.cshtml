@model InfrastructureManagmentWebFramework.Models.FiscalPeriodClosing.FiscalPeriodClosingDetailsVm
@using InfrastructureManagmentWebFramework.Models.FiscalPeriodClosing

@{
    ViewData["Title"] = "مراجعة إقفال فترة مالية";
}

<div style="background:linear-gradient(135deg,#111827,#374151);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-1 text-white">
                <i class="bx bx-lock-alt me-2"></i>@Model.PeriodName
            </h4>
            <div style="opacity:.75;font-size:.82rem">
                من @Model.StartDate.ToString("yyyy/MM/dd") إلى @Model.EndDate.ToString("yyyy/MM/dd")
            </div>
        </div>
        @if (Model.IsClosed)
        {
            <span class="badge bg-dark p-2">مقفلة</span>
        }
        else
        {
            <span class="badge bg-success p-2">مفتوحة</span>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card" style="border-radius:14px"><div class="card-body text-center">
            <div class="text-muted small">عدد القيود</div>
            <div class="fs-4 fw-bold">@Model.JournalEntriesCount</div>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-radius:14px"><div class="card-body text-center">
            <div class="text-muted small">إجمالي المدين</div>
            <div class="fs-4 fw-bold">@Model.TotalDebit.ToString("N2")</div>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-radius:14px"><div class="card-body text-center">
            <div class="text-muted small">إجمالي الدائن</div>
            <div class="fs-4 fw-bold">@Model.TotalCredit.ToString("N2")</div>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card" style="border-radius:14px"><div class="card-body text-center">
            <div class="text-muted small">الفرق</div>
            <div class="fs-4 fw-bold @(Model.Difference == 0 ? "text-success" : "text-danger")">@Model.Difference.ToString("N2")</div>
        </div></div>
    </div>
</div>

@if (!Model.IsClosed)
{
    <div class="card mb-3" style="border-radius:16px">
        <div class="card-body">
            @if (Model.CanClose)
            {
                <form asp-action="Close" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="FiscalPeriodId" value="@Model.FiscalPeriodId" />
                    <div class="mb-3">
                        <label class="form-label">ملاحظات الإقفال</label>
                        <textarea name="ClosingNotes" class="form-control" rows="2"></textarea>
                    </div>
                    <button class="btn btn-dark fw-bold" onclick="return confirm('هل تريد إقفال الفترة المالية؟ لن يمكن تعديل القيود داخلها بعد ذلك.');">
                        <i class="bx bx-lock me-1"></i>إقفال الفترة
                    </button>
                </form>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    لا يمكن إقفال الفترة حاليًا. تأكد من عدم وجود قيود مسودة وأن إجمالي المدين يساوي إجمالي الدائن.
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-dark">
        تم إقفال هذه الفترة بتاريخ:
        @(Model.ClosedAtUtc?.ToLocalTime().ToString("yyyy/MM/dd HH:mm") ?? "-")
        <br />
        @Model.ClosingNotes
    </div>
}

<div class="card" style="border-radius:16px">
    <div class="card-header fw-bold">قيود الفترة</div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>رقم القيد</th>
                        <th>التاريخ</th>
                        <th>الوصف</th>
                        <th>الحالة</th>
                        <th>المصدر</th>
                        <th>مدين</th>
                        <th>دائن</th>
                        <th>فرق</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var e in Model.Entries)
                {
                    <tr>
                        <td>@e.EntryNumber</td>
                        <td>@e.EntryDateUtc.ToLocalTime().ToString("yyyy/MM/dd")</td>
                        <td>@e.Description</td>
                        <td>@e.Status</td>
                        <td>@e.SourceType @if(!string.IsNullOrWhiteSpace(e.SourceNumber)){<span> / @e.SourceNumber</span>}</td>
                        <td>@e.TotalDebit.ToString("N2")</td>
                        <td>@e.TotalCredit.ToString("N2")</td>
                        <td class="@(e.Difference == 0 ? "text-success" : "text-danger")">@e.Difference.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

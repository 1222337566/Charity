@model InfrastructureManagmentWebFramework.Models.FiscalPeriodClosing.FiscalPeriodClosingIndexVm

@{
    ViewData["Title"] = "إقفال الفترات المالية";
}

<div style="background:linear-gradient(135deg,#111827,#374151);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px">
    <h4 class="fw-bold mb-1 text-white">
        <i class="bx bx-lock-alt me-2"></i>إقفال الفترات المالية
    </h4>
    <div style="opacity:.75;font-size:.82rem">
        مراجعة الفترات المالية وإقفالها لمنع تعديل القيود بعد إصدار التقارير.
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card" style="border-radius:16px">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>الفترة</th>
                        <th>من</th>
                        <th>إلى</th>
                        <th>عدد القيود</th>
                        <th>إجمالي المدين</th>
                        <th>إجمالي الدائن</th>
                        <th>الفرق</th>
                        <th>الحالة</th>
                        <th style="width:120px">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Periods)
                {
                    <tr>
                        <td class="fw-bold">@p.PeriodName</td>
                        <td>@p.StartDate.ToString("yyyy/MM/dd")</td>
                        <td>@p.EndDate.ToString("yyyy/MM/dd")</td>
                        <td>@p.JournalEntriesCount</td>
                        <td>@p.TotalDebit.ToString("N2")</td>
                        <td>@p.TotalCredit.ToString("N2")</td>
                        <td class="@(p.Difference == 0 ? "text-success" : "text-danger") fw-bold">@p.Difference.ToString("N2")</td>
                        <td>
                            @if (p.IsClosed)
                            {
                                <span class="badge bg-dark">مقفلة</span>
                            }
                            else
                            {
                                <span class="badge bg-success">مفتوحة</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">
                                مراجعة
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        @if (!Model.Periods.Any())
        {
            <div class="alert alert-info mb-0">لا توجد فترات مالية.</div>
        }
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.FiscalPeriodClosingEntries.FiscalPeriodClosingEntriesIndexVm

@{
    ViewData["Title"] = "قيود الإقفال";
}

<div style="background:linear-gradient(135deg,#312e81,#7c3aed);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px">
    <h4 class="fw-bold mb-1 text-white">
        <i class="bx bx-transfer-alt me-2"></i>قيود الإقفال وترحيل الفائض/العجز
    </h4>
    <div style="opacity:.78;font-size:.82rem">
        إقفال حسابات الإيرادات والمصروفات وترحيل صافي نتيجة الفترة.
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card" style="border-radius:16px">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>الفترة</th>
                        <th>من</th>
                        <th>إلى</th>
                        <th>الإيرادات</th>
                        <th>المصروفات</th>
                        <th>صافي الفائض/العجز</th>
                        <th>حالة الفترة</th>
                        <th>قيد الإقفال</th>
                        <th style="width:140px">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in Model.Periods)
                {
                    <tr>
                        <td class="fw-bold">@p.PeriodName</td>
                        <td>@p.StartDate.ToString("yyyy/MM/dd")</td>
                        <td>@p.EndDate.ToString("yyyy/MM/dd")</td>
                        <td>@p.TotalRevenue.ToString("N2")</td>
                        <td>@p.TotalExpense.ToString("N2")</td>
                        <td class="@(p.NetSurplusOrDeficit >= 0 ? "text-success" : "text-danger") fw-bold">
                            @p.NetSurplusOrDeficit.ToString("N2")
                        </td>
                        <td>
                            @if (p.IsClosed)
                            {
                                <span class="badge bg-dark">مقفلة</span>
                            }
                            else
                            {
                                <span class="badge bg-success">مفتوحة</span>
                            }
                        </td>
                        <td>
                            @if (p.HasClosingEntry)
                            {
                                <span class="badge bg-primary">@p.ClosingEntryNumber</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">لا يوجد</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Prepare" asp-route-fiscalPeriodId="@p.FiscalPeriodId" class="btn btn-sm btn-outline-primary">
                                تجهيز الإقفال
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        @if (!Model.Periods.Any())
        {
            <div class="alert alert-info mb-0">لا توجد فترات مالية.</div>
        }
    </div>
</div>

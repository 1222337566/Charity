@model InfrastructureManagmentWebFramework.Models.Accounting.EditFiscalPeriodVm
@{
    ViewData["Title"] = "تعديل فترة مالية";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header"><h4 class="mb-0">تعديل فترة مالية</h4></div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="PeriodCode" class="form-label"></label>
                        <input asp-for="PeriodCode" class="form-control" />
                        <span asp-validation-for="PeriodCode" class="text-danger"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="PeriodNameAr" class="form-label"></label>
                        <input asp-for="PeriodNameAr" class="form-control" />
                        <span asp-validation-for="PeriodNameAr" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PeriodNameEn" class="form-label"></label>
                        <input asp-for="PeriodNameEn" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="StartDate" class="form-label"></label>
                        <input asp-for="StartDate" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="EndDate" class="form-label"></label>
                        <input asp-for="EndDate" class="form-control" />
                    </div>
                    <div class="col-md-6 form-check mt-3 ms-2">
                        <input asp-for="IsCurrent" class="form-check-input" />
                        <label asp-for="IsCurrent" class="form-check-label"></label>
                    </div>
                    <div class="col-md-6 form-check mt-3 ms-2">
                        <input asp-for="IsClosed" class="form-check-input" />
                        <label asp-for="IsClosed" class="form-check-label"></label>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">حفظ</button>
                    <a asp-action="Index" class="btn btn-secondary">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>

@model List<InfrastructureManagmentWebFramework.Models.Accounting.FiscalPeriodListItemVm>
@{ ViewData["Title"] = "الفترات المالية"; }

<style>
.fp-hero{background:linear-gradient(135deg,#0a4a3a,#0e6f73);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.fp-stat{background:rgba(255,255,255,.13);border-radius:12px;padding:10px 14px;text-align:center;flex:1;min-width:70px}
.fp-stat .n{font-size:1.2rem;font-weight:800;line-height:1}
.fp-stat .l{font-size:.67rem;opacity:.8;margin-top:2px}
.fp-card{background:#fff;border-radius:16px;border:.5px solid rgba(10,74,58,.1);box-shadow:0 2px 8px rgba(10,74,58,.06);overflow:hidden;margin-bottom:12px}
.fp-row{padding:14px 18px;display:flex;align-items:center;gap:12px}
.fp-badge{padding:3px 10px;border-radius:20px;font-size:.72rem;font-weight:700}
.period-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0}
.action-zone{border-top:.5px solid rgba(10,74,58,.06);padding:12px 18px;background:#fafffe;display:flex;gap:8px;flex-wrap:wrap;align-items:center}

/* ترحيل */
.closing-card{background:linear-gradient(135deg,rgba(30,58,95,.05),rgba(30,58,95,.02));border-radius:12px;padding:14px 16px;border:.5px solid rgba(30,58,95,.12);margin:10px 18px}
.closing-step{display:flex;align-items:flex-start;gap:10px;margin-bottom:8px}
.step-num{width:22px;height:22px;border-radius:50%;background:#1e3a5f;color:#fff;font-size:.7rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
</style>

<div class="fp-hero">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h4 class="fw-bold mb-1 text-white"><i class="bx bx-calendar-check me-2"></i>الفترات المالية</h4>
      <div style="opacity:.72;font-size:.8rem">إدارة الفترات المالية وإغلاق نهاية الفترة والترحيل</div>
    </div>
    <a asp-action="Create" class="btn btn-warning fw-bold" style="border-radius:12px">
      <i class="bx bx-plus me-1"></i>فترة جديدة
    </a>
  </div>
  <div class="d-flex gap-3 flex-wrap">
    <div class="fp-stat"><div class="n">@Model.Count</div><div class="l">إجمالي الفترات</div></div>
    <div class="fp-stat" style="background:rgba(52,195,143,.2)">
      <div class="n" style="color:#a7f3d0">@Model.Count(x => x.IsCurrent)</div><div class="l">الفترة الحالية</div>
    </div>
    <div class="fp-stat" style="background:rgba(244,106,106,.2)">
      <div class="n" style="color:#fca5a5">@Model.Count(x => x.IsClosed)</div><div class="l">مقفلة</div>
    </div>
    <div class="fp-stat" style="background:rgba(241,180,76,.15)">
      <div class="n" style="color:#fde68a">@Model.Count(x => !x.IsClosed)</div><div class="l">مفتوحة</div>
    </div>
  </div>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px"><i class="bx bx-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-danger alert-dismissible fade show" style="border-radius:12px">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

@foreach (var item in Model.OrderByDescending(x => x.StartDate))
{
  var isCurrent = item.IsCurrent;
  var isClosed  = item.IsClosed;
  var color     = isClosed ? "#adb5bd" : isCurrent ? "#34c38f" : "#f1b44c";

  <div class="fp-card">
    <div class="fp-row">
      <div class="period-dot" style="background:@color"></div>
      <div class="flex-grow-1">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <span class="fw-bold" style="font-size:.92rem;color:#0a4a3a">@item.PeriodNameAr</span>
          <span style="font-size:.75rem;color:#adb5bd;background:#f8fbfb;padding:1px 8px;border-radius:5px">@item.PeriodCode</span>
          @if (isCurrent)
          { <span class="fp-badge" style="background:rgba(52,195,143,.15);color:#065f46">● الفترة الحالية</span> }
          @if (isClosed)
          { <span class="fp-badge" style="background:rgba(173,181,189,.15);color:#6b7d80">🔒 مقفلة</span> }
          else
          { <span class="fp-badge" style="background:rgba(241,180,76,.15);color:#92400e">🔓 مفتوحة</span> }
        </div>
        <div style="font-size:.78rem;color:#6b7d80;margin-top:3px">
          <i class="bx bx-calendar me-1"></i>
          @item.StartDate.ToString("d/M/yyyy") — @item.EndDate.ToString("d/M/yyyy")
          <span style="margin-right:8px">
            (@((item.EndDate - item.StartDate).Days + 1) يوم)
          </span>
          @if (DateTime.Today >= item.StartDate && DateTime.Today <= item.EndDate)
          { <span style="color:#34c38f;font-weight:600">← اليوم</span> }
        </div>
      </div>
    </div>

    @* منطقة الإجراءات *@
    <div class="action-zone">
      @* تعديل *@
      @if (!isClosed)
      {
        <a asp-action="Edit" asp-route-id="@item.Id"
           class="btn btn-sm fw-semibold" style="border-radius:9px;background:rgba(241,180,76,.12);color:#92400e;border:none">
          <i class="bx bx-edit me-1"></i>تعديل
        </a>
      }

      @* فتح / إغلاق *@
      <form asp-action="ToggleClosed" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@item.Id"/>
        <button type="submit" class="btn btn-sm fw-semibold"
                style="border-radius:9px;background:@(isClosed?"rgba(52,195,143,.12)":"rgba(244,106,106,.12)");color:@(isClosed?"#065f46":"#991b1b");border:none"
                onclick="return confirm('@(isClosed ? "إعادة فتح الفترة؟" : "تأكيد إغلاق الفترة؟")')">
          <i class="bx bx-@(isClosed?"lock-open":"lock") me-1"></i>
          @(isClosed ? "إعادة فتح" : "إغلاق الفترة")
        </button>
      </form>

      @* ترحيل الأرصدة (يظهر فقط للفترات المقفلة) *@
      @if (isClosed)
      {
        <button type="button" class="btn btn-sm fw-bold"
                style="border-radius:9px;background:#1e3a5f;color:#fff;border:none"
                data-bs-toggle="collapse" data-bs-target="#closing-@item.Id.ToString("N")">
          <i class="bx bx-transfer me-1"></i>ترحيل الأرصدة ←
        </button>
      }

      @* تعيين كفترة حالية *@
      @if (!isCurrent && !isClosed)
      {
        <form asp-action="SetCurrent" method="post" class="d-inline">
          @Html.AntiForgeryToken()
          <input type="hidden" name="id" value="@item.Id"/>
          <button type="submit" class="btn btn-sm fw-semibold"
                  style="border-radius:9px;background:rgba(52,195,143,.1);color:#065f46;border:none"
                  onclick="return confirm('تعيين هذه الفترة كالفترة الحالية؟')">
            <i class="bx bx-star me-1"></i>تعيين كحالية
          </button>
        </form>
      }
    </div>

    @* بطاقة الترحيل القابلة للطي *@
    @if (isClosed)
    {
      <div class="collapse" id="closing-@item.Id.ToString("N")">
        <div class="closing-card">
          <div class="fw-bold mb-3" style="font-size:.88rem;color:#1e3a5f">
            <i class="bx bx-transfer me-2"></i>ترحيل أرصدة نهاية الفترة → فترة جديدة
          </div>

          @* خطوات الترحيل *@
          <div class="closing-step">
            <div class="step-num">1</div>
            <div style="font-size:.8rem;color:#374151">
              <strong>إغلاق حسابات الإيرادات والمصروفات</strong> —
              تحويل أرصدتها لحساب الأرباح والخسائر
            </div>
          </div>
          <div class="closing-step">
            <div class="step-num">2</div>
            <div style="font-size:.8rem;color:#374151">
              <strong>إغلاق حساب الأرباح والخسائر</strong> —
              تحويل صافي الربح/الخسارة لحساب الاحتياطيات
            </div>
          </div>
          <div class="closing-step mb-3">
            <div class="step-num">3</div>
            <div style="font-size:.8rem;color:#374151">
              <strong>ترحيل أرصدة الأصول والخصوم وحقوق الملكية</strong> —
              كأرصدة افتتاحية للفترة الجديدة
            </div>
          </div>

          <form asp-action="ClosePeriodAndCarryForward" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="periodId" value="@item.Id"/>
            <div class="row g-2 mb-3">
              <div class="col-md-5">
                <label class="form-label fw-semibold" style="font-size:.82rem">الفترة المالية التالية</label>
                <select name="nextPeriodId" class="form-select" style="border-radius:10px;font-size:.83rem" required>
                  <option value="">-- اختر الفترة التالية --</option>
                  @foreach (var fp in Model.Where(x => !x.IsClosed && x.Id != item.Id).OrderBy(x => x.StartDate))
                  { <option value="@fp.Id">@fp.PeriodNameAr (@fp.StartDate.ToString("d/M/yyyy"))</option> }
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-semibold" style="font-size:.82rem">حساب الأرباح والخسائر</label>
                <input name="retainedEarningsAccount" class="form-control" style="border-radius:10px;font-size:.83rem"
                       placeholder="رقم الحساب مثل: 3101"/>
              </div>
              <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary fw-bold w-100" style="border-radius:10px;font-size:.83rem"
                        onclick="return confirm('سيتم إنشاء قيود ترحيل الأرصدة. هل أنت متأكد؟')">
                  <i class="bx bx-transfer me-1"></i>تنفيذ الترحيل
                </button>
              </div>
            </div>
            <div class="d-flex gap-2">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="closeIncomeAccounts" value="true" id="cia-@item.Id.ToString("N")" checked/>
                <label class="form-check-label" for="cia-@item.Id.ToString("N")" style="font-size:.8rem">إغلاق حسابات الإيرادات والمصروفات</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="carryBalanceAccounts" value="true" id="cba-@item.Id.ToString("N")" checked/>
                <label class="form-check-label" for="cba-@item.Id.ToString("N")" style="font-size:.8rem">ترحيل أرصدة الميزانية</label>
              </div>
            </div>
          </form>
        </div>
      </div>
    }
  </div>
}

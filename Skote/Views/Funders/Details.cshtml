@using InfrastructureManagmentWebFramework.Models.Charity.Funders
@model FunderDetailsVm
@{
    ViewData["Title"] = "تفاصيل ممول";
}
<div class="page-content">
<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h4 class="mb-1">@Model.Name</h4>
                <div class="text-muted small">كود: @Model.Code | النوع: @Model.FunderType | الهاتف: @(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</div>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">تعديل</a>
                <a asp-controller="GrantAgreements" asp-action="Index" asp-route-funderId="@Model.Id" class="btn btn-success">الاتفاقيات</a>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="alert alert-info mb-0">عدد الاتفاقيات: <strong>@Model.AgreementsCount</strong></div></div>
        <div class="col-md-4"><div class="alert alert-warning mb-0">إجمالي التمويل: <strong>@Model.TotalFunding.ToString("N2")</strong></div></div>
        <div class="col-md-4"><div class="alert @(Model.IsActive ? "alert-success" : "alert-secondary") mb-0">الحالة: <strong>@(Model.IsActive ? "نشط" : "غير نشط")</strong></div></div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">البيانات الأساسية</h5>
            <div class="row g-3">
                <div class="col-md-4"><strong>مسؤول التواصل:</strong> @Model.ContactPerson</div>
                <div class="col-md-4"><strong>البريد:</strong> @Model.Email</div>
                <div class="col-md-4"><strong>تاريخ الإضافة:</strong> @Model.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                <div class="col-12"><strong>العنوان:</strong> @Model.AddressLine</div>
                <div class="col-12"><strong>ملاحظات:</strong> @Model.Notes</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <h5 class="card-title">آخر الاتفاقيات</h5>
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>رقم الاتفاقية</th>
                        <th>العنوان</th>
                        <th>التاريخ</th>
                        <th>الفترة</th>
                        <th>القيمة</th>
                        <th>الحالة</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentAgreements.Any())
                {
                    foreach (var item in Model.RecentAgreements)
                    {
                        <tr>
                            <td>@item.AgreementNumber</td>
                            <td>@item.Title</td>
                            <td>@item.AgreementDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.StartDate?.ToString("yyyy-MM-dd") - @item.EndDate?.ToString("yyyy-MM-dd")</td>
                            <td>@item.TotalAmount.ToString("N2") @item.Currency</td>
                            <td>@item.Status</td>
                            <td><a asp-controller="GrantInstallments" asp-action="Index" asp-route-grantAgreementId="@item.Id" class="btn btn-sm btn-outline-primary">الدفعات</a></td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted">لا توجد اتفاقيات بعد</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>

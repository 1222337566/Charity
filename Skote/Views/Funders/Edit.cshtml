@using InfrastructureManagmentWebFramework.Models.Charity.Funders
@model EditFunderVm
@{
    ViewData["Title"] = "تعديل ممول";
}
<div class="page-content">
<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title mb-4">تعديل بيانات الممول</h4>
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                @await Html.PartialAsync("_Form", Model)
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>
</div>

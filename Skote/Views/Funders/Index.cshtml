@using InfrastructureManagmentWebFramework.Models.Charity.Funders
@model FunderListPageVm
@{
    ViewData["Title"] = "الممولون";
}
<div class="page-content">
<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">بحث</label>
                    <input name="q" value="@Model.Filter.Q" class="form-control" placeholder="الكود / الاسم / مسؤول التواصل / الهاتف" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">نوع الممول</label>
                    <select name="funderType" class="form-select" asp-items="Model.Filter.FunderTypes">
                        <option value="">الكل</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">الحالة</label>
                    <select name="isActive" class="form-select">
                        <option value="">الكل</option>
                        <option value="true" selected="@(Model.Filter.IsActive == true)">نشط</option>
                        <option value="false" selected="@(Model.Filter.IsActive == false)">غير نشط</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-primary" type="submit">بحث</button>
                    <a asp-action="Index" class="btn btn-light">إعادة ضبط</a>
                    <a asp-action="Create" class="btn btn-success">إضافة ممول</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4"><div class="alert alert-info mb-0">إجمالي الممولين: <strong>@Model.TotalCount</strong></div></div>
        <div class="col-md-4"><div class="alert alert-success mb-0">النشطون: <strong>@Model.ActiveCount</strong></div></div>
        <div class="col-md-4"><div class="alert alert-warning mb-0">إجمالي التمويل المسجل: <strong>@Model.TotalFunding.ToString("N2")</strong></div></div>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>النوع</th>
                        <th>مسؤول التواصل</th>
                        <th>الهاتف</th>
                        <th>الاتفاقيات</th>
                        <th>إجمالي التمويل</th>
                        <th>الحالة</th>
                        <th style="width:220px">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Rows.Any())
                {
                    foreach (var item in Model.Rows)
                    {
                        <tr>
                            <td>@item.Code</td>
                            <td>@item.Name</td>
                            <td>@item.FunderType</td>
                            <td>@item.ContactPerson</td>
                            <td>@item.PhoneNumber</td>
                            <td>@item.AgreementsCount</td>
                            <td>@item.TotalAmount.ToString("N2")</td>
                            <td><span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">@(item.IsActive ? "نشط" : "غير نشط")</span></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تفاصيل</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a>
                                <a asp-controller="GrantAgreements" asp-action="Index" asp-route-funderId="@item.Id" class="btn btn-sm btn-outline-success">اتفاقيات</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" class="text-center text-muted">لا توجد بيانات</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
</div>

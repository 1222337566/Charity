@using InfrastructureManagmentWebFramework.Models.Charity.FunderProfile.GrantAgreements
@model CreateGrantAgreementVm
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="AgreementNumber" class="form-label"></label>
        <input asp-for="AgreementNumber" class="form-control" />
        <span asp-validation-for="AgreementNumber" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="AgreementDate" class="form-label"></label>
        <input asp-for="AgreementDate" class="form-control" type="date" />
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Model.Statuses" class="form-select"></select>
    </div>
    <div class="col-md-8">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="col-md-2">
        <label asp-for="TotalAmount" class="form-label"></label>
        <input asp-for="TotalAmount" class="form-control" />
    </div>
    <div class="col-md-2">
        <label asp-for="Currency" class="form-label"></label>
        <input asp-for="Currency" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" class="form-control" type="date" />
    </div>
    <div class="col-md-6">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" class="form-control" type="date" />
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="PaymentTerms" class="form-label"></label>
        <textarea asp-for="PaymentTerms" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="ReportingRequirements" class="form-label"></label>
        <textarea asp-for="ReportingRequirements" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>
</div>

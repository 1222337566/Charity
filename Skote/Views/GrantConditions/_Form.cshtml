@using InfrastructureManagmentWebFramework.Models.Charity.FunderProfile.GrantConditions
@model CreateGrantConditionVm
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="ConditionTitle" class="form-label"></label>
        <input asp-for="ConditionTitle" class="form-control" />
        <span asp-validation-for="ConditionTitle" class="text-danger"></span>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <div class="form-check">
            <input asp-for="IsMandatory" class="form-check-input" />
            <label asp-for="IsMandatory" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <div class="form-check">
            <input asp-for="IsFulfilled" class="form-check-input" />
            <label asp-for="IsFulfilled" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-md-6">
        <label asp-for="DueDate" class="form-label"></label>
        <input asp-for="DueDate" class="form-control" type="date" />
    </div>
    <div class="col-md-6">
        <label asp-for="FulfilledDate" class="form-label"></label>
        <input asp-for="FulfilledDate" class="form-control" type="date" />
    </div>
    <div class="col-12">
        <label asp-for="ConditionDetails" class="form-label"></label>
        <textarea asp-for="ConditionDetails" class="form-control" rows="4"></textarea>
        <span asp-validation-for="ConditionDetails" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>
</div>

@using InfrastructureManagmentWebFramework.Models.Charity.FunderProfile
@using InfrastructureManagmentWebFramework.Models.Charity.FunderProfile.GrantInstallments
@model List<GrantInstallmentListItemVm>
@{
    ViewData["Title"] = "دفعات التمويل";
    var agreementHeader = ViewBag.GrantAgreementHeader as GrantAgreementHeaderVm;
}
<div class="page-content"><div class="container-fluid">
@if (agreementHeader != null) { @await Html.PartialAsync("~/Views/Shared/Funders/_GrantAgreementHeader.cshtml", agreementHeader) }
<div class="card"><div class="card-body table-responsive">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="card-title mb-0">دفعات التمويل</h4>
            @if (agreementHeader == null && ViewBag.PageSubtitle != null)
            {
                <small class="text-muted">@ViewBag.PageSubtitle</small>
            }
        </div>
        <a asp-action="Create" asp-route-grantAgreementId="@agreementHeader?.Id" class="btn btn-success">إضافة دفعة</a>
    </div>
    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                @if (agreementHeader == null)
                {
                    <th>الممول</th><th>الاتفاقية</th>
                }
                <th>رقم الدفعة</th><th>الاستحقاق</th><th>القيمة</th><th>المستلم</th><th>تاريخ الاستلام</th><th>الحالة</th><th>طريقة الدفع</th><th>الحساب</th><th></th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    @if (agreementHeader == null)
                    {
                        <td>@(item.FunderName ?? "-")</td><td>@(item.AgreementTitle ?? "-")</td>
                    }
                    <td>@item.InstallmentNumber</td>
                    <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.Amount.ToString("N2")</td>
                    <td>@item.ReceivedAmount?.ToString("N2")</td>
                    <td>@item.ReceivedDate?.ToString("yyyy-MM-dd")</td>
                    <td>@item.Status</td>
                    <td>@item.PaymentMethod</td>
                    <td>@item.FinancialAccount</td>
                    <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a></td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="11" class="text-center text-muted">لا توجد دفعات</td></tr>
        }
        </tbody>
    </table>
</div></div>
</div></div>

@model InfrastructureManagmentWebFramework.Models.Funding.CreateGrantorVm
@{
    ViewData["Title"] = "إضافة جهة مانحة";
}

<div class="card" style="border-radius:16px">
    <div class="card-header fw-bold">إضافة جهة مانحة</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="GrantorCode" class="form-label"></label>
                    <input asp-for="GrantorCode" class="form-control" />
                    <span asp-validation-for="GrantorCode" class="text-danger"></span>
                </div>
                <div class="col-md-5">
                    <label asp-for="NameAr" class="form-label"></label>
                    <input asp-for="NameAr" class="form-control" />
                    <span asp-validation-for="NameAr" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="NameEn" class="form-label"></label>
                    <input asp-for="NameEn" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="ContactPerson" class="form-label"></label>
                    <input asp-for="ContactPerson" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                </div>
                <div class="col-md-12">
                    <label asp-for="Address" class="form-label"></label>
                    <input asp-for="Address" class="form-control" />
                </div>
                <div class="col-md-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary fw-bold">حفظ</button>
                <a asp-action="Index" class="btn btn-light">رجوع</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

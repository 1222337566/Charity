@model InfrastructureManagmentWebFramework.Models.Funding.GrantorIndexVm
@{
    ViewData["Title"] = "الجهات المانحة";
}

<style>
.fn-hero{background:linear-gradient(135deg,#1e3a8a,#0891b2);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.fn-card{background:#fff;border-radius:16px;border:.5px solid rgba(8,145,178,.12);box-shadow:0 2px 8px rgba(8,145,178,.05);overflow:hidden;margin-bottom:16px}
.fn-head{padding:12px 18px;border-bottom:.5px solid rgba(8,145,178,.08);font-size:.9rem;font-weight:700;color:#0e7490;background:rgba(8,145,178,.03)}
.fn-table{width:100%;border-collapse:collapse;font-size:.83rem}
.fn-table th{background:#f8fafc;color:#64748b;font-size:.75rem;font-weight:700;padding:9px;border-bottom:1px solid #e5e7eb}
.fn-table td{padding:9px;border-bottom:1px solid #f1f5f9;vertical-align:middle}
.fn-table tr:hover td{background:#f8fafc}
.fn-stat{background:rgba(255,255,255,.14);border-radius:12px;padding:10px 14px;text-align:center;flex:1;min-width:120px}
.fn-stat .n{font-size:1.2rem;font-weight:800;line-height:1}
.fn-stat .l{font-size:.7rem;opacity:.85;margin-top:2px}
</style>

<div class="fn-hero">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-1 text-white"><i class="bx bx-buildings me-2"></i>الجهات المانحة</h4>
            <div style="opacity:.78;font-size:.82rem">إدارة بيانات الجهات المانحة ومسئولي التواصل</div>
        </div>
        <a asp-action="Create" class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">+ جهة مانحة جديدة</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="fn-card">
    <div class="fn-head">قائمة الجهات المانحة</div>
    <div class="table-responsive">
        <table class="fn-table">
            <thead>
                <tr>
                    <th>الكود</th>
                    <th>اسم الجهة</th>
                    <th>مسئول التواصل</th>
                    <th>البريد الإلكتروني</th>
                    <th>عدد الاتفاقيات</th>
                    <th>إجمالي التمويل</th>
                    <th>الحالة</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model.Rows)
            {
                <tr>
                    <td>@r.GrantorCode</td>
                    <td class="fw-bold">@r.NameAr</td>
                    <td>@r.ContactPerson</td>
                    <td>@r.Email</td>
                    <td>@r.AgreementsCount</td>
                    <td class="fw-bold">@r.TotalFunding.ToString("N2")</td>
                    <td>
                        @if (r.IsActive)
                        {
                            <span class="badge bg-success">نشطة</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">غير نشطة</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

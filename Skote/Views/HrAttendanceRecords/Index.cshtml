@model InfrastructureManagmentWebFramework.Models.HR.Attendance.AttendanceListPageVm
@if (ViewBag.EmployeeHeader != null)
{
    <partial name="~/Views/Shared/HR/_EmployeeHeader.cshtml" />
}
<div class="card"><div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3"><div><h4 class="mb-1">الحضور والانصراف</h4><p class="text-muted mb-0">متابعة حضور الموظفين يوميًا</p></div><a asp-action="Create" asp-route-employeeId="@Model.Filter.EmployeeId" class="btn btn-primary">إضافة سجل</a></div>
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4"><select asp-for="Filter.EmployeeId" asp-items="Model.Filter.Employees" class="form-select"></select></div>
        <div class="col-md-2"><input asp-for="Filter.FromDate" class="form-control" /></div>
        <div class="col-md-2"><input asp-for="Filter.ToDate" class="form-control" /></div>
        <div class="col-md-2"><select asp-for="Filter.Status" asp-items="Model.Filter.Statuses" class="form-select"></select></div>
        <div class="col-md-2"><button class="btn btn-secondary w-100">بحث</button></div>
    </form>
    <div class="table-responsive"><table class="table table-bordered table-hover align-middle"><thead><tr><th>الموظف</th><th>القسم</th><th>التاريخ</th><th>حضور</th><th>انصراف</th><th>الشيفت</th><th>ساعات العمل</th><th>تأخير</th><th>انصراف مبكر</th><th>إضافي</th><th>الحالة</th><th>المصدر</th><th></th></tr></thead><tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.EmployeeName</td><td>@(item.DepartmentName ?? "-")</td><td>@item.AttendanceDate.ToString("yyyy-MM-dd")</td><td>@(item.CheckInTime?.ToString() ?? "-")</td><td>@(item.CheckOutTime?.ToString() ?? "-")</td><td>@(item.ShiftName ?? "-")</td><td>@item.WorkedHours</td><td>@item.LateMinutes</td><td>@item.EarlyLeaveMinutes</td><td>@item.OvertimeMinutes</td><td>@item.Status</td><td>@item.Source</td><td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a></td>
        </tr>
    }
    </tbody></table></div>
</div></div>

@model IEnumerable<InfrastructureManagmentWebFramework.Models.HR.Advanced.EmployeeMovements.EmployeeMovementListItemVm>
@{
    ViewData["Title"] = "الحركات الوظيفية";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">الحركات الوظيفية</h3>
    <a asp-action="Create" asp-route-employeeId="@ViewBag.EmployeeId" class="btn btn-primary">إضافة حركة</a>
</div>
<table class="table table-bordered table-striped align-middle">
    <thead><tr><th>الموظف</th><th>نوع الحركة</th><th>التاريخ</th><th>من</th><th>إلى</th><th>رقم القرار</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.EmployeeName</td><td>@item.MovementType</td><td>@item.EffectiveDate.ToString("yyyy-MM-dd")</td>
            <td>@(item.FromDepartmentName ?? item.FromJobTitleName ?? "-")</td>
            <td>@(item.ToDepartmentName ?? item.ToJobTitleName ?? "-")</td>
            <td>@(item.DecisionNumber ?? "-")</td>
            <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a></td>
        </tr>
    }
    </tbody>
</table>

@model InfrastructureManagmentWebFramework.Models.HR.Advanced.EmployeeMovements.CreateEmployeeMovementVm
<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.Employees" class="form-select"></select><span asp-validation-for="EmployeeId" class="text-danger"></span></div>
        <div class="col-md-6"><label asp-for="MovementType" class="form-label"></label><select asp-for="MovementType" asp-items="Model.MovementTypes" class="form-select"></select></div>
        <div class="col-md-4"><label asp-for="EffectiveDate" class="form-label"></label><input asp-for="EffectiveDate" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="DecisionNumber" class="form-label"></label><input asp-for="DecisionNumber" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="Notes" class="form-label"></label><input asp-for="Notes" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="FromDepartmentId" class="form-label"></label><select asp-for="FromDepartmentId" asp-items="Model.Departments" class="form-select"><option value="">--</option></select></div>
        <div class="col-md-6"><label asp-for="ToDepartmentId" class="form-label"></label><select asp-for="ToDepartmentId" asp-items="Model.Departments" class="form-select"><option value="">--</option></select></div>
        <div class="col-md-6"><label asp-for="FromJobTitleId" class="form-label"></label><select asp-for="FromJobTitleId" asp-items="Model.JobTitles" class="form-select"><option value="">--</option></select></div>
        <div class="col-md-6"><label asp-for="ToJobTitleId" class="form-label"></label><select asp-for="ToJobTitleId" asp-items="Model.JobTitles" class="form-select"><option value="">--</option></select></div>
    </div>
    <div class="mt-3 d-flex gap-2"><button class="btn btn-primary" type="submit">حفظ</button><a asp-action="Index" asp-route-employeeId="@Model.EmployeeId" class="btn btn-secondary">رجوع</a></div>
</form>

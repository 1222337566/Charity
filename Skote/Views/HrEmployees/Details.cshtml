@model InfrastructureManagmentWebFramework.Models.HR.Employees.EmployeeDetailsVm
<partial name="~/Views/Shared/HR/_EmployeeHeader.cshtml" />
<div class="card"><div class="card-body">
    <h4 class="mb-3">بيانات الموظف</h4>
    <div class="row g-3">
        <div class="col-md-3"><strong>الكود:</strong> @Model.Code</div>
        <div class="col-md-3"><strong>الاسم:</strong> @Model.FullName</div>
        <div class="col-md-3"><strong>القسم:</strong> @(Model.DepartmentName ?? "-")</div>
        <div class="col-md-3"><strong>الوظيفة:</strong> @(Model.JobTitleName ?? "-")</div>
        <div class="col-md-3"><strong>الرقم القومي:</strong> @(Model.NationalId ?? "-")</div>
        <div class="col-md-3"><strong>الموبايل:</strong> @(Model.PhoneNumber ?? "-")</div>
        <div class="col-md-3"><strong>البريد:</strong> @(Model.Email ?? "-")</div>
        <div class="col-md-3"><strong>تاريخ التعيين:</strong> @Model.HireDate.ToString("yyyy-MM-dd")</div>
        <div class="col-md-3"><strong>نوع التعيين:</strong> @Model.EmploymentType</div>
        <div class="col-md-3"><strong>الأساسي:</strong> @Model.BasicSalary.ToString("N2")</div>
        <div class="col-md-3"><strong>مرتب التأمين:</strong> @(Model.InsuranceSalary?.ToString("N2") ?? "-")</div>
        <div class="col-md-3"><strong>الحالة:</strong> @Model.Status</div>
        <div class="col-md-6"><strong>العنوان:</strong> @(Model.AddressLine ?? "-")</div>
        <div class="col-md-6"><strong>السجلات الأخيرة للحضور:</strong> @Model.AttendanceRecordsCount</div>
        <div class="col-12"><strong>ملاحظات:</strong><div>@(Model.Notes ?? "-")</div></div>
    </div>
</div></div>

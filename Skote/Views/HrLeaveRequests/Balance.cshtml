@model List<InfrastrfuctureManagmentCore.Domains.HR.HrLeaveBalance>
@{
    ViewData["Title"] = "رصيد الإجازات";
    var emp   = ViewBag.Employee as InfrastrfuctureManagmentCore.Domains.HR.HrEmployee;
    var types = ViewBag.LeaveTypes as List<InfrastrfuctureManagmentCore.Domains.HR.HrLeaveType> ?? new();
    var hist  = ViewBag.History as List<InfrastrfuctureManagmentCore.Domains.HR.HrLeaveRequest> ?? new();
    int year  = ViewBag.Year ?? DateTime.Today.Year;
    var typeMap = types.ToDictionary(x => x.Id);
}

<style>
.bal-hero{background:linear-gradient(135deg,#1e3a5f,#2d5282);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.bal-card{background:#fff;border-radius:16px;border:.5px solid rgba(30,58,95,.1);box-shadow:0 2px 10px rgba(30,58,95,.05);overflow:hidden;margin-bottom:10px}
.bal-row{padding:14px 18px;display:flex;align-items:center;gap:14px}
.bal-prog{height:8px;border-radius:999px;background:#e2e8f0;overflow:hidden;flex:1}
.bal-fill{height:100%;border-radius:999px;transition:width .3s}
.bal-num{font-size:1.1rem;font-weight:800}
.hist-row{padding:9px 16px;display:flex;align-items:center;gap:10px;border-top:.5px solid rgba(30,58,95,.05);font-size:.82rem}
</style>

<div class="bal-hero">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h5 class="fw-bold mb-1 text-white"><i class="bx bx-wallet me-2"></i>رصيد الإجازات</h5>
      <div style="opacity:.75;font-size:.8rem">
        @emp?.FullName — @emp?.JobTitle?.Name — سنة @year
      </div>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <form method="get" class="d-flex gap-2">
        <input type="hidden" name="employeeId" value="@emp?.Id"/>
        <input type="number" name="year" value="@year" class="form-control form-control-sm" style="border-radius:9px;width:80px"/>
        <button type="submit" class="btn btn-light btn-sm" style="border-radius:9px">عرض</button>
      </form>
      <a asp-action="Create" asp-route-employeeId="@emp?.Id"
         class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">
        <i class="bx bx-plus me-1"></i>طلب إجازة
      </a>
    </div>
  </div>
</div>

@* أرصدة أنواع الإجازات *@
@foreach (var bal in Model)
{
  if (!typeMap.TryGetValue(bal.LeaveTypeId, out var lt)) continue;
  var pct = lt.MaxDaysPerYear > 0 ? Math.Min((double)bal.TotalUsed / lt.MaxDaysPerYear * 100, 100) : 0;
  var remColor = bal.Remaining <= 0 ? "#f46a6a" : bal.Remaining <= 3 ? "#f1b44c" : "#34c38f";

  <div class="bal-card">
    <div class="bal-row">
      <div style="width:10px;height:40px;border-radius:5px;background:@lt.Color;flex-shrink:0"></div>
      <div class="flex-grow-1">
        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
          <span class="fw-bold" style="font-size:.9rem">@lt.NameAr</span>
          @if (!lt.PaidLeave)
          { <span style="font-size:.7rem;color:#f46a6a;background:rgba(244,106,106,.1);padding:1px 7px;border-radius:5px">بدون راتب</span> }
          @if (lt.RequiresAttachment)
          { <span style="font-size:.7rem;color:#6b7d80">📎 تتطلب مستند</span> }
        </div>
        <div class="bal-prog">
          <div class="bal-fill" style="width:@pct%;background:@lt.Color"></div>
        </div>
        <div class="d-flex gap-3 mt-1" style="font-size:.73rem;color:#6b7d80">
          <span>مستحق: <strong>@bal.TotalEntitled</strong></span>
          @if (bal.CarriedOver > 0)
          { <span>مُرحَّل: <strong>@bal.CarriedOver</strong></span> }
          <span>مستخدم: <strong style="color:#f46a6a">@bal.TotalUsed</strong></span>
          @if (bal.TotalPending > 0)
          { <span>معلق: <strong style="color:#f1b44c">@bal.TotalPending</strong></span> }
        </div>
      </div>
      <div class="text-center" style="min-width:60px">
        <div class="bal-num" style="color:@remColor">@bal.Remaining</div>
        <div style="font-size:.67rem;color:#adb5bd">متبقي</div>
      </div>

      @* تعديل رصيد *@
      <button type="button" class="btn btn-sm"
              style="border-radius:8px;background:rgba(30,58,95,.08);color:#1e3a5f;border:none;font-size:.72rem"
              data-bs-toggle="modal" data-bs-target="#adj-@bal.Id.ToString("N")">
        <i class="bx bx-edit"></i>
      </button>
    </div>
  </div>

  @* Modal تعديل الرصيد *@
  <div class="modal fade" id="adj-@bal.Id.ToString("N")" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content" style="border-radius:16px">
        <div class="modal-header" style="background:@lt.Color;border-radius:16px 16px 0 0;color:#fff;border:none">
          <h6 class="modal-title fw-bold">تعديل رصيد @lt.NameAr</h6>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form asp-action="AdjustBalance" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" name="employeeId" value="@emp?.Id"/>
          <input type="hidden" name="leaveTypeId" value="@lt.Id"/>
          <input type="hidden" name="year" value="@year"/>
          <div class="modal-body p-3">
            <div class="mb-2">
              <label class="form-label fw-semibold" style="font-size:.82rem">المستحق الجديد</label>
              <input name="newEntitled" type="number" step="0.5" value="@bal.TotalEntitled"
                     class="form-control" style="border-radius:10px"/>
            </div>
            <div class="mb-2">
              <label class="form-label fw-semibold" style="font-size:.82rem">تعديل إضافي (+ أو -)</label>
              <input name="adjustment" type="number" step="0.5" value="0"
                     class="form-control" style="border-radius:10px"/>
            </div>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-primary fw-bold" style="border-radius:10px">حفظ</button>
            <button type="button" class="btn btn-light" data-bs-dismiss="modal">إلغاء</button>
          </div>
        </form>
      </div>
    </div>
  </div>
}

@* سجل الإجازات *@
@if (hist.Any())
{
  <div class="bal-card mt-3">
    <div style="padding:12px 16px;border-bottom:.5px solid rgba(30,58,95,.08);font-weight:700;font-size:.88rem;color:#1e3a5f">
      <i class="bx bx-history me-2"></i>سجل الإجازات — @year
    </div>
    @foreach (var r in hist)
    {
      var sc = r.Status switch{"Approved"=>"#34c38f","Pending"=>"#f1b44c","Rejected"=>"#f46a6a",_=>"#adb5bd"};
      var sa = r.Status switch{"Approved"=>"معتمدة","Pending"=>"معلقة","Rejected"=>"مرفوضة","Cancelled"=>"ملغاة",_=>r.Status};
      <div class="hist-row">
        <div style="width:8px;height:8px;border-radius:50%;background:@(r.LeaveType?.Color ?? "#adb5bd");flex-shrink:0"></div>
        <span class="flex-grow-1">@(r.LeaveType?.NameAr ?? "—")</span>
        <span style="color:#6b7d80">@r.StartDate.ToString("d/M") — @r.EndDate.ToString("d/M")</span>
        <span class="fw-semibold">@r.TotalDays يوم</span>
        <span style="padding:2px 8px;border-radius:5px;font-size:.68rem;font-weight:700;background:@sc + "22";color:@sc">@sa</span>
      </div>
    }
  </div>
}

@model InfrastrfuctureManagmentCore.Domains.HR.HrLeaveRequest
@{
    ViewData["Title"] = "طلب إجازة جديد";
    var balMap = ViewBag.BalanceMap as Dictionary<Guid, decimal> ?? new();
    var types  = ViewBag.LeaveTypes as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<style>
.cr-hero{background:linear-gradient(135deg,#065f46,#0e6f73);border-radius:16px;padding:16px 22px;color:#fff;margin-bottom:18px}
.cr-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 10px rgba(14,111,115,.05);overflow:hidden;margin-bottom:16px}
.cr-head{padding:13px 18px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.9rem;font-weight:700;color:#0a5f63;background:rgba(14,111,115,.03)}
.cr-body{padding:18px}
.balance-alert{background:rgba(52,195,143,.07);border-radius:10px;padding:10px 14px;font-size:.82rem;color:#065f46;border:.5px solid rgba(52,195,143,.2);margin-top:6px;display:none}
</style>

<div class="cr-hero">
  <h5 class="fw-bold mb-1 text-white"><i class="bx bx-calendar-plus me-2"></i>تقديم طلب إجازة</h5>
</div>

<form asp-action="Create" method="post">
  @Html.AntiForgeryToken()
  <div asp-validation-summary="All" class="alert alert-danger mb-3" style="border-radius:12px"></div>

  <div class="cr-card">
    <div class="cr-head"><i class="bx bx-user me-2"></i>بيانات الطلب</div>
    <div class="cr-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label asp-for="EmployeeId" class="form-label fw-semibold" style="font-size:.83rem">الموظف</label>
          <select asp-for="EmployeeId" asp-items="types" class="form-select" style="border-radius:10px" id="empSel">
            <option value="">-- اختر الموظف --</option>
            @if (ViewBag.Employees is List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> emps)
            { @foreach (var e in emps) { <option value="@e.Value">@e.Text</option> } }
          </select>
          <span asp-validation-for="EmployeeId" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
          <label asp-for="LeaveTypeId" class="form-label fw-semibold" style="font-size:.83rem">نوع الإجازة</label>
          <select asp-for="LeaveTypeId" asp-items="types" class="form-select" style="border-radius:10px"
                  id="typeSel" onchange="showBalance()">
            <option value="">-- اختر النوع --</option>
          </select>
          <div id="balance-info" class="balance-alert"></div>
          <span asp-validation-for="LeaveTypeId" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold" style="font-size:.83rem">نصف يوم؟</label>
          <div class="form-check mt-2">
            <input asp-for="IsHalfDay" class="form-check-input" id="halfDayChk" onchange="toggleHalf()"/>
            <label class="form-check-label" for="halfDayChk">طلب نصف يوم فقط</label>
          </div>
        </div>
        <div class="col-md-3">
          <label asp-for="StartDate" class="form-label fw-semibold" style="font-size:.83rem"></label>
          <input asp-for="StartDate" type="date" class="form-control" style="border-radius:10px"
                 onchange="calcDays()"/>
          <span asp-validation-for="StartDate" class="text-danger small"></span>
        </div>
        <div class="col-md-3" id="endDateWrap">
          <label asp-for="EndDate" class="form-label fw-semibold" style="font-size:.83rem"></label>
          <input asp-for="EndDate" type="date" class="form-control" style="border-radius:10px"
                 onchange="calcDays()"/>
        </div>
        <div class="col-md-3" id="halfPeriodWrap" style="display:none">
          <label class="form-label fw-semibold" style="font-size:.83rem">الفترة</label>
          <select asp-for="HalfDayPeriod" class="form-select" style="border-radius:10px">
            <option value="Morning">صباحي</option>
            <option value="Afternoon">مسائي</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">عدد الأيام المحسوبة</label>
          <input id="daysCalc" class="form-control" style="border-radius:10px;background:#f8fbfb"
                 readonly value="0"/>
        </div>
        <div class="col-12">
          <label asp-for="Reason" class="form-label fw-semibold" style="font-size:.83rem"></label>
          <textarea asp-for="Reason" class="form-control" rows="2" style="border-radius:10px"
                    placeholder="سبب الإجازة..."></textarea>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-success fw-bold" style="border-radius:12px">
      <i class="bx bx-send me-1"></i>تقديم الطلب
    </button>
    <a asp-action="Index" class="btn btn-light fw-bold" style="border-radius:12px">إلغاء</a>
  </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial"/>
<script>
var balanceMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(balMap.ToDictionary(x => x.Key.ToString(), x => x.Value)));

function showBalance() {
    var typeId = document.getElementById('typeSel').value;
    var info = document.getElementById('balance-info');
    if (typeId && balanceMap[typeId] !== undefined) {
        info.style.display = '';
        var rem = balanceMap[typeId];
        info.innerHTML = '<i class="bx bx-wallet me-1"></i>الرصيد المتبقي: <strong>' + rem + ' يوم</strong>';
        info.style.color = rem <= 0 ? '#f46a6a' : rem <= 3 ? '#92400e' : '#065f46';
        info.style.background = rem <= 0 ? 'rgba(244,106,106,.07)' : 'rgba(52,195,143,.07)';
        info.style.borderColor = rem <= 0 ? 'rgba(244,106,106,.2)' : 'rgba(52,195,143,.2)';
    } else { info.style.display = 'none'; }
}

function toggleHalf() {
    var half = document.getElementById('halfDayChk').checked;
    document.getElementById('endDateWrap').style.opacity = half ? '.4' : '1';
    document.getElementById('halfPeriodWrap').style.display = half ? '' : 'none';
    document.getElementById('daysCalc').value = half ? '0.5' : '';
    if (!half) calcDays();
}

function calcDays() {
    var start = new Date(document.querySelector('[name="StartDate"]').value);
    var end   = new Date(document.querySelector('[name="EndDate"]').value);
    if (!start || !end || isNaN(start) || isNaN(end)) return;
    var days = 0;
    for (var d = new Date(start); d <= end; d.setDate(d.getDate()+1))
        if (d.getDay() !== 5 && d.getDay() !== 6) days++;
    document.getElementById('daysCalc').value = days;
}
</script>
}

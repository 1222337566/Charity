@model List<InfrastrfuctureManagmentCore.Domains.HR.HrLeaveRequest>
@{
    ViewData["Title"] = "طلبات الإجازات";
    var leaveTypes = ViewBag.LeaveTypes as List<InfrastrfuctureManagmentCore.Domains.HR.HrLeaveType> ?? new();
    string Sc(string s) => s switch { "Approved"=>"#34c38f","Pending"=>"#f1b44c","Rejected"=>"#f46a6a","Cancelled"=>"#adb5bd",_=>"#adb5bd" };
    string Sa(string s) => s switch { "Approved"=>"معتمدة","Pending"=>"معلقة","Rejected"=>"مرفوضة","Cancelled"=>"ملغاة",_=>s };
}

<style>
.lv-hero{background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.lv-stat{background:rgba(255,255,255,.13);border-radius:12px;padding:10px 14px;text-align:center;flex:1;min-width:70px}
.lv-stat .n{font-size:1.3rem;font-weight:800}
.lv-stat .l{font-size:.67rem;opacity:.8}
.lv-card{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 10px rgba(14,111,115,.05);margin-bottom:10px;overflow:hidden}
.lv-row{padding:12px 16px;display:flex;align-items:center;gap:12px}
.type-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.s-badge{padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700}
.filter-bar{background:#f8fbfb;border-radius:14px;padding:12px 16px;margin-bottom:16px;display:flex;gap:10px;flex-wrap:wrap;align-items:center;border:.5px solid rgba(14,111,115,.1)}
</style>

<div class="lv-hero">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h4 class="fw-bold mb-1 text-white"><i class="bx bx-calendar-minus me-2"></i>طلبات الإجازات</h4>
      <div style="opacity:.7;font-size:.8rem">إدارة ومتابعة طلبات الإجازات للموظفين</div>
    </div>
    <div class="d-flex gap-2">
      <a asp-action="LeaveTypes" class="btn btn-light btn-sm fw-bold" style="border-radius:10px">
        <i class="bx bx-cog me-1"></i>أنواع الإجازات
      </a>
      <a asp-action="Create" class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">
        <i class="bx bx-plus me-1"></i>طلب إجازة جديد
      </a>
    </div>
  </div>
  <div class="d-flex gap-3 flex-wrap">
    <div class="lv-stat"><div class="n">@Model.Count</div><div class="l">إجمالي الطلبات</div></div>
    <div class="lv-stat" style="background:rgba(241,180,76,.2)"><div class="n" style="color:#fde68a">@ViewBag.PendingCount</div><div class="l">معلقة</div></div>
    <div class="lv-stat" style="background:rgba(52,195,143,.2)"><div class="n" style="color:#a7f3d0">@ViewBag.ApprovedCount</div><div class="l">معتمدة</div></div>
    <div class="lv-stat" style="background:rgba(244,106,106,.2)"><div class="n" style="color:#fca5a5">@Model.Count(x=>x.Status=="Rejected")</div><div class="l">مرفوضة</div></div>
  </div>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px"><i class="bx bx-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Warning"] != null)
{ <div class="alert alert-warning alert-dismissible fade show" style="border-radius:12px">@TempData["Warning"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-danger alert-dismissible fade show" style="border-radius:12px">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

@* فلتر *@
<form method="get" class="filter-bar">
    @{
        var selectedEmployeeId = Convert.ToString(ViewBag.EmployeeId);
        var selectedStatus = Convert.ToString(ViewBag.Status);
    }

    <select name="employeeId" class="form-select form-select-sm" style="border-radius:9px;width:auto;min-width:160px"
            onchange="this.form.submit()">
        <option value="">-- كل الموظفين --</option>
        @if (ViewBag.Employees is List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> emps)
        {
            foreach (var e in emps)
            {
                <option value="@e.Value" selected="@(selectedEmployeeId == e.Value)">@e.Text</option>
            }
        }
    </select>

    <select name="status" class="form-select form-select-sm" style="border-radius:9px;width:auto"
            onchange="this.form.submit()">
        <option value="">-- كل الحالات --</option>
        @foreach (var s in new[] {
        ("Pending", "معلقة"),
        ("Approved", "معتمدة"),
        ("Rejected", "مرفوضة"),
        ("Cancelled", "ملغاة")
        })
        {
            <option value="@s.Item1" selected="@(selectedStatus == s.Item1)">@s.Item2</option>
        }
    </select>
  <input type="number" name="year" value="@ViewBag.Year" class="form-control form-control-sm"
         style="border-radius:9px;width:90px" onchange="this.form.submit()"/>
</form>

@* قائمة الطلبات *@
@if (!Model.Any())
{
  <div class="text-center py-5" style="background:#fff;border-radius:16px;color:#adb5bd">
    <i class="bx bx-calendar-minus" style="font-size:3rem;display:block;margin-bottom:12px"></i>
    <p>لا توجد طلبات إجازة بالفلتر الحالي</p>
    <a asp-action="Create" class="btn btn-primary fw-bold" style="border-radius:12px">تقديم طلب جديد</a>
  </div>
}

@foreach (var req in Model)
{
  var lt = req.LeaveType;
  <div class="lv-card">
    <div class="lv-row">
      <div class="type-dot" style="background:@(lt?.Color ?? "#adb5bd")"></div>
      <div class="flex-grow-1 min-w-0">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <span class="fw-bold" style="font-size:.88rem">@req.Employee?.FullName</span>
          <span style="font-size:.75rem;color:#6b7d80;background:rgba(14,111,115,.08);padding:1px 7px;border-radius:5px">
            @(lt?.NameAr ?? "—")
          </span>
          <span class="s-badge" style="background:@(Sc(req.Status))22;color:@Sc(req.Status)">
            @Sa(req.Status)
          </span>
          @if (req.IsHalfDay)
          { <span style="font-size:.68rem;color:#6b7d80">نصف يوم</span> }
        </div>
        <div style="font-size:.78rem;color:#6b7d80;margin-top:3px">
          <i class="bx bx-calendar me-1"></i>
          @req.StartDate.ToString("d/M/yyyy")
          @if (req.StartDate != req.EndDate) { <span> — @req.EndDate.ToString("d/M/yyyy")</span> }
          &nbsp;·&nbsp; <strong>@req.TotalDays يوم</strong>
          &nbsp;·&nbsp; @req.RequestNumber
          @if (!string.IsNullOrWhiteSpace(req.Employee?.Department?.Name))
          { <span> · @req.Employee.Department.Name</span> }
        </div>
        @if (!string.IsNullOrWhiteSpace(req.Reason))
        {
          <div style="font-size:.75rem;color:#adb5bd;margin-top:2px">
            <i class="bx bx-comment me-1"></i>@req.Reason
          </div>
        }
        @if (req.Status == "Rejected" && !string.IsNullOrWhiteSpace(req.RejectionReason))
        {
          <div style="font-size:.75rem;color:#f46a6a;margin-top:2px">
            <i class="bx bx-x me-1"></i>@req.RejectionReason
          </div>
        }
      </div>

      @* الإجراءات *@
      <div class="d-flex gap-1 flex-shrink-0 flex-wrap">
        @if (req.Status == "Pending")
        {
          <form asp-action="Approve" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@req.Id"/>
            <button type="submit" class="btn btn-sm fw-bold"
                    style="border-radius:8px;background:rgba(52,195,143,.1);color:#065f46;border:none;font-size:.75rem">
              <i class="bx bx-check me-1"></i>موافقة
            </button>
          </form>
          <button type="button" class="btn btn-sm fw-bold"
                  style="border-radius:8px;background:rgba(244,106,106,.1);color:#f46a6a;border:none;font-size:.75rem"
                  data-bs-toggle="modal" data-bs-target="#reject-@req.Id.ToString("N")">
            <i class="bx bx-x me-1"></i>رفض
          </button>
        }
        @if (req.Status == "Pending" || req.Status == "Approved")
        {
          <form asp-action="Cancel" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@req.Id"/>
            <button type="submit" class="btn btn-sm"
                    style="border-radius:8px;background:rgba(173,181,189,.1);color:#6b7d80;border:none;font-size:.75rem"
                    onclick="return confirm('إلغاء هذا الطلب؟')">
              إلغاء
            </button>
          </form>
        }
        <a asp-action="Balance" asp-route-employeeId="@req.EmployeeId"
           class="btn btn-sm" style="border-radius:8px;background:rgba(14,111,115,.08);color:#0e6f73;border:none;font-size:.75rem">
          <i class="bx bx-wallet"></i>
        </a>
      </div>
    </div>
  </div>

  @* Reject Modal *@
  @if (req.Status == "Pending")
  {
    <div class="modal fade" id="reject-@req.Id.ToString("N")" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border-radius:16px">
          <div class="modal-header" style="background:#f46a6a;border-radius:16px 16px 0 0;color:#fff;border:none">
            <h6 class="modal-title fw-bold">رفض طلب إجازة</h6>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <form asp-action="Reject" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@req.Id"/>
            <div class="modal-body p-3">
              <textarea name="reason" class="form-control" rows="3" style="border-radius:10px"
                        placeholder="سبب الرفض..." required></textarea>
            </div>
            <div class="modal-footer">
              <button type="submit" class="btn btn-danger fw-bold" style="border-radius:10px">تأكيد الرفض</button>
              <button type="button" class="btn btn-light" data-bs-dismiss="modal">إلغاء</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  }
}

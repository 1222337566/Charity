@model IEnumerable<InfrastructureManagmentWebFramework.Models.HR.Advanced.OutRequests.OutRequestListItemVm>
@{ ViewData["Title"] = "طلبات الخروج"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h3 class="mb-0">طلبات الخروج</h3><a asp-action="Create" asp-route-employeeId="@ViewBag.EmployeeId" class="btn btn-primary">إضافة طلب</a></div>
<table class="table table-bordered table-striped align-middle">
<thead><tr><th>الموظف</th><th>التاريخ</th><th>من</th><th>إلى</th><th>الحالة</th><th>السبب</th><th></th></tr></thead>
<tbody>@foreach (var item in Model){<tr><td>@item.EmployeeName</td><td>@item.OutDate.ToString("yyyy-MM-dd")</td><td>@item.FromTime</td><td>@item.ToTime</td><td>@item.Status</td><td>@item.Reason</td><td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a></td></tr>}</tbody>
</table>

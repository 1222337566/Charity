@model IEnumerable<InfrastructureManagmentWebFramework.Models.HR.Advanced.Evaluations.PerformanceEvaluationListItemVm>
@{ ViewData["Title"] = "تقييم الأداء"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h3 class="mb-0">تقييمات الأداء</h3><a asp-action="Create" asp-route-employeeId="@ViewBag.EmployeeId" class="btn btn-primary">إضافة تقييم</a></div>
<table class="table table-bordered table-striped align-middle">
<thead><tr><th>الموظف</th><th>الفترة</th><th>التاريخ</th><th>الإجمالي</th><th>النتيجة</th><th>المقيم</th><th></th></tr></thead>
<tbody>@foreach (var item in Model){<tr><td>@item.EmployeeName</td><td>@item.EvaluationPeriod</td><td>@item.EvaluationDate.ToString("yyyy-MM-dd")</td><td>@item.TotalScore</td><td>@item.Result</td><td>@(item.EvaluatorName ?? "-")</td><td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a></td></tr>}</tbody>
</table>

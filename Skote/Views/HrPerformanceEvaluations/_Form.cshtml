@model InfrastructureManagmentWebFramework.Models.HR.Advanced.Evaluations.CreatePerformanceEvaluationVm
<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.Employees" class="form-select"></select></div>
        <div class="col-md-6"><label asp-for="EvaluatorEmployeeId" class="form-label"></label><select asp-for="EvaluatorEmployeeId" asp-items="Model.Employees" class="form-select"><option value="">--</option></select></div>
        <div class="col-md-6"><label asp-for="EvaluationPeriod" class="form-label"></label><input asp-for="EvaluationPeriod" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="EvaluationDate" class="form-label"></label><input asp-for="EvaluationDate" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="DisciplineScore" class="form-label"></label><input asp-for="DisciplineScore" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="PerformanceScore" class="form-label"></label><input asp-for="PerformanceScore" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="CooperationScore" class="form-label"></label><input asp-for="CooperationScore" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="InitiativeScore" class="form-label"></label><input asp-for="InitiativeScore" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="Result" class="form-label"></label><select asp-for="Result" asp-items="Model.Results" class="form-select"></select></div>
        <div class="col-md-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div>
    </div>
    <div class="mt-3 d-flex gap-2"><button class="btn btn-primary" type="submit">حفظ</button><a asp-action="Index" asp-route-employeeId="@Model.EmployeeId" class="btn btn-secondary">رجوع</a></div>
</form>

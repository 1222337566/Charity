@model IEnumerable<InfrastructureManagmentWebFramework.Models.HR.Advanced.Sanctions.SanctionRecordListItemVm>
@{ ViewData["Title"] = "الجزاءات"; }
<div class="d-flex justify-content-between align-items-center mb-3"><h3 class="mb-0">الجزاءات</h3><a asp-action="Create" asp-route-employeeId="@ViewBag.EmployeeId" class="btn btn-primary">إضافة جزاء</a></div>
<table class="table table-bordered table-striped align-middle">
<thead><tr><th>الموظف</th><th>النوع</th><th>التاريخ</th><th>القيمة</th><th>السبب</th><th></th></tr></thead>
<tbody>@foreach (var item in Model){<tr><td>@item.EmployeeName</td><td>@item.SanctionType</td><td>@item.SanctionDate.ToString("yyyy-MM-dd")</td><td>@(item.Amount?.ToString("N2") ?? "-")</td><td>@item.Reason</td><td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a></td></tr>}</tbody>
</table>

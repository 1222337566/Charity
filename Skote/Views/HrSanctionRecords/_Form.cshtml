@model InfrastructureManagmentWebFramework.Models.HR.Advanced.Sanctions.CreateSanctionRecordVm
<form method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.Employees" class="form-select"></select></div>
        <div class="col-md-6"><label asp-for="SanctionType" class="form-label"></label><select asp-for="SanctionType" asp-items="Model.SanctionTypes" class="form-select"></select></div>
        <div class="col-md-4"><label asp-for="SanctionDate" class="form-label"></label><input asp-for="SanctionDate" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" class="form-control" /></div>
        <div class="col-md-12"><label asp-for="Reason" class="form-label"></label><textarea asp-for="Reason" class="form-control" rows="3"></textarea></div>
        <div class="col-md-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
    </div>
    <div class="mt-3 d-flex gap-2"><button class="btn btn-primary" type="submit">حفظ</button><a asp-action="Index" asp-route-employeeId="@Model.EmployeeId" class="btn btn-secondary">رجوع</a></div>
</form>

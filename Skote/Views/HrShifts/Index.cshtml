@model List<InfrastructureManagmentWebFramework.Models.HR.Shifts.ShiftListItemVm>
<div class="card"><div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3"><div><h4 class="mb-1">الشيفتات</h4><p class="text-muted mb-0">إدارة مواعيد العمل</p></div><a asp-action="Create" class="btn btn-primary">إضافة شيفت</a></div>
    <div class="table-responsive"><table class="table table-bordered table-hover align-middle"><thead><tr><th>الاسم</th><th>من</th><th>إلى</th><th>السماح</th><th>نشط</th><th></th></tr></thead><tbody>@foreach (var item in Model){<tr><td>@item.Name</td><td>@item.StartTime</td><td>@item.EndTime</td><td>@item.GraceMinutes</td><td>@(item.IsActive ? "نعم" : "لا")</td><td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a></td></tr>}</tbody></table></div>
</div></div>

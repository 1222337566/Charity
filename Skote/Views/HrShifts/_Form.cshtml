@model InfrastructureManagmentWebFramework.Models.HR.Shifts.CreateShiftVm
<div class="row g-3">
    <div class="col-md-4"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="StartTime" class="form-label"></label><input asp-for="StartTime" type="time" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="EndTime" class="form-label"></label><input asp-for="EndTime" type="time" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="GraceMinutes" class="form-label"></label><input asp-for="GraceMinutes" class="form-control" /></div>
    <div class="col-md-2 form-check mt-4"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>
    <div class="col-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div>
</div>

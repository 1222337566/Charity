@model InfrastructureManagmentWebFramework.Models.InventoryValuation.InventoryValuationPageVm

@{
    ViewData["Title"] = "تقرير تقييم المخزون";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="card-title mb-0">تقرير تقييم المخزون</h4>
        <span class="badge bg-primary">Average Cost</span>
    </div>

    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-md-4">
                <label class="form-label">المخزن</label>
                <select name="warehouseId" class="form-select" asp-items="Model.Warehouses">
                    <option value="">كل المخازن</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">حتى تاريخ</label>
                <input type="datetime-local" name="asOfDateUtc" class="form-control"
                       value="@Model.AsOfDateUtc.ToString("yyyy-MM-ddTHH:mm")" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">عرض</button>
            </div>
        </form>

        <div class="row mb-3">
            <div class="col-md-4">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted">إجمالي الكمية</div>
                    <div class="fs-5 fw-bold">@Model.TotalQuantity.ToString("N2")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted">إجمالي قيمة المخزون</div>
                    <div class="fs-5 fw-bold">@Model.TotalValue.ToString("N2")</div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead>
                    <tr>
                        <th>المخزن</th>
                        <th>كود الصنف</th>
                        <th>اسم الصنف</th>
                        <th class="text-end">الرصيد الفعلي</th>
                        <th class="text-end">المتاح</th>
                        <th class="text-end">متوسط التكلفة</th>
                        <th class="text-end">قيمة المخزون</th>
                        <th class="text-end">آخر تكلفة شراء</th>
                        <th>آخر حركة</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>@row.WarehouseNameAr</td>
                            <td>@row.ItemCode</td>
                            <td>@row.ItemNameAr</td>
                            <td class="text-end">@row.QuantityOnHand.ToString("N2")</td>
                            <td class="text-end">@row.AvailableQuantity.ToString("N2")</td>
                            <td class="text-end">@row.AverageUnitCost.ToString("N4")</td>
                            <td class="text-end fw-bold">@row.InventoryValue.ToString("N2")</td>
                            <td class="text-end">@row.LastPurchaseUnitCost.ToString("N4")</td>
                            <td>@(row.LastTransactionDateUtc?.ToLocalTime().ToString("yyyy/MM/dd") ?? "-")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-light fw-bold">
                        <td colspan="3">الإجمالي</td>
                        <td class="text-end">@Model.TotalQuantity.ToString("N2")</td>
                        <td></td>
                        <td></td>
                        <td class="text-end">@Model.TotalValue.ToString("N2")</td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        @if (!Model.Rows.Any())
        {
            <div class="alert alert-info mb-0">
                لا توجد أرصدة مخزون للعرض.
            </div>
        }
    </div>
</div>

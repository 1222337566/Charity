@model List<ItemListItemVm>
@using InfrastructureManagmentWebFramework.Models.FinancialAccounting;

@{
    ViewData["Title"] = "الأصناف";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">الأصناف</h4>
            <a asp-action="Create" class="btn btn-primary btn-sm">إضافة صنف</a>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>الكود</th>
                            <th>النوع</th>
                            <th>الماركة</th>
                            <th>الموديل</th>
                            <th>اللون</th>
                            <th>Prescription</th>
                            <th>الاسم</th>
                            <th>الباركود</th>
                            <th>المجموعة</th>
                            <th>الوحدة</th>
                            <th>شراء</th>
                            <th>بيع</th>
                            <th>النوع</th>
                            <th>الضريبة</th>
                            <th>الحالة</th>

                            <th>الإجراءات</th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ItemCode</td>
                                <td>@item.OpticalItemTypeText</td>
                                <td>@(item.BrandName ?? "-")</td>
                                <td>@(item.ModelName ?? "-")</td>
                                <td>@(item.Color ?? "-")</td>
                                <td>@(item.RequiresPrescription ? "نعم" : "-")</td>
                                <td>@item.ItemNameAr</td>
                                <td>@(item.Barcode ?? "-")</td>
                                <td>@item.GroupName</td>
                                <td>@item.UnitName</td>
                                <td>@item.PurchasePrice</td>
                                <td>@item.SalePrice</td>
                                <td>
                                    @if (item.IsService)
                                    {
                                        <span class="badge bg-info">خدمة</span>
                                    }
                                    else if (item.IsStockItem)
                                    {
                                        <span class="badge bg-primary">مخزني</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">غير مخزني</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsTaxable)
                                    {
                                        <span>@item.TaxRate %</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">غير نشط</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                            تعديل
                                        </a>

                                        <form asp-action="ToggleActive" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />

                                            @if (item.IsActive)
                                            {
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('هل تريد تعطيل الصنف؟');">
                                                    تعطيل
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-success"
                                                        onclick="return confirm('هل تريد تفعيل الصنف؟');">
                                                    تفعيل
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
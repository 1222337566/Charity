@model InfrastructureManagmentWebFramework.Models.Accounting.JournalEntryDetailsVm
@{
    ViewData["Title"] = "تفاصيل القيد";

    string StatusText(string s) => s switch
    {
        "Draft"    => "مسودة",
        "Posted"   => "مرحل",
        "Reversed" => "معكوس",
        "Cancelled"=> "ملغي",
        _          => s
    };
    string StatusClass(string s) => s switch
    {
        "Draft"    => "bg-warning-subtle text-warning",
        "Posted"   => "bg-success-subtle text-success",
        "Reversed" => "bg-info-subtle text-info",
        "Cancelled"=> "bg-secondary-subtle text-secondary",
        _          => "bg-light text-dark"
    };
}

<style>
    .details-card { border:none; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,.07); }
    .info-label   { font-size:.75rem; color:#6c757d; text-transform:uppercase; letter-spacing:.5px; font-weight:600; }
    .info-val     { font-size:.95rem; font-weight:500; }
    .manual-badge { background:linear-gradient(135deg,#6f42c1,#495057); color:#fff; border-radius:20px; font-size:.72rem; padding:3px 10px; }
    .source-badge { background:#e3f2fd; color:#1565c0; border-radius:20px; font-size:.72rem; padding:3px 10px; }
    .lines-table thead th { background:#f1f3f5; font-size:.8rem; font-weight:600; color:#495057; white-space:nowrap; }
    .lines-table tbody td { vertical-align:middle; font-size:.88rem; }
    .stat-card    { border:none; border-radius:12px; }
</style>

<div class="page-content">
  <div class="container-fluid" dir="rtl">

    @if (TempData["Success"] != null)
    {
      <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="alert alert-danger alert-dismissible fade show" style="border-radius:12px">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }

    {{!-- رأس الصفحة --}}
    <div class="card details-card mb-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
          <div>
            <h4 class="mb-1 d-flex align-items-center gap-2">
              قيد يومية رقم <span class="text-primary">@Model.EntryNumber</span>
              <span class="badge @StatusClass(Model.Status)">@StatusText(Model.Status)</span>
              @if (Model.IsManual)
              {
                <span class="manual-badge">تم عمله يدوياً</span>
              }
              else if (!string.IsNullOrWhiteSpace(Model.SourceType))
              {
                <span class="source-badge">@Model.SourceType</span>
              }
            </h4>
            <div class="text-muted small">
              التاريخ: <strong>@Model.EntryDate.ToString("yyyy-MM-dd")</strong> |
              الفترة: <strong>@Model.FiscalPeriodName</strong>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
              <div class="mt-2">@Model.Description</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
              <div class="mt-1 text-muted small">@Model.Notes</div>
            }
            @if (Model.IsManual)
            {
              <div class="mt-2">
                <span class="badge bg-purple-subtle" style="background:#ede7f6;color:#6f42c1;border-radius:8px;padding:5px 12px">
                  <i class="bx bx-pencil me-1"></i> هذا القيد تم إنشاؤه يدوياً بدون مصدر تشغيلي
                </span>
              </div>
            }
            @if (!Model.IsManual && Model.SourceId.HasValue)
            {
              <div class="mt-2">
                <span class="badge" style="background:#e3f2fd;color:#1565c0;border-radius:8px;padding:5px 12px">
                  <i class="bx bx-link me-1"></i> مرتبط بالمصدر: @Model.SourceType — رقم @Model.SourceId.ToString()?.Substring(0,8).ToUpper()
                </span>
              </div>
            }
          </div>

          <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Index" class="btn btn-light btn-sm" style="border-radius:10px">رجوع</a>
            <a asp-action="Print" asp-route-id="@Model.Id" target="_blank" class="btn btn-dark btn-sm" style="border-radius:10px">
              <i class="bx bx-printer me-1"></i> طباعة
            </a>
            @if (Model.Status == "Draft")
            {
              <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm" style="border-radius:10px">تعديل</a>
              <a asp-action="AddLine" asp-route-journalEntryId="@Model.Id" class="btn btn-success btn-sm" style="border-radius:10px">
                <i class="bx bx-plus me-1"></i> إضافة سطر
              </a>
              <form asp-action="Post" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning btn-sm" style="border-radius:10px"
                        onclick="return confirm('هل تريد ترحيل هذا القيد؟ بعد الترحيل لن يمكن تعديله.')">ترحيل</button>
              </form>
              <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm" style="border-radius:10px"
                        onclick="return confirm('سيتم إلغاء القيد المسودة. هل تريد المتابعة؟')">إلغاء</button>
              </form>
            }
            @if (Model.Status == "Posted")
            {
              <form asp-action="Reverse" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-sm" style="border-radius:10px"
                        onclick="return confirm('سيتم إنشاء قيد عكسي. هل تريد المتابعة؟')">عكس القيد</button>
              </form>
            }
          </div>
        </div>
      </div>
    </div>

    {{!-- إجماليات --}}
    <div class="row g-2 mb-3">
      <div class="col-md-4">
        <div class="card stat-card" style="background:#e8f5e9">
          <div class="card-body py-2 px-3">
            <div class="info-label">إجمالي المدين</div>
            <div class="text-success fw-bold" style="font-size:1.2rem">@Model.TotalDebit.ToString("N2")</div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card stat-card" style="background:#fce4ec">
          <div class="card-body py-2 px-3">
            <div class="info-label">إجمالي الدائن</div>
            <div class="text-danger fw-bold" style="font-size:1.2rem">@Model.TotalCredit.ToString("N2")</div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card stat-card" style="background:@(Model.IsBalanced ? "#e8f5e9" : "#ffebee")">
          <div class="card-body py-2 px-3">
            <div class="info-label">حالة الاتزان</div>
            <div class="fw-bold" style="font-size:1.1rem;color:@(Model.IsBalanced ? "#198754" : "#dc3545")">
              @(Model.IsBalanced ? "✓ متوازن" : "✗ غير متوازن")
            </div>
          </div>
        </div>
      </div>
    </div>

    {{!-- سطور القيد --}}
    <div class="card details-card">
      <div class="card-header" style="background:#f8f9fa;border-bottom:1px solid #e9ecef;padding:14px 20px;border-radius:16px 16px 0 0">
        <h6 class="mb-0 fw-semibold">سطور القيد (@Model.Lines.Count سطر)</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-bordered table-hover align-middle mb-0 lines-table">
            <thead>
              <tr>
                <th>الحساب</th>
                <th>مركز التكلفة</th>
                <th>المشروع</th>
                <th>البيان</th>
                <th class="text-end">مدين</th>
                <th class="text-end">دائن</th>
                @if (Model.Status == "Draft")
                {
                  <th style="width:120px">إجراءات</th>
                }
              </tr>
            </thead>
            <tbody>
            @if (Model.Lines.Any())
            {
              foreach (var line in Model.Lines)
              {
                <tr>
                  <td>
                    <div class="fw-semibold small">@line.AccountCode</div>
                    <div class="text-muted" style="font-size:.78rem">@line.AccountNameAr</div>
                  </td>
                  <td>@(line.CostCenterName ?? "—")</td>
                  <td>
                    @if (!string.IsNullOrWhiteSpace(line.ProjectName))
                    {
                      <span class="badge bg-info-subtle text-info" style="border-radius:8px;padding:4px 8px;font-size:.75rem">
                        @line.ProjectName
                      </span>
                    }
                    else
                    {
                      <span class="text-muted">—</span>
                    }
                  </td>
                  <td class="text-muted small">@line.Description</td>
                  <td class="text-end fw-semibold text-success">
                    @(line.DebitAmount > 0 ? line.DebitAmount.ToString("N2") : "—")
                  </td>
                  <td class="text-end fw-semibold text-danger">
                    @(line.CreditAmount > 0 ? line.CreditAmount.ToString("N2") : "—")
                  </td>
                  @if (Model.Status == "Draft")
                  {
                    <td>
                      <div class="d-flex gap-1">
                        <a asp-action="EditLine" asp-route-id="@line.Id" class="btn btn-sm btn-primary" style="border-radius:8px;font-size:.75rem">تعديل</a>
                        <form asp-action="DeleteLine" asp-route-id="@line.Id" method="post" class="d-inline">
                          @Html.AntiForgeryToken()
                          <button type="submit" class="btn btn-sm btn-danger" style="border-radius:8px;font-size:.75rem"
                                  onclick="return confirm('حذف هذا السطر؟')">حذف</button>
                        </form>
                      </div>
                    </td>
                  }
                </tr>
              }
            }
            else
            {
              <tr><td colspan="7" class="text-center text-muted py-4">لا توجد سطور حتى الآن</td></tr>
            }
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

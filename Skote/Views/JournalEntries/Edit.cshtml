@model InfrastructureManagmentWebFramework.Models.Accounting.EditJournalEntryVm
@{
    ViewData["Title"] = "تعديل القيد";
}

<div class="page-content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <h4 class="mb-3">تعديل قيد يومية</h4>
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="EntryNumber" class="form-label"></label>
                            <input asp-for="EntryNumber" class="form-control" />
                            <span asp-validation-for="EntryNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EntryDate" class="form-label"></label>
                            <input asp-for="EntryDate" class="form-control" />
                            <span asp-validation-for="EntryDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FiscalPeriodId" class="form-label"></label>
                            <select asp-for="FiscalPeriodId" asp-items="Model.FiscalPeriods" class="form-select">
                                <option value="">-- اختر --</option>
                            </select>
                            <span asp-validation-for="FiscalPeriodId" class="text-danger"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SourceType" class="form-label"></label>
                            <input asp-for="SourceType" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SourceId" class="form-label"></label>
                            <input asp-for="SourceId" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">حفظ</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">رجوع</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

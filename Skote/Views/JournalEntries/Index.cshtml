@model List<InfrastructureManagmentWebFramework.Models.Accounting.JournalEntryListItemVm>
@{
    ViewData["Title"] = "القيود اليومية";
    var q              = Convert.ToString(ViewBag.FilterQ);
    var fromDate       = Convert.ToString(ViewBag.FilterFromDate);
    var toDate         = Convert.ToString(ViewBag.FilterToDate);
    var statusFilter   = Convert.ToString(ViewBag.FilterStatus);
    var sourceTypeFilter = Convert.ToString(ViewBag.FilterSourceType);
    var totalDebit     = (decimal?)ViewBag.TotalDebit   ?? Model.Sum(x => x.TotalDebit);
    var totalCredit    = (decimal?)ViewBag.TotalCredit  ?? Model.Sum(x => x.TotalCredit);

    string StatusText(string s) => s switch
    {
        "Draft"    => "مسودة",
        "Posted"   => "مرحل",
        "Reversed" => "معكوس",
        "Cancelled"=> "ملغي",
        _          => s
    };
    string StatusClass(string s) => s switch
    {
        "Draft"    => "bg-warning-subtle text-warning",
        "Posted"   => "bg-success-subtle text-success",
        "Reversed" => "bg-info-subtle text-info",
        "Cancelled"=> "bg-secondary-subtle text-secondary",
        _          => "bg-light text-dark"
    };
}

<style>
    .je-page-card { border:none; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,.07); }
    .stat-card { border:none; border-radius:12px; }
    .filter-card { border:none; border-radius:16px; box-shadow:0 1px 8px rgba(0,0,0,.05); }
    .je-table thead th { background:#f1f3f5; font-size:.79rem; font-weight:600; color:#495057; white-space:nowrap; border-color:#dee2e6; }
    .je-table tbody td { font-size:.86rem; vertical-align:middle; }
    .je-table tbody tr:hover { background:#f8f9fa; }
    .action-btn { border-radius:8px; font-size:.75rem; padding:3px 10px; }
    .manual-tag { background:linear-gradient(135deg,#6f42c1,#495057); color:#fff; border-radius:20px; font-size:.7rem; padding:2px 9px; }
    .auto-tag   { background:#e3f2fd; color:#1565c0; border-radius:20px; font-size:.7rem; padding:2px 9px; }
</style>

<div class="page-content">
  <div class="container-fluid" dir="rtl">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <div>
        <h4 class="mb-1">القيود اليومية</h4>
        <p class="text-muted mb-0 small">إدارة مسودات القيود وترحيلها وعكسها وإضافة القيود اليدوية</p>
      </div>
      <div class="d-flex gap-2">
        <a asp-action="CreateManual" class="btn btn-success btn-sm" style="border-radius:10px">
          <i class="bx bx-pencil me-1"></i> قيد يدوي
        </a>
        <a asp-action="Create" class="btn btn-primary btn-sm" style="border-radius:10px">
          <i class="bx bx-plus me-1"></i> قيد جديد
        </a>
      </div>
    </div>

    @if (TempData["Success"] != null)
    {
      <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="alert alert-danger alert-dismissible fade show" style="border-radius:12px">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }

   
    <div class="row g-2 mb-3">
      <div class="col-md-3">
        <div class="card stat-card" style="background:#e8f5e9">
          <div class="card-body py-2 px-3">
            <div style="font-size:.72rem;color:#6c757d;text-transform:uppercase;letter-spacing:.5px">إجمالي المدين</div>
            <div class="text-success fw-bold" style="font-size:1.15rem">@totalDebit.ToString("N2")</div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card" style="background:#fce4ec">
          <div class="card-body py-2 px-3">
            <div style="font-size:.72rem;color:#6c757d;text-transform:uppercase;letter-spacing:.5px">إجمالي الدائن</div>
            <div class="text-danger fw-bold" style="font-size:1.15rem">@totalCredit.ToString("N2")</div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card" style="background:@(totalDebit==totalCredit?"#e8f5e9":"#ffebee")">
          <div class="card-body py-2 px-3">
            <div style="font-size:.72rem;color:#6c757d;text-transform:uppercase;letter-spacing:.5px">حالة الاتزان</div>
            <div class="fw-bold" style="font-size:1.1rem;color:@(totalDebit==totalCredit?"#198754":"#dc3545")">
              @(totalDebit == totalCredit ? "✓ متوازن" : "✗ غير متوازن")
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card" style="background:#e3f2fd">
          <div class="card-body py-2 px-3">
            <div style="font-size:.72rem;color:#6c757d;text-transform:uppercase;letter-spacing:.5px">عدد القيود</div>
            <div class="text-primary fw-bold" style="font-size:1.15rem">@Model.Count</div>
          </div>
        </div>
      </div>
    </div>

    {{!-- فلاتر --}}
    <div class="card filter-card mb-3">
      <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
          <div class="col-md-3">
            <label class="form-label small fw-semibold">بحث</label>
            <input name="q" value="@q" class="form-control form-control-sm" style="border-radius:8px"
                   placeholder="رقم القيد / البيان / الملاحظات" />
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-semibold">من تاريخ</label>
            <input type="date" name="fromDate" value="@fromDate" class="form-control form-control-sm" style="border-radius:8px" />
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-semibold">إلى تاريخ</label>
            <input type="date" name="toDate" value="@toDate" class="form-control form-control-sm" style="border-radius:8px" />
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-semibold">الحالة</label>
            <select name="status" class="form-select form-select-sm" style="border-radius:8px">
              <option value="">كل الحالات</option>
              <option value="Draft"    selected=@(statusFilter=="Draft"    ?"selected":"")>مسودة</option>
              <option value="Posted"   selected=@(statusFilter=="Posted"   ?"selected":"")>مرحل</option>
              <option value="Reversed" selected=@(statusFilter=="Reversed" ?"selected":"")>معكوس</option>
              <option value="Cancelled" selected=@(statusFilter=="Cancelled"?"selected":"")>ملغي</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label small fw-semibold">نوع المصدر</label>
            <select name="sourceType" class="form-select form-select-sm" style="border-radius:8px">
              <option value="">الكل</option>
              <option value="Manual"    selected=@(sourceTypeFilter=="Manual"    ?"selected":"")>يدوي</option>
              <option value="Automatic" selected=@(sourceTypeFilter=="Automatic" ?"selected":"")>آلي / تشغيلي</option>
            </select>
          </div>
          <div class="col-md-1">
            <button type="submit" class="btn btn-primary btn-sm w-100" style="border-radius:8px">بحث</button>
          </div>
          <div class="col-12">
            <a asp-action="Index" class="btn btn-sm btn-light" style="border-radius:8px">
              <i class="bx bx-x me-1"></i> مسح الفلاتر
            </a>
          </div>
        </form>
      </div>
    </div>

    {{!-- الجدول --}}
    <div class="card je-page-card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table je-table table-bordered table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>رقم القيد</th>
                <th>التاريخ</th>
                <th>الفترة</th>
                <th>البيان</th>
                <th class="text-center">الحالة</th>
                <th class="text-center">المصدر</th>
                <th class="text-end">المدين</th>
                <th class="text-end">الدائن</th>
                <th class="text-center">اتزان</th>
                <th class="text-center">السطور</th>
                <th style="width:150px" class="text-center">إجراءات</th>
              </tr>
            </thead>
            <tbody>
            @if (Model.Any())
            {
              foreach (var item in Model)
              {
                <tr>
                  <td><span class="fw-semibold text-primary">@item.EntryNumber</span></td>
                  <td><span class="text-muted">@item.EntryDate.ToString("yyyy-MM-dd")</span></td>
                  <td><span class="text-muted small">@item.FiscalPeriodName</span></td>
                  <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@item.Description">
                    @item.Description
                  </td>
                  <td class="text-center">
                    <span class="badge @StatusClass(item.Status)" style="border-radius:20px;padding:3px 10px;font-size:.72rem">
                      @StatusText(item.Status)
                    </span>
                  </td>
                  <td class="text-center">
                    @if (item.IsManual)
                    {
                      <span class="manual-tag">يدوي</span>
                    }
                    else
                    {
                      <span class="auto-tag">@(string.IsNullOrWhiteSpace(item.SourceType) ? "آلي" : item.SourceType)</span>
                    }
                  </td>
                  <td class="text-end fw-semibold text-success">@item.TotalDebit.ToString("N2")</td>
                  <td class="text-end fw-semibold text-danger">@item.TotalCredit.ToString("N2")</td>
                  <td class="text-center">
                    @if (item.IsBalanced)
                    {
                      <span class="badge bg-success-subtle text-success" style="border-radius:20px;font-size:.7rem">✓</span>
                    }
                    else
                    {
                      <span class="badge bg-danger-subtle text-danger" style="border-radius:20px;font-size:.7rem">✗</span>
                    }
                  </td>
                  <td class="text-center">
                    <span class="badge bg-light text-dark" style="border-radius:20px">@item.LinesCount</span>
                  </td>
                  <td class="text-center">
                    <div class="d-flex gap-1 justify-content-center">
                      <a asp-action="Details" asp-route-id="@item.Id" class="action-btn btn btn-sm btn-info">عرض</a>
                      <a asp-action="Print"   asp-route-id="@item.Id" target="_blank" class="action-btn btn btn-sm btn-dark">طباعة</a>
                      @if (item.Status == "Draft")
                      {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn btn btn-sm btn-primary">تعديل</a>
                      }
                    </div>
                  </td>
                </tr>
              }
            }
            else
            {
              <tr>
                <td colspan="11" class="text-center text-muted py-5">
                  <i class="bx bx-search-alt" style="font-size:2rem;display:block;margin-bottom:8px"></i>
                  لا توجد قيود مطابقة للفلاتر
                </td>
              </tr>
            }
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

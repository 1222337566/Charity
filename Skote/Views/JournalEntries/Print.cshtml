@model InfrastructureManagmentWebFramework.Models.Accounting.JournalEntryDetailsVm
@{
    Layout = null;
    var printedAt = DateTime.Now;
    string StatusText(string status) => status switch
    {
        "Draft" => "مسودة",
        "Posted" => "مرحل",
        "Reversed" => "معكوس",
        "Cancelled" => "ملغي",
        _ => status
    };
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>طباعة قيد يومية - @Model.EntryNumber</title>
    <style>
        body{font-family:Arial,'Tahoma',sans-serif;margin:24px;color:#111;font-size:13px}
        .header{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:2px solid #111;padding-bottom:12px;margin-bottom:18px}
        .title{text-align:center;font-size:22px;font-weight:700;margin:10px 0 20px}
        .muted{color:#666;font-size:12px}
        .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:15px}
        .box{border:1px solid #ddd;border-radius:6px;padding:8px;min-height:42px}
        .box strong{display:block;margin-bottom:4px;color:#333}
        table{width:100%;border-collapse:collapse;margin-top:12px}
        th,td{border:1px solid #333;padding:7px;text-align:right;vertical-align:top}
        th{background:#f1f1f1}
        .num{text-align:left;direction:ltr}
        .total td{font-weight:700;background:#fafafa}
        .signatures{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-top:45px;text-align:center}
        .sig{border-top:1px solid #333;padding-top:8px;min-height:50px}
        .actions{margin-bottom:15px;text-align:left}
        .btn{padding:8px 14px;border:1px solid #333;background:#fff;cursor:pointer;border-radius:4px}
        @@media print{.actions{display:none} body{margin:10mm}}
    </style>
</head>
<body>
    <div class="actions">
        <button class="btn" onclick="window.print()">طباعة</button>
        <button class="btn" onclick="window.close()">إغلاق</button>
    </div>

    <div class="header">
        <div>
            <h3 style="margin:0">سند قيد يومية</h3>
            <div class="muted">تمت الطباعة: @printedAt.ToString("yyyy-MM-dd HH:mm")</div>
        </div>
        <div class="muted">النظام المحاسبي</div>
    </div>

    <div class="title">قيد يومية رقم @Model.EntryNumber</div>

    <div class="grid">
        <div class="box"><strong>تاريخ القيد</strong>@Model.EntryDate.ToString("yyyy-MM-dd")</div>
        <div class="box"><strong>الفترة المالية</strong>@Model.FiscalPeriodName</div>
        <div class="box"><strong>حالة القيد</strong>@StatusText(Model.Status)</div>
        <div class="box"><strong>نوع المصدر</strong>@(string.IsNullOrWhiteSpace(Model.SourceType) ? "غير محدد" : Model.SourceType)</div>
        <div class="box"><strong>رقم المصدر</strong>@(Model.SourceId?.ToString() ?? "-")</div>
        <div class="box"><strong>متوازن</strong>@(Model.IsBalanced ? "نعم" : "لا")</div>
    </div>

    <div class="box">
        <strong>البيان</strong>
        @Model.Description
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="muted" style="margin-top:5px">@Model.Notes</div>
        }
    </div>

    <table>
        <thead>
            <tr>
                <th style="width:18%">كود الحساب</th>
                <th>اسم الحساب</th>
                <th>مركز التكلفة</th>
                <th>البيان</th>
                <th style="width:15%">مدين</th>
                <th style="width:15%">دائن</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var line in Model.Lines)
        {
            <tr>
                <td>@line.AccountCode</td>
                <td>@line.AccountNameAr</td>
                <td>@(line.CostCenterName ?? "-")</td>
                <td>@line.Description</td>
                <td class="num">@line.DebitAmount.ToString("N2")</td>
                <td class="num">@line.CreditAmount.ToString("N2")</td>
            </tr>
        }
            <tr class="total">
                <td colspan="4">الإجمالي</td>
                <td class="num">@Model.TotalDebit.ToString("N2")</td>
                <td class="num">@Model.TotalCredit.ToString("N2")</td>
            </tr>
        </tbody>
    </table>

    <div class="signatures">
        <div class="sig">إعداد</div>
        <div class="sig">مراجعة</div>
        <div class="sig">اعتماد</div>
        <div class="sig">المدير المالي</div>
    </div>
</body>
</html>

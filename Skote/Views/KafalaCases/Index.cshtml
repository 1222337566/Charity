@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Kafala.KafalaCaseListItemVm>
@using Skote.Helpers
@{ ViewData["Title"] = "ملفات الكفالات"; }

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h4 class="mb-0"><i class="bx bx-heart text-danger me-2"></i>ملفات الكفالات</h4>
        <div class="text-muted small mt-1">يمكن تحويل الكفالات المستحقة تلقائيًا إلى دورة صرف وربط الصرف بحركات الكفالة.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <form asp-action="GenerateCycle" method="post" class="d-flex gap-2 flex-wrap">
            <input type="date" name="plannedDate" class="form-control" placeholder="تاريخ الدورة"/>
            @if (ViewBag.SponsorId != null) { <input type="hidden" name="sponsorId" value="@ViewBag.SponsorId"/> }
            <button type="submit" class="btn btn-warning"><i class="bx bx-refresh me-1"></i>توليد دورة كفالات</button>
        </form>
        <a asp-action="Create" class="btn btn-primary"><i class="bx bx-plus me-1"></i>إضافة ملف كفالة</a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>رقم الملف</th>
                        <th>الكفيل</th>
                        <th>المكفول</th>
                        <th>نوع الكفالة</th>
                        <th>الدورية</th>
                        <th>القيمة</th>
                        <th>الاستحقاق القادم</th>
                        <th>آخر تحصيل</th>
                        <th>آخر صرف</th>
                        <th>الإدراج التلقائي</th>
                        <th>الحالة</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@item.CaseNumber</td>
                        <td>@item.SponsorName</td>
                        <td>@item.BeneficiaryName</td>
                        <td>
                            <span class="badge bg-info bg-opacity-15 text-info border border-info border-opacity-25">
                                @KafalaArabic.SponsorshipType(item.SponsorshipType)
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-secondary bg-opacity-15 text-secondary">
                                @KafalaArabic.Frequency(item.Frequency)
                            </span>
                        </td>
                        <td class="fw-semibold">@item.MonthlyAmount.ToString("n2")</td>
                        <td>
                            @if (item.NextDueDate.HasValue)
                            {
                                var overdue = item.NextDueDate.Value < DateTime.Today;
                                <span class="badge bg-@(overdue ? "danger" : "success") bg-opacity-15 text-@(overdue ? "danger" : "success")">
                                    @item.NextDueDate.Value.ToString("yyyy-MM-dd")
                                    @if (overdue) { <i class="bx bx-error-circle ms-1"></i> }
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td class="text-muted small">@(item.LastCollectionDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td class="text-muted small">@(item.LastDisbursementDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td>
                            @if (item.AutoIncludeInAidCycles)
                            {
                                <span class="badge bg-success-subtle text-success">مفعّل</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted">متوقف</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-@KafalaArabic.CaseStatusBadge(item.Status) bg-opacity-20 text-@KafalaArabic.CaseStatusBadge(item.Status)">
                                @KafalaArabic.CaseStatus(item.Status)
                            </span>
                        </td>
                        <td class="text-nowrap">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a>
                            <a asp-controller="KafalaPayments" asp-action="Index" asp-route-kafalaCaseId="@item.Id" class="btn btn-sm btn-outline-secondary">الحركات</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.Charity.Kafala.CreateKafalaCaseVm
<div class="row g-3">
    <div class="col-md-3"><label asp-for="CaseNumber" class="form-label"></label><input asp-for="CaseNumber" class="form-control" /><span asp-validation-for="CaseNumber" class="text-danger"></span></div>
    <div class="col-md-3"><label asp-for="SponsorId" class="form-label"></label><select asp-for="SponsorId" asp-items="Model.Sponsors" class="form-select"></select></div>
    <div class="col-md-3"><label asp-for="BeneficiaryId" class="form-label"></label><select asp-for="BeneficiaryId" asp-items="Model.Beneficiaries" class="form-select"></select></div>
    <div class="col-md-3"><label asp-for="SponsorshipType" class="form-label"></label><select asp-for="SponsorshipType" asp-items="Model.SponsorshipTypes" class="form-select"></select></div>
    <div class="col-md-3"><label asp-for="Frequency" class="form-label"></label><select asp-for="Frequency" asp-items="Model.Frequencies" class="form-select"></select></div>
    <div class="col-md-3"><label asp-for="MonthlyAmount" class="form-label"></label><input asp-for="MonthlyAmount" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="StartDate" class="form-label"></label><input asp-for="StartDate" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="EndDate" class="form-label"></label><input asp-for="EndDate" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="NextDueDate" class="form-label"></label><input asp-for="NextDueDate" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="PaymentMethodId" class="form-label"></label><select asp-for="PaymentMethodId" asp-items="Model.PaymentMethods" class="form-select"><option value="">-- بدون --</option></select></div>
    <div class="col-md-3"><label asp-for="FinancialAccountId" class="form-label"></label><select asp-for="FinancialAccountId" asp-items="Model.FinancialAccounts" class="form-select"><option value="">-- بدون --</option></select></div>
    <div class="col-md-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.Statuses" class="form-select"></select></div>
    <div class="col-md-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control"></textarea></div>
    <div class="col-md-4 form-check ms-2"><input asp-for="AutoIncludeInAidCycles" class="form-check-input" /><label asp-for="AutoIncludeInAidCycles" class="form-check-label"></label></div>
</div>
<div class="mt-3"><button type="submit" class="btn btn-primary">حفظ</button><a asp-action="Index" class="btn btn-light">رجوع</a></div>

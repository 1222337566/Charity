@model InfrastructureManagmentWebFramework.Models.Charity.Kafala.CreateKafalaPaymentVm
@{ ViewData["Title"] = "إضافة حركة كفالة"; }
<h4 class="mb-3">إضافة حركة كفالة</h4>
<form asp-action="Create" method="post">
<div class="row g-3">
    <div class="col-md-4"><label asp-for="KafalaCaseId" class="form-label"></label><select asp-for="KafalaCaseId" asp-items="Model.KafalaCases" class="form-select"></select></div>
    <div class="col-md-4"><label asp-for="PaymentDate" class="form-label"></label><input asp-for="PaymentDate" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="PeriodLabel" class="form-label"></label><input asp-for="PeriodLabel" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Direction" class="form-label"></label><select asp-for="Direction" asp-items="Model.Directions" class="form-select"></select></div>
    <div class="col-md-4"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="PaymentMethodId" class="form-label"></label><select asp-for="PaymentMethodId" asp-items="Model.PaymentMethods" class="form-select"><option value="">-- بدون --</option></select></div>
    <div class="col-md-4"><label asp-for="FinancialAccountId" class="form-label"></label><select asp-for="FinancialAccountId" asp-items="Model.FinancialAccounts" class="form-select"><option value="">-- بدون --</option></select></div>
    <div class="col-md-4"><label asp-for="ReferenceNumber" class="form-label"></label><input asp-for="ReferenceNumber" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.Statuses" class="form-select"></select></div>
    <div class="col-md-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control"></textarea></div>
</div>
<div class="mt-3"><button type="submit" class="btn btn-primary">حفظ</button><a asp-action="Index" class="btn btn-light">رجوع</a></div>
</form>

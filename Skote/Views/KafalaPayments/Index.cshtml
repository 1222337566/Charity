@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Kafala.KafalaPaymentListItemVm>
@using Skote.Helpers
@{ ViewData["Title"] = "حركات الكفالة"; }

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bx bx-transfer text-success me-2"></i>حركات الكفالة</h4>
    @if (ViewBag.AidCycleId == null)
    {
        <a asp-action="Create" asp-route-kafalaCaseId="@ViewBag.KafalaCaseId" class="btn btn-primary"><i class="bx bx-plus me-1"></i>إضافة حركة</a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>التاريخ</th>
                        <th>الكفيل</th>
                        <th>المكفول</th>
                        <th>الفترة</th>
                        <th>نوع الحركة</th>
                        <th>القيمة</th>
                        <th>طريقة السداد</th>
                        <th>المرجع</th>
                        <th>الحالة</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PaymentDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.SponsorName</td>
                        <td>@item.BeneficiaryName</td>
                        <td class="text-muted">@item.PeriodLabel</td>
                        <td>
                            <span class="badge bg-@KafalaArabic.DirectionBadge(item.Direction) bg-opacity-15 text-@KafalaArabic.DirectionBadge(item.Direction)">
                                @KafalaArabic.Direction(item.Direction)
                            </span>
                        </td>
                        <td class="fw-semibold">@item.Amount.ToString("n2")</td>
                        <td class="text-muted small">@(item.PaymentMethodName ?? "—")</td>
                        <td>
                            @if (item.AidCycleId.HasValue)
                            {
                                <a asp-controller="AidCycles" asp-action="Details" asp-route-id="@item.AidCycleId" class="btn btn-sm btn-outline-warning">@item.ReferenceNumber</a>
                            }
                            else
                            {
                                <span class="text-muted small">@(item.ReferenceNumber ?? "—")</span>
                            }
                        </td>
                        <td>
                            <span class="badge bg-@KafalaArabic.PaymentStatusBadge(item.Status) bg-opacity-15 text-@KafalaArabic.PaymentStatusBadge(item.Status)">
                                @KafalaArabic.PaymentStatus(item.Status)
                            </span>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Kafala.KafalaSponsorListItemVm>
@using Skote.Helpers
@{ ViewData["Title"] = "الكفلاء"; }
<style>
:root{--teal:#0e6f73;--teal-l:#e1f5f5;--ink:#1e3a5f;--muted:#6b7d80}
.sp-hero{background:linear-gradient(135deg,#1a3c5e,#0e6f73);border-radius:20px;padding:20px 26px;color:#fff;margin-bottom:18px;position:relative;overflow:hidden}
.sp-hero::after{content:'';position:absolute;top:-50px;left:-50px;width:200px;height:200px;background:rgba(255,255,255,.04);border-radius:50%}
.sp-stat{background:rgba(255,255,255,.13);border-radius:12px;padding:10px 16px;text-align:center;flex:1;min-width:90px}
.sp-stat .n{font-size:1.3rem;font-weight:800;line-height:1}
.sp-stat .l{font-size:.67rem;opacity:.8;margin-top:2px}
.sp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;margin-top:16px}
.sp-card{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 10px rgba(14,111,115,.06);padding:16px 18px;display:flex;align-items:flex-start;gap:12px;transition:box-shadow .2s,transform .15s}
.sp-card:hover{box-shadow:0 4px 20px rgba(14,111,115,.13);transform:translateY(-2px)}
.sp-avatar{width:44px;height:44px;border-radius:12px;background:var(--teal-l);color:var(--teal);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.sp-code{font-size:.68rem;font-weight:700;color:var(--teal);background:var(--teal-l);padding:2px 7px;border-radius:5px}
.sp-name{font-weight:700;font-size:.9rem;color:var(--ink);margin:.2rem 0}
.sp-meta{font-size:.74rem;color:var(--muted)}
.sp-cases-badge{background:rgba(14,111,115,.1);color:var(--teal);padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700}
.type-lbl{padding:2px 8px;border-radius:5px;font-size:.67rem;font-weight:700;background:rgba(85,110,230,.1);color:#3145a3}
.search-bar{background:#fff;border-radius:12px;border:.5px solid rgba(14,111,115,.12);padding:12px 16px;margin-bottom:14px}
</style>
@{
    var list=Model.ToList();
    var active=list.Count(x=>x.IsActive);
    var totalCases=list.Sum(x=>x.ActiveCasesCount);
}
<div class="sp-hero">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h4 class="mb-1 fw-bold"><i class="bx bx-user-check me-2"></i>الكفلاء</h4>
            <p class="mb-0" style="opacity:.8;font-size:.87rem">إدارة قاعدة بيانات الكفلاء وتتبع ملفات كفالاتهم</p>
        </div>
        <a asp-action="Create" class="btn btn-light fw-semibold" style="border-radius:10px"><i class="bx bx-plus me-1"></i>إضافة كفيل</a>
    </div>
    <div class="d-flex flex-wrap gap-3 mt-3">
        <div class="sp-stat"><div class="n">@list.Count</div><div class="l">إجمالي الكفلاء</div></div>
        <div class="sp-stat"><div class="n">@active</div><div class="l">كفلاء نشطون</div></div>
        <div class="sp-stat"><div class="n">@totalCases</div><div class="l">ملفات كفالة نشطة</div></div>
    </div>
</div>
<div class="search-bar">
    <div class="d-flex gap-2 align-items-center">
        <i class="bx bx-search text-muted"></i>
        <input type="text" id="spSearch" class="form-control form-control-sm border-0 shadow-none" placeholder="بحث بالاسم أو الكود..." style="outline:none"/>
    </div>
</div>
@if(!list.Any()){
    <div class="text-center py-5 text-muted"><i class="bx bx-user-x" style="font-size:3rem;opacity:.3;display:block;margin-bottom:10px"></i><p>لا يوجد كفلاء</p></div>
}else{
    <div class="sp-grid" id="spGrid">
    @foreach(var item in list){
        <div class="sp-card" data-name="@item.FullName.ToLower()" data-code="@item.SponsorCode.ToLower()">
            <div class="sp-avatar"><i class="bx bx-user-check"></i></div>
            <div class="flex-1">
                <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                    <span class="sp-code">@item.SponsorCode</span>
                    <span class="type-lbl">@KafalaArabic.SponsorType(item.SponsorType)</span>
                    @if(!item.IsActive){<span class="badge bg-secondary" style="font-size:.62rem">غير نشط</span>}
                </div>
                <div class="sp-name">@item.FullName</div>
                @if(!string.IsNullOrEmpty(item.PhoneNumber)){<div class="sp-meta"><i class="bx bx-phone me-1"></i>@item.PhoneNumber</div>}
                <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
                    <span class="sp-cases-badge">@item.ActiveCasesCount كفالة نشطة</span>
                </div>
                <div class="d-flex gap-2 mt-2">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light" style="border-radius:7px;font-size:.75rem"><i class="bx bx-edit-alt me-1"></i>تعديل</a>
                    <a asp-controller="KafalaCases" asp-action="Index" asp-route-sponsorId="@item.Id" class="btn btn-sm" style="background:var(--teal-l);color:var(--teal);border-radius:7px;font-size:.75rem"><i class="bx bx-heart me-1"></i>الكفالات</a>
                </div>
            </div>
        </div>
    }
    </div>
}
@section Scripts {
<script>
document.getElementById('spSearch')?.addEventListener('input',function(){
    const q=this.value.toLowerCase();
    document.querySelectorAll('.sp-card').forEach(c=>{
        const match=c.dataset.name.includes(q)||c.dataset.code.includes(q);
        c.style.display=match?'':'none';
    });
});
</script>
}

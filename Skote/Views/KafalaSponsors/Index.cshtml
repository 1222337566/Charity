@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Kafala.KafalaSponsorListItemVm>
@using Skote.Helpers
@{ ViewData["Title"] = "الكفلاء"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bx bx-user-check text-primary me-2"></i>الكفلاء</h4>
    <a asp-action="Create" class="btn btn-primary"><i class="bx bx-plus me-1"></i>إضافة كفيل</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>الكود</th>
                    <th>الاسم الكامل</th>
                    <th>نوع الكفيل</th>
                    <th>رقم الهاتف</th>
                    <th>عدد الكفالات النشطة</th>
                    <th>الحالة</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold text-primary">@item.SponsorCode</td>
                    <td>@item.FullName</td>
                    <td>
                        <span class="badge bg-info bg-opacity-15 text-info border border-info border-opacity-25">
                            @KafalaArabic.SponsorType(item.SponsorType)
                        </span>
                    </td>
                    <td>@(item.PhoneNumber ?? "—")</td>
                    <td>
                        <span class="badge bg-success bg-opacity-15 text-success">
                            @item.ActiveCasesCount كفالة
                        </span>
                    </td>
                    <td>
                        <span class="badge bg-@(item.IsActive ? "success" : "secondary") bg-opacity-20 text-@(item.IsActive ? "success" : "secondary")">
                            @(item.IsActive ? "نشط" : "غير نشط")
                        </span>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a>
                        <a asp-controller="KafalaCases" asp-action="Index" asp-route-sponsorId="@item.Id" class="btn btn-sm btn-outline-secondary">الكفالات</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.Charity.Kafala.CreateKafalaSponsorVm
<div class="row g-3">
    <div class="col-md-3"><label asp-for="SponsorCode" class="form-label"></label><input asp-for="SponsorCode" class="form-control" /><span asp-validation-for="SponsorCode" class="text-danger"></span></div>
    <div class="col-md-5"><label asp-for="FullName" class="form-label"></label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger"></span></div>
    <div class="col-md-4"><label asp-for="SponsorType" class="form-label"></label><select asp-for="SponsorType" asp-items="Model.SponsorTypes" class="form-select"></select></div>
    <div class="col-md-4"><label asp-for="PhoneNumber" class="form-label"></label><input asp-for="PhoneNumber" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="NationalIdOrTaxNo" class="form-label"></label><input asp-for="NationalIdOrTaxNo" class="form-control" /></div>
    <div class="col-md-12"><label asp-for="AddressLine" class="form-label"></label><input asp-for="AddressLine" class="form-control" /></div>
    <div class="col-md-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control"></textarea></div>
    <div class="col-md-3 form-check ms-2"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>
</div>
<div class="mt-3"><button type="submit" class="btn btn-primary">حفظ</button><a asp-action="Index" class="btn btn-light">رجوع</a></div>

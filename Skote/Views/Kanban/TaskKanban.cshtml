@model KanbanIndexVm
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    ViewBag.Title = "Kanban Board";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles {
<link href="~/assets/libs/dragula/dragula.min.css" rel="stylesheet"/>
<style>
.kb-hero{background:linear-gradient(135deg,#0a5659,#0e6f73,#0c8387);border-radius:20px;padding:20px 26px;color:#fff;margin-bottom:20px}
.kb-col-wrap{background:#fff;border-radius:18px;border:.5px solid rgba(14,111,115,.10);box-shadow:0 2px 12px rgba(14,111,115,.05);overflow:hidden;height:100%}
.kb-col-head{padding:14px 18px 12px;border-bottom:.5px solid rgba(14,111,115,.07);display:flex;align-items:center;justify-content:space-between}
.kb-col-name{font-size:.92rem;font-weight:700;display:flex;align-items:center;gap:8px}
.kb-col-dot{width:10px;height:10px;border-radius:50%}
.kb-count{width:24px;height:24px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;color:#fff}
.kb-col-body{padding:12px;min-height:300px}

.task-box{background:#fafcfc;border-radius:12px;border:.5px solid rgba(14,111,115,.10);padding:12px 14px;margin-bottom:10px;cursor:grab;transition:.15s;position:relative}
.task-box:hover{box-shadow:0 4px 16px rgba(14,111,115,.12);transform:translateY(-1px);border-color:rgba(14,111,115,.2)}
.task-box:last-child{margin-bottom:0}
.task-box.priority-critical{border-right:3px solid #f46a6a}
.task-box.priority-high{border-right:3px solid #f1b44c}
.task-box.priority-medium{border-right:3px solid #556ee6}
.task-box.priority-low{border-right:3px solid #34c38f}
.task-title{font-size:.86rem;font-weight:600;color:#15363a;margin-bottom:6px;line-height:1.3}
.task-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-top:8px}
.kb-tag{padding:2px 7px;border-radius:5px;font-size:.65rem;font-weight:600}
.task-due{font-size:.7rem;color:#6b7d80;display:flex;align-items:center;gap:3px}
.task-due.overdue{color:#f46a6a;font-weight:600}

.kb-add-btn{width:100%;padding:9px;border-radius:10px;border:1.5px dashed rgba(14,111,115,.2);background:transparent;color:#0e6f73;font-size:.8rem;font-weight:600;cursor:pointer;transition:.12s;margin-top:8px}
.kb-add-btn:hover{background:rgba(14,111,115,.05);border-color:#0e6f73}

.kb-filter-bar{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap;align-items:center}
.kb-filter{padding:6px 14px;border-radius:10px;font-size:.8rem;font-weight:600;border:.5px solid rgba(14,111,115,.2);background:#fff;cursor:pointer;transition:.12s}
.kb-filter.active,.kb-filter:hover{background:#0e6f73;color:#fff;border-color:#0e6f73}
.kb-search{flex:1;max-width:220px;padding:7px 12px;border-radius:10px;border:.5px solid rgba(14,111,115,.2);font-size:.82rem;outline:none}
.kb-search:focus{border-color:#0e6f73}

.gu-mirror{opacity:.85;border-radius:12px!important;box-shadow:0 8px 24px rgba(14,111,115,.18)!important}
.gu-over{outline:2px dashed rgba(14,111,115,.3);outline-offset:4px;background:rgba(14,111,115,.03)!important}
#upcoming-task,#inprogress-task,#blocked-task,#complete-task{min-height:260px;transition:background-color .15s}
</style>
}

@* Hero *@
<div class="kb-hero">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
    <div>
      <h4 class="mb-1 text-white fw-bold"><i class="bx bx-columns me-2"></i>لوحة المهام</h4>
      <div style="opacity:.75;font-size:.82rem">اسحب وأفلت لتحريك المهام بين الأعمدة</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <button class="btn btn-light btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#boardMembersModal">
        <i class="bx bx-user-plus me-1"></i>أعضاء البورد
      </button>
      <button class="btn btn-warning btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#addTaskModal">
        <i class="bx bx-plus me-1"></i>مهمة جديدة
      </button>
      <a href="/MyBoard" class="btn btn-outline-light btn-sm fw-bold">
        <i class="bx bx-grid-alt me-1"></i>بوردي الشخصي
      </a>
    </div>
  </div>
  <div class="d-flex gap-3 flex-wrap" id="kb-stats">
    <div style="background:rgba(255,255,255,.13);border-radius:10px;padding:10px 16px;text-align:center;min-width:70px">
      <div style="font-size:1.3rem;font-weight:800" id="st-todo">—</div>
      <div style="font-size:.67rem;opacity:.8">انتظار</div>
    </div>
    <div style="background:rgba(241,180,76,.22);border-radius:10px;padding:10px 16px;text-align:center;min-width:70px">
      <div style="font-size:1.3rem;font-weight:800;color:#fde68a" id="st-inprogress">—</div>
      <div style="font-size:.67rem;opacity:.8">جارية</div>
    </div>
    <div style="background:rgba(244,106,106,.22);border-radius:10px;padding:10px 16px;text-align:center;min-width:70px">
      <div style="font-size:1.3rem;font-weight:800;color:#fca5a5" id="st-blocked">—</div>
      <div style="font-size:.67rem;opacity:.8">محجوبة</div>
    </div>
    <div style="background:rgba(52,195,143,.22);border-radius:10px;padding:10px 16px;text-align:center;min-width:70px">
      <div style="font-size:1.3rem;font-weight:800;color:#a7f3d0" id="st-done">—</div>
      <div style="font-size:.67rem;opacity:.8">مكتملة</div>
    </div>
  </div>
</div>

<div id="page-data" data-api-base="@Config["Realtime:BaseUrl"]" data-board="@(Context.Request.Query["board"])"></div>
<div id="kanban-connection-banner" class="alert alert-warning" style="position:fixed;bottom:16px;right:16px;display:none;z-index:1050">
  انقطع الاتصال... إعادة المحاولة
</div>

@* Filter bar *@
<div class="kb-filter-bar">
  <input id="kanban-filter" class="kb-search" placeholder="🔍 بحث في المهام..."/>
  <button class="kb-filter active" onclick="filterKb('all',this)">الكل</button>
  <button class="kb-filter" onclick="filterKb('Critical',this)">⚠️ عاجل</button>
  <button class="kb-filter" onclick="filterKb('High',this)">🔴 عالي</button>
  <button class="kb-filter" onclick="filterKb('Medium',this)">🔵 متوسط</button>
  <button class="kb-filter" onclick="filterKb('Low',this)">🟢 عادي</button>
</div>

@* Board 4 columns *@
<div class="row g-3">

  @* ToDo *@
  <div class="col-xl-3 col-md-6">
    <div class="kb-col-wrap">
      <div class="kb-col-head">
        <span class="kb-col-name">
          <span class="kb-col-dot" style="background:#50a5f1"></span>قيد الانتظار
        </span>
        <span class="kb-count" style="background:#50a5f1" id="cnt-todo">0</span>
      </div>
      <div class="kb-col-body">
        <div id="upcoming-task" class="task-list"></div>
        <button class="kb-add-btn" data-bs-toggle="modal" data-bs-target="#addTaskModal" data-status="ToDo">
          + إضافة مهمة
        </button>
      </div>
    </div>
  </div>

  @* InProgress *@
  <div class="col-xl-3 col-md-6">
    <div class="kb-col-wrap">
      <div class="kb-col-head">
        <span class="kb-col-name">
          <span class="kb-col-dot" style="background:#f1b44c"></span>جارية
        </span>
        <span class="kb-count" style="background:#f1b44c" id="cnt-inprogress">0</span>
      </div>
      <div class="kb-col-body">
        <div id="inprogress-task" class="task-list"></div>
        <button class="kb-add-btn" data-bs-toggle="modal" data-bs-target="#addTaskModal" data-status="InProgress">
          + إضافة مهمة
        </button>
      </div>
    </div>
  </div>

  @* Blocked *@
  <div class="col-xl-3 col-md-6">
    <div class="kb-col-wrap">
      <div class="kb-col-head">
        <span class="kb-col-name">
          <span class="kb-col-dot" style="background:#f46a6a"></span>محجوبة
        </span>
        <span class="kb-count" style="background:#f46a6a" id="cnt-blocked">0</span>
      </div>
      <div class="kb-col-body">
        <div id="blocked-task" class="task-list"></div>
        <button class="kb-add-btn" data-bs-toggle="modal" data-bs-target="#addTaskModal" data-status="Blocked">
          + إضافة مهمة
        </button>
      </div>
    </div>
  </div>

  @* Done *@
  <div class="col-xl-3 col-md-6">
    <div class="kb-col-wrap">
      <div class="kb-col-head">
        <span class="kb-col-name">
          <span class="kb-col-dot" style="background:#34c38f"></span>مكتملة
        </span>
        <span class="kb-count" style="background:#34c38f" id="cnt-done">0</span>
      </div>
      <div class="kb-col-body">
        <div id="complete-task" class="task-list"></div>
        <button class="kb-add-btn" data-bs-toggle="modal" data-bs-target="#addTaskModal" data-status="Done">
          + إضافة مهمة
        </button>
      </div>
    </div>
  </div>

</div>

@* Add Task Modal *@
<div class="modal fade" id="addTaskModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:18px;border:none">
      <div class="modal-header" style="background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px 18px 0 0;color:#fff;border:none">
        <h5 class="modal-title fw-bold"><i class="bx bx-plus-circle me-2"></i>إضافة مهمة جديدة</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <form id="NewtaskForm">
          <div class="mb-3">
            <label class="form-label fw-semibold">عنوان المهمة <span class="text-danger">*</span></label>
            <input id="taskname" name="taskname" type="text" class="form-control" placeholder="أدخل عنوان المهمة..." required style="border-radius:10px"/>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">الوصف</label>
            <textarea id="taskdesc" name="taskdesc" class="form-control" rows="3" style="border-radius:10px"></textarea>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-6">
              <label class="form-label fw-semibold">الأولوية</label>
              <select id="taskpriority" name="taskpriority" class="form-select" style="border-radius:10px">
                <option value="Medium">متوسط</option>
                <option value="High">عالي</option>
                <option value="Critical">عاجل</option>
                <option value="Low">عادي</option>
              </select>
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">الحالة</label>
              <select id="TaskStatus" class="form-select" style="border-radius:10px">
                <option value="ToDo">قيد الانتظار</option>
                <option value="InProgress">جارية</option>
                <option value="Blocked">محجوبة</option>
                <option value="Done">مكتملة</option>
              </select>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">تاريخ الاستحقاق</label>
            <input id="taskdue" type="date" class="form-control" style="border-radius:10px"/>
          </div>
          <input type="hidden" id="task-edit-id"/>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-primary flex-fill fw-bold" id="addtask" style="border-radius:12px">
              <i class="bx bx-plus me-1"></i>إضافة
            </button>
            <button type="button" class="btn btn-primary flex-fill fw-bold d-none" id="updatetaskdetail" style="border-radius:12px">
              <i class="bx bx-save me-1"></i>تحديث
            </button>
            <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal" style="border-radius:12px">إلغاء</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@* Board Members Modal *@
<div class="modal fade" id="boardMembersModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content" style="border-radius:18px">
      <div class="modal-header" style="background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px 18px 0 0;color:#fff;border:none">
        <h5 class="modal-title fw-bold"><i class="bx bx-group me-2"></i>أعضاء البورد</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <div class="mb-3 d-flex gap-2 align-items-end">
          <div class="flex-grow-1">
            <label class="form-label fw-semibold">معرّف المستخدم</label>
            <input type="text" id="bm-user-id" class="form-control" placeholder="الصق معرّف المستخدم" style="border-radius:10px"/>
          </div>
          <div style="width:160px">
            <label class="form-label fw-semibold">الدور</label>
            <select id="bm-role" class="form-select" style="border-radius:10px">
              <option value="Member">عضو</option>
              <option value="Viewer">مشاهد</option>
              <option value="Owner">مالك</option>
            </select>
          </div>
          <button id="bm-add" class="btn btn-primary" style="border-radius:10px">
            <i class="bx bx-plus me-1"></i>إضافة
          </button>
        </div>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr><th>المستخدم</th><th>الدور</th><th style="width:80px"></th></tr>
            </thead>
            <tbody id="bm-list"><tr><td colspan="3" class="text-muted text-center py-3">لا يوجد أعضاء</td></tr></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

@section scripts {
<link href="~/assets/libs/dragula/dragula.min.css" rel="stylesheet"/>
<script src="~/assets/libs/dragula/dragula.min.js"></script>
<script src="~/assets/libs/jquery-validation/jquery.validate.min.js"></script>
<script src="~/assets/js/kanban.skote.adapter.js"></script>
<script>
(function(){
  "use strict";
  const root    = document.getElementById('page-data');
  const boardId = root?.dataset?.board;
  const API_BASE= (root?.dataset?.apiBase || '').replace(/\/$/, '');

  var allTasks = [];

  // ── Priority helpers ──
  function priColor(p){ return {Critical:'#f46a6a',High:'#f1b44c',Medium:'#556ee6',Low:'#34c38f'}[p]||'#adb5bd'; }
  function priAr(p){    return {Critical:'عاجل',High:'عالي',Medium:'متوسط',Low:'عادي'}[p]||p; }
  function statusId(s){ return {ToDo:'upcoming-task',InProgress:'inprogress-task',Blocked:'blocked-task',Done:'complete-task'}[s]||'upcoming-task'; }

  // ── Render card ──
  function card(t){
    var now  = new Date();
    var due  = t.dueDateUtc ? new Date(t.dueDateUtc) : null;
    var over = due && due < now && t.status !== 'Done';
    var c    = priColor(t.priority||'Medium');

    var el = document.createElement('div');
    el.className = 'task-box priority-'+(t.priority||'medium').toLowerCase();
    el.dataset.taskId   = t.id;
    el.dataset.priority = t.priority||'Medium';
    el.dataset.overdue  = over;
    el.innerHTML =
      '<div class="task-title">'+(t.status==='Done'?'<s style="color:#adb5bd">':'')+escHtml(t.title||'')+(t.status==='Done'?'</s>':'')+'</div>'+
      '<div class="task-meta">'+
        '<span class="kb-tag" style="background:'+c+'22;color:'+c+'">'+priAr(t.priority||'Medium')+'</span>'+
        (over?'<span class="kb-tag" style="background:#f46a6a22;color:#f46a6a">⏰ متأخر</span>':'')+
      '</div>'+
      (due?'<div class="task-due'+(over?' overdue':'')+'"><i class="bx bx-calendar"></i>'+(over?'متأخر! ':'')+due.toLocaleDateString('ar-SA')+'</div>':'')+
      '<div class="d-flex gap-1 mt-2">'+
        '<button class="btn btn-sm" style="padding:2px 8px;border-radius:7px;font-size:.7rem;background:rgba(14,111,115,.08);color:#0e6f73;border:none" onclick="editTask(\''+t.id+'\')"><i class="bx bx-edit"></i></button>'+
        '<button class="btn btn-sm" style="padding:2px 8px;border-radius:7px;font-size:.7rem;background:rgba(244,106,106,.08);color:#f46a6a;border:none" onclick="deleteTask(\''+t.id+'\')"><i class="bx bx-trash"></i></button>'+
      '</div>';
    return el;
  }

  function escHtml(s){ return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // ── Render all ──
  function renderAll(tasks){
    allTasks = tasks||[];
    ['upcoming-task','inprogress-task','blocked-task','complete-task'].forEach(id=>{
      var el = document.getElementById(id);
      if(el) el.innerHTML='';
    });
    tasks.forEach(function(t){
      var col = document.getElementById(statusId(t.status));
      if(col) col.appendChild(card(t));
    });
    updateCounts();
  }

  function updateCounts(){
    var counts = {ToDo:0,InProgress:0,Blocked:0,Done:0};
    allTasks.forEach(function(t){ if(counts[t.status]!==undefined) counts[t.status]++; });
    document.getElementById('cnt-todo').textContent       = counts.ToDo;
    document.getElementById('cnt-inprogress').textContent = counts.InProgress;
    document.getElementById('cnt-blocked').textContent    = counts.Blocked;
    document.getElementById('cnt-done').textContent       = counts.Done;
    document.getElementById('st-todo').textContent        = counts.ToDo;
    document.getElementById('st-inprogress').textContent  = counts.InProgress;
    document.getElementById('st-blocked').textContent     = counts.Blocked;
    document.getElementById('st-done').textContent        = counts.Done;
  }

  // ── Load ──
  async function loadTasks(){
    if(!boardId){ renderAll([]); return; }
    try{
      var t = typeof TokenProvider!=='undefined' ? await TokenProvider.getToken() : '';
      var r = await fetch(API_BASE+'/kanban/boards/'+boardId+'/tasks',{
        credentials:'include',
        headers: t?{Authorization:'Bearer '+t}:{}
      });
      if(!r.ok) throw new Error(r.status);
      var data = await r.json();
      renderAll(data);
      initDrake();
    }catch(e){ console.error('Load failed',e); renderAll([]); }
  }

  // ── Dragula drag-drop ──
  var drake;
  function initDrake(){
    if(drake) drake.destroy();
    drake = dragula([
      document.getElementById('upcoming-task'),
      document.getElementById('inprogress-task'),
      document.getElementById('blocked-task'),
      document.getElementById('complete-task')
    ],{ revertOnSpill:true });

    drake.on('drop',async function(el,target){
      var taskId = el.dataset.taskId;
      var newStatus = {
        'upcoming-task':'ToDo','inprogress-task':'InProgress',
        'blocked-task':'Blocked','complete-task':'Done'
      }[target.id]||'ToDo';

      var idx = Array.from(target.children).indexOf(el);
      try{
        var t = typeof TokenProvider!=='undefined' ? await TokenProvider.getToken() : '';
        await fetch(API_BASE+'/kanban/tasks/move',{
          method:'POST',credentials:'include',
          headers:{'Content-Type':'application/json',...(t?{Authorization:'Bearer '+t}:{})},
          body:JSON.stringify({taskId,newStatus,orderIndex:idx})
        });
        var task = allTasks.find(x=>x.id===taskId);
        if(task) task.status = newStatus;
        updateCounts();
      }catch(e){ console.error(e); }
    });
  }

  // ── Add / Update ──
  document.getElementById('addtask')?.addEventListener('click', async function(){
    var name = document.getElementById('taskname').value.trim();
    if(!name) return;
    var body = {
      boardId, title:name,
      description: document.getElementById('taskdesc').value||null,
      priority: document.getElementById('taskpriority').value||'Medium',
      status:   document.getElementById('TaskStatus').value||'ToDo',
      assignedToUserId: null,
      dueDateUtc: document.getElementById('taskdue').value||null,
      orderIndex:0, createdAtUtc: new Date().toISOString()
    };
    try{
      var t = typeof TokenProvider!=='undefined' ? await TokenProvider.getToken() : '';
      await fetch(API_BASE+'/kanban/tasks',{
        method:'POST',credentials:'include',
        headers:{'Content-Type':'application/json',...(t?{Authorization:'Bearer '+t}:{})},
        body:JSON.stringify(body)
      });
      bootstrap.Modal.getInstance(document.getElementById('addTaskModal'))?.hide();
      document.getElementById('NewtaskForm').reset();
      loadTasks();
    }catch(e){ alert('فشل الإضافة'); }
  });

  // ── Edit / Delete global ──
  window.editTask = function(id){
    var t = allTasks.find(x=>x.id===id);
    if(!t) return;
    document.getElementById('taskname').value    = t.title||'';
    document.getElementById('taskdesc').value    = t.description||'';
    document.getElementById('taskpriority').value= t.priority||'Medium';
    document.getElementById('TaskStatus').value  = t.status||'ToDo';
    document.getElementById('taskdue').value     = t.dueDateUtc?t.dueDateUtc.substring(0,10):'';
    document.getElementById('task-edit-id').value= id;
    document.getElementById('addtask').classList.add('d-none');
    document.getElementById('updatetaskdetail').classList.remove('d-none');
    new bootstrap.Modal(document.getElementById('addTaskModal')).show();
  };

  document.getElementById('updatetaskdetail')?.addEventListener('click', async function(){
    var id = document.getElementById('task-edit-id').value;
    if(!id) return;
    var body = {
      id, boardId,
      title: document.getElementById('taskname').value,
      description: document.getElementById('taskdesc').value||null,
      priority: document.getElementById('taskpriority').value,
      status:   document.getElementById('TaskStatus').value,
      dueDateUtc: document.getElementById('taskdue').value||null
    };
    try{
      var t = typeof TokenProvider!=='undefined' ? await TokenProvider.getToken() : '';
      await fetch(API_BASE+'/kanban/tasks',{
        method:'PUT',credentials:'include',
        headers:{'Content-Type':'application/json',...(t?{Authorization:'Bearer '+t}:{})},
        body:JSON.stringify(body)
      });
      bootstrap.Modal.getInstance(document.getElementById('addTaskModal'))?.hide();
      document.getElementById('NewtaskForm').reset();
      document.getElementById('addtask').classList.remove('d-none');
      document.getElementById('updatetaskdetail').classList.add('d-none');
      loadTasks();
    }catch(e){ alert('فشل التحديث'); }
  });

  window.deleteTask = async function(id){
    if(!confirm('حذف المهمة؟')) return;
    try{
      var t = typeof TokenProvider!=='undefined' ? await TokenProvider.getToken() : '';
      await fetch(API_BASE+'/kanban/tasks/'+id,{
        method:'DELETE',credentials:'include',
        headers:t?{Authorization:'Bearer '+t}:{}
      });
      loadTasks();
    }catch(e){ alert('فشل الحذف'); }
  };

  // ── Filter ──
  document.getElementById('kanban-filter')?.addEventListener('input', function(){
    var q = this.value.toLowerCase();
    document.querySelectorAll('.task-box').forEach(function(c){
      c.style.display = (c.querySelector('.task-title')?.textContent||'').toLowerCase().includes(q)?'':'none';
    });
  });

  // ── Board members modal ──
  var bmList = document.getElementById('bm-list');
  document.getElementById('boardMembersModal')?.addEventListener('show.bs.modal', loadMembers);
  document.getElementById('bm-add')?.addEventListener('click', addMember);

  async function loadMembers(){
    if(!boardId) return;
    bmList.innerHTML = '<tr><td colspan="3" class="text-muted text-center">جاري التحميل...</td></tr>';
    try{
      var t = typeof TokenProvider!=='undefined' ? await TokenProvider.getToken() : '';
      var r = await fetch(API_BASE+'/kanban/boards/'+boardId+'/members',{credentials:'include',headers:t?{Authorization:'Bearer '+t}:{}});
      var data = await r.json();
      bmList.innerHTML = '';
      if(!data?.length){ bmList.innerHTML='<tr><td colspan="3" class="text-muted text-center">لا يوجد أعضاء</td></tr>'; return; }
      data.forEach(function(m){
        var tr = document.createElement('tr');
        tr.innerHTML = '<td><code>'+escHtml(m.userId||m.UserId)+'</code></td><td>'+escHtml(m.role||m.Role)+'</td><td class="text-end"><button class="btn btn-sm btn-danger" style="border-radius:7px">إزالة</button></td>';
        tr.querySelector('button').addEventListener('click',()=>removeMember(m.userId||m.UserId));
        bmList.appendChild(tr);
      });
    }catch(e){ bmList.innerHTML='<tr><td colspan="3" class="text-danger">فشل التحميل</td></tr>'; }
  }

  async function addMember(){
    var uid = (document.getElementById('bm-user-id').value||'').trim();
    if(!uid) return;
    var t = typeof TokenProvider!=='undefined' ? await TokenProvider.getToken() : '';
    await fetch(API_BASE+'/kanban/boards/'+boardId+'/members',{
      method:'POST',credentials:'include',
      headers:{'Content-Type':'application/json',...(t?{Authorization:'Bearer '+t}:{})},
      body:JSON.stringify({userId:uid,role:document.getElementById('bm-role').value})
    });
    document.getElementById('bm-user-id').value='';
    loadMembers();
  }

  async function removeMember(uid){
    if(!confirm('إزالة هذا العضو؟')) return;
    var t = typeof TokenProvider!=='undefined' ? await TokenProvider.getToken() : '';
    await fetch(API_BASE+'/kanban/boards/'+boardId+'/members/'+encodeURIComponent(uid),{
      method:'DELETE',credentials:'include',headers:t?{Authorization:'Bearer '+t}:{}
    });
    loadMembers();
  }

  // set status when clicking add button per column
  document.querySelectorAll('[data-status]').forEach(function(btn){
    btn.addEventListener('click',function(){
      var s = btn.dataset.status;
      if(s && document.getElementById('TaskStatus')) document.getElementById('TaskStatus').value = s;
    });
  });

  // ── Init ──
  loadTasks();

})();
</script>

// global filter function
<script>
function filterKb(p, btn) {
  document.querySelectorAll('.kb-filter').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.task-box').forEach(function(c){
    if(p === 'all') { c.style.display = ''; return; }
    c.style.display = c.dataset.priority === p ? '' : 'none';
  });
}
</script>
}

@model Skote.Controllers.MyBoardVm
@using InfrastructureManagmentCore.Domains.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInMgr
@{
    ViewData["Title"] = "بوردي";
    var userName = ViewBag.UserName as string ?? "المستخدم";

    string PriorityColor(string p) => p switch
    {
        "Critical" => "#f46a6a",
        "High" => "#f1b44c",
        "Medium" => "#556ee6",
        "Low" => "#34c38f",
        _ => "#adb5bd"
    };
    string PriorityAr(string p) => p switch
    {
        "Critical" => "عاجل",
        "High" => "عالي",
        "Medium" => "متوسط",
        "Low" => "عادي",
        _ => p
    };
    string StatusAr(string s) => s switch
    {
        "ToDo" => "قيد الانتظار",
        "InProgress" => "جارية",
        "Blocked" => "محجوبة",
        "Done" => "مكتملة",
        _ => s
    };
    bool IsOverdue(InfrastrfuctureManagmentCore.Domains.Kanaban.TaskItem t) => t.DueDateUtc.HasValue && t.DueDateUtc.Value < DateTime.UtcNow && t.Status != "Done";
}

@section styles {
    <style>
    .kb-hero{background:linear-gradient(135deg,#0a5659,#0e6f73,#0c8387);border-radius:20px;padding:22px 28px;color:#fff;margin-bottom:20px}
    .kb-stat{background:rgba(255,255,255,.13);border-radius:12px;padding:12px 18px;text-align:center;flex:1;min-width:80px}
    .kb-stat .n{font-size:1.4rem;font-weight:800;line-height:1}
    .kb-stat .l{font-size:.68rem;opacity:.8;margin-top:2px}
    .kb-col{background:#fff;border-radius:18px;border:.5px solid rgba(14,111,115,.10);box-shadow:0 2px 12px rgba(14,111,115,.05);overflow:hidden}
    .kb-col-head{padding:14px 18px 12px;border-bottom:.5px solid rgba(14,111,115,.07);display:flex;align-items:center;justify-content:space-between}
    .kb-col-name{font-size:.92rem;font-weight:700;display:flex;align-items:center;gap:8px}
    .kb-count{width:24px;height:24px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;color:#fff}
    .kb-col-body{padding:12px;min-height:260px}
    .kb-card{background:#fafcfc;border-radius:12px;border:.5px solid rgba(14,111,115,.09);padding:12px 14px;margin-bottom:10px;cursor:grab;transition:.15s;position:relative}
    .kb-card:hover{box-shadow:0 4px 16px rgba(14,111,115,.12);transform:translateY(-1px)}
    .kb-card.dragging{opacity:.4;transform:scale(.97)}
    .kb-col-body.drag-over{background:rgba(85,110,230,.07)!important;outline:2px dashed rgba(85,110,230,.3);outline-offset:-4px}
    .kb-card.is-overdue{border-right:3px solid #f46a6a}
    .kb-card.is-blocked{background:#fff8f8;border-right:3px solid #f46a6a}
    .kb-card.is-done{opacity:.6}
    .kb-card-title{font-size:.86rem;font-weight:600;color:#15363a;margin-bottom:7px;line-height:1.3}
    .kb-card.is-done .kb-card-title{text-decoration:line-through;color:#adb5bd}
    .kb-badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:5px;font-size:.65rem;font-weight:700}
    .kb-due{font-size:.7rem;color:#6b7d80;display:flex;align-items:center;gap:3px;margin-top:6px}
    .kb-due.overdue{color:#f46a6a;font-weight:600}
    .kb-actions{display:flex;gap:4px;margin-top:8px;flex-wrap:wrap}
    .kb-move-btn{padding:3px 9px;border-radius:7px;border:none;font-size:.68rem;font-weight:600;cursor:pointer;transition:.1s}
    .kb-move-btn:hover{filter:brightness(.9)}
    .kb-add-form{background:#f5faf9;border-radius:12px;padding:12px;margin-top:8px;border:.5px dashed rgba(14,111,115,.2)}
    .kb-add-form input,.kb-add-form select,.kb-add-form textarea{width:100%;border-radius:8px;border:.5px solid rgba(14,111,115,.2);padding:7px 10px;font-size:.82rem;font-family:inherit;margin-bottom:6px;outline:none}
    .kb-add-form input:focus,.kb-add-form select:focus{border-color:#0e6f73}
    .kb-add-btn-toggle{width:100%;padding:9px;border-radius:10px;border:1.5px dashed rgba(14,111,115,.2);background:transparent;color:#0e6f73;font-size:.8rem;font-weight:600;cursor:pointer;transition:.12s;margin-top:6px}
    .kb-add-btn-toggle:hover{background:rgba(14,111,115,.05);border-color:#0e6f73}
    .kb-filter-bar{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap;align-items:center}
    .kb-filter{padding:6px 14px;border-radius:10px;font-size:.8rem;font-weight:600;border:.5px solid rgba(14,111,115,.2);background:#fff;cursor:pointer;transition:.12s}
    .kb-filter.active{background:#0e6f73;color:#fff;border-color:#0e6f73}
    .kb-filter:hover:not(.active){background:#f5faf9}
    .kb-search{flex:1;max-width:220px;padding:7px 12px;border-radius:10px;border:.5px solid rgba(14,111,115,.2);font-size:.82rem;outline:none}
    .kb-search:focus{border-color:#0e6f73}
    .kb-drag-over{background:rgba(85,110,230,.06)!important;outline:2px dashed rgba(85,110,230,.3);outline-offset:-4px}
    </style>
}

@* Hero *@
<div class="kb-hero mb-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
    <div>
      <h4 class="mb-1 text-white fw-bold">
        <i class="bx bx-columns me-2"></i>بوردي — @userName
      </h4>
      <div style="opacity:.75;font-size:.82rem">@DateTime.Today.ToString("dddd، d MMMM yyyy")</div>
    </div>
    <a asp-action="Index" asp-controller="MyBoard"
       class="btn btn-light btn-sm fw-bold">
      <i class="bx bx-refresh me-1"></i>تحديث
    </a>
  </div>
  <div class="d-flex gap-3 flex-wrap">
    <div class="kb-stat">
      <div class="n" id="cnt-total">@Model.Total</div><div class="l">الإجمالي</div>
    </div>
    <div class="kb-stat" style="background:rgba(80,165,241,.22)">
      <div class="n" style="color:#bae6fd" id="cnt-todo">@Model.ToDo.Count</div><div class="l">انتظار</div>
    </div>
    <div class="kb-stat" style="background:rgba(241,180,76,.22)">
      <div class="n" style="color:#fde68a" id="cnt-inprogress">@Model.InProgress.Count</div><div class="l">جارية</div>
    </div>
    <div class="kb-stat" style="background:rgba(244,106,106,.22)">
      <div class="n" style="color:#fca5a5" id="cnt-blocked">@Model.Blocked.Count</div><div class="l">محجوبة</div>
    </div>
    <div class="kb-stat" style="background:rgba(52,195,143,.22)">
      <div class="n" style="color:#a7f3d0" id="cnt-done">@Model.Done.Count</div><div class="l">مكتملة</div>
    </div>
        @if (Model.Overdue > 0)
        {
          <div class="kb-stat" style="background:rgba(244,106,106,.30)">
            <div class="n" style="color:#fff">@Model.Overdue</div><div class="l">متأخرة!</div>
          </div>
        }
  </div>
</div>

@* Filter bar *@
<div class="kb-filter-bar">
  <input class="kb-search" id="kb-search" placeholder="🔍 بحث..." oninput="filterCards()"/>
  <button class="kb-filter active" onclick="filterPriority('all',this)">الكل</button>
  <button class="kb-filter" onclick="filterPriority('Critical',this)">⚠️ عاجل</button>
  <button class="kb-filter" onclick="filterPriority('High',this)">🔴 عالي</button>
  <button class="kb-filter" onclick="filterPriority('Medium',this)">🔵 متوسط</button>
  <button class="kb-filter" onclick="filterPriority('overdue',this)">⏰ متأخر</button>
</div>

@* Board 4 columns *@
<div class="row g-3" id="kb-board">

    @* ── ToDo ── *@
  <div class="col-xl-3 col-md-6">
    <div class="kb-col">
      <div class="kb-col-head">
        <span class="kb-col-name">
          <span style="width:10px;height:10px;border-radius:50%;background:#50a5f1;display:inline-block"></span>
          قيد الانتظار
        </span>
        <span class="kb-count" style="background:#50a5f1">@Model.ToDo.Count</span>
      </div>
      <div class="kb-col-body" id="col-todo" data-status="ToDo">
                @foreach (var t in Model.ToDo)
                {
              <div class="kb-card @(IsOverdue(t) ? "is-overdue" : "")"
                   data-priority="@t.Priority" data-overdue="@IsOverdue(t).ToString().ToLower()"
                   data-task-id="@t.Id">
                <div class="kb-card-title">@t.Title</div>
                <div class="d-flex flex-wrap gap-1">
                  <span class="kb-badge" style="background:rgba(@(PriorityColor(t.Priority).TrimStart('#')),.15);color:@PriorityColor(t.Priority)">
                                @PriorityAr(t.Priority)
                  </span>
                </div>
                        @if (t.DueDateUtc.HasValue)
                        {
                      <div class="kb-due @(IsOverdue(t) ? "overdue" : "")">
                        <i class="bx bx-calendar"></i>
                                @(IsOverdue(t) ? "متأخر! " : "")@t.DueDateUtc.Value.ToString("d/M/yyyy")
                      </div>
                        }
                <div class="kb-actions">
                  <button type="button" class="kb-move-btn" style="background:rgba(241,180,76,.15);color:#8a5f00"
                            onclick="mvTask('@t.Id','@Model.BoardId','InProgress',this)">← جاري</button>
                  <form asp-action="DeleteTask" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                    <input type="hidden" name="taskId" value="@t.Id"/>
                    <button type="submit" class="kb-move-btn" style="background:rgba(244,106,106,.12);color:#ab2b2b"
                            onclick="return confirm('حذف المهمة؟')">حذف</button>
                  </form>
                </div>
              </div>
                }
                @* Add task form *@
        <button class="kb-add-btn-toggle" onclick="toggleAddForm('form-todo')">+ إضافة مهمة</button>
        <div id="form-todo" class="kb-add-form" style="display:none">
          <form asp-action="AddTask" method="post">
                        @Html.AntiForgeryToken()
            <input type="hidden" name="boardId" value="@Model.BoardId"/>
            <input type="text" name="title" placeholder="عنوان المهمة *" required/>
            <select name="priority">
              <option value="Medium">متوسط</option>
              <option value="High">عالي</option>
              <option value="Critical">عاجل</option>
              <option value="Low">عادي</option>
            </select>
            <input type="date" name="dueDate" placeholder="تاريخ الاستحقاق"/>
            <textarea name="description" rows="2" placeholder="وصف (اختياري)"></textarea>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary btn-sm flex-fill" style="border-radius:8px">إضافة</button>
              <button type="button" class="btn btn-light btn-sm flex-fill" style="border-radius:8px"
                      onclick="toggleAddForm('form-todo')">إلغاء</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

    @* ── InProgress ── *@
  <div class="col-xl-3 col-md-6">
    <div class="kb-col">
      <div class="kb-col-head">
        <span class="kb-col-name">
          <span style="width:10px;height:10px;border-radius:50%;background:#f1b44c;display:inline-block"></span>
          جارية
        </span>
        <span class="kb-count" style="background:#f1b44c">@Model.InProgress.Count</span>
      </div>
      <div class="kb-col-body" id="col-inprogress" data-status="InProgress">
                @foreach (var t in Model.InProgress)
                {
              <div class="kb-card @(IsOverdue(t) ? "is-overdue" : "")"
                   data-priority="@t.Priority" data-overdue="@IsOverdue(t).ToString().ToLower()"
                   data-task-id="@t.Id">
                <div class="kb-card-title">@t.Title</div>
                <div class="d-flex flex-wrap gap-1">
                  <span class="kb-badge" style="background:rgba(241,180,76,.15);color:#8a5f00">جاري</span>
                  <span class="kb-badge" style="background:rgba(@(PriorityColor(t.Priority).TrimStart('#')),.15);color:@PriorityColor(t.Priority)">
                                @PriorityAr(t.Priority)
                  </span>
                </div>
                        @if (t.DueDateUtc.HasValue)
                        {
                      <div class="kb-due @(IsOverdue(t) ? "overdue" : "")">
                        <i class="bx bx-calendar"></i>
                                @(IsOverdue(t) ? "متأخر! " : "")@t.DueDateUtc.Value.ToString("d/M/yyyy")
                      </div>
                        }
                <div class="kb-actions">
                  <button type="button" class="kb-move-btn" style="background:rgba(244,106,106,.12);color:#ab2b2b"
                            onclick="mvTask('@t.Id','@Model.BoardId','Blocked',this)">محجوب</button>
                  <button type="button" class="kb-move-btn" style="background:rgba(52,195,143,.15);color:#0d7a5a"
                            onclick="mvTask('@t.Id','@Model.BoardId','Done',this)">✓ مكتمل</button>
                  <button type="button" class="kb-move-btn" style="background:rgba(80,165,241,.12);color:#1a6faf"
                            onclick="mvTask('@t.Id','@Model.BoardId','ToDo',this)">↩ رجوع</button>
                </div>
              </div>
                }
        <button class="kb-add-btn-toggle" onclick="toggleAddForm('form-inprogress')">+ إضافة مهمة</button>
        <div id="form-inprogress" class="kb-add-form" style="display:none">
          <form asp-action="AddTask" method="post">
                        @Html.AntiForgeryToken()
            <input type="hidden" name="boardId" value="@Model.BoardId"/>
            <input type="text" name="title" placeholder="عنوان المهمة *" required/>
            <select name="priority">
              <option value="High">عالي</option>
              <option value="Critical">عاجل</option>
              <option value="Medium">متوسط</option>
              <option value="Low">عادي</option>
            </select>
            <input type="date" name="dueDate"/>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-warning btn-sm flex-fill" style="border-radius:8px">إضافة</button>
              <button type="button" class="btn btn-light btn-sm flex-fill" style="border-radius:8px"
                      onclick="toggleAddForm('form-inprogress')">إلغاء</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

    @* ── Blocked ── *@
  <div class="col-xl-3 col-md-6">
    <div class="kb-col">
      <div class="kb-col-head">
        <span class="kb-col-name">
          <span style="width:10px;height:10px;border-radius:50%;background:#f46a6a;display:inline-block"></span>
          محجوبة
        </span>
        <span class="kb-count" style="background:#f46a6a">@Model.Blocked.Count</span>
      </div>
      <div class="kb-col-body" id="col-blocked" data-status="Blocked">
                @foreach (var t in Model.Blocked)
                {
              <div class="kb-card is-blocked" data-priority="@t.Priority" data-overdue="false"
                   data-task-id="@t.Id">
                <div class="kb-card-title">@t.Title</div>
                <div class="d-flex flex-wrap gap-1">
                  <span class="kb-badge" style="background:rgba(244,106,106,.15);color:#ab2b2b">🚫 محجوب</span>
                </div>
                        @if (t.Description != null)
                        {
                      <div style="font-size:.75rem;color:#f46a6a;margin-top:5px;padding:4px 8px;background:rgba(244,106,106,.08);border-radius:6px">
                                @t.Description
                      </div>
                        }
                <div class="kb-actions">
                  <button type="button" class="kb-move-btn" style="background:rgba(241,180,76,.15);color:#8a5f00"
                            onclick="mvTask('@t.Id','@Model.BoardId','InProgress',this)">↩ استئناف</button>
                </div>
              </div>
                }
                @if (!Model.Blocked.Any())
                {
              <div class="text-center text-muted py-4" style="font-size:.82rem">
                <i class="bx bx-check-shield" style="font-size:2rem;color:#34c38f;display:block"></i>
                لا مهام محجوبة 👍
              </div>
                }
      </div>
    </div>
  </div>

    @* ── Done ── *@
  <div class="col-xl-3 col-md-6">
    <div class="kb-col">
      <div class="kb-col-head">
        <span class="kb-col-name">
          <span style="width:10px;height:10px;border-radius:50%;background:#34c38f;display:inline-block"></span>
          مكتملة
        </span>
        <span class="kb-count" style="background:#34c38f">@Model.Done.Count</span>
      </div>
      <div class="kb-col-body" id="col-done" data-status="Done">
                @foreach (var t in Model.Done)
                {
              <div class="kb-card is-done" data-priority="@t.Priority" data-overdue="false"
                   data-task-id="@t.Id">
                <div class="kb-card-title">@t.Title</div>
                <div class="d-flex flex-wrap gap-1">
                  <span class="kb-badge" style="background:rgba(52,195,143,.15);color:#0d7a5a">✓ مكتمل</span>
                </div>
                        @if (t.DueDateUtc.HasValue)
                        {
                      <div class="kb-due">
                        <i class="bx bx-calendar"></i> @t.DueDateUtc.Value.ToString("d/M/yyyy")
                      </div>
                        }
                <div class="kb-actions">
                  <button type="button" class="kb-move-btn" style="background:rgba(85,110,230,.12);color:#3145a3"
                            onclick="mvTask('@t.Id','@Model.BoardId','InProgress',this)">↩ إعادة فتح</button>
                  <form asp-action="DeleteTask" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                    <input type="hidden" name="taskId" value="@t.Id"/>
                    <button type="submit" class="kb-move-btn" style="background:rgba(244,106,106,.10);color:#adb5bd"
                            onclick="return confirm('حذف؟')">حذف</button>
                  </form>
                </div>
              </div>
                }
                @if (!Model.Done.Any())
                {
              <div class="text-center text-muted py-4" style="font-size:.82rem">لا مهام مكتملة بعد</div>
                }
      </div>
    </div>
  </div>

</div>

<script>
// ══ Drag & Drop ══
document.addEventListener('DOMContentLoaded', function() {
    var _dragId = null, _dragEl = null;

    // Make all cards draggable
    function enableDrag() {
        document.querySelectorAll('.kb-card[data-task-id]').forEach(function(card) {
            if (card.draggable) return;
            card.draggable = true;
            card.addEventListener('dragstart', function(e) {
                _dragId = card.dataset.taskId;
                _dragEl = card;
                e.dataTransfer.effectAllowed = 'move';
                setTimeout(function(){ card.classList.add('dragging'); }, 0);
            });
            card.addEventListener('dragend', function() {
                card.classList.remove('dragging');
                document.querySelectorAll('.kb-col-body').forEach(function(z){
                    z.classList.remove('drag-over');
                });
                _dragEl = null;
            });
        });
        // Drop zones
        document.querySelectorAll('.kb-col-body[data-status]').forEach(function(zone) {
            if (zone._dropReady) return;
            zone._dropReady = true;
            zone.addEventListener('dragover', function(e) {
                e.preventDefault();
                zone.classList.add('drag-over');
            });
            zone.addEventListener('dragleave', function(e) {
                if (!zone.contains(e.relatedTarget)) zone.classList.remove('drag-over');
            });
            zone.addEventListener('drop', function(e) {
                e.preventDefault();
                zone.classList.remove('drag-over');
                var id = _dragId;
                var newStatus = zone.dataset.status;
                if (!id || !newStatus) return;

                // تحريك في UI
                zone.insertBefore(document.querySelector('[data-task-id="'+id+'"]'), zone.firstChild);

                // حفظ في DB
                var tok = document.querySelector('[name="__RequestVerificationToken"]')?.value || '';
                var fd = new FormData();
                fd.append('taskId', id);
                fd.append('newStatus', newStatus);
                fd.append('boardId', '@Model.BoardId');
                fd.append('__RequestVerificationToken', tok);
                fetch('/MyBoard/MoveTask', { method:'POST', body: fd })
                    .catch(function(){ location.reload(); });

                _dragId = null;
            });
        });
    }
    enableDrag();
});

function mvTask(taskId, boardId, newStatus, btn) {
    btn.disabled = true;
    var tok = document.querySelector('[name="__RequestVerificationToken"]')?.value || '';
    var fd  = new FormData();
    fd.append('taskId', taskId);
    fd.append('newStatus', newStatus);
    fd.append('boardId', boardId);
    fd.append('__RequestVerificationToken', tok);
    fetch('/MyBoard/MoveTask', { method: 'POST', body: fd })
        .then(function(r) { location.reload(); })
        .catch(function()  { btn.disabled = false; });
}
function toggleAddForm(id) {
    var el = document.getElementById(id);
    el.style.display = el.style.display === 'none' ? '' : 'none';
    if (el.style.display !== 'none') el.querySelector('input[name="title"]')?.focus();
}
function filterCards() {
    var q = document.getElementById('kb-search').value.toLowerCase();
    document.querySelectorAll('.kb-card').forEach(function(c){
        var t = c.querySelector('.kb-card-title')?.textContent.toLowerCase() || '';
        c.style.display = t.includes(q) ? '' : 'none';
    });
}
function filterPriority(p, btn) {
    document.querySelectorAll('.kb-filter').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.kb-card').forEach(function(c){
        if (p === 'all')     { c.style.display = ''; return; }
        if (p === 'overdue') { c.style.display = c.dataset.overdue === 'true' ? '' : 'none'; return; }
        c.style.display = c.dataset.priority === p ? '' : 'none';
    });
}
</script>

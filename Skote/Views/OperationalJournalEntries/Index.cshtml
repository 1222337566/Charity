@using InfrastructureManagmentWebFramework.Models.AccountingIntegration
@model List<OperationalPostingSectionVm>
@{ ViewData["Title"] = "ربط الحركات بالقيود المحاسبية"; }

<style>
    .ops-page-header { margin-bottom: 1.5rem; }
    .ops-empty { background:#fff; border-radius:16px; padding:60px 20px; text-align:center; box-shadow:0 2px 12px rgba(0,0,0,.06); }
    .ops-empty-icon { font-size:3.5rem; color:#adb5bd; display:block; margin-bottom:12px; }
</style>

<div class="page-content">
  <div class="container-fluid" dir="rtl">

    <div class="ops-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
      <div>
        <h4 class="mb-1">ربط الحركات بالقيود المحاسبية</h4>
        <p class="text-muted mb-0 small">عرض الحركات التشغيلية وإنشاء القيود المحاسبية المقابلة لها تلقائياً</p>
      </div>
      <a asp-controller="AccountingIntegrationSources" asp-action="Index" class="btn btn-outline-secondary btn-sm" style="border-radius:10px">
        <i class="bx bx-cog me-1"></i> إعدادات مصادر الربط
      </a>
    </div>

    @if (TempData["Success"] != null)
    {
      <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px;margin-bottom:1rem">
        <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="alert alert-danger alert-dismissible fade show" style="border-radius:12px;margin-bottom:1rem">
        <i class="bx bx-error-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    }

    @if (!Model.Any())
    {
      <div class="ops-empty">
        <i class="bx bx-link ops-empty-icon"></i>
        <h5 class="text-muted">لا توجد مصادر نشطة بالتوليد الديناميكي</h5>
        <p class="text-muted small mb-3">فعّل الخيار في صفحة مصادر الربط لتظهر الحركات هنا</p>
        <a asp-controller="AccountingIntegrationSources" asp-action="Index" class="btn btn-primary" style="border-radius:12px">
          <i class="bx bx-cog me-1"></i> مصادر الربط المحاسبي
        </a>
      </div>
    }

    @foreach (var section in Model)
    {
      @await Html.PartialAsync("_SectionTable", new OperationalPostingSectionVm
      {
          Title      = section.Title,
          ActionName = "GenerateDynamic",
          SourceType = section.SourceType,
          Rows       = section.Rows
      })
    }

  </div>
</div>

@model InfrastructureManagmentWebFramework.Models.AccountingIntegration.OperationalPostingSectionVm

@{
    var total      = Model.Rows.Count;
    var withEntry  = Model.Rows.Count(r => r.HasJournalEntry);
    var pct        = total > 0 ? (int)(withEntry * 100.0 / total) : 0;
}

<style>
    .section-card { border:none; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,.07); margin-bottom:1.5rem; overflow:hidden; }
    .section-card .card-header { background:linear-gradient(135deg,#f8f9fa,#e9ecef); border-bottom:1px solid #dee2e6; padding:14px 20px; }
    .ops-table thead th { background:#f1f3f5; font-size:.79rem; font-weight:600; color:#495057; white-space:nowrap; padding:9px 10px; border-color:#dee2e6; }
    .ops-table tbody td { font-size:.86rem; vertical-align:middle; padding:8px 10px; }
    .ops-table tbody tr:hover { background:#f8f9fa; }
    .progress-bar-thin { height:6px; border-radius:3px; }
    .has-entry-link { font-weight:600; }
    .entry-btn { border-radius:10px; font-size:.78rem; padding:4px 12px; white-space:nowrap; }
    .badge-source { border-radius:20px; padding:3px 10px; font-size:.72rem; }
</style>

<div class="section-card">
  <div class="card-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
      <div>
        <h6 class="mb-0 fw-semibold">@Model.Title</h6>
        <div class="text-muted" style="font-size:.78rem">@withEntry من @total حركة مرتبطة بقيود</div>
      </div>
      <div class="d-flex align-items-center gap-3">
        @if (total > 0)
        {
          <div style="min-width:140px">
            <div class="d-flex justify-content-between mb-1">
              <span style="font-size:.72rem;color:#6c757d">نسبة الربط</span>
              <span style="font-size:.72rem;font-weight:700;color:@(pct==100?"#198754":"#fd7e14")">@pct%</span>
            </div>
            <div class="progress progress-bar-thin">
              <div class="progress-bar bg-@(pct==100?"success":"warning")" style="width:@pct%"></div>
            </div>
          </div>
        }
        <span class="badge badge-source bg-primary-subtle text-primary">@Model.SourceType</span>
      </div>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table ops-table table-bordered mb-0">
      <thead>
        <tr>
          <th>#</th>
          <th>المرجع</th>
          <th>البيان</th>
          <th>التاريخ</th>
          <th class="text-end">القيمة</th>
          <th class="text-center">الحالة</th>
          <th class="text-center" style="min-width:160px">القيد المحاسبي</th>
          <th class="text-center" style="min-width:120px">إجراء</th>
        </tr>
      </thead>
      <tbody>
        @if (Model.Rows.Any())
        {
          var i = 1;
          foreach (var row in Model.Rows)
          {
            <tr>
              <td class="text-muted">@(i++)</td>
              <td><span class="fw-semibold text-primary">@row.ReferenceNumber</span></td>
              <td>@row.Title</td>
              <td><span class="text-muted">@row.DocumentDate.ToString("yyyy-MM-dd")</span></td>
              <td class="text-end fw-semibold">@row.Amount.ToString("N2")</td>
              <td class="text-center">
                <span class="badge bg-light text-dark" style="border-radius:20px;font-size:.72rem;padding:3px 10px">@row.Status</span>
              </td>
              <td class="text-center">
                @if (row.HasJournalEntry)
                {
                  <a asp-controller="JournalEntries" asp-action="Details" asp-route-id="@row.JournalEntryId"
                     class="entry-btn btn btn-sm btn-success has-entry-link">
                    <i class="bx bx-check me-1"></i> عرض القيد
                  </a>
                }
                else
                {
                  <span class="text-muted small"><i class="bx bx-minus-circle me-1"></i>لا يوجد</span>
                }
              </td>
              <td class="text-center">
                @if (!row.HasJournalEntry)
                {
                  <form asp-action="GenerateDynamic" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="sourceType" value="@Model.SourceType" />
                    <input type="hidden" name="id" value="@row.SourceId" />
                    <button type="submit" class="entry-btn btn btn-sm btn-primary"
                            onclick="return confirm('إنشاء قيد محاسبي لهذه الحركة؟')">
                      <i class="bx bx-plus-circle me-1"></i> إنشاء قيد
                    </button>
                  </form>
                }
                else
                {
                  <span class="badge bg-success-subtle text-success" style="border-radius:20px;padding:4px 10px;font-size:.72rem">
                    <i class="bx bx-check-circle me-1"></i> مرتبط
                  </span>
                }
              </td>
            </tr>
          }
        }
        else
        {
          <tr>
            <td colspan="8" class="text-center text-muted py-4">
              <i class="bx bx-inbox" style="font-size:1.5rem;display:block;margin-bottom:6px"></i>
              لا توجد بيانات لهذا المصدر
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>

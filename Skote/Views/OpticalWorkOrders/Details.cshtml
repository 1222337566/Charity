@model OpticalWorkOrderDetailsVm
@using InfrastructureManagmentWebFramework.Models.Optics.WorkOrders

@{
    ViewData["Title"] = "تفاصيل أمر الشغل";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">تفاصيل أمر الشغل</h4>
            <a asp-action="Index" class="btn btn-secondary btn-sm">رجوع</a>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-3">
                    <label class="form-label">رقم الأمر</label>
                    <input class="form-control" value="@Model.WorkOrderNumber" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label">الفاتورة</label>
                    <input class="form-control" value="@Model.InvoiceNumber" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label">العميل</label>
                    <input class="form-control" value="@Model.CustomerName" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Prescription</label>
                    <input class="form-control" value="@Model.PrescriptionText" readonly />
                </div>

                <div class="col-md-3 mt-3">
                    <label class="form-label">الحالة</label>
                    <input class="form-control" value="@Model.StatusText" readonly />
                </div>
                <div class="col-md-3 mt-3">
                    <label class="form-label">تاريخ الأمر</label>
                    <input class="form-control" value="@Model.OrderDateUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")" readonly />
                </div>
                <div class="col-md-3 mt-3">
                    <label class="form-label">التسليم المتوقع</label>
                    <input class="form-control" value="@(Model.ExpectedDeliveryDateUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "")" readonly />
                </div>
                <div class="col-md-3 mt-3">
                    <label class="form-label">عاجل</label>
                    <input class="form-control" value="@(Model.IsUrgent ? "نعم" : "لا")" readonly />
                </div>
            </div>

            <h5 class="mb-3">الأصناف</h5>
            <div class="table-responsive mb-4">
                <table class="table table-bordered table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>الكود</th>
                            <th>الصنف</th>
                            <th>الكمية</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ItemCode</td>
                                <td>@item.ItemNameAr</td>
                                <td>@item.Quantity</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label">ملاحظات الإطار</label>
                    <textarea class="form-control" rows="3" readonly>@Model.FrameNotes</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">ملاحظات العدسة</label>
                    <textarea class="form-control" rows="3" readonly>@Model.LensNotes</textarea>
                </div>
                <div class="col-md-6 mt-3">
                    <label class="form-label">ملاحظات المعمل</label>
                    <textarea class="form-control" rows="3" readonly>@Model.WorkshopNotes</textarea>
                </div>
                <div class="col-md-6 mt-3">
                    <label class="form-label">ملاحظات التسليم</label>
                    <textarea class="form-control" rows="3" readonly>@Model.DeliveryNotes</textarea>
                </div>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-dark">
                    طباعة أمر الشغل
                </a>
                <form asp-action="MarkInLab" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-warning">إلى المعمل</button>
                </form>

                <form asp-action="MarkReady" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-info">جاهز</button>
                </form>

                <form asp-action="MarkDelivered" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success">تم التسليم</button>
                </form>
            </div>
        </div>
    </div>
</div>
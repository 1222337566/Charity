@model OpticalWorkOrderPrintVm
@using InfrastructureManagmentWebFramework.Models.Optics.WorkOrders

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>طباعة أمر شغل</title>
    <style>
        body {
            font-family: Tahoma, Arial, sans-serif;
            background: #fff;
            color: #000;
            margin: 0;
            padding: 20px;
            font-size: 13px;
        }

        .sheet {
            max-width: 900px;
            margin: 0 auto;
            border: 1px solid #000;
            padding: 20px;
        }

        .title {
            text-align: center;
            font-size: 22px;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 15px;
            font-weight: bold;
            margin: 18px 0 10px;
            padding-bottom: 4px;
            border-bottom: 1px solid #000;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        .field label {
            display: block;
            font-weight: bold;
            margin-bottom: 4px;
        }

        .field .value {
            min-height: 34px;
            border: 1px solid #999;
            padding: 6px 8px;
            background: #fafafa;
        }

        .full {
            grid-column: span 4;
        }

        .half {
            grid-column: span 2;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th, table td {
            border: 1px solid #000;
            padding: 8px;
            text-align: center;
        }

        table th {
            background: #f2f2f2;
        }

        .notes-box {
            border: 1px solid #999;
            min-height: 80px;
            padding: 8px;
            background: #fafafa;
            white-space: pre-line;
        }

        .urgent-badge {
            display: inline-block;
            padding: 4px 10px;
            border: 1px solid #c00;
            color: #c00;
            font-weight: bold;
            border-radius: 4px;
        }

        .signatures {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 30px;
        }

        .signature-box {
            text-align: center;
            padding-top: 30px;
            border-top: 1px solid #000;
            min-height: 50px;
        }

        .no-print {
            text-align: center;
            margin-top: 20px;
        }

        .no-print button {
            padding: 8px 16px;
            margin: 0 4px;
            cursor: pointer;
        }

        @@media print {
            .no-print {
                display: none;
            }

            body {
                padding: 0;
            }

            .sheet {
                border: none;
                max-width: none;
                padding: 0;
            }
        }
    </style>
</head>
<body>
    <div class="sheet">
        <div class="title">أمر شغل نظارات</div>

        <div class="grid">
            <div class="field">
                <label>رقم أمر الشغل</label>
                <div class="value">@Model.WorkOrderNumber</div>
            </div>

            <div class="field">
                <label>رقم الفاتورة</label>
                <div class="value">@Model.InvoiceNumber</div>
            </div>

            <div class="field">
                <label>تاريخ أمر الشغل</label>
                <div class="value">@Model.OrderDateUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
            </div>

            <div class="field">
                <label>الحالة</label>
                <div class="value">
                    @Model.StatusText
                    @if (Model.IsUrgent)
                    {
                            <span class="urgent-badge">عاجل</span>
                    }
                </div>
            </div>

            <div class="field half">
                <label>اسم العميل</label>
                <div class="value">@Model.CustomerName</div>
            </div>

            <div class="field">
                <label>رقم العميل</label>
                <div class="value">@(Model.CustomerNumber ?? "-")</div>
            </div>

            <div class="field">
                <label>التسليم المتوقع</label>
                <div class="value">@(Model.ExpectedDeliveryDateUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
            </div>

            <div class="field full">
                <label>Prescription</label>
                <div class="value">@(Model.PrescriptionText ?? "-")</div>
            </div>
        </div>

        <div class="section-title">الأصناف</div>
        <table>
            <thead>
                <tr>
                    <th style="width: 20%;">الكود</th>
                    <th>الصنف</th>
                    <th style="width: 15%;">الكمية</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                                <tr>
                                    <td>@item.ItemCode</td>
                                    <td>@item.ItemNameAr</td>
                                    <td>@item.Quantity</td>
                                </tr>
                    }
                }
                else
                {
                        <tr>
                            <td colspan="3">لا توجد أصناف</td>
                        </tr>
                }
            </tbody>
        </table>

        <div class="section-title">ملاحظات العمل</div>
        <div class="grid">
            <div class="field half">
                <label>ملاحظات الإطار</label>
                <div class="notes-box">@(Model.FrameNotes ?? "-")</div>
            </div>

            <div class="field half">
                <label>ملاحظات العدسة</label>
                <div class="notes-box">@(Model.LensNotes ?? "-")</div>
            </div>

            <div class="field half">
                <label>ملاحظات المعمل</label>
                <div class="notes-box">@(Model.WorkshopNotes ?? "-")</div>
            </div>

            <div class="field half">
                <label>ملاحظات التسليم</label>
                <div class="notes-box">@(Model.DeliveryNotes ?? "-")</div>
            </div>
        </div>

        <div class="signatures">
            <div class="signature-box">مسؤول المبيعات</div>
            <div class="signature-box">الفني / المعمل</div>
            <div class="signature-box">المستلم</div>
        </div>

        <div class="no-print">
            <button onclick="window.print()">طباعة</button>
            <button onclick="window.close()">إغلاق</button>
        </div>
    </div>
</body>
</html>
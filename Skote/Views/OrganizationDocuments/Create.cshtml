@model InfrastructureManagmentWebFramework.Models.OrganizationDocuments.CreateOrganizationDocumentVm

@{
    ViewData["Title"] = "إضافة مستند";
}

<div style="background:linear-gradient(135deg,#334155,#0f766e);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px">
    <h4 class="fw-bold mb-1 text-white">
        <i class="bx bx-file-plus me-2"></i>إضافة مستند للجمعية
    </h4>
    <div style="opacity:.78;font-size:.82rem">
        حفظ المستندات داخل قاعدة البيانات مع تصنيفها وربطها بالكيانات المختلفة
    </div>
</div>

<div class="card" style="border-radius:16px">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="DocumentNumber" class="form-label"></label>
                    <input asp-for="DocumentNumber" class="form-control" />
                    <span asp-validation-for="DocumentNumber" class="text-danger"></span>
                </div>

                <div class="col-md-5">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DocumentType" class="form-label"></label>
                    <select asp-for="DocumentType" asp-items="Model.DocumentTypes" class="form-select"></select>
                    <span asp-validation-for="DocumentType" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="DocumentDateUtc" class="form-label"></label>
                    <input asp-for="DocumentDateUtc" type="date" class="form-control" />
                    <span asp-validation-for="DocumentDateUtc" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="RelatedEntityType" class="form-label"></label>
                    <select asp-for="RelatedEntityType" asp-items="Model.RelatedEntityTypes" class="form-select">
                        <option value="">بدون ربط</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label asp-for="RelatedEntityId" class="form-label"></label>
                    <input asp-for="RelatedEntityId" class="form-control" placeholder="اختياري" />
                </div>

                <div class="col-md-3">
                    <label asp-for="RelatedEntityName" class="form-label"></label>
                    <input asp-for="RelatedEntityName" class="form-control" placeholder="مثال: مشروع تمكين السيدات" />
                </div>

                <div class="col-md-12">
                    <label asp-for="File" class="form-label"></label>
                    <input asp-for="File" type="file" class="form-control" />
                    <span asp-validation-for="File" class="text-danger"></span>
                    <small class="text-muted">الحد المقترح في الباتش: 30MB.</small>
                </div>

                <div class="col-md-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary fw-bold">
                    <i class="bx bx-save me-1"></i>حفظ المستند
                </button>
                <a asp-action="Index" class="btn btn-light">رجوع</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

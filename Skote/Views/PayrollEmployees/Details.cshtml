@model InfrastructureManagmentWebFramework.Models.Payroll.Employees.PayrollEmployeeDetailsVm
@{
    ViewData["Title"] = "تفاصيل مرتب الموظف";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-1">@Model.EmployeeName</h4>
        <div class="text-muted">@Model.EmployeeCode - شهر @Model.MonthName</div>
    </div>
</div>
<div class="row g-3 mb-3">
    <div class="col-md-2"><div class="card"><div class="card-body"><div class="text-muted">الأساسي</div><strong>@Model.BasicSalary.ToString("N2")</strong></div></div></div>
    <div class="col-md-2"><div class="card"><div class="card-body"><div class="text-muted">الإضافات</div><strong>@Model.Additions.ToString("N2")</strong></div></div></div>
    <div class="col-md-2"><div class="card"><div class="card-body"><div class="text-muted">خصم الحضور</div><strong>@Model.AttendanceDeduction.ToString("N2")</strong></div></div></div>
    <div class="col-md-2"><div class="card"><div class="card-body"><div class="text-muted">خصومات أخرى</div><strong>@Model.OtherDeductions.ToString("N2")</strong></div></div></div>
    <div class="col-md-2"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الخصومات</div><strong>@Model.TotalDeductions.ToString("N2")</strong></div></div></div>
    <div class="col-md-2"><div class="card"><div class="card-body"><div class="text-muted">الصافي</div><strong>@Model.NetAmount.ToString("N2")</strong></div></div></div>
</div>
<h5>تفاصيل البنود</h5>
<table class="table table-bordered table-striped align-middle">
    <thead><tr><th>البند</th><th>النوع</th><th>القيمة</th><th>ملاحظات</th></tr></thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.ItemType</td>
            <td>@item.Value.ToString("N2")</td>
            <td>@item.Notes</td>
        </tr>
    }
    </tbody>
</table>

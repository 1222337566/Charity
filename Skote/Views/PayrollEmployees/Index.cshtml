@model List<InfrastructureManagmentWebFramework.Models.Payroll.Employees.PayrollEmployeeListItemVm>
@using InfrastrfuctureManagmentCore.Domains.Payroll
@{ var payrollMonth = ViewBag.PayrollMonth as PayrollMonth; ViewData["Title"] = "موظفو المرتبات"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-1">موظفو المرتبات</h4>
        <div class="text-muted">@payrollMonth?.Year / @payrollMonth?.Month.ToString("00") - @payrollMonth?.Status</div>
    </div>
    <a asp-controller="PayrollMonths" asp-action="Details" asp-route-id="@payrollMonth?.Id" class="btn btn-light">رجوع للشهر</a>
</div>
<table class="table table-bordered table-striped align-middle">
    <thead><tr><th>الكود</th><th>الموظف</th><th>الأساسي</th><th>الإضافات</th><th>الخصومات</th><th>الصافي</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.EmployeeCode</td>
            <td>@item.EmployeeName</td>
            <td>@item.BasicSalary.ToString("N2")</td>
            <td>@item.Additions.ToString("N2")</td>
            <td>@item.TotalDeductions.ToString("N2")</td>
            <td>@item.NetAmount.ToString("N2")</td>
            <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">تفاصيل</a></td>
        </tr>
    }
    </tbody>
</table>

@model InfrastructureManagmentWebFramework.Models.Payroll.Months.CreatePayrollMonthVm
@{
    ViewData["Title"] = "إضافة شهر مرتبات";
}
<h4 class="mb-3">إضافة شهر مرتبات</h4>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="Year" class="form-label"></label>
            <input asp-for="Year" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Month" class="form-label"></label>
            <input asp-for="Month" class="form-control" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">حفظ</button>
        <a asp-action="Index" class="btn btn-light">رجوع</a>
    </div>
</form>

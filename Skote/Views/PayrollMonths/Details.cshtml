@model InfrastructureManagmentWebFramework.Models.Payroll.Months.PayrollMonthDetailsVm
@{
    ViewData["Title"] = "تفاصيل شهر المرتبات";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-1">شهر المرتبات @Model.Year / @Model.Month.ToString("00")</h4>
        <div class="text-muted">الحالة: @Model.Status</div>
    </div>
    <div class="d-flex gap-2">
        <form asp-action="Generate" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-primary">احتساب المرتبات</button>
        </form>
        @if (Model.Status != "Approved")
        {
            <form asp-action="Approve" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success">اعتماد الشهر</button>
            </form>
        }
        <a asp-controller="PayrollEmployees" asp-action="Index" asp-route-payrollMonthId="@Model.Id" class="btn btn-info">عرض الموظفين</a>
    </div>
</div>
<div class="row g-3">
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">عدد الموظفين</div><h5>@Model.EmployeesCount</h5></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الأساسي</div><h5>@Model.TotalBasic.ToString("N2")</h5></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الإضافات</div><h5>@Model.TotalAdditions.ToString("N2")</h5></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الخصومات</div><h5>@Model.TotalDeductions.ToString("N2")</h5></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">إجمالي الصافي</div><h5>@Model.TotalNet.ToString("N2")</h5></div></div></div>
</div>

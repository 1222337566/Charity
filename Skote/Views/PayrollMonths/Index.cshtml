@model List<InfrastructureManagmentWebFramework.Models.Payroll.Months.PayrollMonthListItemVm>
@using Skote.Helpers
@{
    ViewData["Title"] = "مسيرات الرواتب";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">مسيرات الرواتب</h4>
    <authz policy="PayrollManage">
        <a asp-action="Create" class="btn btn-primary">إضافة شهر مرتبات</a>
    </authz>
</div>
<table class="table table-bordered table-striped align-middle">
    <thead>
        <tr>
            <th>الشهر</th>
            <th>الحالة</th>
            <th>عدد الموظفين</th>
            <th>إجمالي الصافي</th>
            <th style="width:280px"></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Year / @item.Month.ToString("00")</td>
            <td>@item.Status</td>
            <td>@item.EmployeesCount</td>
            <td>@item.TotalNet.ToString("N2")</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">تفاصيل</a>
                <a asp-controller="PayrollEmployees" asp-action="Index" asp-route-payrollMonthId="@item.Id" class="btn btn-sm btn-secondary">الموظفون</a>
            </td>
        </tr>
    }
    </tbody>
</table>

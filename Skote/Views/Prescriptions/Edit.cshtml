
@using InfrastructureManagmentWebFramework.Models.Optics;
@model EditPrescriptionVm
@{
    ViewData["Title"] = "تعديل روشتة";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">تعديل روشتة</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />
                <input asp-for="CustomerId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row mb-3">
                    <div class="col-md-3">
                        <label class="form-label">رقم العميل</label>
                        <input class="form-control" value="@Model.CustomerNumber" readonly />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">اسم العميل</label>
                        <input class="form-control" value="@Model.CustomerName" readonly />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PrescriptionDateUtc" class="form-label"></label>
                        <input asp-for="PrescriptionDateUtc" type="datetime-local" class="form-control"
                               value="@(Model.PrescriptionDateUtc.ToString("yyyy-MM-ddTHH:mm"))" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="DoctorName" class="form-label"></label>
                    <input asp-for="DoctorName" class="form-control" />
                </div>

                <div class="table-responsive mb-3">
                    <table class="table table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th></th>
                                <th>Sph</th>
                                <th>Cyl</th>
                                <th>Axis</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <th>Right</th>
                                <td><input asp-for="RightSph" class="form-control" /></td>
                                <td><input asp-for="RightCyl" class="form-control" /></td>
                                <td><input asp-for="RightAxis" class="form-control" /></td>
                            </tr>
                            <tr>
                                <th>Left</th>
                                <td><input asp-for="LeftSph" class="form-control" /></td>
                                <td><input asp-for="LeftCyl" class="form-control" /></td>
                                <td><input asp-for="LeftAxis" class="form-control" /></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label asp-for="AddValue" class="form-label"></label>
                        <input asp-for="AddValue" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="IPD" class="form-label"></label>
                        <input asp-for="IPD" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="SHeight" class="form-label"></label>
                        <input asp-for="SHeight" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Remarks" class="form-label"></label>
                        <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">حفظ التعديل</button>
                <a asp-action="Index" asp-route-customerId="@Model.CustomerId" class="btn btn-secondary">رجوع</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@using InfrastructureManagmentWebFramework.Models.Optics;
@model List<PrescriptionListItemVm>
@{
    ViewData["Title"] = "Prescriptions";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0">Prescriptions</h4>
                <small class="text-muted">
                    العميل: @ViewBag.CustomerName - @ViewBag.CustomerNumber
                </small>
            </div>

            <div class="d-flex gap-2">
                <a asp-controller="Customers" asp-action="Details" asp-route-id="@ViewBag.CustomerId" class="btn btn-secondary btn-sm">
                    ملف العميل
                </a>
                <a asp-action="Create" asp-route-customerId="@ViewBag.CustomerId" class="btn btn-primary btn-sm">
                    إضافة روشتة
                </a>
            </div>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>التاريخ</th>
                            <th>Doctor</th>
                            <th>R Sph</th>
                            <th>R Cyl</th>
                            <th>R Axis</th>
                            <th>L Sph</th>
                            <th>L Cyl</th>
                            <th>L Axis</th>
                            <th>Add</th>
                            <th>IPD</th>
                            <th>S Height</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.PrescriptionDateUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@(item.DoctorName ?? "-")</td>
                                <td>@item.RightSph</td>
                                <td>@item.RightCyl</td>
                                <td>@item.RightAxis</td>
                                <td>@item.LeftSph</td>
                                <td>@item.LeftCyl</td>
                                <td>@item.LeftAxis</td>
                                <td>@item.AddValue</td>
                                <td>@item.IPD</td>
                                <td>@item.SHeight</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">نشطة</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">غير نشطة</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        تعديل
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
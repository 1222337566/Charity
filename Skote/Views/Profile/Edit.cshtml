@model InfrastructureManagmentWebFramework.DTOs.Profile.ProfileEditDto
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="page-content">
    <div class="container-fluid">

        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">

                        <h4 class="mb-3">Edit Profile</h4>

                        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="row">
                                <div class="col-lg-4">
                                    <div class="border rounded p-3 h-100">
                                        <div class="mb-3 text-center">
                                            <img id="profilePreview"
                                                 src="@(Model?.ProfileImagePath ?? "/assets/images/users/avatar-1.jpg")"
                                                 class="rounded-circle mb-3"
                                                 style="width:120px;height:120px;object-fit:cover;"
                                                 alt="preview" />
                                            <div class="mb-2">
                                                <input asp-for="NewProfileImage"
                                                       type="file"
                                                       accept=".jpg,.jpeg,.png,.webp"
                                                       class="form-control" />
                                                <small class="text-muted d-block">Allowed: jpg, jpeg, png, webp — Max 2MB</small>
                                            </div>
                                        </div>

                                        <div class="alert alert-info mb-0">
                                            ملاحظة: عند رفع صورة جديدة سيتم حذف الصورة القديمة تلقائيًا.
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-8">
                                    <div class="border rounded p-3">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Full Name</label>
                                                <input asp-for="FullName" class="form-control" />
                                                <span asp-validation-for="FullName" class="text-danger"></span>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Phone</label>
                                                <input asp-for="Phone" class="form-control" />
                                                <span asp-validation-for="Phone" class="text-danger"></span>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Department</label>
                                                <input asp-for="Department" class="form-control" />
                                                <span asp-validation-for="Department" class="text-danger"></span>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Job Title</label>
                                                <input asp-for="JobTitle" class="form-control" />
                                                <span asp-validation-for="JobTitle" class="text-danger"></span>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Birth Date</label>
                                                <input asp-for="BirthDate" type="date" class="form-control" />
                                                <span asp-validation-for="BirthDate" class="text-danger"></span>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Gender</label>
                                                <select asp-for="Gender" class="form-select">
                                                    <option value="">-- Select --</option>
                                                    <option>Male</option>
                                                    <option>Female</option>
                                                </select>
                                                <span asp-validation-for="Gender" class="text-danger"></span>
                                            </div>

                                            <div class="col-12">
                                                <label class="form-label">National ID</label>
                                                <input asp-for="NationalId" class="form-control" />
                                                <span asp-validation-for="NationalId" class="text-danger"></span>
                                            </div>

                                            <div class="col-12">
                                                <label class="form-label">Address</label>
                                                <input asp-for="Address" class="form-control" />
                                                <span asp-validation-for="Address" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2 justify-content-end mt-3">
                                        <a class="btn btn-light" asp-controller="Profile" asp-action="Index">Cancel</a>
                                        <button class="btn btn-primary" type="submit">
                                            <i class="bx bx-save align-middle"></i> Save
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-3 text-danger">
                                @Html.ValidationSummary()
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function(){
          const input = document.querySelector('input[name="NewProfileImage"]');
          const img = document.getElementById('profilePreview');
          if(!input || !img) return;

          input.addEventListener('change', function(e){
            const file = e.target.files && e.target.files[0];
            if(!file) return;
            const allowed = ['image/jpeg','image/png','image/webp'];
            if(allowed.indexOf(file.type) === -1){ return; }
            const url = URL.createObjectURL(file);
            img.src = url;
          });
        })();
    </script>
}

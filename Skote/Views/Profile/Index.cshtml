@model ProfileVm
@{
    ViewData["Title"] = "My Profile";
}

<div class="page-content">
    <div class="container-fluid">

        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">

                        <div class="d-flex align-items-center mb-4">
                            <img src="@(Model?.ProfileImagePath ?? "/assets/images/users/avatar-1.jpg")"
                                 class="rounded-circle me-3"
                                 style="width:96px;height:96px;object-fit:cover;"
                                 alt="profile" />
                            <div>
                                <h4 class="mb-0">@Model?.FullName</h4>
                                <small class="text-muted">@Model?.JobTitle @if (!string.IsNullOrWhiteSpace(Model?.Department))
                                    {
                                        <text>- @Model.Department</text>
                                    }</small>
                            </div>
                            <div class="ms-auto">
                                <a class="btn btn-primary" asp-controller="Profile" asp-action="Edit">
                                    <i class="bx bx-edit-alt align-middle"></i> Edit Profile
                                </a>
                            </div>
                        </div>

                        @if (Model is null)
                        {
                            <div class="alert alert-warning mb-0">
                                لا توجد بيانات شخصية بعد. اضغط <a asp-controller="Profile" asp-action="Edit" class="alert-link">هنا</a> لإكمال ملفك.
                            </div>
                        }
                        else
                        {
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100">
                                        <h6 class="text-muted mb-3">Basic Info</h6>
                                        <dl class="row mb-0">
                                            <dt class="col-sm-4">Full Name</dt>
                                            <dd class="col-sm-8">@Model.FullName</dd>
                                            <dt class="col-sm-4">Gender</dt>
                                            <dd class="col-sm-8">@Model.Gender</dd>
                                            <dt class="col-sm-4">Birth Date</dt>
                                            <dd class="col-sm-8">@Model.BirthDate?.ToString("yyyy-MM-dd")</dd>
                                            <dt class="col-sm-4">National ID</dt>
                                            <dd class="col-sm-8">@Model.NationalId</dd>
                                        </dl>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100">
                                        <h6 class="text-muted mb-3">Contact & Work</h6>
                                        <dl class="row mb-0">
                                            <dt class="col-sm-4">Phone</dt>
                                            <dd class="col-sm-8">@Model.Phone</dd>
                                            <dt class="col-sm-4">Department</dt>
                                            <dd class="col-sm-8">@Model.Department</dd>
                                            <dt class="col-sm-4">Job Title</dt>
                                            <dd class="col-sm-8">@Model.JobTitle</dd>
                                            <dt class="col-sm-4">Address</dt>
                                            <dd class="col-sm-8">@Model.Address</dd>
                                        </dl>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

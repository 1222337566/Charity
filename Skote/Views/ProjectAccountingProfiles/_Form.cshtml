@model InfrastructureManagmentWebFramework.Models.AccountingProjects.CreateProjectAccountingProfileVm
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="ProjectId" class="form-label">المشروع</label>
        <select asp-for="ProjectId" asp-items="Model.Projects" class="form-select"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="DefaultCostCenterId" class="form-label">مركز التكلفة الافتراضي</label>
        <select asp-for="DefaultCostCenterId" asp-items="Model.CostCenters" class="form-select">
            <option value="">-- اختر --</option>
        </select>
    </div>
    <div class="col-md-6">
        <label asp-for="DefaultRevenueAccountId" class="form-label">حساب الإيراد الافتراضي</label>
        <select asp-for="DefaultRevenueAccountId" asp-items="Model.Accounts" class="form-select">
            <option value="">-- اختر --</option>
        </select>
    </div>
    <div class="col-md-6">
        <label asp-for="DefaultExpenseAccountId" class="form-label">حساب المصروف الافتراضي</label>
        <select asp-for="DefaultExpenseAccountId" asp-items="Model.Accounts" class="form-select">
            <option value="">-- اختر --</option>
        </select>
    </div>
    <div class="col-md-4 form-check mt-4 ms-3">
        <input asp-for="AutoTagJournalLinesWithProject" class="form-check-input" />
        <label asp-for="AutoTagJournalLinesWithProject" class="form-check-label">وسم القيود بالمشروع تلقائيًا</label>
    </div>
    <div class="col-md-4 form-check mt-4 ms-3">
        <input asp-for="AutoUseProjectCostCenter" class="form-check-input" />
        <label asp-for="AutoUseProjectCostCenter" class="form-check-label">استخدام مركز تكلفة المشروع تلقائيًا</label>
    </div>
    <div class="col-md-3 form-check mt-4 ms-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">نشط</label>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label">ملاحظات</label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.AccountingProjects.ProjectLedgerVm
@{ ViewData["Title"] = "دفتر أستاذ المشروع"; }
<form method="get" class="row g-3 mb-3">
    <div class="col-md-6"><select asp-for="ProjectId" asp-items="Model.Projects" class="form-select"><option value="">اختر المشروع</option></select></div>
    <div class="col-md-2"><input asp-for="FromDate" type="date" class="form-control" /></div>
    <div class="col-md-2"><input asp-for="ToDate" type="date" class="form-control" /></div>
    <div class="col-md-2"><button class="btn btn-primary w-100">عرض</button></div>
</form>
@if (Model.Ledger != null)
{
    <div class="alert alert-light">الرصيد الافتتاحي: <strong>@Model.Ledger.OpeningBalance</strong></div>
    <table class="table table-bordered table-striped">
        <thead><tr><th>التاريخ</th><th>رقم القيد</th><th>الحساب</th><th>مركز التكلفة</th><th>الوصف</th><th>مدين</th><th>دائن</th><th>الرصيد الجاري</th></tr></thead>
        <tbody>
        @foreach (var row in Model.Ledger.Rows)
        {
            <tr>
                <td>@row.EntryDate.ToString("yyyy-MM-dd")</td>
                <td>@row.EntryNumber</td>
                <td>@row.AccountName</td>
                <td>@row.CostCenterName</td>
                <td>@row.Description</td>
                <td>@row.DebitAmount</td>
                <td>@row.CreditAmount</td>
                <td>@row.RunningBalance</td>
            </tr>
        }
        </tbody>
    </table>
}

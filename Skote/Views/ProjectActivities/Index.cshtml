@model List<InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Activities.ProjectActivityListItemVm>
<partial name="~/Views/Shared/Projects/_ProjectHeader.cshtml" />
<div class="card"><div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">الأنشطة</h4>
        <a asp-action="Create" asp-route-projectId="@ViewBag.ProjectHeader.Id" class="btn btn-primary">إضافة نشاط</a>
    </div>
    <table class="table table-bordered">
        <thead><tr><th>العنوان</th><th>المخطط</th><th>الفعلي</th><th>الحالة</th><th>المخطط</th><th>الفعلي</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.PlannedDate.ToString("yyyy-MM-dd")</td>
                <td>@(item.ActualDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                <td>@item.Status</td>
                <td>@item.PlannedCost.ToString("N2")</td>
                <td>@item.ActualCost.ToString("N2")</td>
                <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a></td>
            </tr>
        }
        </tbody>
    </table>
</div></div>

@model InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Activities.CreateProjectActivityVm
<input asp-for="ProjectId" type="hidden" />
<div class="row g-3">
    <div class="col-md-8"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Status" class="form-label"></label><input asp-for="Status" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="PlannedDate" class="form-label"></label><input asp-for="PlannedDate" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="ActualDate" class="form-label"></label><input asp-for="ActualDate" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="PlannedCost" class="form-label"></label><input asp-for="PlannedCost" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="ActualCost" class="form-label"></label><input asp-for="ActualCost" class="form-control" /></div>
    <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
    <div class="col-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
</div>

@model List<InfrastrfuctureManagmentCore.Domains.Charity.Projects.ProjectActivityBeneficiary>
@{
    ViewData["Title"] = "إثبات مشاركة المستفيد";
    var pb = ViewBag.ProjectBeneficiary as InfrastrfuctureManagmentCore.Domains.Charity.Projects.ProjectBeneficiary;
    var name = pb?.Beneficiary?.FullName ?? "—";
    var code = pb?.Beneficiary?.Code ?? "";

    string Sbg(string s) => s switch {
        "Verified"=>"bg-success","Rejected"=>"bg-danger",
        "NeedsReview"=>"bg-warning text-dark",_=>"bg-secondary"
    };
    string SaV(string s) => s switch {
        "Verified"=>"مثبَّت ✓","Rejected"=>"مرفوض ✗",
        "NeedsReview"=>"يحتاج مراجعة ⚠",_=>"غير مثبَّت"
    };
    string PtAr(string s) => s == "Participant" ? "مشارك" : "منتفع";
}

<partial name="~/Views/Shared/Projects/_ProjectHeader.cshtml" />

<style>
:root{--teal:#0e6f73}
.bn-hero{background:linear-gradient(135deg,#065f46,#0e6f73);border-radius:16px;padding:16px 22px;color:#fff;margin-bottom:18px}
.act-card{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 2px 10px rgba(14,111,115,.05);padding:16px;margin-bottom:12px;transition:box-shadow .15s}
.act-card:hover{box-shadow:0 4px 16px rgba(14,111,115,.1)}
.act-card.verified{border-color:rgba(52,195,143,.3);background:rgba(52,195,143,.02)}
.act-card.rejected{border-color:rgba(244,106,106,.25);background:rgba(244,106,106,.02)}
.act-card.needsreview{border-color:rgba(241,180,76,.3);background:rgba(241,180,76,.02)}
.phase-badge{padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700;background:rgba(14,111,115,.08);color:var(--teal)}
.verify-btn{padding:6px 14px;border-radius:10px;font-size:.8rem;font-weight:600;text-decoration:none;transition:all .15s}
.verify-btn.green{background:rgba(52,195,143,.12);color:#1a7a55;border:.5px solid rgba(52,195,143,.25)}
.verify-btn.green:hover{background:#34c38f;color:#fff}
.stat-bar{display:flex;gap:12px;flex-wrap:wrap}
.stat-item{background:rgba(255,255,255,.15);border-radius:10px;padding:8px 14px;text-align:center;min-width:70px}
.stat-item .n{font-size:1.1rem;font-weight:800;line-height:1}
.stat-item .l{font-size:.65rem;opacity:.8;margin-top:2px}
.empty-state{text-align:center;padding:50px 20px;color:#adb5bd}
</style>

<div class="container-fluid">

    @* ── Hero: معلومات المستفيد ── *@
    <div class="bn-hero">
        <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
            <div class="d-flex align-items-center gap-3">
                <div style="width:50px;height:50px;border-radius:14px;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:800;flex-shrink:0">
                    @(name.Length >= 2 ? name[..2] : name)
                </div>
                <div>
                    <div class="fw-bold" style="font-size:1rem">@name</div>
                    <div style="opacity:.75;font-size:.78rem">
                        @code
                        @if (!string.IsNullOrEmpty(pb?.TargetGroupName))
                        {
                            <span style="background:rgba(255,255,255,.18);padding:2px 9px;border-radius:10px;margin-right:6px;font-size:.72rem">
                                @pb.TargetGroupName
                            </span>
                        }
                    </div>
                </div>
            </div>
            <div class="stat-bar">
                <div class="stat-item">
                    <div class="n">@Model.Count</div>
                    <div class="l">الأنشطة</div>
                </div>
                <div class="stat-item" style="background:rgba(52,195,143,.25)">
                    <div class="n">@Model.Count(x=>x.VerificationStatus=="Verified")</div>
                    <div class="l">مثبَّت</div>
                </div>
                <div class="stat-item" style="background:rgba(244,106,106,.2)">
                    <div class="n">@Model.Count(x=>x.VerificationStatus=="Unverified")</div>
                    <div class="l">غير مثبَّت</div>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show py-2 small">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── الأنشطة ── *@
    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bx bx-link-alt" style="font-size:3rem;display:block;margin-bottom:12px;opacity:.3"></i>
            <p>هذا المستفيد لم يُسكَّن في أي نشاط بعد</p>
            <a asp-controller="ActivityBeneficiaryAssignment"
               asp-action="Index"
               asp-route-projectId="@ViewBag.ProjectId"
               class="btn btn-sm" style="background:var(--teal);color:#fff;border-radius:10px;margin-top:8px">
                <i class="bx bx-transfer-alt me-1"></i>اذهب لشاشة التسكين
            </a>
        </div>
    }
    else
    {
        @* تجميع حسب المرحلة *@
        var byPhase = Model.GroupBy(ab => ab.Phase?.Name ?? "—").OrderBy(g => g.Key);

        @foreach (var grp in byPhase)
        {
            <div style="font-size:.8rem;font-weight:700;color:#6b7d80;margin:14px 0 8px;display:flex;align-items:center;gap:6px">
                <i class="bx bx-git-branch" style="color:var(--teal)"></i>
                @grp.Key
            </div>

            @foreach (var ab in grp)
            {
                var cardClass = ab.VerificationStatus switch {
                    "Verified"    => "verified",
                    "Rejected"    => "rejected",
                    "NeedsReview" => "needsreview",
                    _ => ""
                };

                <div class="act-card @cardClass">
                    <div class="d-flex align-items-start gap-3 flex-wrap">

                        @* أيقونة الحالة *@
                        <div style="width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:@(ab.VerificationStatus=="Verified"?"rgba(52,195,143,.15)":ab.VerificationStatus=="Rejected"?"rgba(244,106,106,.12)":"rgba(14,111,115,.08)")">
                            <i class="bx @(ab.VerificationStatus=="Verified"?"bx-check-shield text-success":ab.VerificationStatus=="Rejected"?"bx-x-circle text-danger":"bx-shield")"
                               style="font-size:1.1rem;color:var(--teal)"></i>
                        </div>

                        @* معلومات النشاط *@
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <span class="fw-bold" style="font-size:.9rem;color:#1e3a5f">
                                    @ab.Activity?.Title
                                </span>
                                <span class="phase-badge">@ab.Phase?.Name</span>
                                <span class="badge @(ab.ParticipationType=="Participant"?"bg-primary":"bg-success")"
                                      style="font-size:.65rem">
                                    @PtAr(ab.ParticipationType)
                                </span>
                                @if (!string.IsNullOrEmpty(ab.TargetGroupName))
                                {
                                    <span style="background:rgba(14,111,115,.08);color:var(--teal);padding:2px 8px;border-radius:10px;font-size:.68rem;font-weight:700">
                                        @ab.TargetGroupName
                                    </span>
                                }
                            </div>

                            @* حالة الإثبات الحالية *@
                            <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                <span class="badge @Sbg(ab.VerificationStatus)" style="font-size:.7rem">
                                    @SaV(ab.VerificationStatus)
                                </span>
                                @if (ab.VerificationDate.HasValue)
                                {
                                    <span style="font-size:.72rem;color:#adb5bd">
                                        <i class="bx bx-calendar me-1"></i>
                                        @ab.VerificationDate.Value.ToString("yyyy/MM/dd")
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(ab.VerificationNotes))
                                {
                                    <span style="font-size:.72rem;color:#6b7d80;font-style:italic">
                                        "@ab.VerificationNotes"
                                    </span>
                                }
                                @if (ab.Attachments?.Any() == true)
                                {
                                    <span style="background:rgba(14,111,115,.08);color:var(--teal);padding:2px 8px;border-radius:8px;font-size:.68rem">
                                        <i class="bx bx-paperclip me-1"></i>@ab.Attachments.Count مرفق
                                    </span>
                                }
                            </div>
                        </div>

                        @* زر الإثبات *@
                        <a asp-controller="ProjectBeneficiaries"
                           asp-action="Verify"
                           asp-route-activityBeneficiaryId="@ab.Id"
                           class="verify-btn green">
                            <i class="bx bx-shield-check me-1"></i>
                            @(ab.VerificationStatus == "Unverified" ? "إثبات" : "تعديل الإثبات")
                        </a>

                    </div>
                </div>
            }
        }
    }

    <div class="mt-3">
        <a asp-action="Index" asp-route-projectId="@ViewBag.ProjectId"
           class="btn btn-light btn-sm" style="border-radius:10px">
            <i class="bx bx-arrow-back me-1"></i>قائمة المستفيدين
        </a>
    </div>
</div>

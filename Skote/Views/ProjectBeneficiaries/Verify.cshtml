@model InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Beneficiaries.VerifyActivityBeneficiaryVm
@using InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Beneficiaries
@{
    ViewData["Title"] = "إثبات مشاركة مستفيد";
    var ab = ViewBag.ActivityBeneficiary as InfrastrfuctureManagmentCore.Domains.Charity.Projects.ProjectActivityBeneficiary;
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">

            <h5 class="fw-bold mb-4">
                <i class="bx bx-shield-check me-2 text-success"></i>إثبات مشاركة مستفيد
            </h5>

            @if (ab != null)
            {
                <div class="alert alert-light border mb-4">
                    <div class="row g-2 small">
                        <div class="col-md-4">
                            <span class="text-muted">المستفيد:</span>
                            <strong>@ab.Beneficiary?.Beneficiary?.FullName</strong>
                        </div>
                        <div class="col-md-4">
                            <span class="text-muted">المرحلة:</span>
                            <strong>@ab.Phase?.Name</strong>
                        </div>
                        <div class="col-md-4">
                            <span class="text-muted">النشاط:</span>
                            <strong>@ab.Activity?.Title</strong>
                        </div>
                        <div class="col-md-4">
                            <span class="text-muted">الفئة المستهدفة:</span>
                            <strong>@(ab.TargetGroupName ?? "—")</strong>
                        </div>
                        <div class="col-md-4">
                            <span class="text-muted">نوع المشاركة:</span>
                            <strong>@(ab.ParticipationType == "Participant" ? "مشارك" : "منتفع")</strong>
                        </div>
                    </div>
                </div>
            }

            <form asp-action="Verify" method="post" enctype="multipart/form-data">
                <input asp-for="ActivityBeneficiaryId" type="hidden" />

                <div class="row g-3">

                    <div class="col-md-6">
                        <label asp-for="VerificationStatus" class="form-label fw-semibold">حالة الإثبات *</label>
                        <select asp-for="VerificationStatus" class="form-select">
                            <option value="Unverified">غير مثبت</option>
                            <option value="Verified">مثبت ✓</option>
                            <option value="Rejected">مرفوض ✗</option>
                            <option value="NeedsReview">يحتاج مراجعة ⚠</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="VerificationDate" class="form-label fw-semibold">تاريخ الإثبات</label>
                        <input asp-for="VerificationDate" type="date" class="form-control" />
                    </div>

                    <div class="col-12">
                        <label asp-for="VerificationNotes" class="form-label fw-semibold">ملاحظات الإثبات</label>
                        <textarea asp-for="VerificationNotes" class="form-control" rows="2"></textarea>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="AttachmentType" class="form-label fw-semibold">نوع المرفق</label>
                        <select asp-for="AttachmentType" class="form-select">
                            <option value="AttendancePhoto">صورة حضور</option>
                            <option value="Signature">توقيع</option>
                            <option value="ParticipationForm">استمارة مشاركة</option>
                            <option value="IdPhoto">صورة هوية</option>
                            <option value="ActivityReport">تقرير نشاط</option>
                            <option value="Other">أخرى</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="NewAttachments" class="form-label fw-semibold">رفع مرفقات</label>
                        <input asp-for="NewAttachments" type="file" class="form-control" multiple
                               accept="image/*,.pdf" />
                        <small class="text-muted">صور أو PDF</small>
                    </div>

                    @if (ab?.Attachments?.Any() == true)
                    {
                        <div class="col-12">
                            <label class="form-label fw-semibold">المرفقات الموجودة</label>
                            <ul class="list-group list-group-flush">
                            @foreach (var att in ab.Attachments)
                            {
                                <li class="list-group-item d-flex justify-content-between small">
                                    <span><i class="bx bx-file me-1"></i>@att.OriginalFileName</span>
                                    <span class="text-muted">@VerifyActivityBeneficiaryVm.GetAttachmentTypeAr(att.AttachmentType)</span>
                                </li>
                            }
                            </ul>
                        </div>
                    }

                </div>

                <div class="mt-4 d-flex gap-2 border-top pt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bx bx-save me-1"></i>حفظ الإثبات
                    </button>
                    <a asp-action="Index" asp-route-projectId="@ab?.ProjectId" class="btn btn-light">رجوع</a>
                </div>
            </form>

        </div>
    </div>
</div>

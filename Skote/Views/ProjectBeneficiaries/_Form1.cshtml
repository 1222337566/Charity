@model InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Beneficiaries.CreateProjectBeneficiaryVm
<input asp-for="ProjectId" type="hidden" />
<div class="row g-3">
    <div class="col-md-12">
        <label asp-for="BeneficiaryId" class="form-label"></label>
        <select asp-for="BeneficiaryId" asp-items="Model.Beneficiaries" class="form-select"></select>
    </div>
    <div class="col-md-6"><label asp-for="EnrollmentDate" class="form-label"></label><input asp-for="EnrollmentDate" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="ExitDate" class="form-label"></label><input asp-for="ExitDate" class="form-control" /></div>
    <div class="col-md-12"><label asp-for="BenefitType" class="form-label"></label><input asp-for="BenefitType" class="form-control" /></div>
    <div class="col-md-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
</div>

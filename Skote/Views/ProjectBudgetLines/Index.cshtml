@model List<InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.BudgetLines.ProjectBudgetLineListItemVm>
<partial name="~/Views/Shared/Projects/_ProjectHeader.cshtml" />
<div class="card"><div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">بنود الموازنة</h4>
        <a asp-action="Create" asp-route-projectId="@ViewBag.ProjectHeader.Id" class="btn btn-primary">إضافة بند</a>
    </div>
    <table class="table table-bordered">
        <thead><tr><th>البند</th><th>النوع</th><th>المخطط</th><th>الفعلي</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.LineName</td><td>@item.LineType</td>
                <td>@item.PlannedAmount.ToString("N2")</td><td>@item.ActualAmount.ToString("N2")</td>
                <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a></td>
            </tr>
        }
        </tbody>
    </table>
</div></div>

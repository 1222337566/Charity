@model List<InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.BudgetLines.ProjectBudgetLineListItemVm>
<partial name="~/Views/Shared/Projects/_ProjectHeader.cshtml" />
@{
    var totalPlanned=Model.Sum(x=>x.PlannedAmount);
    var totalActual=Model.Sum(x=>x.ActualAmount);
    var overBudget=Model.Where(x=>x.ActualAmount>x.PlannedAmount).ToList();
    string TypeAr(string s)=>s switch{"Revenue"=>"إيراد","Expense"=>"مصروف","Capital"=>"رأسمال","Operational"=>"تشغيلي",_=>s};
    string TypeColor(string s)=>s switch{"Revenue"=>"#34c38f","Expense"=>"#f46a6a","Capital"=>"#556ee6",_=>"#f1b44c"};
}
<style>
:root{--teal:#0e6f73;--teal-l:#e1f5f5;--ink:#1e3a5f;--muted:#6b7d80}
.bgt-top{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.bgt-stat{background:#fff;border-radius:12px;border:.5px solid rgba(14,111,115,.1);padding:12px 16px;flex:1;min-width:90px;text-align:center;box-shadow:0 2px 8px rgba(14,111,115,.05)}
.bgt-stat .n{font-size:1.3rem;font-weight:800;color:var(--teal)}
.bgt-stat .l{font-size:.67rem;color:var(--muted);margin-top:2px}
.bgt-table{width:100%;border-collapse:collapse;font-size:.84rem}
.bgt-table th{padding:10px 14px;font-size:.73rem;font-weight:700;color:var(--muted);background:#f4f9f9;text-align:right;border-bottom:.5px solid rgba(14,111,115,.12);white-space:nowrap}
.bgt-table td{padding:12px 14px;border-bottom:.5px solid rgba(14,111,115,.05);vertical-align:middle}
.bgt-table tr:hover td{background:rgba(14,111,115,.02)}
.bgt-table .total-row{background:#f0f9f9;font-weight:700}
.type-badge{padding:3px 10px;border-radius:20px;font-size:.68rem;font-weight:700;color:#fff}
.prog-cell{min-width:130px}
.prog-bar{height:6px;border-radius:999px;background:#e2e8f0;overflow:hidden;margin-bottom:2px}
.prog-fill{height:100%;border-radius:999px}
.over-badge{background:rgba(244,106,106,.12);color:#d63301;padding:2px 7px;border-radius:5px;font-size:.67rem;font-weight:700}
.empty-bgt{padding:48px;text-align:center;color:var(--muted)}
.empty-bgt i{font-size:2.5rem;opacity:.3;display:block;margin-bottom:10px}
</style>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h4 class="mb-0 fw-bold" style="color:var(--ink)">بنود الموازنة</h4>
        @if(overBudget.Any()){
            <small class="text-danger"><i class="bx bx-error-circle me-1"></i>@overBudget.Count بند تجاوز الموازنة</small>
        }
    </div>
    @if(ViewBag.ProjectHeader!=null){
        <a asp-action="Create" asp-route-projectId="@ViewBag.ProjectHeader.Id" class="btn btn-sm fw-semibold" style="background:var(--teal);color:#fff;border-radius:10px">
            <i class="bx bx-plus me-1"></i>إضافة بند
        </a>
    }
</div>
<div class="bgt-top">
    <div class="bgt-stat"><div class="n">@Model.Count</div><div class="l">عدد البنود</div></div>
    <div class="bgt-stat"><div class="n" style="color:var(--ink)">@totalPlanned.ToString("N0")</div><div class="l">إجمالي مخطط</div></div>
    <div class="bgt-stat"><div class="n" style="color:@(totalActual>totalPlanned?"#f46a6a":"var(--teal)")">@totalActual.ToString("N0")</div><div class="l">إجمالي فعلي</div></div>
    <div class="bgt-stat">
        @{var totalPct=totalPlanned>0?Math.Min(100,Math.Round((double)totalActual/(double)totalPlanned*100)):0;}
        <div class="n" style="color:@(totalPct>100?"#f46a6a":"var(--teal)")">@totalPct%</div>
        <div class="l">نسبة الصرف</div>
    </div>
</div>
@if(!Model.Any()){
    <div class="empty-bgt"><i class="bx bx-spreadsheet"></i><p>لا توجد بنود موازنة</p></div>
}else{
    <div class="card" style="border-radius:14px;border:.5px solid rgba(14,111,115,.1);overflow:hidden">
        <div class="table-responsive">
            <table class="bgt-table">
                <thead>
                    <tr>
                        <th>البند</th><th>النوع</th>
                        <th>المخطط</th><th>الفعلي</th>
                        <th>نسبة الاستخدام</th><th style="width:80px"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach(var item in Model){
                    var pct=item.PlannedAmount>0?Math.Min(150,Math.Round((double)item.ActualAmount/(double)item.PlannedAmount*100)):0;
                    var barColor=pct>100?"#f46a6a":pct>=75?"#f1b44c":"#34c38f";
                    var over=item.ActualAmount>item.PlannedAmount;
                    <tr>
                        <td>
                            <div class="fw-semibold" style="color:var(--ink)">@item.LineName</div>
                            @if(!string.IsNullOrWhiteSpace(item.Notes)){<div class="text-muted" style="font-size:.72rem">@item.Notes</div>}
                        </td>
                        <td><span class="type-badge" style="background:@TypeColor(item.LineType)">@TypeAr(item.LineType)</span></td>
                        <td class="fw-semibold">@item.PlannedAmount.ToString("N0")</td>
                        <td class="fw-semibold" style="color:@(over?"#f46a6a":"var(--ink)")">
                            @item.ActualAmount.ToString("N0")
                            @if(over){<span class="over-badge ms-1">تجاوز</span>}
                        </td>
                        <td class="prog-cell">
                            <div class="prog-bar"><div class="prog-fill" style="width:@(Math.Min(100,pct))%;background:@barColor"></div></div>
                            <div style="font-size:.7rem;color:var(--muted)">@pct%</div>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light" style="border-radius:7px"><i class="bx bx-edit-alt"></i></a>
                        </td>
                    </tr>
                }
                <tr class="total-row">
                    <td colspan="2">الإجمالي</td>
                    <td>@totalPlanned.ToString("N0")</td>
                    <td style="color:@(totalActual>totalPlanned?"#f46a6a":"var(--teal)")">@totalActual.ToString("N0")</td>
                    <td>
                        <div class="prog-bar"><div class="prog-fill" style="width:@(Math.Min(100,totalPct))%;background:@(totalPct>100?"#f46a6a":totalPct>=75?"#f1b44c":"#34c38f")"></div></div>
                        <div style="font-size:.7rem;color:var(--muted)">@totalPct%</div>
                    </td>
                    <td></td>
                </tr>
                </tbody>
            </table>
        </div>
    </div>
}

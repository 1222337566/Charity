@model InfrastructureManagmentWebFramework.Models.AccountingProjects.CreateProjectExpenseLinkVm
@{ ViewData["Title"] = "ربط مصروف بمشروع"; }
<form method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="ExpenseId" class="form-label">المصروف</label>
            <select asp-for="ExpenseId" asp-items="Model.Expenses" class="form-select"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="ProjectId" class="form-label">المشروع</label>
            <select asp-for="ProjectId" asp-items="Model.Projects" class="form-select"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="ProjectBudgetLineId" class="form-label">بند الموازنة</label>
            <select asp-for="ProjectBudgetLineId" asp-items="Model.BudgetLines" class="form-select"><option value="">-- اختر --</option></select>
        </div>
        <div class="col-md-6">
            <label asp-for="CostCenterId" class="form-label">مركز التكلفة</label>
            <select asp-for="CostCenterId" asp-items="Model.CostCenters" class="form-select"><option value="">-- اختر --</option></select>
        </div>
        <div class="col-12">
            <label asp-for="Notes" class="form-label">ملاحظات</label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        </div>
    </div>
    <div class="mt-3">
        <button class="btn btn-primary">حفظ</button>
        <a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-light">رجوع</a>
    </div>
</form>

@model List<InfrastructureManagmentWebFramework.Models.AccountingProjects.ProjectExpenseLinkListItemVm>
@{
    ViewData["Title"] = "ربط المصروفات بالمشروعات";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>ربط المصروفات بالمشروعات</h4>
    <a asp-action="Create" asp-route-projectId="@ViewBag.ProjectId" class="btn btn-primary">ربط مصروف</a>
</div>
<table class="table table-bordered table-striped">
    <thead><tr><th>رقم المصروف</th><th>التاريخ</th><th>القيمة</th><th>المشروع</th><th>بند الموازنة</th><th>مركز التكلفة</th><th>ملاحظات</th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ExpenseNumber</td>
            <td>@item.ExpenseDateUtc.ToString("yyyy-MM-dd")</td>
            <td>@item.Amount</td>
            <td>@item.ProjectName</td>
            <td>@item.BudgetLineName</td>
            <td>@item.CostCenterName</td>
            <td>@item.Notes</td>
        </tr>
    }
    </tbody>
</table>

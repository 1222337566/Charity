@model List<InfrastrfuctureManagmentCore.Domains.Charity.Projects.ProjectGoal>
@using InfrastrfuctureManagmentCore.Domains.Charity.Projects
@{
    ViewData["Title"] = "الأهداف والأنشطة";
    var project = ViewBag.Project as CharityProject;
    var phases   = ViewBag.Phases  as List<ProjectPhase> ?? new();
    var phasesJson = ViewBag.PhasesJson as string ?? "[]";

    string Sc(string s) => s switch {
        "Completed" or "Achieved" => "#34c38f", "InProgress" or "Active" => "#556ee6",
        "Cancelled" => "#f46a6a", _ => "#adb5bd"
    };
    string Sa(string s) => s switch {
        "Planned" => "مخطط", "InProgress" => "جارٍ", "Completed" => "مكتمل",
        "Cancelled" => "ملغى", "Active" => "نشط", "Achieved" => "محقق", _ => s
    };
    string Pa(string s) => s switch {
        "Critical" => "🔴 حرج", "High" => "🟠 عالي",
        "Medium" => "🟡 متوسط", "Low" => "🟢 منخفض", _ => s
    };
    decimal TotalPlanned = Model.SelectMany(g => g.SubGoals)
        .SelectMany(s => s.Activities).Sum(a => a.PlannedCost);
    decimal TotalActual  = Model.SelectMany(g => g.SubGoals)
        .SelectMany(s => s.Activities).Sum(a => a.ActualCost);
}

<style>
.pg-hero{background:linear-gradient(135deg,#1a3c5e,#2d6a8a);border-radius:18px;padding:20px 26px;color:#fff;margin-bottom:16px}
.pg-stat{background:rgba(255,255,255,.15);border-radius:12px;padding:10px 16px;text-align:center;flex:1;min-width:80px}
.pg-stat .n{font-size:1.1rem;font-weight:800;line-height:1}
.pg-stat .l{font-size:.65rem;opacity:.8;margin-top:2px}

.goal-wrap{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 2px 10px rgba(14,111,115,.05);margin-bottom:12px;overflow:hidden}
.goal-hdr{padding:13px 18px;display:flex;align-items:center;gap:10px;cursor:pointer;background:rgba(14,111,115,.03)}
.goal-hdr:hover{background:rgba(14,111,115,.06)}
.goal-body{display:none;padding:0 12px 12px 12px}
.goal-body.open{display:block}

.sub-wrap{background:#f8fbfb;border-radius:12px;border:.5px solid rgba(14,111,115,.09);margin-bottom:8px;overflow:hidden}
.sub-hdr{padding:10px 14px;display:flex;align-items:center;gap:8px;cursor:pointer}
.sub-hdr:hover{background:rgba(14,111,115,.04)}
.sub-body{display:none;padding:0 12px 10px 12px}
.sub-body.open{display:block}

.act-card{background:#fff;border-radius:10px;border:.5px solid rgba(14,111,115,.08);margin-bottom:6px;overflow:hidden}
.act-hdr{padding:9px 12px;display:flex;align-items:center;gap:8px;cursor:pointer}
.act-hdr:hover{background:rgba(14,111,115,.03)}
.act-body{display:none;padding:8px 12px 10px}
.act-body.open{display:block}

.phase-chip{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:8px;font-size:.72rem;background:rgba(85,110,230,.08);color:#3145a3;margin:2px}
.prog-bar{height:5px;border-radius:999px;background:#e2e8f0;overflow:hidden;flex:1;min-width:50px}
.prog-fill{height:100%;border-radius:999px;transition:width .3s}

.add-form{background:rgba(14,111,115,.04);border-radius:12px;border:.5px dashed rgba(14,111,115,.2);padding:12px 14px;margin-top:8px}
.add-form input,.add-form select,.add-form textarea{border-radius:8px;border:.5px solid rgba(14,111,115,.2);padding:5px 9px;font-size:.82rem;width:100%}
.add-form input:focus,.add-form select:focus{outline:none;border-color:#0e6f73}
.add-form label{font-size:.75rem;color:#6b7d80;font-weight:600;margin-bottom:2px;display:block}

.badge-s{padding:2px 8px;border-radius:5px;font-size:.67rem;font-weight:700}
.tree-l{border-right:2px solid rgba(14,111,115,.12);margin-right:10px;padding-right:10px}
</style>

@* Hero *@
<div class="pg-hero">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
      <h5 class="fw-bold mb-1 text-white">
        <i class="bx bx-target-lock me-2"></i>الأهداف والأنشطة — @project?.Name
      </h5>
      <div style="opacity:.7;font-size:.78rem">
        الهدف الرئيسي → الأهداف الفرعية → الأنشطة → المراحل
      </div>
    </div>
    <div class="d-flex gap-2">
      <a asp-controller="ProjectGoals" asp-action="QuickAddBeneficiary"
         asp-route-projectId="@project?.Id"
         class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">
        <i class="bx bx-user-plus me-1"></i>إضافة مستفيد سريعة
      </a>
      <a asp-controller="CharityProjects" asp-action="Details" asp-route-id="@project?.Id"
         class="btn btn-light btn-sm fw-bold" style="border-radius:10px">← رجوع</a>
    </div>
  </div>
  <div class="d-flex gap-3 flex-wrap">
    <div class="pg-stat">
      <div class="n">@Model.Count</div><div class="l">أهداف رئيسية</div>
    </div>
    <div class="pg-stat">
      <div class="n">@Model.Sum(g => g.SubGoals.Count)</div><div class="l">أهداف فرعية</div>
    </div>
    <div class="pg-stat">
      <div class="n">@Model.SelectMany(g => g.SubGoals).Sum(s => s.Activities.Count)</div>
      <div class="l">أنشطة</div>
    </div>
    <div class="pg-stat" style="background:rgba(52,195,143,.2)">
      <div class="n" style="color:#a7f3d0">@TotalPlanned.ToString("N0")</div>
      <div class="l">تكلفة مخططة</div>
    </div>
    <div class="pg-stat" style="background:rgba(241,180,76,.15)">
      <div class="n" style="color:#fde68a">@TotalActual.ToString("N0")</div>
      <div class="l">تكلفة فعلية</div>
    </div>
  </div>
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">
    <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
}

@* إضافة هدف رئيسي *@
<div class="add-form mb-3">
  <div class="fw-bold mb-2" style="color:#0a5f63;font-size:.88rem">
    <i class="bx bx-plus-circle me-1"></i>إضافة هدف رئيسي جديد
  </div>
  <form asp-action="AddGoal" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="projectId" value="@project?.Id"/>
    <div class="row g-2">
      <div class="col-md-4"><label>عنوان الهدف *</label><input name="title" required placeholder="مثال: تعزيز الاستدامة البيئية"/></div>
      <div class="col-md-3"><label>مؤشر النجاح</label><input name="successIndicator" placeholder="كيف نقيس النجاح؟"/></div>
      <div class="col-md-3"><label>القيمة المستهدفة</label><input name="targetValue" placeholder="مثال: 200 شخص"/></div>
      <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary fw-bold w-100" style="border-radius:10px">
          <i class="bx bx-plus me-1"></i>إضافة
        </button>
      </div>
    </div>
  </form>
</div>

@* شجرة الأهداف *@
@if (!Model.Any())
{
  <div class="text-center py-5" style="background:#fff;border-radius:16px;color:#adb5bd">
    <i class="bx bx-target-lock" style="font-size:3rem;display:block;margin-bottom:12px"></i>
    <p>لا توجد أهداف — أضف أول هدف رئيسي أعلاه</p>
  </div>
}

@foreach (var goal in Model)
{
  var gProg = goal.SubGoals.Any()
      ? goal.SubGoals.Average(s => (double)s.ProgressPercent) : 0;
  var gActs = goal.SubGoals.Sum(s => s.Activities.Count);

  <div class="goal-wrap">
    <div class="goal-hdr" onclick="tog('g-@goal.Id')">
      <div style="width:32px;height:32px;border-radius:9px;background:#0e6f73;color:#fff;display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:800;flex-shrink:0">@goal.SortOrder</div>
      <div class="flex-grow-1">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <span class="fw-bold" style="font-size:.93rem;color:#0a5f63">@goal.Title</span>
          @if (!string.IsNullOrWhiteSpace(goal.SuccessIndicator))
          { <span style="font-size:.72rem;color:#6b7d80">📊 @goal.SuccessIndicator</span> }
          @if (!string.IsNullOrWhiteSpace(goal.TargetValue))
          { <span class="badge-s" style="background:rgba(14,111,115,.1);color:#0a5f63">🎯 @goal.TargetValue</span> }
        </div>
        <div class="d-flex align-items-center gap-2 mt-1">
          <div class="prog-bar"><div class="prog-fill" style="width:@gProg%;background:#0e6f73"></div></div>
          <span style="font-size:.7rem;color:#6b7d80">@((int)gProg)% · @goal.SubGoals.Count هدف فرعي · @gActs نشاط</span>
        </div>
      </div>
      <div class="d-flex gap-2 align-items-center flex-shrink-0">
        <form asp-action="DeleteGoal" method="post" class="d-inline">
          @Html.AntiForgeryToken()
          <input type="hidden" name="id" value="@goal.Id"/>
          <input type="hidden" name="projectId" value="@project?.Id"/>
          <button type="submit" class="btn btn-sm" style="border-radius:7px;background:rgba(244,106,106,.1);color:#f46a6a;border:none" onclick="return confirm('حذف الهدف؟')"><i class="bx bx-trash"></i></button>
        </form>
        <i class="bx bx-chevron-down" style="color:#adb5bd"></i>
      </div>
    </div>

    <div id="g-@goal.Id" class="goal-body">
      <div class="tree-l mt-2">
        @* إضافة هدف فرعي *@
        <div class="add-form mb-3">
          <div class="fw-semibold mb-2" style="font-size:.8rem;color:#0a5f63">+ إضافة هدف فرعي لـ «@goal.Title»</div>
          <form asp-action="AddSubGoal" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@project?.Id"/>
            <input type="hidden" name="goalId" value="@goal.Id"/>
            <div class="row g-2">
              <div class="col-md-5"><label>الهدف الفرعي *</label><input name="title" required placeholder="مثال: رفع الوعي المجتمعي لـ 200 شخص"/></div>
              <div class="col-md-3"><label>مؤشر النجاح</label><input name="successIndicator" placeholder="مثال: نسبة الحضور"/></div>
              <div class="col-md-3"><label>المستهدف</label><input name="targetValue" placeholder="مثال: 200 شخص / 100%"/></div>
              <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-success btn-sm fw-bold w-100" style="border-radius:8px">+</button>
              </div>
            </div>
          </form>
        </div>

        @foreach (var sub in goal.SubGoals.OrderBy(s => s.SortOrder))
        {
          var sActCount = sub.Activities.Count;
          var sTotalQ   = sub.Activities.Sum(a => a.PlannedQuantity);
          var sTotalC   = sub.Activities.Sum(a => a.PlannedCost);

          <div class="sub-wrap mb-3">
            <div class="sub-hdr" onclick="tog('s-@sub.Id')">
              <div style="width:26px;height:26px;border-radius:7px;background:rgba(85,110,230,.15);color:#3145a3;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;flex-shrink:0">@sub.SortOrder</div>
              <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <span class="fw-semibold" style="font-size:.88rem">@sub.Title</span>
                  @if (!string.IsNullOrWhiteSpace(sub.TargetValue))
                  { <span class="badge-s" style="background:rgba(85,110,230,.1);color:#3145a3">🎯 @sub.TargetValue</span> }
                  <span style="font-size:.7rem;color:#adb5bd">@sActCount نشاط · تكلفة @sTotalC.ToString("N0")</span>
                </div>
                <div class="d-flex align-items-center gap-2 mt-1">
                  <div class="prog-bar"><div class="prog-fill" style="width:@sub.ProgressPercent%;background:#556ee6"></div></div>
                  <span style="font-size:.7rem;color:#6b7d80">@sub.ProgressPercent%</span>
                </div>
              </div>
              <div class="d-flex gap-2 align-items-center flex-shrink-0">
                <form asp-action="DeleteSubGoal" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="id" value="@sub.Id"/>
                  <input type="hidden" name="projectId" value="@project?.Id"/>
                  <button type="submit" class="btn btn-sm" style="border-radius:6px;background:rgba(244,106,106,.1);color:#f46a6a;border:none;padding:3px 7px" onclick="return confirm('حذف الهدف الفرعي؟')"><i class="bx bx-trash" style="font-size:.8rem"></i></button>
                </form>
                <i class="bx bx-chevron-down" style="color:#adb5bd;font-size:.9rem"></i>
              </div>
            </div>

            <div id="s-@sub.Id" class="sub-body">
              <div class="tree-l">
                @* إضافة نشاط *@
                <div class="add-form mb-3">
                  <div class="fw-semibold mb-2" style="font-size:.78rem;color:#0a5f63">+ إضافة نشاط لـ «@sub.Title»</div>
                  <form asp-action="AddActivity" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@project?.Id"/>
                    <input type="hidden" name="subGoalId" value="@sub.Id"/>
                    <div class="row g-2">
                      <div class="col-md-4"><label>عنوان النشاط *</label><input name="title" required placeholder="مثال: تنفيذ ورشات تدريبية"/></div>
                      <div class="col-md-2"><label>الفئة المستهدفة</label><input name="targetGroup" placeholder="شباب / مزارعون / قيادات"/></div>
                      <div class="col-md-1"><label>الكمية المخططة</label><input name="plannedQuantity" type="number" value="0" min="0" step="0.01"/></div>
                      <div class="col-md-1"><label>الوحدة</label><input name="quantityUnit" placeholder="شخص"/></div>
                      <div class="col-md-1"><label>مدة (أيام)</label><input name="plannedDurationDays" type="number" min="0"/></div>
                      <div class="col-md-1"><label>ساعات/يوم</label><input name="plannedHoursPerDay" type="number" step="0.5" min="0"/></div>
                      <div class="col-md-1"><label>الأولوية</label>
                        <select name="priority"><option value="High">عالي</option><option value="Medium" selected>متوسط</option><option value="Low">منخفض</option></select>
                      </div>
                      <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary btn-sm fw-bold w-100" style="border-radius:8px">+</button>
                      </div>
                    </div>
                    <div class="row g-2 mt-1">
                      <div class="col-md-4"><label>مؤشر الأداء</label><input name="performanceIndicator" placeholder="مثال: عدد حضور الندوات"/></div>
                      <div class="col-md-4"><label>وسائل التحقق</label><input name="verificationMeans" placeholder="مثال: كشف حضور - صور - فواتير"/></div>
                      <div class="col-md-4"><label>المسؤول</label><input name="responsiblePersonName" placeholder="مثال: مشرف + منسق"/></div>
                    </div>
                  </form>
                </div>

                @* الأنشطة *@
                @foreach (var act in sub.Activities.OrderBy(a => a.SortOrder))
                {
                  var phasesInAct = act.PhaseAssignments.OrderBy(p => p.SortOrder).ToList();
                  <div class="act-card">
                    <div class="act-hdr" onclick="tog('a-@act.Id')">
                      <div style="width:8px;height:8px;border-radius:50%;background:@Sc(act.Status);flex-shrink:0"></div>
                      <div class="flex-grow-1 min-w-0">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                          <span class="fw-semibold" style="font-size:.85rem">@act.Title</span>
                          @if (!string.IsNullOrWhiteSpace(act.TargetGroup))
                          { <span class="badge-s" style="background:rgba(52,195,143,.12);color:#065f46">👥 @act.TargetGroup</span> }
                          @if (act.PlannedQuantity > 0)
                          { <span class="badge-s" style="background:rgba(14,111,115,.1);color:#0a5f63">@act.PlannedQuantity @act.QuantityUnit</span> }
                          @if (act.PlannedDurationDays != null)
                          { <span style="font-size:.7rem;color:#adb5bd">⏱ @act.PlannedDurationDays يوم@(act.PlannedHoursPerDay!= null ? $" · {act.PlannedHoursPerDay}س/يوم" : "")</span> }
                          <span style="font-size:.7rem;color:#adb5bd">@Pa(act.Priority)</span>
                        </div>
                        @* المراحل *@
                        @if (phasesInAct.Any())
                        {
                          <div class="d-flex flex-wrap gap-1 mt-1">
                            @foreach (var pa in phasesInAct)
                            {
                              <span class="phase-chip">
                                <span style="font-weight:700">@(pa.Phase?.Name ?? "مرحلة")</span>
                                @if (pa.PlannedQuantity > 0) { <span>@pa.PlannedQuantity</span> }
                                <div style="width:30px;height:4px;border-radius:999px;background:rgba(85,110,230,.2);overflow:hidden">
                                  <div style="width:@pa.ProgressPercent%;height:100%;background:#556ee6"></div>
                                </div>
                                <span>@pa.ProgressPercent%</span>
                              </span>
                            }
                          </div>
                        }
                        <div class="d-flex align-items-center gap-2 mt-1">
                          <div class="prog-bar"><div class="prog-fill" style="width:@act.ProgressPercent%;background:@Sc(act.Status)"></div></div>
                          <span style="font-size:.7rem;color:#6b7d80">@act.ProgressPercent%</span>
                          <span class="badge-s" style="background:@(Sc(act.Status))22;color:@Sc(act.Status);font-size:.65rem">@Sa(act.Status)</span>
                          @if (act.PlannedCost > 0) { <span style="font-size:.7rem;color:#adb5bd">@act.PlannedCost.ToString("N0") ج.م</span> }
                        </div>
                      </div>
                      <div class="d-flex gap-1 flex-shrink-0">
                        <button type="button" class="btn btn-sm"
                                style="border-radius:7px;background:rgba(14,111,115,.08);color:#0e6f73;border:none;font-size:.72rem"
                                onclick="event.stopPropagation();openUpdate('@act.Id','@act.Title','@act.ProgressPercent','@act.Status','@act.ActualQuantity','@act.ActualCost')">
                          <i class="bx bx-edit"></i>
                        </button>
                        <button type="button" class="btn btn-sm"
                                style="border-radius:7px;background:rgba(85,110,230,.1);color:#3145a3;border:none;font-size:.72rem"
                                title="ربط بمرحلة"
                                onclick="event.stopPropagation();tog('assign-@act.Id')">
                          <i class="bx bx-git-branch"></i>
                        </button>
                        <a asp-controller="ActivityPhaseTracking" asp-action="Index"
                           asp-route-activityId="@act.Id"
                           class="btn btn-sm" title="تتبع النشاط عبر المراحل"
                           style="border-radius:7px;background:rgba(14,111,115,.1);color:#0e6f73;border:none;font-size:.72rem"
                           onclick="event.stopPropagation()">
                          <i class="bx bx-bar-chart-alt-2"></i>
                        </a>
                        <form asp-action="DeleteActivity" method="post" class="d-inline">
                          @Html.AntiForgeryToken()
                          <input type="hidden" name="id" value="@act.Id"/>
                          <input type="hidden" name="projectId" value="@project?.Id"/>
                          <button type="submit" class="btn btn-sm" style="border-radius:7px;background:rgba(244,106,106,.1);color:#f46a6a;border:none;font-size:.72rem" onclick="return confirm('حذف النشاط؟')"><i class="bx bx-trash"></i></button>
                        </form>
                      </div>
                    </div>

                    <div id="a-@act.Id" class="act-body">
                      @if (!string.IsNullOrWhiteSpace(act.PerformanceIndicator))
                      {
                        <div class="row g-2 mb-2">
                          <div class="col-md-6" style="font-size:.78rem;color:#6b7d80">
                            <strong>مؤشر الأداء:</strong> @act.PerformanceIndicator
                          </div>
                          <div class="col-md-6" style="font-size:.78rem;color:#6b7d80">
                            <strong>وسائل التحقق:</strong> @act.VerificationMeans
                          </div>
                        </div>
                      }
                      @* تفاصيل كل مرحلة *@
                      @if (phasesInAct.Any())
                      {
                        <table style="width:100%;font-size:.77rem;border-collapse:collapse" class="mb-2">
                          <thead>
                            <tr style="background:#f8fbfb">
                              <th style="padding:6px 10px;font-weight:700;color:#6b7d80">المرحلة</th>
                              <th style="padding:6px 10px;text-align:center;font-weight:700;color:#6b7d80">ك.مخططة</th>
                              <th style="padding:6px 10px;text-align:center;font-weight:700;color:#6b7d80">ك.فعلية</th>
                              <th style="padding:6px 10px;text-align:center;font-weight:700;color:#6b7d80">مدة</th>
                              <th style="padding:6px 10px;text-align:center;font-weight:700;color:#6b7d80">تكلفة مخططة</th>
                              <th style="padding:6px 10px;text-align:center;font-weight:700;color:#6b7d80">تكلفة فعلية</th>
                              <th style="padding:6px 10px;text-align:center;font-weight:700;color:#6b7d80">التقدم</th>
                              <th style="padding:6px 10px;text-align:center;font-weight:700;color:#6b7d80"></th>
                            </tr>
                          </thead>
                          <tbody>
                            @foreach (var pa in phasesInAct)
                            {
                              <tr style="border-top:.5px solid rgba(14,111,115,.06)">
                                <td style="padding:6px 10px;font-weight:600;color:#0a5f63">@(pa.Phase?.Name ?? "—")</td>
                                <td style="padding:6px 10px;text-align:center">@pa.PlannedQuantity</td>
                                <td style="padding:6px 10px;text-align:center;color:#34c38f;font-weight:600">@pa.ActualQuantity</td>
                                <td style="padding:6px 10px;text-align:center">@(pa.PlannedDurationDays.HasValue ? $"{pa.PlannedDurationDays} يوم" : "—")</td>
                                <td style="padding:6px 10px;text-align:center">@pa.PlannedCost.ToString("N0")</td>
                                <td style="padding:6px 10px;text-align:center;color:#f1b44c">@pa.ActualCost.ToString("N0")</td>
                                <td style="padding:6px 10px;text-align:center">
                                  <div class="d-flex align-items-center gap-2">
                                    <div class="prog-bar"><div class="prog-fill" style="width:@pa.ProgressPercent%;background:#556ee6"></div></div>
                                    <span>@pa.ProgressPercent%</span>
                                  </div>
                                </td>
                                <td style="padding:6px 10px">
                                  <div class="d-flex gap-1">
                                    <button type="button" class="btn btn-sm"
                                            style="border-radius:6px;background:rgba(14,111,115,.08);color:#0e6f73;border:none;font-size:.68rem"
                                            onclick="openPhaseUpdate('@pa.Id','@(pa.Phase?.Name ?? "المرحلة")','@pa.ProgressPercent','@pa.Status','@pa.ActualQuantity','@pa.ActualCost','@pa.ActualDurationDays')">
                                      تحديث
                                    </button>
                                    <form asp-action="RemovePhase" method="post" class="d-inline">
                                      @Html.AntiForgeryToken()
                                      <input type="hidden" name="assignmentId" value="@pa.Id"/>
                                      <input type="hidden" name="projectId" value="@project?.Id"/>
                                      <button type="submit" class="btn btn-sm" style="border-radius:6px;background:rgba(244,106,106,.08);color:#f46a6a;border:none;font-size:.68rem" onclick="return confirm('إزالة؟')">×</button>
                                    </form>
                                  </div>
                                </td>
                              </tr>
                            }
                          </tbody>
                        </table>
                      }
                    </div>

                    @* نموذج ربط مرحلة *@
                    <div id="assign-@act.Id" style="display:none;padding:10px 12px;background:rgba(85,110,230,.04);border-top:.5px solid rgba(85,110,230,.1)">
                      <div style="font-size:.78rem;font-weight:600;color:#3145a3;margin-bottom:6px">
                        <i class="bx bx-plus me-1"></i>ربط النشاط بمرحلة
                      </div>
                      <form asp-action="AssignPhase" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="activityId" value="@act.Id"/>
                        <input type="hidden" name="projectId" value="@project?.Id"/>
                        <div class="row g-2">
                          <div class="col-md-2">
                            <label>المرحلة *</label>
                            <select name="phaseId" class="form-select form-select-sm" style="border-radius:8px" required>
                              <option value="">-- اختر --</option>
                              @foreach (var p in phases)
                              { <option value="@p.Id">@p.Name</option> }
                            </select>
                          </div>
                          <div class="col-md-2"><label>ك.مخططة</label><input name="plannedQuantity" type="number" value="@act.PlannedQuantity" step="0.01" min="0"/></div>
                          <div class="col-md-1"><label>مساهمة %</label><input name="contributionPercent" type="number" value="100" min="1" max="100"/></div>
                          <div class="col-md-1"><label>مدة (أيام)</label><input name="plannedDurationDays" type="number" min="0" value="@act.PlannedDurationDays"/></div>
                          <div class="col-md-1"><label>س/يوم</label><input name="plannedHoursPerDay" type="number" step="0.5" value="@act.PlannedHoursPerDay"/></div>
                          <div class="col-md-2"><label>تكلفة مخططة</label><input name="plannedCost" type="number" value="0" step="0.01" min="0"/></div>
                          <div class="col-md-2"><label>بداية ← نهاية</label>
                            <div class="d-flex gap-1">
                              <input name="plannedStartDate" type="date" style="width:50%"/>
                              <input name="plannedEndDate" type="date" style="width:50%"/>
                            </div>
                          </div>
                          <div class="col-md-1 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary btn-sm fw-bold w-100" style="border-radius:8px">+</button>
                          </div>
                        </div>
                      </form>
                    </div>
                  </div>
                }
              </div>
            </div>
          </div>
        }
      </div>
    </div>
  </div>
}

@* Modal تحديث نشاط *@
<div class="modal fade" id="updateModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:18px">
      <div class="modal-header" style="background:linear-gradient(135deg,#1a3c5e,#2d6a8a);border-radius:18px 18px 0 0;color:#fff;border:none">
        <h6 class="modal-title fw-bold" id="upd-title">تحديث النشاط</h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form asp-action="UpdateActivity" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="upd-id"/>
        <input type="hidden" name="projectId" value="@project?.Id"/>
        <div class="modal-body p-4">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold" style="font-size:.82rem">نسبة الإنجاز %</label>
              <input type="range" name="progress" id="upd-prog" min="0" max="100" value="0" class="form-range"
                     oninput="document.getElementById('upd-prog-val').textContent=this.value+'%'"/>
              <div class="text-center fw-bold" id="upd-prog-val" style="color:#0e6f73;font-size:1.1rem">0%</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" style="font-size:.82rem">الحالة</label>
              <select name="status" id="upd-status" class="form-select" style="border-radius:10px">
                <option value="Planned">مخطط</option>
                <option value="InProgress">جارٍ</option>
                <option value="Completed">مكتمل</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" style="font-size:.82rem">الكمية الفعلية</label>
              <input type="number" name="actualQuantity" id="upd-qty" step="0.01" min="0" class="form-control" style="border-radius:10px"/>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" style="font-size:.82rem">التكلفة الفعلية</label>
              <input type="number" name="actualCost" id="upd-cost" step="0.01" min="0" class="form-control" style="border-radius:10px"/>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold" style="font-size:.82rem">ملاحظات</label>
              <textarea name="notes" class="form-control" rows="2" style="border-radius:10px"></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary fw-bold" style="border-radius:12px"><i class="bx bx-save me-1"></i>حفظ</button>
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">إلغاء</button>
        </div>
      </form>
    </div>
  </div>
</div>

@* Modal تحديث مرحلة *@
<div class="modal fade" id="phaseUpdateModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:18px">
      <div class="modal-header" style="background:linear-gradient(135deg,#2d4080,#3d52a0);border-radius:18px 18px 0 0;color:#fff;border:none">
        <h6 class="modal-title fw-bold" id="pu-title">تحديث تقدم المرحلة</h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form asp-action="UpdatePhaseProgress" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="assignmentId" id="pu-id"/>
        <input type="hidden" name="projectId" value="@project?.Id"/>
        <div class="modal-body p-4">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold" style="font-size:.82rem">التقدم %</label>
              <input type="range" name="progress" id="pu-prog" min="0" max="100" value="0" class="form-range"
                     oninput="document.getElementById('pu-prog-val').textContent=this.value+'%'"/>
              <div class="text-center fw-bold" id="pu-prog-val" style="color:#556ee6;font-size:1.1rem">0%</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold" style="font-size:.82rem">الحالة</label>
              <select name="status" id="pu-status" class="form-select" style="border-radius:10px">
                <option value="Planned">مخطط</option>
                <option value="InProgress">جارٍ</option>
                <option value="Completed">مكتمل</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold" style="font-size:.82rem">الكمية الفعلية</label>
              <input type="number" name="actualQuantity" id="pu-qty" step="0.01" min="0" class="form-control" style="border-radius:10px"/>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold" style="font-size:.82rem">التكلفة الفعلية</label>
              <input type="number" name="actualCost" id="pu-cost" step="0.01" min="0" class="form-control" style="border-radius:10px"/>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold" style="font-size:.82rem">المدة الفعلية (أيام)</label>
              <input type="number" name="actualDurationDays" id="pu-dur" min="0" class="form-control" style="border-radius:10px"/>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary fw-bold" style="border-radius:12px"><i class="bx bx-save me-1"></i>حفظ</button>
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">إلغاء</button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
function tog(id) { var el=document.getElementById(id); if(el) el.classList.toggle('open'); }

function openUpdate(id, title, prog, status, qty, cost) {
    document.getElementById('upd-id').value = id;
    document.getElementById('upd-title').textContent = 'تحديث: ' + title;
    document.getElementById('upd-prog').value = prog;
    document.getElementById('upd-prog-val').textContent = prog + '%';
    document.getElementById('upd-status').value = status;
    document.getElementById('upd-qty').value = qty;
    document.getElementById('upd-cost').value = cost;
    new bootstrap.Modal(document.getElementById('updateModal')).show();
}

function openPhaseUpdate(id, phaseName, prog, status, qty, cost, dur) {
    document.getElementById('pu-id').value = id;
    document.getElementById('pu-title').textContent = 'تحديث: ' + phaseName;
    document.getElementById('pu-prog').value = prog;
    document.getElementById('pu-prog-val').textContent = prog + '%';
    document.getElementById('pu-status').value = status;
    document.getElementById('pu-qty').value = qty;
    document.getElementById('pu-cost').value = cost;
    document.getElementById('pu-dur').value = dur || '';
    new bootstrap.Modal(document.getElementById('phaseUpdateModal')).show();
}

// فتح أول هدف تلقائياً
document.addEventListener('DOMContentLoaded', function() {
    var first = document.querySelector('.goal-body');
    if (first) first.classList.add('open');
});
</script>
}

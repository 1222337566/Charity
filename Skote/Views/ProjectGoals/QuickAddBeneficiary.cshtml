@model QuickBeneficiaryVm;
@using Skote.Controllers;
@{
    ViewData["Title"] = "إضافة مستفيد سريعة";
    var project = ViewBag.Project as InfrastrfuctureManagmentCore.Domains.Charity.Projects.CharityProject;
}

<style>
:root{--teal:#0e6f73}
.qb-hero{background:linear-gradient(135deg,#065f46,#0e6f73);border-radius:16px;padding:18px 24px;color:#fff;margin-bottom:18px}
.qb-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 2px 10px rgba(14,111,115,.05);overflow:hidden}
.qb-head{padding:14px 18px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.92rem;font-weight:700;color:#0a5f63;display:flex;align-items:center;gap:8px}
.qb-body{padding:20px}
.note-box{background:rgba(52,195,143,.08);border-radius:12px;padding:12px 16px;border:.5px solid rgba(52,195,143,.2);font-size:.82rem;color:#065f46;margin-bottom:16px}
.tg-opt{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:10px;border:.5px solid rgba(14,111,115,.15);cursor:pointer;transition:all .15s;margin-bottom:6px}
.tg-opt:hover,.tg-opt.selected{background:rgba(14,111,115,.08);border-color:var(--teal)}
.tg-dot{width:10px;height:10px;border-radius:50%;background:rgba(14,111,115,.2);flex-shrink:0}
.tg-opt.selected .tg-dot{background:var(--teal)}
</style>

<div class="qb-hero">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h5 class="fw-bold mb-1 text-white">
                <i class="bx bx-user-plus me-2"></i>إضافة مستفيد داخل المشروع
            </h5>
            <div style="opacity:.75;font-size:.8rem">
                المشروع: @project?.Name — يُضاف تلقائياً بدون موافقة إضافية
            </div>
        </div>
        <a asp-action="Index" asp-route-projectId="@Model.ProjectId"
           class="btn btn-light btn-sm fw-bold" style="border-radius:10px">← رجوع</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="border-radius:12px">
        <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning" style="border-radius:12px">
        <i class="bx bx-error me-2"></i>@TempData["Warning"]
    </div>
}

<div class="note-box">
    <i class="bx bx-info-circle me-2"></i>
    <strong>ملاحظة:</strong>
    إذا كان الرقم القومي موجوداً في النظام، سيتم ربط المستفيد الحالي بالمشروع تلقائياً بدون تكرار.
    إذا كان جديداً، سيتم إنشاؤه فوراً وإضافته للمشروع.
</div>

<div class="qb-card">
    <div class="qb-head">
        <i class="bx bx-user"></i>بيانات المستفيد
    </div>
    <div class="qb-body">
        <form asp-action="QuickAddBeneficiary" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProjectId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius:10px"></div>

            <div class="row g-3">

                @* ── البيانات الأساسية ── *@
                <div class="col-md-4">
                    <label asp-for="FullName" class="form-label fw-semibold">
                        الاسم الكامل <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FullName" class="form-control" style="border-radius:10px"
                           placeholder="اسم المستفيد" autocomplete="off" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="NationalId" class="form-label fw-semibold">الرقم القومي</label>
                    <input asp-for="NationalId" class="form-control" style="border-radius:10px"
                           placeholder="14 رقم" maxlength="14" />
                </div>

                <div class="col-md-3">
                    <label asp-for="PhoneNumber" class="form-label fw-semibold">رقم الهاتف</label>
                    <input asp-for="PhoneNumber" class="form-control" style="border-radius:10px"
                           placeholder="01xxxxxxxxx" />
                </div>

                <div class="col-md-2">
                    <label asp-for="FamilyMembersCount" class="form-label fw-semibold">عدد الأسرة</label>
                    <input asp-for="FamilyMembersCount" type="number" min="0" max="30"
                           class="form-control" style="border-radius:10px" />
                </div>

                <div class="col-md-3">
                    <label asp-for="MonthlyIncome" class="form-label fw-semibold">الدخل الشهري</label>
                    <div class="input-group">
                        <input asp-for="MonthlyIncome" type="number" step="0.01" min="0"
                               class="form-control" style="border-radius:10px 0 0 10px" placeholder="0" />
                        <span class="input-group-text" style="border-radius:0 10px 10px 0">ج.م</span>
                    </div>
                </div>

                <div class="col-md-3">
                    <label asp-for="BenefitType" class="form-label fw-semibold">نوع الاستفادة</label>
                    <input asp-for="BenefitType" class="form-control" style="border-radius:10px"
                           placeholder="تدريب / توعية / إنتاج..." />
                </div>

                @* ── الفئة المستهدفة ── *@
                <div class="col-md-4">
                    <label asp-for="TargetGroupName" class="form-label fw-semibold">
                        الفئة المستهدفة
                        @if (Model.TargetGroups.Any())
                        {
                            <span style="font-size:.7rem;color:#0e6f73;font-weight:400">
                                (من مقترح المشروع)
                            </span>
                        }
                    </label>

                    @if (Model.TargetGroups.Any())
                    {
                        @* عرض الفئات كـ radio buttons مرئية *@
                        <input asp-for="TargetGroupName" type="hidden" id="hiddenTargetGroup"
                               value="@Model.TargetGroupName" />
                        <div class="d-flex flex-wrap gap-2" id="tgRadioGroup">
                            @foreach (var tg in Model.TargetGroups)
                            {
                                @* data-group تتجنب مشاكل الأحرف الخاصة داخل onclick *@
                                <button type="button"
                                        data-group="@tg"
                                        onclick="selectGroup(this)"
                                        class="tg-opt px-3 py-2 @(Model.TargetGroupName==tg?"selected":"")"
                                        style="border-radius:20px;font-size:.82rem;font-weight:600;border:.5px solid rgba(14,111,115,.2);background:@(Model.TargetGroupName==tg?"rgba(14,111,115,.1)":"#fff");color:@(Model.TargetGroupName==tg?"#0e6f73":"#1e3a5f")">
                                    <span class="tg-dot" style="@(Model.TargetGroupName==tg?"background:#0e6f73":"")"></span>
                                    @tg
                                </button>
                            }
                            @* زر بدون فئة — بدون tg-dot حتى لا يحدث null error *@
                            <button type="button" onclick="clearGroup()"
                                    class="tg-opt px-3 py-2"
                                    style="border-radius:20px;font-size:.78rem;color:#adb5bd;border-color:#e2e8f0">
                                بدون فئة
                            </button>
                        </div>
                    }
                    else
                    {
                        @* إدخال نصي لو مافيش فئات في المقترح *@
                        <input asp-for="TargetGroupName" class="form-control" style="border-radius:10px"
                               placeholder="أطفال / نساء / شباب..." />
                    }
                    <small class="text-muted" style="font-size:.72rem">
                        ستُستخدم هذه الفئة عند تسكين المستفيد في الأنشطة
                    </small>
                </div>

                <div class="col-md-2">
                    <label asp-for="Notes" class="form-label fw-semibold">ملاحظات</label>
                    <input asp-for="Notes" class="form-control" style="border-radius:10px"
                           placeholder="أي ملاحظات..." />
                </div>

            </div>

            <div class="d-flex gap-3 mt-4 align-items-center border-top pt-3">
                <button type="submit" name="AddAnother" value="false"
                        class="btn fw-bold" style="background:var(--teal);color:#fff;border-radius:12px;min-width:140px">
                    <i class="bx bx-save me-1"></i>حفظ والعودة
                </button>
                <button type="submit" name="AddAnother" value="true"
                        class="btn btn-success fw-bold" style="border-radius:12px;min-width:140px">
                    <i class="bx bx-plus me-1"></i>حفظ وإضافة آخر
                </button>
                <a asp-action="Index" asp-route-projectId="@Model.ProjectId"
                   class="btn btn-light fw-bold" style="border-radius:12px">إلغاء</a>
            </div>
        </form>
    </div>
</div>

<script>
// قراءة اسم الفئة من data-group بدلاً من تمريرها مباشرةً في onclick
// — يتجنب كسر الـ string عند وجود أحرف خاصة (', ", &, ...)
function selectGroup(btn) {
    var groupName = btn.getAttribute('data-group') || '';
    document.getElementById('hiddenTargetGroup').value = groupName;

    document.querySelectorAll('#tgRadioGroup button').forEach(function(b) {
        b.style.background  = '#fff';
        b.style.borderColor = 'rgba(14,111,115,.2)';
        b.style.color       = '#1e3a5f';
        var dot = b.querySelector('.tg-dot');
        if (dot) dot.style.background = 'rgba(14,111,115,.2)';
    });

    btn.style.background  = 'rgba(14,111,115,.1)';
    btn.style.color       = '#0e6f73';
    btn.style.borderColor = '#0e6f73';
    var dot = btn.querySelector('.tg-dot');
    if (dot) dot.style.background = '#0e6f73';
}

function clearGroup() {
    document.getElementById('hiddenTargetGroup').value = '';

    document.querySelectorAll('#tgRadioGroup button').forEach(function(b) {
        var isClear = b.textContent.trim() === 'بدون فئة';
        b.style.background  = '#fff';
        b.style.color       = isClear ? '#adb5bd' : '#1e3a5f';
        b.style.borderColor = isClear ? '#e2e8f0' : 'rgba(14,111,115,.2)';
        var dot = b.querySelector('.tg-dot');
        if (dot) dot.style.background = 'rgba(14,111,115,.2)';
    });
}
</script>

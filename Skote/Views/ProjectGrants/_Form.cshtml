@model InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Grants.CreateProjectGrantVm
<input asp-for="ProjectId" type="hidden" />
<div class="row g-3">
    <div class="col-md-12">
        <label asp-for="GrantAgreementId" class="form-label"></label>
        <select asp-for="GrantAgreementId" asp-items="Model.GrantAgreements" class="form-select"></select>
    </div>
    <div class="col-md-6"><label asp-for="AllocatedAmount" class="form-label"></label><input asp-for="AllocatedAmount" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="AllocatedDate" class="form-label"></label><input asp-for="AllocatedDate" class="form-control" /></div>
    <div class="col-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
</div>

@model InfrastructureManagmentWebFramework.Models.AccountingProjects.Phases.ProjectPhaseAlertsVm
@{ ViewData["Title"] = "تنبيهات مراحل المشروع"; }
<form method="get" class="row g-3 mb-3">
    <div class="col-md-4"><label class="form-label">المشروع</label><select asp-for="ProjectId" asp-items="Model.Projects" class="form-select"><option value="">الكل</option></select></div>
    <div class="col-md-3"><label class="form-label">حتى تاريخ</label><input asp-for="AsOfDate" type="date" class="form-control" /></div>
    <div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100">عرض</button></div>
</form>
<table class="table table-bordered table-striped">
    <thead><tr><th>المشروع</th><th>المرحلة</th><th>النوع</th><th>الخطورة</th><th>الرسالة</th><th>التاريخ</th><th>المخطط</th><th>الفعلي</th></tr></thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@row.ProjectName</td><td>@row.PhaseName</td><td>@row.AlertType</td>
            <td><span class="badge @(row.Severity == "High" ? "bg-danger" : "bg-warning")">@row.Severity</span></td>
            <td>@row.Message</td><td>@row.RelatedDate?.ToString("yyyy-MM-dd")</td>
            <td>@row.PlannedCost?.ToString("N2")</td><td>@row.ActualCost?.ToString("N2")</td>
        </tr>
    }
    </tbody>
</table>

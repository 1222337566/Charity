@model InfrastructureManagmentWebFramework.Models.AccountingProjects.Phases.ProjectPhaseCostSummaryVm
@{ ViewData["Title"] = "ملخص تكلفة المراحل"; }
<form method="get" class="row g-3 mb-3">
    <div class="col-md-3"><label class="form-label">المشروع</label><select asp-for="ProjectId" asp-items="Model.Projects" class="form-select"><option value="">الكل</option></select></div>
    <div class="col-md-3"><label class="form-label">المرحلة</label><select asp-for="PhaseId" asp-items="Model.Phases" class="form-select"><option value="">الكل</option></select></div>
    <div class="col-md-2"><label class="form-label">من</label><input asp-for="FromDate" type="date" class="form-control" /></div>
    <div class="col-md-2"><label class="form-label">إلى</label><input asp-for="ToDate" type="date" class="form-control" /></div>
    <div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100">عرض</button></div>
</form>
<table class="table table-bordered table-striped">
    <thead><tr><th>المشروع</th><th>المرحلة</th><th>الحالة</th><th>الإنجاز %</th><th>المخطط</th><th>الفعلي</th><th>الانحراف</th><th>Milestones</th></tr></thead>
    <tbody>
    @foreach (var row in Model.Rows)
    {
        <tr>
            <td>@row.ProjectName</td><td>@row.PhaseName</td><td>@row.PhaseStatus</td><td>@row.ProgressPercent</td>
            <td>@row.PlannedCost.ToString("N2")</td><td>@row.ActualCost.ToString("N2")</td>
            <td class="@(row.VarianceAmount > 0 ? "text-danger" : row.VarianceAmount < 0 ? "text-success" : "")">@row.VarianceAmount.ToString("N2") (@row.VariancePercent.ToString("N1")%)</td>
            <td>@row.CompletedMilestonesCount / @row.MilestonesCount</td>
        </tr>
    }
    </tbody>
</table>

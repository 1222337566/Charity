@model InfrastructureManagmentWebFramework.Models.AccountingProjects.Phases.ProjectPhaseLedgerVm
@{ ViewData["Title"] = "دفتر المرحلة"; }
<form method="get" class="row g-3 mb-3">
    <div class="col-md-3"><label class="form-label">المشروع</label><select asp-for="ProjectId" asp-items="Model.Projects" class="form-select"><option value="">اختر</option></select></div>
    <div class="col-md-3"><label class="form-label">المرحلة</label><select asp-for="PhaseId" asp-items="Model.Phases" class="form-select"><option value="">اختر</option></select></div>
    <div class="col-md-2"><label class="form-label">من</label><input asp-for="FromDate" type="date" class="form-control" /></div>
    <div class="col-md-2"><label class="form-label">إلى</label><input asp-for="ToDate" type="date" class="form-control" /></div>
    <div class="col-md-2 d-flex align-items-end"><button class="btn btn-primary w-100">عرض</button></div>
</form>
@if (Model.Ledger != null)
{
    <div class="card mb-3"><div class="card-body"><h5>@Model.Ledger.ProjectName - @Model.Ledger.PhaseName</h5><div class="text-muted">إجمالي التكلفة: @Model.Ledger.TotalAmount.ToString("N2")</div></div></div>
    <table class="table table-bordered table-striped">
        <thead><tr><th>النوع</th><th>المرجع</th><th>التاريخ</th><th>الوصف</th><th>بند الموازنة</th><th>مركز التكلفة</th><th>القيمة</th></tr></thead>
        <tbody>
        @foreach (var row in Model.Ledger.Rows)
        {
            <tr>
                <td>@row.SourceType</td><td>@row.ReferenceNumber</td><td>@row.EntryDate.ToString("yyyy-MM-dd")</td><td>@row.Description</td><td>@row.BudgetLineName</td><td>@row.CostCenterName</td><td>@row.Amount.ToString("N2")</td>
            </tr>
        }
        </tbody>
    </table>
}

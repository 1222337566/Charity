@model List<InfrastructureManagmentWebFramework.Models.AccountingProjects.Phases.ProjectPhaseExpenseLinkListItemVm>
@{ ViewData["Title"] = "ربط مصروفات بمراحل المشروع"; }
@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")
@{
    var showProjectColumn = ViewBag.ShowProjectColumn as bool? == true;
    var projectId = ViewBag.ProjectId as Guid?;
    var totalAmount = Model.Sum(x => x.Amount);
    var actualCount = Model.Count(x => x.IncludeInActualCost);
    var actualTotal = Model.Where(x => x.IncludeInActualCost).Sum(x => x.Amount);
}

<style>
:root {
    --teal:      #0e6f73;
    --teal-dark: #0a5558;
    --teal-soft: rgba(14,111,115,.07);
    --gold:      #f5a623;
    --danger:    #e8534a;
    --success:   #34c38f;
    --text-main: #1a2e35;
    --text-muted:#5a7a80;
    --border:    rgba(14,111,115,.12);
}

.stats-strip {
    display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:20px;
}
.stat-card {
    background:#fff; border-radius:14px; border:.5px solid var(--border);
    padding:14px 18px; display:flex; align-items:center; gap:14px;
    box-shadow:0 2px 8px rgba(14,111,115,.04);
}
.stat-icon {
    width:44px; height:44px; border-radius:12px;
    display:flex; align-items:center; justify-content:center; font-size:1.25rem; flex-shrink:0;
}
.stat-label { font-size:.7rem; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:.4px; }
.stat-value { font-size:1.1rem; font-weight:800; color:var(--text-main); line-height:1.3; }

.pel-toolbar {
    display:flex; align-items:center; justify-content:space-between;
    flex-wrap:wrap; gap:10px; margin-bottom:16px;
}
.pel-title { font-size:1rem; font-weight:800; color:var(--text-main); }
.pel-title small { font-size:.73rem; color:var(--text-muted); font-weight:500; margin-right:6px; }

.btn-link-new {
    display:inline-flex; align-items:center; gap:7px;
    background:var(--teal); color:#fff;
    border:none; border-radius:12px; padding:9px 20px;
    font-size:.85rem; font-weight:700; text-decoration:none;
    box-shadow:0 3px 12px rgba(14,111,115,.28);
    transition:background .15s, transform .12s, box-shadow .15s;
}
.btn-link-new:hover {
    background:var(--teal-dark); color:#fff;
    transform:translateY(-2px); box-shadow:0 5px 18px rgba(14,111,115,.36);
}
.btn-link-new .icon-wrap {
    width:26px; height:26px; background:rgba(255,255,255,.2);
    border-radius:7px; display:flex; align-items:center; justify-content:center; font-size:.95rem;
}

.search-wrap { position:relative; }
.search-wrap input {
    padding:8px 12px 8px 34px; border-radius:10px;
    border:.5px solid var(--border); background:#fff;
    font-size:.82rem; color:var(--text-main); width:210px;
    transition:border .15s, box-shadow .15s;
}
.search-wrap input:focus {
    outline:none; border-color:var(--teal);
    box-shadow:0 0 0 3px rgba(14,111,115,.1);
}
.search-wrap .s-icon {
    position:absolute; left:10px; top:50%; transform:translateY(-50%);
    color:var(--text-muted); font-size:.9rem; pointer-events:none;
}

.table-card {
    background:#fff; border-radius:16px; border:.5px solid var(--border);
    box-shadow:0 2px 10px rgba(14,111,115,.05); overflow:hidden;
}
.pel-table { width:100%; border-collapse:collapse; font-size:.83rem; }
.pel-table thead tr { background:var(--teal); }
.pel-table thead th {
    color:#fff; font-weight:700; padding:12px 14px; text-align:right;
    font-size:.77rem; letter-spacing:.3px; white-space:nowrap; border:none;
}
.pel-table tbody tr { border-bottom:.5px solid rgba(14,111,115,.06); transition:background .1s; }
.pel-table tbody tr:hover { background:var(--teal-soft); }
.pel-table tbody tr:last-child { border-bottom:none; }
.pel-table td { padding:11px 14px; color:var(--text-main); vertical-align:middle; }

.exp-badge {
    display:inline-flex; align-items:center; gap:5px;
    background:var(--teal-soft); border:.5px solid var(--border);
    border-radius:8px; padding:3px 10px;
    font-size:.78rem; font-weight:700; color:var(--teal);
}
.amount-val { font-weight:800; font-size:.88rem; }
.amount-val small { font-size:.68rem; color:var(--text-muted); font-weight:500; margin-right:2px; }
.phase-pill {
    display:inline-block; background:rgba(85,110,230,.08); color:#3a4fc0;
    border-radius:20px; padding:3px 11px; font-size:.75rem; font-weight:700;
}
.meta-tag {
    display:inline-block; border-radius:6px;
    padding:2px 8px; font-size:.72rem; font-weight:600;
}
.badge-yes {
    display:inline-flex; align-items:center; gap:3px;
    background:rgba(52,195,143,.1); color:#1a7a5e;
    border-radius:6px; padding:3px 9px; font-size:.73rem; font-weight:700;
}
.badge-no-actual {
    background:rgba(180,180,180,.1); color:#8a9aaa;
    border-radius:6px; padding:3px 9px; font-size:.73rem; font-weight:600;
    display:inline-flex; align-items:center; gap:3px;
}
.btn-unlink {
    background:rgba(232,83,74,.07); color:var(--danger);
    border:.5px solid rgba(232,83,74,.18); border-radius:8px;
    padding:5px 13px; font-size:.75rem; font-weight:700; cursor:pointer;
    transition:background .12s; white-space:nowrap;
}
.btn-unlink:hover { background:rgba(232,83,74,.16); }

.empty-state { text-align:center; padding:52px 20px; color:var(--text-muted); }
.empty-icon {
    width:68px; height:68px; border-radius:20px; background:var(--teal-soft);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 14px; font-size:1.7rem; color:var(--teal);
}
.alert-ok {
    background:rgba(52,195,143,.09); border:.5px solid rgba(52,195,143,.25);
    border-radius:12px; padding:11px 16px; color:#1a7a5e;
    font-size:.85rem; margin-bottom:14px; display:flex; align-items:center; gap:8px;
}
@@media(max-width:768px){
    .stats-strip{grid-template-columns:1fr;}
    .search-wrap input{width:150px;}
}
</style>

<div>

@if (TempData["Success"] != null)
{
    <div class="alert-ok">
        <i class="bx bx-check-circle" style="font-size:1.05rem"></i>
        @TempData["Success"]
    </div>
}

{{-- Stats --}}
<div class="stats-strip">
    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(14,111,115,.09)">
            <i class="bx bx-link" style="color:var(--teal)"></i>
        </div>
        <div>
            <div class="stat-label">إجمالي الربوط</div>
            <div class="stat-value">@Model.Count</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(245,166,35,.1)">
            <i class="bx bx-money" style="color:var(--gold)"></i>
        </div>
        <div>
            <div class="stat-label">إجمالي القيم</div>
            <div class="stat-value" style="font-size:.92rem">
                @totalAmount.ToString("N2")
                <span style="font-size:.65rem;color:var(--text-muted);font-weight:500">ج.م</span>
            </div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(52,195,143,.1)">
            <i class="bx bx-check-double" style="color:var(--success)"></i>
        </div>
        <div>
            <div class="stat-label">محتسب فعلياً — @actualCount ربط</div>
            <div class="stat-value" style="font-size:.92rem">
                @actualTotal.ToString("N2")
                <span style="font-size:.65rem;color:var(--text-muted);font-weight:500">ج.م</span>
            </div>
        </div>
    </div>
</div>

{{-- Toolbar --}}
<div class="pel-toolbar">
    <span class="pel-title">
        ربط المصروفات بمراحل المشروع
        <small>(@Model.Count سجل)</small>
    </span>
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <div class="search-wrap">
            <i class="bx bx-search s-icon"></i>
            <input type="text" placeholder="بحث سريع..." oninput="filterTable(this.value)" />
        </div>
        @if (projectId != null)
        {
            <a asp-action="Create" asp-route-projectId="@projectId" class="btn-link-new">
                <span class="icon-wrap"><i class="bx bx-plus"></i></span>
                ربط مصروف جديد
            </a>
        }
        else
        {
            <a asp-controller="CharityProjects" asp-action="Index"
               class="btn-link-new" style="background:#3a4fc0;box-shadow:0 3px 12px rgba(58,79,192,.25)">
                <span class="icon-wrap"><i class="bx bx-search-alt"></i></span>
                اختر مشروعاً
            </a>
        }
    </div>
</div>

{{-- Table --}}
<div class="table-card">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="bx bx-link-alt"></i></div>
            <div style="font-size:.9rem;font-weight:700;color:#2a4a50;margin-bottom:6px">لا توجد ربوط حتى الآن</div>
            <div style="font-size:.8rem;margin-bottom:20px">اضغط الزر أدناه لبدء ربط المصروفات بمراحل المشروع</div>
            @if (projectId != null)
            {
                <a asp-action="Create" asp-route-projectId="@projectId" class="btn-link-new" style="display:inline-flex">
                    <span class="icon-wrap"><i class="bx bx-plus"></i></span>
                    ربط مصروف جديد
                </a>
            }
        </div>
    }
    else
    {
        <div style="overflow-x:auto">
        <table class="pel-table" id="pelTable">
            <thead>
                <tr>
                    @if (showProjectColumn) { <th>المشروع</th> }
                    <th>#</th>
                    <th>رقم المصروف</th>
                    <th>التاريخ</th>
                    <th>القيمة</th>
                    <th>المرحلة</th>
                    <th>بند الموازنة</th>
                    <th>مركز التكلفة</th>
                    <th>يُحسب فعلياً</th>
                    <th style="text-align:center">إجراء</th>
                </tr>
            </thead>
            <tbody>
            @{ int i = 0; }
            @foreach (var item in Model)
            {
                i++;
                <tr>
                    @if (showProjectColumn)
                    { <td style="font-size:.79rem;color:var(--text-muted)">@item.ProjectName</td> }
                    <td style="color:#a0b0b5;font-size:.74rem;font-weight:700">@i</td>
                    <td>
                        <span class="exp-badge">
                            <i class="bx bx-receipt" style="font-size:.78rem"></i>
                            @item.ExpenseNumber
                        </span>
                    </td>
                    <td style="font-size:.8rem;color:var(--text-muted)">
                        @item.ExpenseDateUtc.ToString("yyyy/MM/dd")
                    </td>
                    <td>
                        <span class="amount-val">
                            @item.Amount.ToString("N2")
                            <small>ج.م</small>
                        </span>
                    </td>
                    <td><span class="phase-pill">@item.PhaseName</span></td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.BudgetLineName))
                        {
                            <span class="meta-tag" style="background:rgba(245,166,35,.09);color:#a07010">@item.BudgetLineName</span>
                        }
                        else { <span style="color:#c8d5d8;font-size:.75rem">—</span> }
                    </td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.CostCenterName))
                        {
                            <span class="meta-tag" style="background:rgba(85,110,230,.08);color:#3a4fc0">@item.CostCenterName</span>
                        }
                        else { <span style="color:#c8d5d8;font-size:.75rem">—</span> }
                    </td>
                    <td>
                        @if (item.IncludeInActualCost)
                        {
                            <span class="badge-yes">
                                <i class="bx bx-check" style="font-size:.85rem"></i>نعم
                            </span>
                        }
                        else
                        {
                            <span class="badge-no-actual">
                                <i class="bx bx-minus" style="font-size:.85rem"></i>لا
                            </span>
                        }
                    </td>
                    <td style="text-align:center">
                        <form method="post" asp-action="Delete" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="projectId" value="@(projectId ?? item.ProjectId)" />
                            <button type="submit" class="btn-unlink"
                                    onclick="return confirm('تأكيد حذف هذا الربط؟')">
                                <i class="bx bx-unlink me-1"></i>حذف
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
</div>

</div>

<script>
function filterTable(q) {
    q = q.toLowerCase();
    document.querySelectorAll('#pelTable tbody tr').forEach(function (row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}
</script>

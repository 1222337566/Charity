@model IReadOnlyList<InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Milestones.ProjectPhaseMilestoneListItemVm>
@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")
<div class="card"><div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div><h4 class="mb-0">Milestones المرحلة</h4><div class="text-muted">@ViewBag.PhaseName</div></div>
        <a asp-action="Create" asp-route-phaseId="@ViewBag.PhaseId" class="btn btn-primary">إضافة milestone</a>
    </div>
    <table class="table table-striped align-middle">
        <thead><tr><th>العنوان</th><th>الاستحقاق</th><th>الإنجاز</th><th>الحالة</th><th>النسبة</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                <td>@(item.CompletedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                <td>@item.Status</td>
                <td>@item.ProgressPercent %</td>
                <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a></td>
            </tr>
        }
        </tbody>
    </table>
</div></div>

@model InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Milestones.CreateProjectPhaseMilestoneVm
<input type="hidden" asp-for="ProjectPhaseId" />
<div class="row g-3">
    <div class="col-md-8"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="DueDate" class="form-label"></label><input asp-for="DueDate" type="date" class="form-control" /></div>
    <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
    <div class="col-md-4"><label asp-for="CompletedDate" class="form-label"></label><input asp-for="CompletedDate" type="date" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Status" class="form-label"></label><select asp-for="Status" class="form-select"><option>Pending</option><option>InProgress</option><option>Completed</option><option>Delayed</option></select></div>
    <div class="col-md-4"><label asp-for="ProgressPercent" class="form-label"></label><input asp-for="ProgressPercent" class="form-control" /></div>
    <div class="col-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
    <div class="col-12 form-check ms-2"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>
</div>

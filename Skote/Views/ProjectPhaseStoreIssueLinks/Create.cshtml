@model InfrastructureManagmentWebFramework.Models.AccountingProjects.Phases.CreateProjectPhaseStoreIssueLinkVm
@{ ViewData["Title"] = "ربط إذن صرف بمرحلة"; }
@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")
<form method="post">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="StoreIssueId" class="form-label">إذن الصرف</label><select asp-for="StoreIssueId" asp-items="Model.StoreIssues" class="form-select"></select></div>
        <div class="col-md-6"><label asp-for="ProjectPhaseId" class="form-label">المرحلة</label><select asp-for="ProjectPhaseId" asp-items="Model.Phases" class="form-select"></select></div>
        <div class="col-md-6"><label asp-for="CostCenterId" class="form-label">مركز التكلفة</label><select asp-for="CostCenterId" asp-items="Model.CostCenters" class="form-select"><option value="">-- اختر --</option></select></div>
        <div class="col-md-12"><div class="form-check"><input asp-for="IncludeInActualCost" class="form-check-input" /><label asp-for="IncludeInActualCost" class="form-check-label">احتساب الربط ضمن التكلفة الفعلية</label></div></div>
        <div class="col-12"><label asp-for="Notes" class="form-label">ملاحظات</label><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div>
    </div>
    <input type="hidden" asp-for="ProjectId" />
    <div class="mt-3"><button class="btn btn-primary">حفظ</button><a asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-light">رجوع</a></div>
</form>

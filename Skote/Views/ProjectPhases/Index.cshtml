@model IReadOnlyList<InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Phases.ProjectPhaseListItemVm>
@using InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile
@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")
@{
    var header = ViewBag.ProjectHeader as ProjectHeaderVm;
    var showProjectColumn = ViewBag.ShowProjectColumn as bool? == true;
    string StatusColor(string s)=>s switch{"Completed"=>"#34c38f","InProgress"=>"#556ee6","Active"=>"#556ee6","Planned"=>"#f1b44c","Cancelled"=>"#f46a6a","OnHold"=>"#74788d",_=>"#adb5bd"};
    string StatusAr(string s)=>s switch{"Completed"=>"مكتمل","InProgress"=>"جارٍ","Active"=>"نشط","Planned"=>"مخطط","Cancelled"=>"ملغى","OnHold"=>"موقوف",_=>s};
}
<style>
:root{--teal:#0e6f73;--teal-l:#e1f5f5;--ink:#1e3a5f;--muted:#6b7d80}
.phase-card{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.1);box-shadow:0 2px 10px rgba(14,111,115,.05);margin-bottom:12px;overflow:hidden;transition:box-shadow .2s}
.phase-card:hover{box-shadow:0 4px 20px rgba(14,111,115,.12)}
.phase-hdr{padding:14px 18px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.phase-order{width:36px;height:36px;border-radius:50%;background:var(--teal);color:#fff;font-size:.88rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.phase-name{font-weight:700;font-size:.92rem;color:var(--ink);flex:1}
.phase-badge{padding:3px 10px;border-radius:20px;font-size:.68rem;font-weight:700;color:#fff;white-space:nowrap}
.phase-meta{font-size:.76rem;color:var(--muted);display:flex;flex-wrap:wrap;gap:1rem}
.phase-foot{padding:10px 18px;background:#f8fbfb;border-top:.5px solid rgba(14,111,115,.07);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.prog-wrap{flex:1;min-width:120px}
.prog-bar{height:6px;border-radius:999px;background:#e2e8f0;overflow:hidden}
.prog-fill{height:100%;border-radius:999px;transition:width .4s}
.cost-pair{font-size:.78rem;color:var(--muted);text-align:end}
.cost-pair strong{color:var(--ink)}
.empty-ph{padding:48px;text-align:center;color:var(--muted)}
.empty-ph i{font-size:2.5rem;opacity:.3;display:block;margin-bottom:10px}
</style>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h4 class="mb-0 fw-bold" style="color:var(--ink)">مراحل المشروع</h4>
        @if(header==null){<p class="text-muted small mb-0">عرض عام — اختر مشروعًا لإضافة مراحل</p>}
    </div>
    @if(header!=null){
        <a asp-action="Create" asp-route-projectId="@header.Id" class="btn btn-sm fw-semibold" style="background:var(--teal);color:#fff;border-radius:10px">
            <i class="bx bx-plus me-1"></i>إضافة مرحلة
        </a>
    }
</div>
@if(!Model.Any()){
    <div class="empty-ph"><i class="bx bx-git-branch"></i><p>لا توجد مراحل بعد</p></div>
}else{
    @foreach(var item in Model){
        var pct=Math.Min(100,Math.Max(0,(int)item.ProgressPercent));
        var barColor=pct>=100?"#34c38f":pct>=50?"#556ee6":pct>0?"#f1b44c":"#e2e8f0";
        var durationDays=(item.PlannedEndDate-item.PlannedStartDate).Days;
        <div class="phase-card">
            <div class="phase-hdr">
                <span class="phase-order">@item.SortOrder</span>
                <div class="flex-1">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="phase-name">@item.Name</span>
                        @if(!string.IsNullOrWhiteSpace(item.Code)){<span style="font-size:.68rem;color:var(--teal);background:var(--teal-l);padding:1px 7px;border-radius:5px;font-weight:700">@item.Code</span>}
                        <span class="phase-badge" style="background:@StatusColor(item.Status)">@StatusAr(item.Status)</span>
                    </div>
                    <div class="phase-meta mt-1">
                        <span><i class="bx bx-calendar me-1"></i>@item.PlannedStartDate.ToString("yyyy/MM/dd") — @item.PlannedEndDate.ToString("yyyy/MM/dd")</span>
                        <span><i class="bx bx-time me-1"></i>@durationDays يوم</span>
                        @if(!string.IsNullOrWhiteSpace(item.ResponsiblePersonName)){<span><i class="bx bx-user me-1"></i>@item.ResponsiblePersonName</span>}
                    </div>
                </div>
                <div class="ms-auto d-flex gap-2">
                    <a asp-controller="ProjectPhaseMilestones" asp-action="Index" asp-route-phaseId="@item.Id" class="btn btn-sm" style="background:var(--teal-l);color:var(--teal);border-radius:8px;font-size:.76rem"><i class="bx bx-flag me-1"></i>Milestones</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light" style="border-radius:8px"><i class="bx bx-edit-alt"></i></a>
                </div>
            </div>
            <div class="phase-foot">
                <div class="prog-wrap">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:.72rem;color:var(--muted)">التقدم</span>
                        <span style="font-size:.72rem;font-weight:700" class="text-@(pct>=100?"success":pct>=50?"primary":"warning")">@pct%</span>
                    </div>
                    <div class="prog-bar"><div class="prog-fill" style="width:@pct%;background:@barColor"></div></div>
                </div>
                <div class="cost-pair me-3">
                    <div>مخطط: <strong>@item.PlannedCost.ToString("N0")</strong></div>
                    <div>فعلي: <strong>@item.ActualCost.ToString("N0")</strong></div>
                </div>
            </div>
        </div>
    }
}

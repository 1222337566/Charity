@model IReadOnlyList<InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Phases.ProjectPhaseListItemVm>
@using InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile
@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")
@{
    var header = ViewBag.ProjectHeader as ProjectHeaderVm;
    var showProjectColumn = ViewBag.ShowProjectColumn as bool? == true;
    var projectNamesByPhaseId = ViewBag.ProjectNamesByPhaseId as IDictionary<Guid, string>;
}
<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
            <div>
                <h4 class="mb-0">مراحل المشروع</h4>
                @if (header == null)
                {
                    <div class="text-muted">عرض عام لجميع المراحل. اختر مشروعًا من التفاصيل لإضافة مرحلة جديدة.</div>
                }
            </div>
            @if (header != null)
            {
                <a asp-action="Create" asp-route-projectId="@header.Id" class="btn btn-primary">إضافة مرحلة</a>
            }
            else
            {
                <a asp-controller="CharityProjects" asp-action="Index" class="btn btn-outline-primary">اختيار مشروع</a>
            }
        </div>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead><tr><th>الترتيب</th>@if (showProjectColumn) { <th>المشروع</th> }<th>الكود</th><th>الاسم</th><th>الفترة</th><th>الحالة</th><th>الإنجاز</th><th>التكلفة</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.SortOrder</td>
                        @if (showProjectColumn)
                        {
                            <td>
                                @(projectNamesByPhaseId != null && projectNamesByPhaseId.TryGetValue(item.Id, out var projectName) ? projectName : "-")
                            </td>
                        }
                        <td>@item.Code</td>
                        <td>
                            <div class="fw-semibold">@item.Name</div>
                            <div class="text-muted small">@item.ResponsiblePersonName</div>
                        </td>
                        <td>@item.PlannedStartDate.ToString("yyyy-MM-dd")<br/><span class="text-muted">@item.PlannedEndDate.ToString("yyyy-MM-dd")</span></td>
                        <td>@item.Status</td>
                        <td style="min-width:160px;">
                            <div class="progress" style="height:8px;"><div class="progress-bar" role="progressbar" style="width:@item.ProgressPercent%;"></div></div>
                            <small class="text-muted">@item.ProgressPercent %</small>
                        </td>
                        <td>@item.ActualCost.ToString("N2") / @item.PlannedCost.ToString("N2")</td>
                        <td class="text-nowrap">
                            <a asp-controller="ProjectPhaseMilestones" asp-action="Index" asp-route-phaseId="@item.Id" class="btn btn-sm btn-outline-secondary">Milestones</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.Charity.ProjectPlanning.ProjectPlanningCalendarVm
<partial name="~/Views/Shared/Projects/_ProjectHeader.cshtml" />
@{
    var prev  = new DateTime(Model.Year, Model.Month, 1).AddMonths(-1);
    var next  = new DateTime(Model.Year, Model.Month, 1).AddMonths(1);
    var today = DateTime.Today;

    // kind → icon
    string KindIcon(string kind) => kind switch {
        "Phase"     => "bx bx-layer",
        "Task"      => "bx bx-task",
        "Milestone" => "bx bx-flag",
        "Activity"  => "bx bx-calendar-event",
        _           => "bx bx-circle"
    };

    string KindLabel(string kind) => kind switch {
        "Phase"     => "مرحلة",
        "Task"      => "مهمة",
        "Milestone" => "إنجاز",
        "Activity"  => "نشاط",
        _           => kind
    };

    // status → badge color
    string StatusBg(string status) => status?.ToLower() switch {
        "completed"   or "مكتمل"   => "success",
        "inprogress"  or "جاري"    => "primary",
        "pending"     or "قيد الانتظار" => "warning",
        "delayed"     or "متأخر"   => "danger",
        "approved"    or "معتمد"   => "info",
        _                          => "secondary"
    };

    string StatusDot(string status) => status?.ToLower() switch {
        "completed" or "مكتمل"         => "#34c38f",
        "inprogress" or "جاري"         => "#556ee6",
        "pending" or "قيد الانتظار"    => "#f1b44c",
        "delayed" or "متأخر"           => "#f46a6a",
        "approved" or "معتمد"          => "#50a5f1",
        _                              => "#adb5bd"
    };
}

<style>
.joud-cal-wrap { background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 4px 24px rgba(14,111,115,.08); border:1px solid rgba(14,111,115,.10); }

/* ── Header ── */
.joud-cal-header { background:linear-gradient(135deg,#0a5659,#0e6f73,#0c8387); padding:20px 28px; display:flex; align-items:center; justify-content:space-between; }
.joud-cal-nav { display:flex; align-items:center; gap:12px; }
.joud-cal-nav-btn { width:38px; height:38px; border-radius:10px; border:1.5px solid rgba(255,255,255,.30); background:rgba(255,255,255,.12); color:#fff; display:flex; align-items:center; justify-content:center; text-decoration:none; font-size:18px; transition:.15s; }
.joud-cal-nav-btn:hover { background:rgba(255,255,255,.22); color:#fff; transform:scale(1.08); }
.joud-cal-month { color:#fff; font-size:1.45rem; font-weight:700; letter-spacing:.01em; }
.joud-cal-year { color:rgba(255,255,255,.70); font-size:1rem; font-weight:500; }

/* ── Legend ── */
.joud-cal-legend { display:flex; gap:16px; align-items:center; flex-wrap:wrap; }
.joud-cal-legend-item { display:flex; align-items:center; gap:5px; color:rgba(255,255,255,.85); font-size:11.5px; }
.joud-cal-legend-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

/* ── Day names row ── */
.joud-cal-daynames { display:grid; grid-template-columns:repeat(7,1fr); background:#f0f9f9; border-bottom:1px solid rgba(14,111,115,.08); }
.joud-cal-dayname { padding:10px 4px; text-align:center; font-size:11.5px; font-weight:700; color:#0e6f73; letter-spacing:.04em; text-transform:uppercase; }
.joud-cal-dayname.weekend { color:#d9a44a; }

/* ── Grid ── */
.joud-cal-grid { display:grid; grid-template-columns:repeat(7,1fr); }
.joud-cal-cell { border-right:1px solid rgba(14,111,115,.07); border-bottom:1px solid rgba(14,111,115,.07); min-height:130px; padding:8px 7px; transition:background .15s; position:relative; }
.joud-cal-cell:nth-child(7n) { border-right:none; }
.joud-cal-cell.outside { background:#fafcfc; }
.joud-cal-cell.today { background:linear-gradient(135deg,rgba(14,111,115,.05),rgba(217,164,74,.05)); }
.joud-cal-cell.today .joud-cal-date { background:#0e6f73; color:#fff; }
.joud-cal-cell.weekend-cell { background:rgba(249,250,251,.6); }
.joud-cal-cell:hover { background:rgba(14,111,115,.03); }

/* ── Date number ── */
.joud-cal-date { width:28px; height:28px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:600; color:#15363a; margin-bottom:5px; }
.outside .joud-cal-date { color:#adb5bd; font-weight:400; }

/* ── Event pills ── */
.joud-cal-events { display:flex; flex-direction:column; gap:3px; }
.joud-cal-event { display:flex; align-items:center; gap:4px; padding:3px 6px; border-radius:6px; font-size:10.5px; font-weight:500; cursor:pointer; transition:.12s; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; text-decoration:none; }
.joud-cal-event:hover { filter:brightness(.92); transform:translateX(-1px); }
.joud-cal-event i { font-size:11px; flex-shrink:0; }
.joud-cal-event-title { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1; min-width:0; }

/* event colors */
.ev-success { background:rgba(52,195,143,.15); color:#0d7a5a; border-left:2.5px solid #34c38f; }
.ev-primary { background:rgba(85,110,230,.14); color:#3145a3; border-left:2.5px solid #556ee6; }
.ev-warning { background:rgba(241,180,76,.15); color:#8a5f00; border-left:2.5px solid #f1b44c; }
.ev-danger  { background:rgba(244,106,106,.14); color:#ab2b2b; border-left:2.5px solid #f46a6a; }
.ev-info    { background:rgba(80,165,241,.14); color:#1a6faf; border-left:2.5px solid #50a5f1; }
.ev-secondary{ background:rgba(173,181,189,.15); color:#495057; border-left:2.5px solid #adb5bd; }

/* ── "+N more" ── */
.joud-cal-more { font-size:10px; color:#0e6f73; font-weight:600; padding:2px 4px; cursor:pointer; }
.joud-cal-more:hover { text-decoration:underline; }

/* ── Empty cell placeholder ── */
.joud-cal-empty { font-size:11px; color:#dee2e6; text-align:center; margin-top:20px; }

/* ── Stats bar ── */
.joud-cal-stats { background:#f5faf9; border-top:1px solid rgba(14,111,115,.08); padding:14px 24px; display:flex; gap:28px; flex-wrap:wrap; }
.joud-cal-stat { display:flex; align-items:center; gap:8px; }
.joud-cal-stat-dot { width:10px; height:10px; border-radius:3px; flex-shrink:0; }
.joud-cal-stat-label { font-size:12px; color:#6b7d80; }
.joud-cal-stat-count { font-size:13px; font-weight:700; color:#15363a; }

media (max-width:767.98px) {
  .joud-cal-cell { min-height:70px; padding:5px 4px; }
  .joud-cal-event { font-size:9px; padding:2px 4px; }
  .joud-cal-legend { display:none; }
  .joud-cal-month { font-size:1.1rem; }
}
</style>

<div class="joud-cal-wrap mb-4">


  <div class="joud-cal-header">
    <div class="joud-cal-nav">
      <a class="joud-cal-nav-btn"
         asp-action="Calendar"
         asp-route-projectId="@Model.ProjectHeader.Id"
         asp-route-year="@prev.Year"
         asp-route-month="@prev.Month"
         title="الشهر السابق">
        <i class="bx bx-chevron-right"></i>
      </a>
      <div>
        <div class="joud-cal-month">@Model.MonthName</div>
        <div class="joud-cal-year">@Model.Year</div>
      </div>
      <a class="joud-cal-nav-btn"
         asp-action="Calendar"
         asp-route-projectId="@Model.ProjectHeader.Id"
         asp-route-year="@next.Year"
         asp-route-month="@next.Month"
         title="الشهر التالي">
        <i class="bx bx-chevron-left"></i>
      </a>
    </div>

    <div class="joud-cal-legend d-none d-md-flex">
      <div class="joud-cal-legend-item">
        <div class="joud-cal-legend-dot" style="background:#34c38f"></div> مكتمل
      </div>
      <div class="joud-cal-legend-item">
        <div class="joud-cal-legend-dot" style="background:#556ee6"></div> جاري
      </div>
      <div class="joud-cal-legend-item">
        <div class="joud-cal-legend-dot" style="background:#f1b44c"></div> قيد الانتظار
      </div>
      <div class="joud-cal-legend-item">
        <div class="joud-cal-legend-dot" style="background:#f46a6a"></div> متأخر
      </div>
      <div class="joud-cal-legend-item">
        <div class="joud-cal-legend-dot" style="background:#50a5f1"></div> معتمد
      </div>
    </div>
  </div>

 
  <div class="joud-cal-daynames">
    <div class="joud-cal-dayname">الأحد</div>
    <div class="joud-cal-dayname">الإثنين</div>
    <div class="joud-cal-dayname">الثلاثاء</div>
    <div class="joud-cal-dayname">الأربعاء</div>
    <div class="joud-cal-dayname">الخميس</div>
    <div class="joud-cal-dayname weekend">الجمعة</div>
    <div class="joud-cal-dayname weekend">السبت</div>
  </div>

  
  <div class="joud-cal-grid">
    @foreach (var day in Model.Days)
    {
        var isToday   = day.Date.Date == today;
        var isOutside = !day.InCurrentMonth;
        var dow       = (int)day.Date.DayOfWeek;
        var isWeekend = dow == 5 || dow == 6;
        var cellClass = "joud-cal-cell"
            + (isOutside  ? " outside"      : "")
            + (isToday    ? " today"        : "")
            + (isWeekend  ? " weekend-cell" : "");

        <div class="@cellClass">
          <div class="joud-cal-date">@day.Date.Day</div>

          @if (day.Items.Count == 0 && !isOutside)
          {
            <div class="joud-cal-empty"><i class="bx bx-minus"></i></div>
          }
          else
          {
            <div class="joud-cal-events">
              @foreach (var item in day.Items.Take(3))
              {
                  var bg    = StatusBg(item.Status);
                  var icon  = KindIcon(item.Kind);
                  <a href="#"
                     class="joud-cal-event ev-@bg"
                     title="@item.Title — @KindLabel(item.Kind) — @item.Status"
                     data-bs-toggle="tooltip"
                     data-bs-placement="top">
                    <i class="@icon"></i>
                    <span class="joud-cal-event-title">@item.Title</span>
                  </a>
              }
              @if (day.Items.Count > 3)
              {
                <div class="joud-cal-more">
                  <i class="bx bx-dots-horizontal-rounded"></i>
                  +@(day.Items.Count - 3) المزيد
                </div>
              }
            </div>
          }
        </div>
    }
  </div>

 
  @{
      var allItems   = Model.Days.SelectMany(d => d.Items).ToList();
      var cntTotal   = allItems.Count;
      var cntDone    = allItems.Count(x => x.Status?.ToLower() is "completed" or "مكتمل");
      var cntActive  = allItems.Count(x => x.Status?.ToLower() is "inprogress" or "جاري");
      var cntPending = allItems.Count(x => x.Status?.ToLower() is "pending" or "قيد الانتظار");
      var cntLate    = allItems.Count(x => x.Status?.ToLower() is "delayed" or "متأخر");
  }
  <div class="joud-cal-stats">
    <div class="joud-cal-stat">
      <div class="joud-cal-stat-dot" style="background:#0e6f73"></div>
      <span class="joud-cal-stat-label">إجمالي الأحداث</span>
      <span class="joud-cal-stat-count">@cntTotal</span>
    </div>
    <div class="joud-cal-stat">
      <div class="joud-cal-stat-dot" style="background:#34c38f"></div>
      <span class="joud-cal-stat-label">مكتملة</span>
      <span class="joud-cal-stat-count">@cntDone</span>
    </div>
    <div class="joud-cal-stat">
      <div class="joud-cal-stat-dot" style="background:#556ee6"></div>
      <span class="joud-cal-stat-label">جارية</span>
      <span class="joud-cal-stat-count">@cntActive</span>
    </div>
    <div class="joud-cal-stat">
      <div class="joud-cal-stat-dot" style="background:#f1b44c"></div>
      <span class="joud-cal-stat-label">قيد الانتظار</span>
      <span class="joud-cal-stat-count">@cntPending</span>
    </div>
    @if (cntLate > 0)
    {
      <div class="joud-cal-stat">
        <div class="joud-cal-stat-dot" style="background:#f46a6a"></div>
        <span class="joud-cal-stat-label">متأخرة</span>
        <span class="joud-cal-stat-count text-danger">@cntLate</span>
      </div>
    }
  </div>

</div>

@section scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {
  // Bootstrap tooltips
  document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
    new bootstrap.Tooltip(el, { trigger: "hover" });
  });
});
</script>
}

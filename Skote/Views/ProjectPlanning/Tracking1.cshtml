@model InfrastructureManagmentWebFramework.Models.Charity.ProjectPlanning.ProjectTrackingBoardVm
<partial name="~/Views/Shared/Projects/_ProjectHeader.cshtml" />
@{
    string StatusAr(string s) => s switch {
        "Completed"  => "مكتمل",  "InProgress" => "جارٍ",
        "Planned"    => "مخطط",   "Delayed"    => "متأخر",
        "OnHold"     => "موقوف",  "Pending"    => "قيد الانتظار",
        _ => s
    };
    string StatusColor(string s) => s switch {
        "Completed"  => "#34c38f", "InProgress" => "#556ee6",
        "Planned"    => "#50a5f1", "Delayed"    => "#f46a6a",
        "OnHold"     => "#adb5bd", "Pending"    => "#f1b44c",
        _ => "#adb5bd"
    };
    string StatusBadge(string s) => s switch {
        "Completed"  => "success",  "InProgress" => "primary",
        "Planned"    => "info",     "Delayed"    => "danger",
        "OnHold"     => "secondary","Pending"    => "warning",
        _ => "secondary"
    };
    string EntryTypeAr(string s) => s switch {
        "Update"    => "تحديث",   "Issue"     => "مشكلة",
        "Decision"  => "قرار",    "Note"      => "ملاحظة",
        "Milestone" => "إنجاز",   _ => s
    };

    var today = DateTime.Today;
    var projectDays = Model.ProjectHeader.EndDate.HasValue
        ? Math.Max(1, (Model.ProjectHeader.EndDate.Value - Model.ProjectHeader.StartDate).Days)
        : 365;
    var elapsedDays = Math.Max(0, (today - Model.ProjectHeader.StartDate).Days);
    var timeProgress = Math.Min(100, Math.Round((decimal)elapsedDays / projectDays * 100, 0));
}

<style>
.trk-hero{background:linear-gradient(135deg,#0a5659,#0e6f73,#0c8387);border-radius:20px;padding:24px 28px;color:#fff;margin-bottom:1.5rem}
.trk-overall-ring{width:100px;height:100px;border-radius:50%;background:conic-gradient(rgba(255,255,255,.9) @Model.OverallProgress%, rgba(255,255,255,.15) 0);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.trk-ring-inner{width:76px;height:76px;border-radius:50%;background:rgba(14,111,115,.8);display:flex;flex-direction:column;align-items:center;justify-content:center}
.trk-kpi{background:rgba(255,255,255,.12);border-radius:14px;padding:14px 18px;text-align:center;flex:1}
.trk-kpi-num{font-size:1.6rem;font-weight:800;line-height:1}
.trk-kpi-lbl{font-size:.75rem;opacity:.8;margin-top:2px}

/* Phase stepper */
.trk-stepper{position:relative;padding-right:24px}
.trk-stepper::before{content:'';position:absolute;right:11px;top:0;bottom:0;width:2px;background:rgba(14,111,115,.12)}
.trk-step{position:relative;margin-bottom:20px}
.trk-step:last-child{margin-bottom:0}
.trk-step-dot{width:24px;height:24px;border-radius:50%;position:absolute;right:-24px;top:8px;display:flex;align-items:center;justify-content:center;font-size:11px;color:#fff;font-weight:700;border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.15);z-index:1}
.trk-step-card{border-radius:14px;border:.5px solid rgba(14,111,115,.12);padding:14px 16px;background:#fff;box-shadow:0 2px 10px rgba(14,111,115,.05);transition:.15s}
.trk-step-card:hover{box-shadow:0 4px 18px rgba(14,111,115,.10)}
.trk-phase-bar{height:8px;border-radius:999px;background:#eef4f3;margin-top:8px}
.trk-phase-fill{height:100%;border-radius:999px;transition:width .5s}

/* Milestone timeline */
.ms-item{display:flex;gap:12px;align-items:flex-start;padding:10px 0;border-bottom:.5px dashed rgba(14,111,115,.10)}
.ms-item:last-child{border-bottom:none}
.ms-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;margin-top:4px}
.ms-overdue{background:#fff0f0;border-radius:10px;padding:4px 8px}

/* Activities */
.act-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:.5px dashed rgba(14,111,115,.10)}
.act-item:last-child{border-bottom:none}
.act-icon{width:32px;height:32px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.act-check{width:20px;height:20px;border-radius:6px;border:2px solid;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px}

/* Log feed */
.log-item{display:flex;gap:12px;padding:12px 0;border-bottom:.5px dashed rgba(14,111,115,.10)}
.log-item:last-child{border-bottom:none}
.log-dot{width:36px;height:36px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}

/* Budget bar */
.budget-bar{height:12px;border-radius:999px;background:#eef4f3;overflow:hidden}
.budget-fill{height:100%;border-radius:999px}
</style>

@* ═══ HERO ═══ *@
<div class="trk-hero mb-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-3">
    <div>
      <div class="fw-bold fs-5">متابعة تنفيذ المشروع</div>
      <div style="opacity:.75;font-size:.85rem">
        @Model.ProjectHeader.StartDate.ToString("dd/MM/yyyy")
        @if (Model.ProjectHeader.EndDate.HasValue) { <span>← @Model.ProjectHeader.EndDate.Value.ToString("dd/MM/yyyy")</span> }
        &nbsp;·&nbsp; @elapsedDays يوم منذ البداية
      </div>
    </div>
    <div class="d-flex align-items-center gap-3">
      <div class="trk-overall-ring">
        <div class="trk-ring-inner">
          <span style="font-size:1.3rem;font-weight:800">@Model.OverallProgress%</span>
          <span style="font-size:.65rem;opacity:.8">إنجاز</span>
        </div>
      </div>
      <a asp-controller="ProjectTrackingLogs" asp-action="Create"
         asp-route-projectId="@Model.ProjectHeader.Id"
         class="btn btn-light btn-sm fw-bold">
        <i class="bx bx-plus me-1"></i>إضافة متابعة
      </a>
    </div>
  </div>

  <div class="d-flex gap-3 flex-wrap">
    <div class="trk-kpi">
      <div class="trk-kpi-num">@Model.PhaseSummaries.Count</div>
      <div class="trk-kpi-lbl">إجمالي المراحل</div>
    </div>
    <div class="trk-kpi" style="background:rgba(52,195,143,.20)">
      <div class="trk-kpi-num" style="color:#a7f3d0">@Model.CompletedPhases</div>
      <div class="trk-kpi-lbl">مكتملة</div>
    </div>
    <div class="trk-kpi" style="background:rgba(255,255,255,.18)">
      <div class="trk-kpi-num">@Model.InProgressPhases</div>
      <div class="trk-kpi-lbl">جارية</div>
    </div>
    <div class="trk-kpi" style="background:rgba(241,180,76,.20)">
      <div class="trk-kpi-num" style="color:#fde68a">@Model.RemainingPhases</div>
      <div class="trk-kpi-lbl">متبقية</div>
    </div>
    @if (Model.DelayedPhases > 0)
    {
      <div class="trk-kpi" style="background:rgba(244,106,106,.22)">
        <div class="trk-kpi-num" style="color:#fca5a5">@Model.DelayedPhases</div>
        <div class="trk-kpi-lbl">تحتاج متابعة</div>
      </div>
    }
    <div class="trk-kpi" style="background:rgba(255,255,255,.10)">
      <div class="trk-kpi-num">@Model.MilestoneDone / @Model.Milestones.Count</div>
      <div class="trk-kpi-lbl">إنجازات</div>
    </div>
    <div class="trk-kpi" style="background:rgba(255,255,255,.10)">
      <div class="trk-kpi-num">@Model.ActivityDone / @Model.Activities.Count</div>
      <div class="trk-kpi-lbl">أنشطة</div>
    </div>
  </div>

  @* Time progress bar *@
  <div class="mt-3">
    <div class="d-flex justify-content-between mb-1" style="font-size:.78rem;opacity:.8">
      <span>تقدم الزمن: @timeProgress%</span>
      <span>تقدم التنفيذ: @Model.OverallProgress%</span>
    </div>
    <div style="height:6px;border-radius:999px;background:rgba(255,255,255,.15)">
      <div style="height:100%;border-radius:999px;background:rgba(255,255,255,.55);width:@timeProgress%"></div>
    </div>
    <div style="height:6px;border-radius:999px;background:rgba(255,255,255,.15);margin-top:4px">
      <div style="height:100%;border-radius:999px;background:#34c38f;width:@Model.OverallProgress%"></div>
    </div>
  </div>
</div>

<div class="row g-4">

  @* ═══ عمود المراحل ═══ *@
  <div class="col-xl-4">
    <div class="card h-100" style="border-radius:18px;border:.5px solid rgba(14,111,115,.12)">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h5 class="mb-0 fw-bold" style="color:#0a5f63">
            <i class="bx bx-layer me-2"></i>المراحل
          </h5>
          <a asp-controller="ProjectPhases" asp-action="Index"
             asp-route-projectId="@Model.ProjectHeader.Id"
             class="btn btn-sm btn-outline-primary" style="border-radius:10px">كل المراحل</a>
        </div>

        @if (!Model.PhaseSummaries.Any())
        {
          <div class="text-center text-muted py-4"><i class="bx bx-layer" style="font-size:2rem"></i><br/>لا توجد مراحل</div>
        }
        else
        {
          <div class="trk-stepper">
            @foreach (var (phase, idx) in Model.PhaseSummaries.Select((p,i)=>(p,i)))
            {
              var dotColor = StatusColor(phase.Status);
              var isLast   = phase.Status == "Completed";
              var isCur    = phase.Status == "InProgress";
              <div class="trk-step">
                <div class="trk-step-dot" style="background:@dotColor">
                  @if (isLast) { <i class="bx bx-check" style="font-size:13px"></i> }
                  else if (phase.RequiresAttention) { <i class="bx bx-error" style="font-size:12px"></i> }
                  else { <span>@(idx+1)</span> }
                </div>
                <div class="trk-step-card @(isCur ? "border-primary" : "") @(phase.RequiresAttention ? "border-danger" : "")">
                  <div class="d-flex justify-content-between align-items-start">
                    <div class="fw-semibold" style="font-size:.92rem;color:#15363a">@phase.PhaseName</div>
                    <span class="badge bg-@StatusBadge(phase.Status) bg-opacity-15 text-@StatusBadge(phase.Status)" style="font-size:.72rem">
                      @StatusAr(phase.Status)
                    </span>
                  </div>
                  <div class="trk-phase-bar mt-2">
                    <div class="trk-phase-fill" style="width:@phase.ProgressPercent%;background:@dotColor"></div>
                  </div>
                  <div class="d-flex justify-content-between mt-1" style="font-size:.75rem;color:#6b7d80">
                    <span>@phase.ProgressPercent%</span>
                    <span>
                      @phase.PlannedStartDate.ToString("d/M") → @phase.PlannedEndDate.ToString("d/M/yy")
                      @if (phase.RequiresAttention) { <i class="bx bx-error-circle text-danger ms-1"></i> }
                    </span>
                  </div>
                  @if (phase.ActualStartDate.HasValue)
                  {
                    <div style="font-size:.72rem;color:#34c38f;margin-top:2px">
                      <i class="bx bx-play-circle me-1"></i>بدأ فعلياً: @phase.ActualStartDate.Value.ToString("d/M/yy")
                    </div>
                  }
                </div>
              </div>
            }
          </div>
        }
      </div>
    </div>
  </div>

  @* ═══ عمود الإنجازات + الأنشطة ═══ *@
  <div class="col-xl-4">

    @* Milestones *@
    <div class="card mb-4" style="border-radius:18px;border:.5px solid rgba(14,111,115,.12)">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0 fw-bold" style="color:#0a5f63">
            <i class="bx bx-flag me-2"></i>الإنجازات
            <span class="badge bg-success ms-1">@Model.MilestoneDone</span>
            <span class="badge bg-secondary ms-1">@Model.MilestonePending</span>
          </h5>
        </div>
        @if (!Model.Milestones.Any())
        {
          <div class="text-center text-muted py-3" style="font-size:.85rem"><i class="bx bx-flag" style="font-size:1.8rem"></i><br/>لا توجد إنجازات</div>
        }
        else
        {
          <div style="max-height:280px;overflow-y:auto">
            @foreach (var ms in Model.Milestones.OrderBy(x => x.Status == "Completed").ThenBy(x => x.DueDate))
            {
              var done   = ms.Status == "Completed";
              var over   = ms.IsOverdue;
              var soon   = ms.IsDueSoon;
              <div class="ms-item @(over && !done ? "ms-overdue" : "")">
                <div class="ms-dot" style="background:@(done ? "#34c38f" : over ? "#f46a6a" : soon ? "#f1b44c" : "#e2e8f0")"></div>
                <div class="flex-grow-1 min-w-0">
                  <div class="d-flex align-items-center gap-1 flex-wrap">
                    <span class="fw-semibold" style="font-size:.85rem;@(done ? "text-decoration:line-through;color:#adb5bd" : "color:#15363a")">@ms.Title</span>
                    @if (over && !done) { <span class="badge bg-danger" style="font-size:.65rem">متأخر</span> }
                    @if (soon && !done) { <span class="badge bg-warning text-dark" style="font-size:.65rem">قريب</span> }
                  </div>
                  <div style="font-size:.75rem;color:#6b7d80">
                    @ms.PhaseName &nbsp;·&nbsp;
                    @if (done) { <span class="text-success">✓ @ms.CompletedDate?.ToString("d/M/yy")</span> }
                    else { <span>@ms.DueDate.ToString("d/M/yy")</span> }
                  </div>
                </div>
              </div>
            }
          </div>
        }
      </div>
    </div>

    @* Activities *@
    <div class="card" style="border-radius:18px;border:.5px solid rgba(14,111,115,.12)">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0 fw-bold" style="color:#0a5f63">
            <i class="bx bx-task me-2"></i>الأنشطة
            <span class="badge bg-success ms-1">@Model.ActivityDone</span>
            <span class="badge bg-secondary ms-1">@Model.ActivityRemaining</span>
          </h5>
        </div>
        @if (!Model.Activities.Any())
        {
          <div class="text-center text-muted py-3" style="font-size:.85rem"><i class="bx bx-task" style="font-size:1.8rem"></i><br/>لا توجد أنشطة</div>
        }
        else
        {
          @* progress circle *@
        
         
            var actPct = Model.Activities.Count > 0
              ? Math.Round((decimal)Model.ActivityDone / Model.Activities.Count * 100, 0) : 0m;
          
          <div class="d-flex align-items-center gap-3 mb-3 p-2 rounded-3" style="background:#f5faf9">
            <div style="width:48px;height:48px;border-radius:50%;background:conic-gradient(#34c38f @actPct%,#e2e8f0 0);display:flex;align-items:center;justify-content:center;flex-shrink:0">
              <div style="width:36px;height:36px;border-radius:50%;background:#f5faf9;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:#0a5f63">@actPct%</div>
            </div>
            <div style="font-size:.82rem;color:#6b7d80">
              <strong class="text-success">@Model.ActivityDone مكتمل</strong> من @Model.Activities.Count نشاط
              @if (Model.Activities.Any(x => x.IsOverdue)) {
                <br/><span class="text-danger"><i class="bx bx-error-circle me-1"></i>@Model.Activities.Count(x=>x.IsOverdue) نشاط متأخر</span>
              }
            </div>
          </div>
          <div style="max-height:220px;overflow-y:auto">
            @foreach (var act in Model.Activities.OrderBy(x => x.IsCompleted).ThenBy(x => x.PlannedDate))
            {
              var done = act.IsCompleted;
              var over = act.IsOverdue;
              <div class="act-item">
                <div class="act-check" style="color:@(done?"#34c38f":over?"#f46a6a":"#adb5bd");border-color:@(done?"#34c38f":over?"#f46a6a":"#e2e8f0");background:@(done?"rgba(52,195,143,.1)":over?"rgba(244,106,106,.08)":"#fff")">
                  @if (done) { <i class="bx bx-check"></i> }
                  else if (over) { <i class="bx bx-x"></i> }
                </div>
                <div class="flex-grow-1 min-w-0">
                  <div class="fw-semibold" style="font-size:.85rem;@(done?"text-decoration:line-through;color:#adb5bd":"color:#15363a")">@act.Title</div>
                  <div style="font-size:.75rem;color:#6b7d80">
                    @act.PlannedDate.ToString("d/M/yy")
                    @if (over && !done) { <span class="badge bg-danger ms-1" style="font-size:.65rem">متأخر</span> }
                    @if (act.PlannedCost > 0) { <span class="ms-2 text-muted">@act.PlannedCost.ToString("N0")</span> }
                  </div>
                </div>
              </div>
            }
          </div>
        }
      </div>
    </div>
  </div>

  @* ═══ عمود المتابعات + الميزانية ═══ *@
  <div class="col-xl-4">

    @* Budget *@
    @if (Model.TotalPlannedBudget > 0)
    {
      <div class="card mb-4" style="border-radius:18px;border:.5px solid rgba(14,111,115,.12)">
        <div class="card-body">
          <h5 class="mb-3 fw-bold" style="color:#0a5f63"><i class="bx bx-money me-2"></i>الميزانية</h5>
          <div class="budget-bar mb-2">
            <div class="budget-fill" style="width:@Model.BudgetUtilization%;background:@(Model.BudgetUtilization>90?"#f46a6a":Model.BudgetUtilization>70?"#f1b44c":"#34c38f")"></div>
          </div>
          <div class="d-flex justify-content-between" style="font-size:.8rem;color:#6b7d80;margin-bottom:10px">
            <span>المصروف: <strong style="color:#15363a">@Model.TotalActualSpent.ToString("N0")</strong></span>
            <span>المخطط: <strong style="color:#15363a">@Model.TotalPlannedBudget.ToString("N0")</strong></span>
          </div>
          <div class="d-flex gap-2">
            <div class="flex-fill text-center p-2 rounded-3" style="background:#f5faf9;font-size:.8rem">
              <div class="fw-bold" style="color:#0a5f63;font-size:1.1rem">@Model.BudgetUtilization%</div>
              <div class="text-muted">نسبة الإنفاق</div>
            </div>
            <div class="flex-fill text-center p-2 rounded-3" style="background:@(Model.BudgetVariance>=0?"rgba(52,195,143,.08)":"rgba(244,106,106,.08)");font-size:.8rem">
              <div class="fw-bold @(Model.BudgetVariance>=0?"text-success":"text-danger")" style="font-size:1.1rem">@Model.BudgetVariance.ToString("N0")</div>
              <div class="text-muted">@(Model.BudgetVariance>=0?"وفر":"تجاوز")</div>
            </div>
          </div>
        </div>
      </div>
    }

    @* Logs *@
    <div class="card" style="border-radius:18px;border:.5px solid rgba(14,111,115,.12)">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0 fw-bold" style="color:#0a5f63">
            <i class="bx bx-history me-2"></i>سجل المتابعات
          </h5>
          <a asp-controller="ProjectTrackingLogs" asp-action="Create"
             asp-route-projectId="@Model.ProjectHeader.Id"
             class="btn btn-sm btn-primary" style="border-radius:10px">
            <i class="bx bx-plus"></i>
          </a>
        </div>
        @if (!Model.RecentLogs.Any())
        {
          <div class="text-center text-muted py-4" style="font-size:.85rem"><i class="bx bx-history" style="font-size:1.8rem"></i><br/>لا توجد متابعات بعد</div>
        }
        else
        {
          <div style="max-height:480px;overflow-y:auto">
            @foreach (var log in Model.RecentLogs)
            {
              var logColor = log.RequiresAttention ? "#f46a6a"
                : log.EntryType == "Issue" ? "#f1b44c" : "#0e6f73";
              var logBg = log.RequiresAttention ? "rgba(244,106,106,.10)"
                : log.EntryType == "Issue" ? "rgba(241,180,76,.10)" : "rgba(14,111,115,.07)";
              var logIcon = log.EntryType switch {
                "Issue" => "bx-error", "Decision" => "bx-check-shield",
                "Milestone" => "bx-flag", "Note" => "bx-note",
                _ => "bx-edit"
              };
              <div class="log-item">
                <div class="log-dot" style="background:@logBg;color:@logColor">
                  <i class="bx @logIcon"></i>
                </div>
                <div class="flex-grow-1 min-w-0">
                  <div class="d-flex align-items-start justify-content-between gap-1">
                    <span class="fw-semibold" style="font-size:.88rem;color:#15363a">@log.Title</span>
                    @if (log.RequiresAttention)
                    { <span class="badge bg-danger" style="font-size:.65rem;flex-shrink:0">تنبيه</span> }
                  </div>
                  <div style="font-size:.75rem;color:#6b7d80;margin-top:2px">
                    @log.EntryDate.ToString("d/M/yyyy")
                    &nbsp;·&nbsp; @EntryTypeAr(log.EntryType)
                    @if (log.Status != null) { <span>&nbsp;·&nbsp; @StatusAr(log.Status)</span> }
                    @if (log.ProgressPercent.HasValue) { <span>&nbsp;·&nbsp; @log.ProgressPercent%</span> }
                  </div>
                  @if (!string.IsNullOrWhiteSpace(log.Details))
                  {
                    <p class="mb-0 mt-1" style="font-size:.8rem;color:#6b7d80;white-space:pre-wrap">@log.Details</p>
                  }
                </div>
              </div>
            }
          </div>
        }
      </div>
    </div>
  </div>

</div>

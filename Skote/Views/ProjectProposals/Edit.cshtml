@model Skote.Models.Charity.ProjectProposals.ProjectProposalVm
@{
    ViewData["Title"] = "تعديل مقترح مشروع";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                <div>
                    <h4 class="mb-0">تعديل مقترح / ميثاق مشروع</h4>
                    @if (!string.IsNullOrWhiteSpace(Model.ProposalNumber))
                    {
                        <small class="text-muted">
                            رقم المقترح: @Model.ProposalNumber
                            &nbsp;|&nbsp;
                            <span class="badge @(Model.Status == "Draft" ? "bg-secondary" : "bg-primary")">@Model.Status</span>
                        </small>
                    }
                </div>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light btn-sm">
                    <i class="bx bx-arrow-back me-1"></i>رجوع للتفاصيل
                </a>
            </div>

            @* ── ملخص أخطاء الـ Validation ── *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <h6 class="alert-heading fw-bold mb-2"><i class="bx bx-error-circle me-1"></i>يوجد أخطاء يجب تصحيحها:</h6>
                    <div asp-validation-summary="All" class="mb-0 small"></div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editForm">
                <input asp-for="Id" type="hidden" />
                <input type="hidden" name="IsDraftSave" id="isDraftSave" value="false" />

                @await Html.PartialAsync("_Form", Model)

                <div class="mt-4 d-flex gap-2 flex-wrap border-top pt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bx bx-save me-1"></i>حفظ التعديلات
                    </button>
                    <button type="button" class="btn btn-outline-secondary"
                            onclick="document.getElementById('isDraftSave').value='true'; document.getElementById('editForm').submit()">
                        <i class="bx bx-file me-1"></i>حفظ كمسودة
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

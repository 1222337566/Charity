@model IEnumerable<InfrastrfuctureManagmentCore.Domains.Charity.ProjectProposals.ProjectProposal>
@{
    ViewData["Title"] = "مقترحات المشروعات";
}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">مقترحات / مواثيق المشروعات</h3>
        <a asp-action="Create" class="btn btn-primary">إضافة مقترح مشروع</a>
    </div>
    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead>
                    <tr>
                        <th>رقم المقترح</th>
                        <th>العنوان</th>
                        <th>الجهة المانحة</th>
                        <th>الموقع</th>
                        <th>المدة</th>
                        <th>الميزانية</th>
                        <th>الحالة</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProposalNumber</td>
                        <td>@item.Title</td>
                        <td>@item.DonorName</td>
                        <td>@item.ProjectLocation</td>
                        <td>@item.DurationMonths شهر</td>
                        <td>@item.RequestedBudget.ToString("N2") @item.Currency</td>
                        <td><span class="badge bg-info">@item.Status</span></td>
                        <td class="text-nowrap">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تفاصيل</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

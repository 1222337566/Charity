@* ══════════════════════ 2. الأهداف ══════════════════════ *@
<div class="pp-section">
    <div class="pp-head">
        <h6><i class="bx bx-target-lock me-2"></i>الأهداف الفرعية والنتائج</h6>
        <button type="button" class="add-row-btn" onclick="addRow('objectives-body','objective-tpl')">
            <i class="bx bx-plus me-1"></i>إضافة هدف
        </button>
    </div>
    <div class="pp-body p-0">
        <table class="pp-table">
            <thead>
                <tr>
                    <th style="width:110px">النوع</th>
                    <th>العنوان / الهدف</th>
                    <th>الوصف / النتيجة المتوقعة</th>
                    <th style="width:40px"></th>
                </tr>
            </thead>
            <tbody id="objectives-body">
                @if (Model.Objectives != null)
                {
                    for (int i = 0; i < Model.Objectives.Count; i++)
                    {
                        <tr>
                            <td>
                                @{
                                    var objType = Model.Objectives[i].ObjectiveType;
                                }
                                <select name="Objectives[@i].ObjectiveType" class="pp-select">
                                    @if (objType == "Specific")
                                    {
                                        <option value="Specific" selected>هدف فرعي</option>
                                        <option value="Result">نتيجة</option>
                                        <option value="General">هدف عام</option>
                                    }
                                    else if (objType == "Result")
                                    {
                                        <option value="Specific">هدف فرعي</option>
                                        <option value="Result" selected>نتيجة</option>
                                        <option value="General">هدف عام</option>
                                    }
                                    else
                                    {
                                        <option value="Specific">هدف فرعي</option>
                                        <option value="Result">نتيجة</option>
                                        <option value="General" selected>هدف عام</option>
                                    }
                                </select>
                            </td>
                            <td><input name="Objectives[@i].Title" class="pp-input obj-title-inp" value="@Model.Objectives[i].Title" placeholder="عنوان الهدف أو النتيجة" oninput="syncObjectiveDropdowns()" /></td>
                            <td><input name="Objectives[@i].Description" class="pp-input" value="@Model.Objectives[i].Description" placeholder="وصف أو مؤشر" /></td>
                            <td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <template id="objective-tpl">
            <tr>
                <td><select name="Objectives[__IDX__].ObjectiveType" class="pp-select"><option value="Specific">هدف فرعي</option><option value="Result">نتيجة</option><option value="General">هدف عام</option></select></td>
                <td><input name="Objectives[__IDX__].Title" class="pp-input obj-title-inp" placeholder="عنوان الهدف" oninput="syncObjectiveDropdowns()" /></td>
                <td><input name="Objectives[__IDX__].Description" class="pp-input" placeholder="الوصف أو المؤشر" /></td>
                <td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>
            </tr>
        </template>
    </div>
</div>

@* ══════════════════════ 3. الأنشطة ══════════════════════ *@
<div class="pp-section">
    <div class="pp-head">
        <h6><i class="bx bx-list-check me-2"></i>الأنشطة</h6>
        <button type="button" class="add-row-btn" onclick="addActivity()">
            <i class="bx bx-plus me-1"></i>إضافة نشاط
        </button>
    </div>
    <div class="pp-body" id="activities-container" style="padding:10px">
        @if (Model.Activities != null)
        {
            for (int i = 0; i < Model.Activities.Count; i++)
            {
                var act = Model.Activities[i];
                <div class="act-block" id="actb-@i" style="border:.5px solid rgba(14,111,115,.12);border-radius:12px;margin-bottom:10px;overflow:hidden">
                    @* رأس النشاط — السطر الأول *@
                    <div style="background:rgba(14,111,115,.04);padding:10px 14px">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span style="font-size:.75rem;font-weight:700;color:#0a5f63">عنوان النشاط *</span>
                            <input name="Activities[@i].Title" class="pp-input fw-semibold act-title-inp" style="flex:1"
                                   value="@act.Title" placeholder="مثال: تنفيذ ورشات تدريبية"
                                   oninput="syncActivityDropdowns()" />
                            <select name="Activities[@i].Priority" class="pp-select" style="width:100px" data-val="@(act.Priority ?? "Medium")" onchange="">
                                @{
                                    var _pri = act.Priority ?? "Medium";
                                }
                                <option value="Low">🟢 منخفض</option>
                                <option value="Medium">🟡 متوسط</option>
                                <option value="High">🟠 عالي</option>
                                <option value="Critical">🔴 حرج</option>
                            </select>
                            <button type="button" class="del-btn" onclick="this.closest('.act-block').remove()">
                                <i class="bx bx-trash"></i>
                            </button>
                        </div>
                        @* السطر الثاني — التفاصيل الكمية *@
                        <div class="d-flex gap-2 flex-wrap align-items-center" style="font-size:.78rem">
                            <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
                                <span style="color:#6b7d80">الفئة المستهدفة</span>
                                <input name="Activities[@i].TargetGroup" class="pp-input" style="width:140px"
                                       value="@act.TargetGroup" placeholder="شباب / مزارعون / قيادات" />
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
                                <span style="color:#6b7d80">الكمية المخططة</span>
                                <input name="Activities[@i].PlannedCount" type="number" class="pp-input" style="width:70px"
                                       value="@act.PlannedCount" placeholder="0" />
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
                                <span style="color:#6b7d80">الوحدة</span>
                                <input name="Activities[@i].Responsible" class="pp-input" style="width:65px"
                                       value="@(act.Responsible ?? "شخص")" placeholder="شخص" />
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
                                <span style="color:#6b7d80">مدة (أيام)</span>
                                <input name="Activities[@i].PlannedStartMonth" type="number" class="pp-input" style="width:65px"
                                       value="@act.PlannedStartMonth" placeholder="0" />
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
                                <span style="color:#6b7d80">ساعات/يوم</span>
                                <input name="Activities[@i].PlannedEndMonth" type="number" class="pp-input" style="width:65px"
                                       value="@act.PlannedEndMonth" placeholder="0" />
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
                                <span style="color:#6b7d80">عدد الأنشطة</span>
                                <input name="Activities[@i].ResponsibleRole" type="number" class="pp-input" style="width:65px"
                                       value="@act.ResponsibleRole" placeholder="1" />
                            </div>
                        </div>
                        @* السطر الثالث — المؤشر والوسائل والمسؤول *@
                        <div class="d-flex gap-2 flex-wrap mt-2" style="font-size:.78rem">
                            <div style="flex:1;min-width:180px">
                                <div style="color:#6b7d80;margin-bottom:2px">مؤشر الأداء</div>
                                <input name="Activities[@i].Description" class="pp-input"
                                       value="@act.Description" placeholder="مثال: عدد حضور الندوات" />
                            </div>
                            <div style="flex:1;min-width:180px">
                                <div style="color:#6b7d80;margin-bottom:2px">وسائل التحقق</div>
                                <input name="Activities[@i].NeededResources" class="pp-input"
                                       value="@act.NeededResources" placeholder="مثال: كشف حضور — صور — فواتير" />
                            </div>
                            <div style="width:150px">
                                <div style="color:#6b7d80;margin-bottom:2px">المسؤول</div>
                                <input name="Activities[@i].ResponsibleRole" class="pp-input"
                                       value="@act.ResponsibleRole" placeholder="مثال: مشرف + منسق" />
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* ══════════════════════ 4. خطة العمل الإرشادية ══════════════════════ *@
<div class="pp-section">
    <div class="pp-head">
        <h6><i class="bx bx-calendar-check me-2"></i>خطة العمل الإرشادية</h6>
        <button type="button" class="add-row-btn" onclick="addWpRow()">
            <i class="bx bx-plus me-1"></i>إضافة سطر
        </button>
    </div>
    <div class="pp-body p-0" style="overflow-x:auto">
        <table class="pp-table" style="min-width:1200px;table-layout:fixed">
            <thead>
                <tr>
                    <th style="width:200px">النشاط</th>
                    <th style="width:170px">المرحلة</th>
                    <th style="width:90px">نسبة المساهمة</th>
                    <th style="width:70px">الكمية</th>
                    <th style="width:80px">مدة (أيام)</th>
                    <th style="width:150px">الهدف الفرعي</th>
                    <th style="width:130px">المسؤول</th>
                    <th style="width:130px">الموارد</th>
                    <th style="width:700px">الأشهر (انقر للتحديد)</th>
                    <th style="width:40px"></th>
                </tr>
            </thead>
            <tbody id="wp-body">
                @if (Model.WorkPlanItems != null)
                {
                    for (int i = 0; i < Model.WorkPlanItems.Count; i++)
                    {
                        var start = Model.WorkPlanItems[i].StartMonth ?? 1;
                        var end_  = Model.WorkPlanItems[i].EndMonth   ?? 1;
                        <tr>
                            <td>
                                <select name="WorkPlanItems[@i].ActivityTitle" class="pp-select wp-act-sel"
                                        data-selected="@Model.WorkPlanItems[i].ActivityTitle">
                                    <option value="">-- النشاط --</option>
                                    @if (Model.Activities != null)
                                    {
                                        foreach (var a in Model.Activities)
                                        {
                                            <option value="@a.Title"
                                                selected=@(Model.WorkPlanItems[i].ActivityTitle == a.Title ? "selected" : "")>
                                                @a.Title
                                            </option>
                                        }
                                    }
                                </select>
                            </td>
                            <td>
                                <select name="WorkPlanItems[@i].PhaseName" class="pp-select wp-phase-sel"
                                        data-selected="@Model.WorkPlanItems[i].PhaseName">
                                    <option value="">-- المرحلة --</option>
                                    @if (Model.Phases != null)
                                    {
                                        foreach (var ph in Model.Phases)
                                        {
                                            <option value="@ph.Name"
                                                selected=@(Model.WorkPlanItems[i].PhaseName == ph.Name ? "selected" : "")>
                                                @ph.Name
                                            </option>
                                        }
                                    }
                                </select>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <input type="number" name="WorkPlanItems[@i].ContributionPercent"
                                           class="pp-input contrib-inp" style="width:54px;text-align:center"
                                           value="@Model.WorkPlanItems[i].ContributionPercent"
                                           min="1" max="100" oninput="recalcWpBar(this)" />
                                    <span style="font-size:.8rem;color:#6b7d80">%</span>
                                </div>
                            </td>
                            <td><input type="number" name="WorkPlanItems[@i].PlannedQuantity" class="pp-input" style="text-align:center" value="@Model.WorkPlanItems[i].PlannedQuantity" placeholder="0" /></td>
                            <td><input type="number" name="WorkPlanItems[@i].DurationDays" class="pp-input" style="text-align:center" value="@Model.WorkPlanItems[i].DurationDays" placeholder="0" /></td>
                            <td>
                                <select name="WorkPlanItems[@i].GoalTitle" class="pp-select wp-goal-sel"
                                        data-selected="@Model.WorkPlanItems[i].GoalTitle">
                                    <option value="">-- الهدف الفرعي --</option>
                                    @if (Model.Objectives != null)
                                    {
                                        foreach (var obj in Model.Objectives.Where(o => !string.IsNullOrWhiteSpace(o.Title)))
                                        {
                                            <option value="@obj.Title"
                                                selected=@(Model.WorkPlanItems[i].GoalTitle == obj.Title ? "selected" : "")>
                                                @obj.Title
                                            </option>
                                        }
                                    }
                                </select>
                            </td>
                            <td><input name="WorkPlanItems[@i].Responsible" class="pp-input" value="@Model.WorkPlanItems[i].Responsible" placeholder="المسؤول" /></td>
                            <td><input name="WorkPlanItems[@i].Resources" class="pp-input" value="@Model.WorkPlanItems[i].Resources" placeholder="الموارد" /></td>
                            <td>
                                <input type="hidden" name="WorkPlanItems[@i].StartMonth" class="wp-start" value="@start" />
                                <input type="hidden" name="WorkPlanItems[@i].EndMonth"   class="wp-end"   value="@end_" />
                                <div class="month-grid">
                                    @for (int m = 1; m <= 24; m++)
                                    {
                                        <div class="month-cell @(m >= start && m <= end_ ? "on" : "")"
                                             onclick="toggleMonth(this,@i)" title="الشهر @m">@m</div>
                                    }
                                </div>
                            </td>
                            <td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>


@* ══════════════════════ 4b. مراحل المشروع ══════════════════════ *@
<div class="pp-section">
    <div class="pp-head">
        <h6><i class="bx bx-git-branch me-2"></i>مراحل المشروع</h6>
        <button type="button" class="add-row-btn" id="add-phase-btn" onclick="addPhaseBlock()">
            <i class="bx bx-plus me-1"></i>إضافة مرحلة
        </button>
    </div>
    <div class="pp-body" id="phases-container" style="padding:10px">
        @if (Model.Phases != null)
        {
            for (int pi = 0; pi < Model.Phases.Count; pi++)
            {
                var ph = Model.Phases[pi];
                <div class="phase-block" id="ph-@pi"
                     style="border:.5px solid rgba(30,58,95,.15);border-radius:14px;margin-bottom:10px;overflow:hidden">
                    <div style="background:linear-gradient(135deg,rgba(30,58,95,.08),rgba(30,58,95,.04));padding:12px 16px">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <div style="width:28px;height:28px;border-radius:8px;background:#1e3a5f;color:#fff;font-size:.8rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                @(pi + 1)
                            </div>
                            <input name="Phases[@pi].Name" class="pp-input fw-semibold" style="flex:1;font-size:.9rem"
                                   value="@ph.Name" placeholder="اسم المرحلة"
                                   oninput="syncPhaseDropdowns()" />
                            <div class="d-flex align-items-center gap-1">
                                <span style="font-size:.78rem;color:#6b7d80">من شهر</span>
                                <input name="Phases[@pi].StartMonth" type="number" class="pp-input" style="width:52px"
                                       value="@ph.StartMonth" min="1" max="48" />
                                <span style="font-size:.78rem;color:#6b7d80">إلى</span>
                                <input name="Phases[@pi].EndMonth" type="number" class="pp-input" style="width:52px"
                                       value="@ph.EndMonth" min="1" max="48" />
                            </div>
                            <button type="button" class="del-btn"
                                    onclick="this.closest('.phase-block').remove();recalcPhaseNums();syncPhaseDropdowns()">
                                <i class="bx bx-trash"></i>
                            </button>
                        </div>
                        <textarea name="Phases[@pi].Description" class="pp-textarea" rows="1"
                                  placeholder="وصف المرحلة (اختياري)...">@ph.Description</textarea>
                    </div>
                </div>
            }
        }
    </div>
</div>

@* ══════════════════════ 5. الرصد والتقييم ══════════════════════ *@
<div class="pp-section">
    <div class="pp-head">
        <h6><i class="bx bx-bar-chart me-2"></i>خطة الرصد والتقييم</h6>
        <button type="button" class="add-row-btn" onclick="addRow('mon-body','mon-tpl')">
            <i class="bx bx-plus me-1"></i>إضافة مؤشر
        </button>
    </div>
    <div class="pp-body p-0">
        <table class="pp-table">
            <thead>
                <tr>
                    <th>النشاط</th>
                    <th>مؤشرات الأداء</th>
                    <th style="width:110px">المستهدف</th>
                    <th style="width:110px">المحقق</th>
                    <th>وسائل التحقق</th>
                    <th style="width:40px"></th>
                </tr>
            </thead>
            <tbody id="mon-body">
                @if (Model.MonitoringIndicators != null)
                {
                    for (int i = 0; i < Model.MonitoringIndicators.Count; i++)
                    {
                        <tr>
                            <td><input name="MonitoringIndicators[@i].ActivityTitle" class="pp-input" value="@Model.MonitoringIndicators[i].ActivityTitle" placeholder="النشاط" /></td>
                            <td><input name="MonitoringIndicators[@i].Indicator" class="pp-input" value="@Model.MonitoringIndicators[i].Indicator" placeholder="مؤشر الأداء" /></td>
                            <td><input name="MonitoringIndicators[@i].TargetValue" class="pp-input" value="@Model.MonitoringIndicators[i].TargetValue" placeholder="100%" /></td>
                            <td><input name="MonitoringIndicators[@i].AchievedValue" class="pp-input" value="@Model.MonitoringIndicators[i].AchievedValue" placeholder="—" /></td>
                            <td><input name="MonitoringIndicators[@i].VerificationMeans" class="pp-input" value="@Model.MonitoringIndicators[i].VerificationMeans" placeholder="كشف حضور — صور — فواتير" /></td>
                            <td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <template id="mon-tpl">
            <tr>
                <td><input name="MonitoringIndicators[__IDX__].ActivityTitle" class="pp-input" placeholder="النشاط" /></td>
                <td><input name="MonitoringIndicators[__IDX__].Indicator" class="pp-input" placeholder="مؤشر الأداء" /></td>
                <td><input name="MonitoringIndicators[__IDX__].TargetValue" class="pp-input" placeholder="100%" /></td>
                <td><input name="MonitoringIndicators[__IDX__].AchievedValue" class="pp-input" placeholder="—" /></td>
                <td><input name="MonitoringIndicators[__IDX__].VerificationMeans" class="pp-input" placeholder="وسائل التحقق" /></td>
                <td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>
            </tr>
        </template>
    </div>
</div>

@* ══════════════════════ 6. خبرات سابقة ══════════════════════ *@
<div class="pp-section">
    <div class="pp-head">
        <h6><i class="bx bx-award me-2"></i>الخبرات في مشاريع مماثلة</h6>
        <button type="button" class="add-row-btn" onclick="addRow('exp-body','exp-tpl')">

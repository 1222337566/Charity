
<script>
    // ══ كل دوال المقترح ══

    function addRow(bodyId, tplId) {
        var tbody = document.getElementById(bodyId);
        var tpl   = document.getElementById(tplId);
        if (!tbody || !tpl) return;
        var idx = tbody.querySelectorAll('tr').length;
        var html = tpl.innerHTML.replace(/__IDX__/g, String(idx));
        tbody.insertAdjacentHTML('beforeend', html);
    }
    function delRow(btn) { btn.closest('tr').remove(); }
    function addTargetGroup() { addRow('tgt-body','tgt-tpl'); }

    // ══ الأنشطة ══
    var actIdx = 0;
    var subCounts = {};
    document.addEventListener('DOMContentLoaded', function(){
        actIdx  = document.querySelectorAll('#activities-container .act-block').length;
        wpIdx   = document.querySelectorAll('#wp-body tr').length;
        phaseIdx= document.querySelectorAll('#phases-container .phase-block').length;
        document.querySelectorAll('select[data-val]').forEach(function(s){ s.value=s.dataset.val; });
        document.querySelectorAll('[id^="sub-body-"]').forEach(function(el){
            var ai = el.id.replace('sub-body-','');
            subCounts[ai] = el.querySelectorAll('.d-flex').length;
        });
        // تعبئة الـ dropdowns بالبيانات الموجودة عند فتح صفحة التعديل
        syncActivityDropdowns();
        syncPhaseDropdowns();
        syncObjectiveDropdowns();
    });
    function addActivity() {
        var html =
          '<div class="act-block" style="border:.5px solid rgba(14,111,115,.12);border-radius:12px;margin-bottom:10px;overflow:hidden">' +
            '<div style="background:rgba(14,111,115,.04);padding:10px 14px">' +
              '<div class="d-flex align-items-center gap-2 mb-2">' +
                '<span style="font-size:.75rem;font-weight:700;color:#0a5f63">عنوان النشاط *</span>' +
                '<input name="Activities['+actIdx+'].Title" class="pp-input fw-semibold act-title-inp" style="flex:1" placeholder="مثال: تنفيذ ورشات تدريبية" oninput="syncActivityDropdowns()"/>' +
                '<select name="Activities['+actIdx+'].Priority" class="pp-select" style="width:100px">' +
                  '<option value="Low">🟢 منخفض</option><option value="Medium" selected>🟡 متوسط</option>' +
                  '<option value="High">🟠 عالي</option><option value="Critical">🔴 حرج</option>' +
                '</select>' +
                '<button type="button" class="del-btn" onclick="this.closest(\'.act-block\').remove();syncActivityDropdowns()"><i class="bx bx-trash"></i></button>' +
              '</div>' +
              '<div class="d-flex gap-2 flex-wrap align-items-end">' +
                buildField('Activities['+actIdx+'].TargetGroup','الفئة المستهدفة','140px','text','شباب / مزارعون') +
                buildField('Activities['+actIdx+'].PlannedCount','الكمية المخططة','70px','number','0') +
                buildField('Activities['+actIdx+'].Responsible','الوحدة','65px','text','شخص') +
                buildField('Activities['+actIdx+'].PlannedStartMonth','مدة (أيام)','65px','number','0') +
                buildField('Activities['+actIdx+'].PlannedEndMonth','ساعات/يوم','65px','number','0') +
                buildField('Activities['+actIdx+'].ResponsibleRole','عدد الأنشطة','65px','number','1') +
              '</div>' +
              '<div class="d-flex gap-2 flex-wrap mt-2">' +
                '<div style="flex:1;min-width:180px"><div style="color:#6b7d80;margin-bottom:2px;font-size:.78rem">مؤشر الأداء</div><input name="Activities['+actIdx+'].Description" class="pp-input" placeholder="مثال: عدد حضور الندوات"/></div>' +
                '<div style="flex:1;min-width:180px"><div style="color:#6b7d80;margin-bottom:2px;font-size:.78rem">وسائل التحقق</div><input name="Activities['+actIdx+'].NeededResources" class="pp-input" placeholder="كشف حضور — صور — فواتير"/></div>' +
              '</div>' +
            '</div>' +
          '</div>';
        document.getElementById('activities-container').insertAdjacentHTML('beforeend', html);
        actIdx++;
    }
    function buildField(name,label,width,type,placeholder){
        return '<div style="display:flex;flex-direction:column;align-items:center;gap:2px">'+
            '<span style="color:#6b7d80;font-size:.75rem">'+label+'</span>'+
            '<input name="'+name+'" type="'+type+'" class="pp-input" style="width:'+width+';text-align:center" placeholder="'+placeholder+'"/>'+
        '</div>';
    }
    function addSubActivity(actI){
        if(!subCounts[actI]) subCounts[actI]=0;
        var j=subCounts[actI]++;
        var html='<div class="d-flex gap-2 mb-2">'+
            '<input name="Activities['+actI+'].SubActivities['+j+'].Title" class="pp-input" style="flex:1" placeholder="عنوان الفرعي"/>'+
            '<input name="Activities['+actI+'].SubActivities['+j+'].Count" type="number" class="pp-input" style="width:60px" placeholder="عدد"/>'+
            '<input name="Activities['+actI+'].SubActivities['+j+'].Unit" class="pp-input" style="width:70px" placeholder="وحدة"/>'+
            '<button type="button" class="del-btn" onclick="this.closest(\'.d-flex\').remove()"><i class="bx bx-x"></i></button>'+
        '</div>';
        document.getElementById('sub-body-'+actI)?.insertAdjacentHTML('beforeend',html);
    }

    // ══ مزامنة الـ dropdowns ══
    function syncActivityDropdowns(){
        var titles=[];
        document.querySelectorAll('.act-title-inp').forEach(function(i){ if(i.value.trim()) titles.push(i.value.trim()); });
        document.querySelectorAll('.wp-act-sel').forEach(function(sel){
            // احفظ القيمة الحالية أو خذها من data-selected لو أول تشغيل
            var cur = sel.value || sel.dataset.selected || '';
            sel.innerHTML='<option value="">-- النشاط --</option>';
            titles.forEach(function(t){ var o=document.createElement('option'); o.value=t; o.textContent=t; if(t===cur)o.selected=true; sel.appendChild(o); });
            // لو لم تُعين القيمة بعد، حاول تعيينها
            if(cur && sel.value !== cur){ sel.value = cur; }
        });
    }
    function syncPhaseDropdowns(){
        var names=[];
        document.querySelectorAll('#phases-container input[name$="].Name"]').forEach(function(i){ if(i.value.trim()) names.push(i.value.trim()); });
        document.querySelectorAll('.wp-phase-sel').forEach(function(sel){
            var cur = sel.value || sel.dataset.selected || '';
            sel.innerHTML='<option value="">-- المرحلة --</option>';
            names.forEach(function(n){ var o=document.createElement('option'); o.value=n; o.textContent=n; if(n===cur)o.selected=true; sel.appendChild(o); });
            if(cur && sel.value !== cur){ sel.value = cur; }
        });
    }
    function refreshActivitySelects(){ syncActivityDropdowns(); }
    function syncObjectiveDropdowns(){
        var titles=[];
        document.querySelectorAll('.obj-title-inp').forEach(function(i){ if(i.value.trim()) titles.push(i.value.trim()); });
        document.querySelectorAll('.wp-goal-sel').forEach(function(sel){
            var cur=sel.value || sel.dataset.selected || '';
            sel.innerHTML='<option value="">-- الهدف الفرعي --</option>';
            titles.forEach(function(t){ var o=document.createElement('option'); o.value=t; o.textContent=t; if(t===cur)o.selected=true; sel.appendChild(o); });
            if(cur && sel.value!==cur){ sel.value=cur; }
        });
    }

    // ══ خطة العمل: إضافة سطر ══
    var wpIdx=0;
    function addWpRow(){
        var tbody=document.getElementById('wp-body');
        var i=wpIdx++;
        var actTitles=[]; document.querySelectorAll('.act-title-inp').forEach(function(x){ if(x.value.trim()) actTitles.push(x.value.trim()); });
        var phaseNames=[]; document.querySelectorAll('#phases-container input[name$="].Name"]').forEach(function(x){ if(x.value.trim()) phaseNames.push(x.value.trim()); });
        var actOpts='<option value="">-- النشاط --</option>';
        actTitles.forEach(function(t){ actOpts+='<option value="'+t+'">'+t+'</option>'; });
        var phOpts='<option value="">-- المرحلة --</option>';
        phaseNames.forEach(function(n){ phOpts+='<option value="'+n+'">'+n+'</option>'; });
        var goalTitles=[]; document.querySelectorAll('.obj-title-inp').forEach(function(x){ if(x.value.trim()) goalTitles.push(x.value.trim()); });
        var goalOpts='<option value="">-- الهدف الفرعي --</option>';
        goalTitles.forEach(function(g){ goalOpts+='<option value="'+g+'">'+g+'</option>'; });
        var cells='';
        for(var m=1;m<=24;m++){ cells+='<div class="month-cell" onclick="toggleMonth(this,'+i+')" title="الشهر '+m+'">'+m+'</div>'; }
        var html='<tr>'+
            '<td><select name="WorkPlanItems['+i+'].ActivityTitle" class="pp-select wp-act-sel">'+actOpts+'</select></td>'+
            '<td><select name="WorkPlanItems['+i+'].PhaseName" class="pp-select wp-phase-sel">'+phOpts+'</select></td>'+
            '<td><div class="d-flex align-items-center gap-1"><input type="number" name="WorkPlanItems['+i+'].ContributionPercent" class="pp-input contrib-inp" style="width:54px;text-align:center" value="100" min="1" max="100" oninput="recalcWpBar(this)"/><span style="font-size:.8rem;color:#6b7d80">%</span></div></td>'+
            '<td><input type="number" name="WorkPlanItems['+i+'].PlannedQuantity" class="pp-input" style="text-align:center" placeholder="0"/></td>'+
            '<td><input type="number" name="WorkPlanItems['+i+'].DurationDays" class="pp-input" style="text-align:center" placeholder="0"/></td>'+
            '<td><select name="WorkPlanItems['+i+'].GoalTitle" class="pp-select wp-goal-sel">'+goalOpts+'</select></td>'+
            '<td><input name="WorkPlanItems['+i+'].Responsible" class="pp-input" placeholder="المسؤول"/></td>'+
            '<td><input name="WorkPlanItems['+i+'].Resources" class="pp-input" placeholder="الموارد"/></td>'+
            '<td>'+
              '<input type="hidden" name="WorkPlanItems['+i+'].StartMonth" class="wp-start" value="1"/>'+
              '<input type="hidden" name="WorkPlanItems['+i+'].EndMonth" class="wp-end" value="1"/>'+
              '<div class="month-grid">'+cells+'</div>'+
            '</td>'+
            '<td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>'+
        '</tr>';
        tbody.insertAdjacentHTML('beforeend',html);
    }

    // ══ مراحل المشروع ══
    var phaseIdx=0;
    function addPhaseBlock(){
        var pi=phaseIdx;
        var html=
          '<div class="phase-block" style="border:.5px solid rgba(30,58,95,.15);border-radius:14px;margin-bottom:10px;overflow:hidden">'+
            '<div style="background:linear-gradient(135deg,rgba(30,58,95,.08),rgba(30,58,95,.04));padding:12px 16px">'+
              '<div class="d-flex align-items-center gap-2 mb-2">'+
                '<div style="width:28px;height:28px;border-radius:8px;background:#1e3a5f;color:#fff;font-size:.8rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0">'+(pi+1)+'</div>'+
                '<input name="Phases['+pi+'].Name" class="pp-input fw-semibold" style="flex:1;font-size:.9rem" placeholder="اسم المرحلة" oninput="syncPhaseDropdowns()"/>'+
                '<span style="font-size:.78rem;color:#6b7d80">من شهر</span>'+
                '<input name="Phases['+pi+'].StartMonth" type="number" class="pp-input" style="width:52px" value="1"/>'+
                '<span style="font-size:.78rem;color:#6b7d80">إلى</span>'+
                '<input name="Phases['+pi+'].EndMonth" type="number" class="pp-input" style="width:52px" value="6"/>'+
                '<button type="button" class="del-btn" onclick="this.closest(\'.phase-block\').remove();recalcPhaseNums();syncPhaseDropdowns()"><i class="bx bx-trash"></i></button>'+
              '</div>'+
              '<textarea name="Phases['+pi+'].Description" class="pp-textarea" rows="1" placeholder="وصف المرحلة (اختياري)..."></textarea>'+
            '</div>'+
          '</div>';
        document.getElementById('phases-container').insertAdjacentHTML('beforeend',html);
        phaseIdx++;
        syncPhaseDropdowns();
    }
    function recalcPhaseNums(){
        document.querySelectorAll('#phases-container .phase-block').forEach(function(el,idx){
            var badge=el.querySelector('div[style*="background:#1e3a5f"]');
            if(badge) badge.textContent=idx+1;
        });
    }

    // ══ خطة العمل: تبديل الشهور ══
    function toggleMonth(cell,rowIdx){
        cell.classList.toggle('on');
        var row=cell.closest('tr');
        if(!row) return;
        var onCells=Array.from(row.querySelectorAll('.month-cell.on')).map(function(c){ return parseInt(c.textContent); });
        if(onCells.length===0){ row.querySelector('.wp-start')?.setAttribute('value',''); row.querySelector('.wp-end')?.setAttribute('value',''); return; }
        row.querySelector('.wp-start')?.setAttribute('value',Math.min.apply(null,onCells));
        row.querySelector('.wp-end')?.setAttribute('value',Math.max.apply(null,onCells));
    }
    function updateWorkPlanMonths(){}
    function recalcWpBar(inp){ /* optional: could show per-activity total */ }
</script>

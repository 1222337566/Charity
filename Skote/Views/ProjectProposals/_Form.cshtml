@* ══════════════════════ 1. البيانات الأساسية ══════════════════════ *@
<div class="pp-section">
    <div class="pp-head"><h6><i class="bx bx-info-circle me-2"></i>بيانات المقترح الأساسية</h6></div>
    <div class="pp-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="ProposalNumber" class="form-label fw-semibold" style="font-size:.82rem">رقم المقترح *</label>
                <input asp-for="ProposalNumber" class="pp-input" placeholder="مثال: PP-2025-001" />
                <span asp-validation-for="ProposalNumber" class="text-danger small"></span>
            </div>
            <div class="col-md-8">
                <label asp-for="Title" class="form-label fw-semibold" style="font-size:.82rem"></label>
                <input asp-for="Title" class="pp-input" placeholder="عنوان المشروع المقترح" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="DurationMonths" class="form-label fw-semibold" style="font-size:.82rem">مدة التنفيذ (شهر)</label>
                <input asp-for="DurationMonths" type="number" min="1" max="60" class="pp-input" placeholder="24" />
                <span asp-validation-for="DurationMonths" class="text-danger small"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="Status" class="form-label fw-semibold" style="font-size:.82rem"></label>
                <select asp-for="Status" class="pp-select">
                    <option value="Draft">مسودة</option>
                    <option value="UnderReview">قيد المراجعة</option>
                    <option value="Approved">معتمد</option>
                    <option value="Rejected">مرفوض</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="OrganizationName" class="form-label fw-semibold" style="font-size:.82rem"></label>
                <input asp-for="OrganizationName" class="pp-input" placeholder="اسم المنظمة المقدِّمة" />
                <span asp-validation-for="OrganizationName" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="DonorName" class="form-label fw-semibold" style="font-size:.82rem"></label>
                <input asp-for="DonorName" class="pp-input" placeholder="الجهة المانحة (GIZ, UNICEF...)" />
            </div>
            <div class="col-md-2">
                <label asp-for="RequestedBudget" class="form-label fw-semibold" style="font-size:.82rem"></label>
                <input asp-for="RequestedBudget" type="number" step="0.01" class="pp-input" placeholder="0.00" />
            </div>
            <div class="col-md-2">
                <label asp-for="Currency" class="form-label fw-semibold" style="font-size:.82rem"></label>
                <select asp-for="Currency" class="pp-select">
                    <option value="EGP">ج.م</option>
                    <option value="EUR">يورو</option>
                    <option value="USD">دولار</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="ProjectLocation" class="form-label fw-semibold" style="font-size:.82rem"></label>
                <input asp-for="ProjectLocation" class="pp-input" placeholder="قرى باقور، المطيعة — مركز أبوتيج، أسيوط" />
            </div>
            <div class="col-md-3">
                <label asp-for="SubmissionDate" class="form-label fw-semibold" style="font-size:.82rem"></label>
                <input asp-for="SubmissionDate" type="date" class="pp-input" />
            </div>
            <div class="col-md-3">
                <label asp-for="ContactPerson" class="form-label fw-semibold" style="font-size:.82rem">جهة الاتصال</label>
                <input asp-for="ContactPerson" class="pp-input" placeholder="اسم الشخص المسؤول" />
            </div>
            <div class="col-md-3">
                <label asp-for="ContactPhone" class="form-label fw-semibold" style="font-size:.82rem">الهاتف</label>
                <input asp-for="ContactPhone" class="pp-input" placeholder="01xxxxxxxxx" />
            </div>
            <div class="col-md-3">
                <label asp-for="ContactEmail" class="form-label fw-semibold" style="font-size:.82rem">البريد الإلكتروني</label>
                <input asp-for="ContactEmail" class="pp-input" placeholder="email@org.com" />
            </div>
            <div class="col-md-3">
                <label asp-for="Address" class="form-label fw-semibold" style="font-size:.82rem">العنوان</label>
                <input asp-for="Address" class="pp-input" placeholder="عنوان المنظمة" />
            </div>
            <div class="col-md-3">
                <label asp-for="RegistrationNumber" class="form-label fw-semibold" style="font-size:.82rem">رقم التسجيل</label>
                <input asp-for="RegistrationNumber" class="pp-input" placeholder="رقم التسجيل الرسمي" />
            </div>
            <div class="col-md-2">
                <label asp-for="RegistrationYear" class="form-label fw-semibold" style="font-size:.82rem">سنة التسجيل</label>
                <input asp-for="RegistrationYear" type="number" class="pp-input" placeholder="2010" />
            </div>
            <div class="col-md-2">
                <label asp-for="EmployeesCount" class="form-label fw-semibold" style="font-size:.82rem">عدد الموظفين</label>
                <input asp-for="EmployeesCount" type="number" class="pp-input" placeholder="0" />
            </div>
            <div class="col-md-2">
                <label asp-for="VolunteersCount" class="form-label fw-semibold" style="font-size:.82rem">عدد المتطوعين</label>
                <input asp-for="VolunteersCount" type="number" class="pp-input" placeholder="0" />
            </div>
            <div class="col-md-3">
                <label asp-for="YearsOfExperience" class="form-label fw-semibold" style="font-size:.82rem">سنوات الخبرة</label>
                <input asp-for="YearsOfExperience" type="number" class="pp-input" placeholder="0" />
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold" style="font-size:.82rem">الملخص التنفيذي للمشروع</label>

    </div>
    <div class="pp-body p-0">
        <table class="pp-table">
            <thead>
                <tr>
                    <th>اسم المشروع</th>
                    <th>الجهة المانحة</th>
                    <th style="width:80px">الميزانية</th>
                    <th style="width:110px">فترة التنفيذ</th>
                    <th>النتائج المحققة</th>
                    <th style="width:40px"></th>

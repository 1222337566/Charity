                            <td><input name="TargetGroups[@i].BenefitDescription" class="pp-input" value="@Model.TargetGroups[i].BenefitDescription" placeholder="وصف الاستفادة" /></td>
                            <td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <template id="tgt-tpl">
            <tr>
                <td><input name="TargetGroups[__IDX__].CategoryName" class="pp-input" placeholder="شباب / مزارعون..." /></td>
                <td><input name="TargetGroups[__IDX__].TargetCount" type="number" class="pp-input" style="text-align:center" placeholder="0" /></td>
                <td><input name="TargetGroups[__IDX__].AgeRange" class="pp-input" placeholder="18-35" /></td>
                <td><input name="TargetGroups[__IDX__].GenderNotes" class="pp-input" placeholder="ذكور/إناث" /></td>
                <td><input name="TargetGroups[__IDX__].SelectionCriteria" class="pp-input" placeholder="معايير الاختيار" /></td>
                <td><input name="TargetGroups[__IDX__].BenefitDescription" class="pp-input" placeholder="وصف الاستفادة" /></td>

                            <td><input name="TargetGroups[@i].AgeRange" class="pp-input" value="@Model.TargetGroups[i].AgeRange" placeholder="18-35" /></td>
                            <td><input name="TargetGroups[@i].GenderNotes" class="pp-input" value="@Model.TargetGroups[i].GenderNotes" placeholder="ذكور/إناث" /></td>

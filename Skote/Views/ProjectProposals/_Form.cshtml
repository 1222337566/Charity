                            <td><input name="PastExperiences[@i].Funder" class="pp-input" value="@Model.PastExperiences[i].Donor" placeholder="الجهة المانحة" /></td>
                            <td><input name="PastExperiences[@i].Budget" class="pp-input" value="@Model.PastExperiences[i].Budget" placeholder="الميزانية" /></td>
                            <td><input name="PastExperiences[@i].Period" class="pp-input" value="@Model.PastExperiences[i].DurationText" placeholder="2022 — عامان" /></td>
                            <td><input name="PastExperiences[@i].Results" class="pp-input" value="@Model.PastExperiences[i].ResultAchieved" placeholder="النتائج" /></td>
                            <td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        <template id="exp-tpl">
            <tr>
                <td><input name="PastExperiences[__IDX__].ProjectName" class="pp-input" placeholder="اسم المشروع" /></td>
                <td><input name="PastExperiences[__IDX__].Funder" class="pp-input" placeholder="الجهة المانحة" /></td>
                <td><input name="PastExperiences[__IDX__].Budget" class="pp-input" placeholder="الميزانية" /></td>
                <td><input name="PastExperiences[__IDX__].Period" class="pp-input" placeholder="الفترة" /></td>
                <td><input name="PastExperiences[__IDX__].Results" class="pp-input" placeholder="النتائج" /></td>
                <td><button type="button" class="del-btn" onclick="delRow(this)"><i class="bx bx-trash"></i></button></td>
            </tr>
        </template>
    </div>
</div>


@model List<InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.TaskUpdates.ProjectTaskDailyUpdateListItemVm>
@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")
<div class="card"><div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div><h4 class="mb-1">المتابعة اليومية للمهمة</h4><div class="text-muted">@ViewBag.TaskTitle</div></div>
        <a class="btn btn-primary" asp-action="Create" asp-route-taskId="@ViewBag.TaskId">إضافة متابعة</a>
    </div>
    <table class="table table-striped table-bordered align-middle">
        <thead><tr><th>التاريخ</th><th>الحالة</th><th>الإنجاز</th><th>الساعات</th><th>ما تم</th><th>المعوقات</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.UpdateDate.ToString("yyyy-MM-dd")</td>
                <td>@item.Status</td>
                <td>@item.ProgressPercent %</td>
                <td>@item.HoursSpent</td>
                <td>@item.Note</td>
                <td>@item.BlockerNote</td>
                <td><a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">تعديل</a></td>
            </tr>
        }
        </tbody>
    </table>
</div></div>

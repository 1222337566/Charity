@model InfrastructureManagmentWebFramework.Models.Charity.ProjectPlanning.Tasks.ProjectTaskBoardVm
@{
    ViewData["Title"] = "لوحة المهام Kanban";
    string PriorityColor(string p) => p switch {
        "Critical" => "#f46a6a", "High" => "#f1b44c",
        "Medium"   => "#556ee6", "Low"  => "#34c38f", _ => "#adb5bd"
    };
    string PriorityAr(string p) => p switch {
        "Critical" => "حرج", "High" => "عالي", "Medium" => "متوسط", "Low" => "منخفض", _ => p
    };
    string ColColor(string s) => s switch {
        "Done"       => "#34c38f", "InProgress" => "#556ee6",
        "InReview"   => "#f1b44c", "Blocked"    => "#f46a6a",
        _ => "#adb5bd"
    };
    string ColAr(string s) => s switch {
        "Todo"       => "للبدء",    "InProgress" => "جارٍ",
        "InReview"   => "للمراجعة", "Done"       => "مكتمل",
        "Blocked"    => "موقوف",    _ => s
    };
}

<style>
:root{--teal:#0e6f73}
.kb-wrap{display:flex;gap:14px;overflow-x:auto;padding:0 0 20px;align-items:flex-start;min-height:60vh}
.kb-col{flex:0 0 260px;border-radius:16px;background:#f4f6f9;overflow:hidden}
.kb-col-head{padding:12px 14px;font-size:.82rem;font-weight:700;display:flex;align-items:center;justify-content:space-between}
.kb-col-body{padding:8px;min-height:200px;max-height:75vh;overflow-y:auto}
.kb-card{background:#fff;border-radius:12px;border:.5px solid rgba(0,0,0,.07);padding:12px;margin-bottom:8px;box-shadow:0 1px 4px rgba(0,0,0,.05);cursor:grab;transition:box-shadow .15s}
.kb-card:hover{box-shadow:0 4px 14px rgba(0,0,0,.1)}
.kb-card.dragging{opacity:.5;box-shadow:0 8px 20px rgba(0,0,0,.15)}
.kb-col.drag-over .kb-col-body{background:rgba(14,111,115,.06)}
.prio-dot{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0}
.prog-bar{height:4px;border-radius:999px;background:#e2e8f0;overflow:hidden;margin-top:6px}
.prog-fill{height:100%;border-radius:999px}
.kb-stats{display:flex;gap:10px;margin-bottom:16px}
.kb-stat{background:#fff;border-radius:12px;border:.5px solid rgba(14,111,115,.12);padding:10px 16px;text-align:center;flex:1}
.kb-stat .n{font-size:1.2rem;font-weight:800;color:var(--teal)}
.kb-stat .l{font-size:.68rem;color:#6b7d80;margin-top:1px}
.tag{padding:2px 7px;border-radius:6px;font-size:.65rem;font-weight:700}
</style>

@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")

@* ── إشعارات ── *@
@if (Model.OverdueCount > 0)
{
    <div class="alert alert-danger alert-dismissible fade show py-2 mb-2" style="border-radius:12px;font-size:.83rem">
        <i class="bx bx-alarm me-1"></i>
        <strong>@Model.OverdueCount مهمة متأخرة</strong> — يرجى المراجعة
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (Model.NeedsFollowUpCount > 0)
{
    <div class="alert alert-warning alert-dismissible fade show py-2 mb-3" style="border-radius:12px;font-size:.83rem">
        <i class="bx bx-bell me-1"></i>
        <strong>@Model.NeedsFollowUpCount مهمة</strong> تحتاج متابعة اليوم
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

@* ── إحصائيات ── *@
<div class="kb-stats">
    @foreach (var col in Model.Columns)
    {
        <div class="kb-stat">
            <div class="n" style="color:@ColColor(col.Status)">@col.Tasks.Count</div>
            <div class="l">@ColAr(col.Status)</div>
        </div>
    }
    <div class="kb-stat">
        <div class="n">@Model.Columns.Sum(c => c.Tasks.Count)</div>
        <div class="l">إجمالي</div>
    </div>
</div>

@* ── Kanban Board ── *@
<div class="kb-wrap" id="kanbanBoard">
    @foreach (var col in Model.Columns)
    {
        <div class="kb-col" id="col-@col.Status"
             ondragover="allowDrop(event)"
             ondrop="drop(event,'@col.Status')"
             ondragenter="this.classList.add('drag-over')"
             ondragleave="this.classList.remove('drag-over')">

            <div class="kb-col-head" style="background:@ColColor(col.Status)18;border-bottom:2px solid @ColColor(col.Status)">
                <div class="d-flex align-items-center gap-2">
                    <div style="width:10px;height:10px;border-radius:50%;background:@ColColor(col.Status);flex-shrink:0"></div>
                    <span style="color:@ColColor(col.Status)">@ColAr(col.Status)</span>
                </div>
                <span class="badge" style="background:@ColColor(col.Status);font-size:.68rem">@col.Tasks.Count</span>
            </div>

            <div class="kb-col-body" id="body-@col.Status">
                @foreach (var task in col.Tasks.OrderBy(t => t.Priority == "Critical" ? 0 : t.Priority == "High" ? 1 : 2))
                {
                    <div class="kb-card"
                         id="card-@task.Id"
                         draggable="true"
                         ondragstart="drag(event,'@task.Id')"
                         ondragend="this.classList.remove('dragging')">

                        @* رأس البطاقة *@
                        <div class="d-flex align-items-start gap-2 mb-2">
                            <div class="prio-dot mt-1" style="background:@PriorityColor(task.Priority)"
                                 title="@PriorityAr(task.Priority)"></div>
                            <div class="fw-semibold flex-grow-1" style="font-size:.82rem;line-height:1.3">
                                @task.Title
                            </div>
                        </div>

                        @* Tags *@
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            <span class="tag" style="background:@PriorityColor(task.Priority)18;color:@PriorityColor(task.Priority)">
                                @PriorityAr(task.Priority)
                            </span>
                            @if (!string.IsNullOrEmpty(task.AssignedToName))
                            {
                                <span class="tag" style="background:rgba(85,110,230,.1);color:#3145a3">
                                    <i class="bx bx-user me-1"></i>@task.AssignedToName
                                </span>
                            }
                        </div>

                        @* شريط الإنجاز *@
                        @if (task.PercentComplete > 0)
                        {
                            <div class="prog-bar">
                                <div class="prog-fill"
                                     style="width:@task.PercentComplete%;background:@ColColor(col.Status)">
                                </div>
                            </div>
                            <div style="font-size:.68rem;color:#adb5bd;margin-top:2px">
                                @task.PercentComplete% مكتمل
                            </div>
                        }

                        @* الاستحقاق *@
                        @if (task.DueDate.HasValue)
                        {
                            var isLate = task.DueDate < DateTime.Today && col.Status != "Done";
                            <div style="font-size:.7rem;color:@(isLate?"#f46a6a":"#adb5bd");margin-top:4px">
                                <i class="bx bx-calendar me-1"></i>
                                @task.DueDate.Value.ToString("yyyy/MM/dd")
                                @(isLate ? " ⚠ متأخر" : "")
                            </div>
                        }

                        @* أزرار *@
                        <div class="d-flex gap-1 mt-2">
                            <a asp-controller="ProjectTaskDailyUpdates" asp-action="Index"
                               asp-route-taskId="@task.Id"
                               class="btn btn-sm flex-grow-1"
                               style="font-size:.72rem;padding:3px 8px;background:rgba(14,111,115,.08);color:var(--teal);border-radius:7px">
                                <i class="bx bx-calendar-check me-1"></i>متابعة
                            </a>
                            <a asp-controller="ProjectPhaseTasks" asp-action="Edit"
                               asp-route-id="@task.Id"
                               class="btn btn-sm"
                               style="font-size:.72rem;padding:3px 8px;background:#f0f4f8;color:#6b7d80;border-radius:7px">
                                <i class="bx bx-edit"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
// ── Drag & Drop ──
let draggedId = null;

function drag(e, taskId) {
    draggedId = taskId;
    document.getElementById('card-' + taskId)?.classList.add('dragging');
    e.dataTransfer.effectAllowed = 'move';
}
function allowDrop(e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; }

async function drop(e, newStatus) {
    e.preventDefault();
    const col = e.currentTarget;
    col.classList.remove('drag-over');
    if (!draggedId) return;

    const card = document.getElementById('card-' + draggedId);
    if (!card) return;

    // نقل البطاقة بصرياً
    document.getElementById('body-' + newStatus)?.appendChild(card);

    // تحديث الـ backend
    const token = document.querySelector('[name=__RequestVerificationToken]')?.value
                ?? document.cookie.split(';').find(c=>c.includes('RequestVerificationToken'))?.split('=')[1]?.trim() ?? '';

    try {
        await fetch('/ProjectPhaseTasks/UpdateStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${draggedId}&status=${encodeURIComponent(newStatus)}&__RequestVerificationToken=${encodeURIComponent(token)}`
        });
        // تحديث عداد الأعمدة
        updateColCounts();
    } catch(err) { console.error('Update failed', err); }

    draggedId = null;
}

function updateColCounts() {
    document.querySelectorAll('.kb-col').forEach(col => {
        const status = col.id.replace('col-','');
        const count  = col.querySelectorAll('.kb-card').length;
        const badge  = col.querySelector('.kb-col-head .badge');
        if (badge) badge.textContent = count;
    });
}
</script>
}

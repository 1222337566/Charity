@model InfrastructureManagmentWebFramework.Models.Charity.ProjectPlanning.Tasks.ProjectTaskBoardVm
@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")
<div class="row mb-3">
    <div class="col-md-6"><div class="alert alert-warning mb-0">المهام المتأخرة: <strong>@Model.OverdueCount</strong></div></div>
    <div class="col-md-6"><div class="alert alert-info mb-0">المهام التي تحتاج متابعة اليوم: <strong>@Model.NeedsFollowUpCount</strong></div></div>
</div>
<div class="row g-3">
@foreach (var col in Model.Columns)
{
    <div class="col-lg-3 col-md-6">
        <div class="card h-100"><div class="card-body">
            <h5 class="mb-3">@col.Status</h5>
            @foreach (var task in col.Tasks)
            {
                <div class="border rounded p-2 mb-2">
                    <div class="fw-semibold">@task.Title</div>
                    <div class="small text-muted">@task.AssignedToName - @task.Priority</div>
                    <div class="small">الإنجاز: @task.PercentComplete %</div>
                    <div class="small">الاستحقاق: @(task.DueDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="mt-2">
                        <a class="btn btn-sm btn-outline-primary" asp-controller="ProjectTaskDailyUpdates" asp-action="Index" asp-route-taskId="@task.Id">متابعة</a>
                    </div>
                </div>
            }
        </div></div>
    </div>
}
</div>

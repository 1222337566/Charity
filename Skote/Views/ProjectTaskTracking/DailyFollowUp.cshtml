@model InfrastructureManagmentWebFramework.Models.Charity.ProjectPlanning.Tasks.ProjectTaskDailyFollowUpVm
@await Html.PartialAsync("~/Views/Shared/Projects/_ProjectHeader.cshtml")
<div class="card"><div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">المتابعة اليومية للمشروع</h4>
        <form method="get" class="d-flex gap-2">
            <input type="hidden" name="projectId" value="@Model.ProjectHeader.Id" />
            <input type="date" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" class="form-control" />
            <button class="btn btn-primary">عرض</button>
        </form>
    </div>
    <table class="table table-striped table-bordered align-middle">
        <thead><tr><th>المرحلة</th><th>النشاط</th><th>المهمة</th><th>المسؤول</th><th>الحالة</th><th>إنجاز</th><th>ساعات اليوم</th><th>ملخص اليوم</th><th>تنبيه</th></tr></thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td>@row.PhaseName</td>
                <td>@row.ActivityTitle</td>
                <td>@row.TaskTitle</td>
                <td>@row.AssignedToName</td>
                <td>@row.Status</td>
                <td>@row.PercentComplete %</td>
                <td>@row.TodayHours</td>
                <td>@row.TodayNote</td>
                <td>@(row.MissingFollowUp ? "لم يتم تحديثها اليوم" : "-")</td>
            </tr>
        }
        </tbody>
    </table>
</div></div>

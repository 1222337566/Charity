@model Skote.Controllers.VerifyTeamMemberVm
@{
    ViewData["Title"] = "إثبات مشاركة عضو الفريق";
    var tm = ViewBag.TeamMember as InfrastrfuctureManagmentCore.Domains.Charity.Projects.ProjectTeamMember;
    var name = tm?.MemberType == "Employee" ? tm.Employee?.FullName : tm?.Volunteer?.FullName;
}
<div class="container-fluid"><div class="card"><div class="card-body" style="max-width:680px">
    <h5 class="fw-bold mb-4"><i class="bx bx-shield-check me-2 text-success"></i>إثبات مشاركة عضو الفريق</h5>

    @if (tm != null)
    {
        <div class="alert alert-light border mb-4 small">
            <div class="row g-1">
                <div class="col-6"><span class="text-muted">الاسم:</span> <strong>@name</strong></div>
                <div class="col-6"><span class="text-muted">النوع:</span>
                    <span class="badge @(tm.MemberType=="Employee"?"bg-primary":"bg-success")">
                        @(tm.MemberType=="Employee"?"موظف":"متطوع")
                    </span>
                </div>
                <div class="col-6"><span class="text-muted">الدور:</span> <strong>@tm.RoleTitle</strong></div>
                <div class="col-6"><span class="text-muted">النشاط:</span> <strong>@tm.Activity?.Title</strong></div>
            </div>
        </div>
    }

    <form asp-action="Verify" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="TeamMemberId" type="hidden" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="VerificationStatus" class="form-label fw-semibold">حالة الإثبات *</label>
                <select asp-for="VerificationStatus" class="form-select">
                    <option value="Unverified">غير مثبَّت</option>
                    <option value="Verified">مثبَّت ✓</option>
                    <option value="Rejected">مرفوض ✗</option>
                    <option value="NeedsReview">يحتاج مراجعة ⚠</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="VerificationDate" class="form-label fw-semibold">تاريخ الإثبات</label>
                <input asp-for="VerificationDate" type="date" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="ActualHours" class="form-label fw-semibold">الساعات الفعلية</label>
                <input asp-for="ActualHours" type="number" min="0" step="0.5" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="ActualDays" class="form-label fw-semibold">الأيام الفعلية</label>
                <input asp-for="ActualDays" type="number" min="0" class="form-control" />
            </div>
            <div class="col-12">
                <label asp-for="VerificationNotes" class="form-label fw-semibold">ملاحظات</label>
                <textarea asp-for="VerificationNotes" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-6">
                <label asp-for="AttachmentType" class="form-label fw-semibold">نوع المرفق</label>
                <select asp-for="AttachmentType" class="form-select">
                    <option value="AttendanceSheet">كشف الحضور</option>
                    <option value="Contract">عقد التطوع</option>
                    <option value="IdPhoto">صورة هوية</option>
                    <option value="Certificate">شهادة مشاركة</option>
                    <option value="Other">أخرى</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="NewAttachments" class="form-label fw-semibold">رفع مرفقات</label>
                <input asp-for="NewAttachments" type="file" class="form-control" multiple accept="image/*,.pdf" />
            </div>
        </div>
        <div class="mt-4 d-flex gap-2 border-top pt-3">
            <button type="submit" class="btn btn-success"><i class="bx bx-save me-1"></i>حفظ الإثبات</button>
            <a asp-action="Index" asp-route-projectId="@tm?.ProjectId" class="btn btn-light">رجوع</a>
        </div>
    </form>
</div></div></div>

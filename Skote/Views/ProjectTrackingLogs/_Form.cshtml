@model InfrastructureManagmentWebFramework.Models.Charity.ProjectProfile.Tracking.CreateProjectTrackingLogVm
<input type="hidden" asp-for="ProjectId" />
<div class="row g-3">
    <div class="col-md-4"><label asp-for="EntryDate" class="form-label"></label><input asp-for="EntryDate" type="date" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="EntryType" class="form-label"></label><select asp-for="EntryType" class="form-select"><option>Update</option><option>Issue</option><option>Decision</option><option>Risk</option><option>Achievement</option></select></div>
    <div class="col-md-4"><label asp-for="ProjectPhaseId" class="form-label"></label><select asp-for="ProjectPhaseId" class="form-select" asp-items="@(new SelectList((IEnumerable<SelectListItem>)ViewBag.PhaseOptions, "Value", "Text"))"><option value="">بدون مرحلة</option></select></div>
    <div class="col-md-8"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Status" class="form-label"></label><input asp-for="Status" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="ProgressPercent" class="form-label"></label><input asp-for="ProgressPercent" class="form-control" /></div>
    <div class="col-12"><label asp-for="Details" class="form-label"></label><textarea asp-for="Details" class="form-control" rows="4"></textarea></div>
    <div class="col-12 form-check ms-2"><input asp-for="RequiresAttention" class="form-check-input" /><label asp-for="RequiresAttention" class="form-check-label"></label></div>
</div>

@using InfrastructureManagmentWebFramework.Models.Purchase
@model CreatePurchaseInvoiceVm
@{ ViewData["Title"] = "إضافة فاتورة شراء / توريد"; }

<style>
.pi-hero{background:linear-gradient(135deg,#1e3a5f,#2d5282);border-radius:16px;padding:16px 22px;color:#fff;margin-bottom:18px}
.pi-card{background:#fff;border-radius:14px;border:.5px solid rgba(30,58,95,.1);box-shadow:0 2px 8px rgba(30,58,95,.05);margin-bottom:14px;overflow:hidden}
.pi-head{padding:11px 16px;border-bottom:.5px solid rgba(30,58,95,.07);font-size:.88rem;font-weight:700;color:#1e3a5f;background:rgba(30,58,95,.02)}
.pi-body{padding:16px}

/* Lines table */
.lines-table{width:100%;border-collapse:collapse;font-size:.84rem}
.lines-table th{padding:8px 10px;background:#f8fbfb;font-weight:700;color:#6b7d80;border-bottom:.5px solid rgba(30,58,95,.1);white-space:nowrap}
.lines-table td{padding:6px 8px;border-bottom:.5px solid rgba(30,58,95,.05);vertical-align:middle}
.lines-table tr:last-child td{border-bottom:none}
.lines-table input,.lines-table select{border-radius:7px;border:.5px solid rgba(30,58,95,.2);padding:5px 8px;font-size:.82rem;width:100%;background:#fff}
.lines-table input:focus,.lines-table select:focus{outline:none;border-color:#2d5282}
.line-total{font-weight:700;color:#1e3a5f;min-width:70px}
.del-btn{background:rgba(244,106,106,.1);color:#f46a6a;border:none;border-radius:6px;padding:4px 8px;cursor:pointer;font-size:.8rem}
.del-btn:hover{background:rgba(244,106,106,.2)}
.add-line-btn{background:rgba(30,58,95,.08);color:#1e3a5f;border:none;border-radius:9px;padding:7px 16px;font-size:.82rem;font-weight:600;cursor:pointer}
.add-line-btn:hover{background:rgba(30,58,95,.15)}

/* Totals */
.totals-row{background:#f8fbfb;border-top:.5px solid rgba(30,58,95,.1)}
.totals-row td{padding:8px 10px;font-weight:600}
.grand-total{font-size:1rem;font-weight:800;color:#1e3a5f}

/* Supplier search */
.supplier-search-wrap{position:relative}
.supplier-dropdown{position:absolute;top:100%;right:0;left:0;background:#fff;border-radius:10px;box-shadow:0 4px 16px rgba(30,58,95,.15);z-index:100;max-height:200px;overflow-y:auto;border:.5px solid rgba(30,58,95,.1);display:none}
.supplier-opt{padding:8px 12px;cursor:pointer;font-size:.83rem}
.supplier-opt:hover{background:rgba(30,58,95,.05)}
.supplier-opt .name{font-weight:600;color:#1e3a5f}
.supplier-opt .code{font-size:.72rem;color:#adb5bd}
</style>

<div class="pi-hero">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <h5 class="fw-bold mb-1 text-white"><i class="bx bx-cart-alt me-2"></i>إضافة فاتورة شراء / توريد</h5>
      <div style="opacity:.72;font-size:.8rem">المشتريات والتوريدات</div>
    </div>
    <a asp-action="Index" class="btn btn-light btn-sm fw-bold" style="border-radius:10px">← رجوع</a>
  </div>
</div>

<form asp-action="Create" method="post" id="inv-form">
  @Html.AntiForgeryToken()
  <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="border-radius:12px"></div>

  @* ── بيانات الفاتورة ── *@
  <div class="pi-card">
    <div class="pi-head"><i class="bx bx-file me-2"></i>بيانات الفاتورة</div>
    <div class="pi-body">
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">رقم الفاتورة</label>
          <input asp-for="InvoiceNumber" class="form-control" style="border-radius:10px"/>
          <span asp-validation-for="InvoiceNumber" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">تاريخ الفاتورة</label>
          <input asp-for="InvoiceDateUtc" type="datetime-local" class="form-control" style="border-radius:10px"
                 value="@Model.InvoiceDateUtc.ToString("yyyy-MM-ddTHH:mm")"/>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">رقم فاتورة المورد</label>
          <input asp-for="SupplierInvoiceNumber" class="form-control" style="border-radius:10px"
                 placeholder="اختياري"/>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">المخزن</label>
          <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select" style="border-radius:10px">
            <option value="">-- اختر المخزن --</option>
          </select>
          <span asp-validation-for="WarehouseId" class="text-danger small"></span>
        </div>
      </div>
    </div>
  </div>

  @* ── المورد ── *@
  <div class="pi-card">
    <div class="pi-head"><i class="bx bx-store me-2"></i>المورد</div>
    <div class="pi-body">
      <div class="row g-3">
        <div class="col-md-5">
          <label class="form-label fw-semibold" style="font-size:.83rem">اختر من قائمة الموردين</label>
          <select id="supplier-select" name="_supplierSelect"
                  class="form-select" style="border-radius:10px"
                  onchange="onSupplierSelect(this)">
            <option value="">-- اختر مورداً --</option>
            @if (Model.Suppliers.Any())
            {
              @foreach (var s in Model.Suppliers)
              { <option value="@s.Value" data-name="@s.Text">@s.Text</option> }
            }
          </select>
        </div>
        <div class="col-md-1 d-flex align-items-end justify-content-center" style="font-size:.8rem;color:#adb5bd;padding-bottom:8px">أو</div>
        <div class="col-md-4">
          <label class="form-label fw-semibold" style="font-size:.83rem">اسم المورد (يدوي)</label>
          <input asp-for="SupplierName" class="form-control" style="border-radius:10px"
                 placeholder="اسم المورد إذا لم يكن في القائمة"/>
          <input asp-for="SupplierId" type="hidden"/>
          <span asp-validation-for="SupplierName" class="text-danger small"></span>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <a asp-controller="Suppliers" asp-action="Create" target="_blank"
             class="btn btn-outline-primary btn-sm fw-bold w-100" style="border-radius:10px">
            <i class="bx bx-plus me-1"></i>مورد جديد
          </a>
        </div>
      </div>
    </div>
  </div>

  @* ── الربط بالمشروع ── *@
  <div class="pi-card">
    <div class="pi-head"><i class="bx bx-briefcase me-2"></i>الربط بالمشروعات والتمويل</div>
    <div class="pi-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold" style="font-size:.83rem">تصنيف العملية</label>
          <select asp-for="ProcurementCategory" class="form-select" style="border-radius:10px">
            <option value="">-- اختر التصنيف --</option>
            <option value="ProgramSupplies">مستلزمات برامج ومساعدات</option>
            <option value="OperationalSupplies">مستلزمات تشغيلية</option>
            <option value="AssetPurchase">أصل أو تجهيز</option>
            <option value="ServiceProcurement">خدمة أو تعاقد</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold" style="font-size:.83rem">المشروع المرتبط</label>
          <select asp-for="ProjectId" asp-items="Model.Projects" class="form-select" style="border-radius:10px">
            <option value="">-- بدون مشروع --</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold" style="font-size:.83rem">اتفاقية التمويل</label>
          <select asp-for="GrantAgreementId" asp-items="Model.GrantAgreements" class="form-select" style="border-radius:10px">
            <option value="">-- بدون اتفاقية --</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  @* ── سطور الفاتورة ── *@
  <div class="pi-card">
    <div class="pi-head d-flex justify-content-between align-items-center">
      <span><i class="bx bx-list-ul me-2"></i>سطور الفاتورة</span>
      <button type="button" class="add-line-btn" onclick="addLine()">
        <i class="bx bx-plus me-1"></i>إضافة سطر
      </button>
    </div>
    <div class="pi-body" style="padding:0;overflow-x:auto">
      <table class="lines-table">
        <thead>
          <tr>
            <th style="width:30%">الصنف</th>
            <th style="width:10%">الكمية</th>
            <th style="width:13%">سعر الوحدة</th>
            <th style="width:10%">الخصم</th>
            <th style="width:10%">الضريبة</th>
            <th style="width:12%">الإجمالي</th>
            <th style="width:5%"></th>
          </tr>
        </thead>
        <tbody id="lines-body">
          @for (int i = 0; i < Model.Lines.Count; i++)
          {
            <tr class="line-row" data-idx="@i">
              <td>
                <select name="Lines[@i].ItemId" class="item-select" onchange="calcLine(this)">
                  <option value="">-- اختر الصنف --</option>
                  @foreach (var item in Model.Lines[i].Items)
                  { <option value="@item.Value" sselected=@(item.Selected)>@item.Text</option> }
                </select>
              </td>
              <td><input type="number" name="Lines[@i].Quantity" value="@Model.Lines[i].Quantity" min="0" step="0.01" class="qty-input" onchange="calcLine(this)"/></td>
              <td><input type="number" name="Lines[@i].UnitCost" value="@Model.Lines[i].UnitCost" min="0" step="0.01" class="cost-input" onchange="calcLine(this)"/></td>
              <td><input type="number" name="Lines[@i].DiscountAmount" value="@Model.Lines[i].DiscountAmount" min="0" step="0.01" class="disc-input" onchange="calcLine(this)"/></td>
              <td><input type="number" name="Lines[@i].TaxAmount" value="@Model.Lines[i].TaxAmount" min="0" step="0.01" class="tax-input" onchange="calcLine(this)"/></td>
              <td class="line-total">@Model.Lines[i].LineTotal.ToString("N2")</td>
              <td><button type="button" class="del-btn" onclick="removeLine(this)">✕</button></td>
            </tr>
          }
        </tbody>
        <tfoot>
          <tr class="totals-row">
            <td colspan="5" style="text-align:left;padding:8px 10px;color:#6b7d80;font-size:.82rem">
              المجموع الفرعي
            </td>
            <td class="grand-total" id="subtotal-display">0.00</td>
            <td></td>
          </tr>
          <tr class="totals-row">
            <td colspan="5" style="text-align:left;padding:8px 10px;color:#6b7d80;font-size:.82rem">
              إجمالي الخصم
            </td>
            <td style="font-weight:700;color:#f46a6a" id="discount-display">0.00</td>
            <td></td>
          </tr>
          <tr class="totals-row">
            <td colspan="5" style="text-align:left;padding:8px 10px;color:#6b7d80;font-size:.82rem">
              إجمالي الضريبة
            </td>
            <td style="font-weight:700;color:#f1b44c" id="tax-display">0.00</td>
            <td></td>
          </tr>
          <tr style="background:#f0f4ff;border-top:.5px solid rgba(30,58,95,.15)">
            <td colspan="5" style="text-align:left;padding:10px;font-weight:800;font-size:.9rem;color:#1e3a5f">
              صافي الإجمالي
            </td>
            <td style="font-weight:800;font-size:1rem;color:#1e3a5f;padding:10px" id="net-display">0.00</td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  @* ── ملاحظات ── *@
  <div class="pi-card">
    <div class="pi-head"><i class="bx bx-notepad me-2"></i>ملاحظات</div>
    <div class="pi-body">
      <textarea asp-for="Notes" class="form-control" rows="2" style="border-radius:10px"
                placeholder="ملاحظات اختيارية..."></textarea>
    </div>
  </div>

  <div class="d-flex gap-2 mb-4">
    <button type="submit" class="btn btn-primary fw-bold" style="border-radius:12px;min-width:120px">
      <i class="bx bx-save me-1"></i>حفظ الفاتورة
    </button>
    <a asp-action="Index" class="btn btn-light fw-bold" style="border-radius:12px">إلغاء</a>
  </div>
</form>

@{
    var itemsJson = Newtonsoft.Json.JsonConvert.SerializeObject(
        Model.Lines.FirstOrDefault()?.Items?.Select(x => new { value = x.Value, text = x.Text })
    );
    var lineCountJson = Model.Lines.Count;
}

@section Scripts {
<partial name="_ValidationScriptsPartial"/>
<script>
var _items = @Html.Raw(itemsJson);
var _lineCount = @lineCountJson;

// ── مورد ──
function onSupplierSelect(sel) {
    var opt  = sel.options[sel.selectedIndex];
    var name = opt.dataset.name || opt.text;
    document.querySelector('[name="SupplierName"]').value = name || '';
    document.querySelector('[name="SupplierId"]').value   = sel.value;
}

// ── سطر جديد ──
function addLine() {
    var idx  = _lineCount++;
    var opts = _items.map(function(i){ return '<option value="'+i.value+'">'+i.text+'</option>'; }).join('');
    var row  = '<tr class="line-row" data-idx="'+idx+'">' +
        '<td><select name="Lines['+idx+'].ItemId" class="item-select" onchange="calcLine(this)"><option value="">-- اختر الصنف --</option>'+opts+'</select></td>' +
        '<td><input type="number" name="Lines['+idx+'].Quantity" value="1" min="0" step="0.01" class="qty-input" onchange="calcLine(this)"/></td>' +
        '<td><input type="number" name="Lines['+idx+'].UnitCost" value="0" min="0" step="0.01" class="cost-input" onchange="calcLine(this)"/></td>' +
        '<td><input type="number" name="Lines['+idx+'].DiscountAmount" value="0" min="0" step="0.01" class="disc-input" onchange="calcLine(this)"/></td>' +
        '<td><input type="number" name="Lines['+idx+'].TaxAmount" value="0" min="0" step="0.01" class="tax-input" onchange="calcLine(this)"/></td>' +
        '<td class="line-total">0.00</td>' +
        '<td><button type="button" class="del-btn" onclick="removeLine(this)">✕</button></td></tr>';
    document.getElementById('lines-body').insertAdjacentHTML('beforeend', row);
    calcTotals();
}

// ── حذف سطر ──
function removeLine(btn) {
    btn.closest('tr').remove();
    reindexLines();
    calcTotals();
}

// ── إعادة ترقيم ──
function reindexLines() {
    document.querySelectorAll('#lines-body tr.line-row').forEach(function(row, i) {
        row.querySelectorAll('[name]').forEach(function(el){
            el.name = el.name.replace(/Lines\[\d+\]/, 'Lines['+i+']');
        });
    });
    _lineCount = document.querySelectorAll('#lines-body tr.line-row').length;
}

// ── حساب سطر ──
function calcLine(el) {
    var row  = el.closest('tr');
    var qty  = parseFloat(row.querySelector('.qty-input')?.value)  || 0;
    var cost = parseFloat(row.querySelector('.cost-input')?.value) || 0;
    var disc = parseFloat(row.querySelector('.disc-input')?.value) || 0;
    var tax  = parseFloat(row.querySelector('.tax-input')?.value)  || 0;
    var tot  = qty * cost - disc + tax;
    row.querySelector('.line-total').textContent = tot.toFixed(2);
    calcTotals();
}

// ── إجماليات ──
function calcTotals() {
    var subtotal = 0, discount = 0, taxes = 0;
    document.querySelectorAll('#lines-body tr.line-row').forEach(function(row) {
        var qty  = parseFloat(row.querySelector('.qty-input')?.value)  || 0;
        var cost = parseFloat(row.querySelector('.cost-input')?.value) || 0;
        var disc = parseFloat(row.querySelector('.disc-input')?.value) || 0;
        var tax  = parseFloat(row.querySelector('.tax-input')?.value)  || 0;
        subtotal += qty * cost;
        discount += disc;
        taxes    += tax;
    });
    var net = subtotal - discount + taxes;
    document.getElementById('subtotal-display').textContent = subtotal.toFixed(2);
    document.getElementById('discount-display').textContent = discount.toFixed(2);
    document.getElementById('tax-display').textContent      = taxes.toFixed(2);
    document.getElementById('net-display').textContent      = net.toFixed(2);
}

// ── تحميل أولي ──
document.addEventListener('DOMContentLoaded', function() {
    calcTotals();
    // لو ما في سطور أضف سطر افتراضي
    if (document.querySelectorAll('#lines-body tr.line-row').length === 0) addLine();
});
</script>
}

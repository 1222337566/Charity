@model Skote.ViewModels.QaAudit.QaAuditIndexVm
@{
    ViewData["Title"] = "Sprint 41.1 - Routes Audit";

    string BadgeClass(string triage) => triage switch
    {
        "NeedsFix" => "bg-danger",
        "ManualCheck" => "bg-warning text-dark",
        "Ignore" => "bg-secondary",
        "Ready" => "bg-success",
        _ => "bg-info"
    };

    string TriageAr(string triage) => triage switch
    {
        "NeedsFix" => "يحتاج إصلاح",
        "ManualCheck" => "مراجعة يدوية",
        "Ignore" => "تجاهله الآن",
        "Ready" => "جاهز للتجربة",
        _ => triage
    };
}
<div class="container-fluid">
    <div class="row mb-3 g-3">
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">يحتاج إصلاح</div><div class="h4 mb-0">@Model.NeedsFixCount</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">مراجعة يدوية</div><div class="h4 mb-0">@Model.ManualCheckCount</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">تجاهله الآن</div><div class="h4 mb-0">@Model.IgnoreCount</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">جاهز للتجربة</div><div class="h4 mb-0">@Model.ReadyCount</div></div></div></div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0">Buttons & Routes Checklist</h4>
                <div class="small text-muted mt-1">ابدأ من "يحتاج إصلاح" ثم انتقل إلى "مراجعة يدوية". لا تستهلك وقتك في POST أو Download إلا بعد اختبار الشاشة الأساسية.</div>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-sm btn-outline-primary" asp-controller="QaAudit" asp-action="Index">الملخص</a>
                <a class="btn btn-sm btn-outline-primary" asp-controller="QaAudit" asp-action="Workflows">السيناريوهات</a>
            </div>
        </div>
        <div class="card-body">
            @foreach (var controller in Model.Controllers)
            {
                <div class="mb-4">
                    <h5 class="mb-2">@controller.ControllerName</h5>
                    <div class="small text-muted mb-2">
                        إجمالي Actions: @controller.ActionsCount |
                        جاهز: @controller.Actions.Count(x => x.TriageCategory == "Ready") |
                        يحتاج إصلاح: @controller.Actions.Count(x => x.TriageCategory == "NeedsFix") |
                        مراجعة يدوية: @controller.Actions.Count(x => x.TriageCategory == "ManualCheck")
                    </div>
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Action</th>
                                    <th>URL</th>
                                    <th>HTTP</th>
                                    <th>Parameters</th>
                                    <th>View</th>
                                    <th>التصنيف</th>
                                    <th>السبب</th>
                                    <th>الإجراء المقترح</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var action in controller.Actions)
                            {
                                <tr>
                                    <td>@action.ActionName</td>
                                    <td><code>@action.SuggestedUrl</code></td>
                                    <td>
                                        @if (action.IsHttpGet)
                                        {<span class="badge bg-info me-1">GET</span>}
                                        @if (action.IsHttpPost)
                                        {<span class="badge bg-secondary">POST</span>}
                                    </td>
                                    <td>
                                        @if (action.RequiresParameters)
                                        {
                                            <span>@action.ParametersDescription</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (action.ViewFileExists)
                                        {
                                            <span class="badge bg-success">Found</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Check</span>
                                        }
                                        <div class="small text-muted">@action.ExpectedViewPath</div>
                                    </td>
                                    <td><span class="badge @BadgeClass(action.TriageCategory)">@TriageAr(action.TriageCategory)</span></td>
                                    <td class="small">@action.TriageReason</td>
                                    <td class="small">@action.SuggestedNextStep</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@model Skote.ViewModels.QaAudit.QaAuditIndexVm
@{
    ViewData["Title"] = "Sprint 41 - Workflows";
}
<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Workflow Validation Plan</h4>
            <a class="btn btn-sm btn-outline-primary" asp-controller="QaAudit" asp-action="Index">الملخص</a>
        </div>
        <div class="card-body">
            <div class="accordion" id="workflowAccordion">
                @for (var i = 0; i < Model.Workflows.Count; i++)
                {
                    var wf = Model.Workflows[i];
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="heading-@i">
                            <button class="accordion-button @(i == 0 ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@i">
                                @wf.ModuleName - @wf.ScenarioTitle
                            </button>
                        </h2>
                        <div id="collapse-@i" class="accordion-collapse collapse @(i == 0 ? "show" : "")" data-bs-parent="#workflowAccordion">
                            <div class="accordion-body">
                                <div class="mb-3">
                                    <div class="fw-bold">Steps</div>
                                    <div>@wf.Steps</div>
                                </div>
                                <div>
                                    <div class="fw-bold">Expected Result</div>
                                    <div>@wf.ExpectedResult</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@using Microsoft.AspNetCore.Mvc.Rendering
@model Skote.Controllers.CompareVm
@{ ViewData["Title"] = "المقارنة الزمنية"; }
@{
    decimal Pct(decimal cur, decimal prev) => prev == 0 ? 0 : Math.Round((cur - prev) / prev * 100, 1);
    decimal PctI(int cur, int prev) => prev == 0 ? 0 : Math.Round((decimal)(cur - prev) / prev * 100, 1);
    string Arrow(decimal p) => p > 0 ? "↑" : p < 0 ? "↓" : "—";
    string ArrowColor(decimal p) => p > 0 ? "#34c38f" : p < 0 ? "#f46a6a" : "#adb5bd";

    var months = Enumerable.Range(1, 12)
        .Select(m => new { Val = m, Name = new DateTime(2000, m, 1).ToString("MMMM") }).ToList();
    var years  = Enumerable.Range(DateTime.Today.Year - 3, 5).ToList();
}

<style>
.cmp-hero{background:linear-gradient(135deg,#0a5659,#0e6f73);border-radius:18px;padding:20px 26px;color:#fff;margin-bottom:20px}
.cmp-card{background:#fff;border-radius:14px;border:.5px solid rgba(14,111,115,.12);overflow:hidden;box-shadow:0 2px 10px rgba(14,111,115,.05)}
.cmp-head{padding:12px 18px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.88rem;font-weight:700;color:#0a5f63}
.cmp-table{width:100%;border-collapse:collapse}
.cmp-table th{padding:10px 14px;font-size:.8rem;font-weight:700;color:#6b7d80;background:#f8fbfb;text-align:center}
.cmp-table th:first-child{text-align:right}
.cmp-table td{padding:10px 14px;font-size:.85rem;border-top:.5px solid rgba(14,111,115,.07);text-align:center}
.cmp-table td:first-child{text-align:right;font-weight:600;color:#15363a}
.cmp-table tr:hover td{background:rgba(14,111,115,.02)}
.arrow-badge{font-size:.72rem;font-weight:700;padding:2px 6px;border-radius:5px;margin-right:4px}
.period-selector select{border-radius:10px;border:.5px solid rgba(14,111,115,.2);padding:6px 12px;font-size:.85rem;outline:none}
</style>

<div class="cmp-hero mb-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
      <h4 class="mb-1 text-white fw-bold"><i class="bx bx-bar-chart-alt-2 me-2"></i>المقارنة الزمنية</h4>
      <div style="opacity:.75;font-size:.82rem">@Model.MonthName vs الشهر الماضي vs نفس الشهر السنة الماضية</div>
    </div>
    <form method="get" class="d-flex gap-2 period-selector flex-wrap">
      <select name="year" onchange="this.form.submit()"
              asp-items="@(new SelectList(years.Select(y => new { V = y.ToString(), T = y.ToString() }), "V", "T", Model.Year.ToString()))">
      </select>
      <select name="month" onchange="this.form.submit()"
              asp-items="@(new SelectList(months.Select(m => new { V = m.Val.ToString(), T = m.Name }), "V", "T", Model.Month.ToString()))">
      </select>
    </form>
  </div>
</div>

@{
    var prev = new DateTime(Model.Year, Model.Month, 1).AddMonths(-1);
    var yago = new DateTime(Model.Year - 1, Model.Month, 1);
}

<div class="cmp-card">
  <div class="cmp-head">📊 مقارنة مفصّلة — @Model.MonthName</div>
  <table class="cmp-table">
    <thead>
      <tr>
        <th>المؤشر</th>
        <th>@Model.MonthName <span style="opacity:.6">(الحالي)</span></th>
        <th>@prev.ToString("MMMM yyyy") <span style="opacity:.6">(الماضي)</span></th>
        <th>التغيير</th>
        <th>@yago.ToString("MMMM yyyy") <span style="opacity:.6">(السنة الماضية)</span></th>
        <th>التغيير السنوي</th>
      </tr>
    </thead>
    <tbody>
      @{
        void Row(string label, string icon, decimal cur, decimal prev2, decimal yago2, bool isMoney = false) {
          var pct1 = Pct(cur, prev2);
          var pct2 = Pct(cur, yago2);
          string fmt(decimal v) => isMoney ? v.ToString("N0") : v.ToString("N0");
        <tr>
          <td>@icon @label</td>
          <td><strong>@fmt(cur)</strong></td>
          <td class="text-muted">@fmt(prev2)</td>
          <td>
            <span class="arrow-badge" style="background:@(pct1 >= 0 ? "rgba(52,195,143,.15)" : "rgba(244,106,106,.15)");color:@ArrowColor(pct1)">
              @Arrow(pct1) @Math.Abs(pct1)%
            </span>
          </td>
          <td class="text-muted">@fmt(yago2)</td>
          <td>
            <span class="arrow-badge" style="background:@(pct2 >= 0 ? "rgba(52,195,143,.15)" : "rgba(244,106,106,.15)");color:@ArrowColor(pct2)">
              @Arrow(pct2) @Math.Abs(pct2)%
            </span>
          </td>
        </tr>
        }
      }
      @{ Row("مستفيدون جدد", "👤", Model.NewBeneficiaries, Model.NewBeneficiariesPrev, Model.NewBeneficiariesYAgo); }
      @{ Row("طلبات مساعدة", "📋", Model.AidRequests, Model.AidRequestsPrev, Model.AidRequestsYAgo); }
      @{ Row("صرف المساعدات", "💸", Model.AidDisbursed, Model.AidDisbursedPrev, Model.AidDisbursedYAgo, true); }
      @{ Row("التبرعات", "💰", Model.Donations, Model.DonationsPrev, Model.DonationsYAgo, true); }
      @{ Row("كفالات جديدة", "🤝", Model.NewKafalas, Model.NewKafalasPrev, Model.NewKafalasYAgo); }
      @{ Row("تحصيل الكفالات", "💳", Model.KafalaCollected, Model.KafalaCollectedPrev, Model.KafalaCollectedYAgo, true); }
      @{ Row("مشروعات جديدة", "🏗", Model.NewProjects, Model.NewProjectsPrev, Model.NewProjectsYAgo); }
    </tbody>
  </table>
</div>

@model InfrastructureManagmentWebFramework.Models.RfpReports.BeneficiariesPageVm
@{
    ViewData["Title"] = "تقرير المستفيدين";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>تقرير المستفيدين</h3>
    <a class="btn btn-outline-secondary" asp-action="ExportWord" asp-route-reportName="beneficiaries" asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")">تصدير Word</a>
</div>

<table class="table table-bordered table-striped">
    <thead><tr><th>الكود</th><th>الاسم</th><th>الرقم القومي</th><th>عدد الأسرة</th><th>الدخل الشهري</th><th>الحالة</th><th>التسجيل</th><th>الهاتف</th></tr></thead>
    <tbody>
    @foreach (var item in Model.Rows)
    {
        <tr><td>@item.Code</td><td>@item.FullName</td><td>@item.NationalId</td><td>@item.FamilyMembersCount</td><td>@item.MonthlyIncome.ToString("N2")</td><td>@item.StatusName</td><td>@item.RegistrationDate.ToString("yyyy-MM-dd")</td><td>@item.PhoneNumber</td></tr>
    }
    </tbody>
</table>

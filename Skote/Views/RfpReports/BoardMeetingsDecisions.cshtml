@model InfrastructureManagmentWebFramework.Models.RfpReports.BoardMeetingsDecisionsPageVm
@{
    ViewData["Title"] = "تقرير المحاضر والقرارات";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>تقرير المحاضر والقرارات</h3>
    <a class="btn btn-outline-secondary" asp-action="ExportWord" asp-route-reportName="boardmeetingsdecisions" asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")">تصدير Word</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3"><input type="date" class="form-control" asp-for="Filter.FromDate" /></div>
    <div class="col-md-3"><input type="date" class="form-control" asp-for="Filter.ToDate" /></div>
    <div class="col-md-3"><button class="btn btn-primary">عرض</button></div>
</form>

<table class="table table-bordered table-striped">
    <thead><tr><th>رقم الاجتماع</th><th>عنوان الاجتماع</th><th>تاريخ الاجتماع</th><th>رقم القرار</th><th>عنوان القرار</th><th>الحالة</th><th>الجهة المسؤولة</th><th>الاستحقاق</th></tr></thead>
    <tbody>
    @foreach (var item in Model.Rows)
    {
        <tr><td>@item.MeetingNumber</td><td>@item.MeetingTitle</td><td>@item.MeetingDate.ToString("yyyy-MM-dd")</td><td>@item.DecisionNumber</td><td>@item.DecisionTitle</td><td>@item.DecisionStatus</td><td>@item.ResponsibleParty</td><td>@item.DueDate?.ToString("yyyy-MM-dd")</td></tr>
    }
    </tbody>
</table>

@model InfrastructureManagmentWebFramework.Models.RfpReports.ExecutiveDashboardVm
@{
    ViewData["Title"] = "لوحة تنفيذية";
}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3"><input type="date" class="form-control" asp-for="Filter.FromDate" /></div>
    <div class="col-md-3"><input type="date" class="form-control" asp-for="Filter.ToDate" /></div>
    <div class="col-md-3"><button class="btn btn-primary">تحديث</button></div>
</form>

<div class="row g-3">
    <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><div class="text-muted">الموظفون</div><h3>@Model.Summary.EmployeesCount</h3><div>النشطون: @Model.Summary.ActiveEmployeesCount</div></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><div class="text-muted">المستفيدون</div><h3>@Model.Summary.BeneficiariesCount</h3><div>المعتمدون: @Model.Summary.ApprovedBeneficiariesCount</div></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><div class="text-muted">المساعدات الشهرية</div><h3>@Model.Summary.MonthlyAidDisbursementsCount</h3><div>@Model.Summary.MonthlyAidTotalAmount.ToString("N2") جنيه</div></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><div class="text-muted">المشروعات</div><h3>@Model.Summary.ProjectsCount</h3><div>الجارية: @Model.Summary.ActiveProjectsCount</div></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><div class="text-muted">الاجتماعات</div><h3>@Model.Summary.BoardMeetingsCount</h3></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card"><div class="card-body"><div class="text-muted">القرارات</div><h3>@Model.Summary.BoardDecisionsCount</h3></div></div></div>
</div>

@model InfrastructureManagmentWebFramework.Models.RfpReports.HrEmployeesPageVm
@{
    ViewData["Title"] = "تقرير الموظفين";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>تقرير الموظفين</h3>
    <a class="btn btn-outline-secondary" asp-action="ExportWord" asp-route-reportName="hremployees" asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")">تصدير Word</a>
</div>

<table class="table table-bordered table-striped">
    <thead><tr><th>الكود</th><th>الاسم</th><th>الإدارة</th><th>الوظيفة</th><th>تاريخ التعيين</th><th>نوع التعاقد</th><th>الأساسي</th><th>الحالة</th><th>الهاتف</th></tr></thead>
    <tbody>
    @foreach (var item in Model.Rows)
    {
        <tr><td>@item.Code</td><td>@item.FullName</td><td>@item.DepartmentName</td><td>@item.JobTitleName</td><td>@item.HireDate?.ToString("yyyy-MM-dd")</td><td>@item.EmploymentType</td><td>@item.BasicSalary.ToString("N2")</td><td>@item.Status</td><td>@item.PhoneNumber</td></tr>
    }
    </tbody>
</table>

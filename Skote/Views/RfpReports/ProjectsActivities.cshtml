@model InfrastructureManagmentWebFramework.Models.RfpReports.ProjectsActivitiesPageVm
@{
    ViewData["Title"] = "تقرير المشروعات والأنشطة";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>تقرير المشروعات والأنشطة</h3>
    <a class="btn btn-outline-secondary" asp-action="ExportWord" asp-route-reportName="projectsactivities" asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")">تصدير Word</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3"><input type="date" class="form-control" asp-for="Filter.FromDate" /></div>
    <div class="col-md-3"><input type="date" class="form-control" asp-for="Filter.ToDate" /></div>
    <div class="col-md-3"><button class="btn btn-primary">عرض</button></div>
</form>

<table class="table table-bordered table-striped">
    <thead><tr><th>كود المشروع</th><th>اسم المشروع</th><th>حالة المشروع</th><th>النشاط</th><th>حالة النشاط</th><th>التاريخ المخطط</th><th>التاريخ الفعلي</th><th>التكلفة المخططة</th><th>التكلفة الفعلية</th></tr></thead>
    <tbody>
    @foreach (var item in Model.Rows)
    {
        <tr><td>@item.ProjectCode</td><td>@item.ProjectName</td><td>@item.ProjectStatus</td><td>@item.ActivityTitle</td><td>@item.ActivityStatus</td><td>@item.PlannedDate?.ToString("yyyy-MM-dd")</td><td>@item.ActualDate?.ToString("yyyy-MM-dd")</td><td>@item.PlannedCost.ToString("N2")</td><td>@item.ActualCost.ToString("N2")</td></tr>
    }
    </tbody>
</table>

@model InfrastructureManagmentWebFramework.Models.Payroll.SalaryItems.EditSalaryItemDefinitionVm
@{ ViewData["Title"] = "تعديل بند مرتب"; }
<h4 class="mb-3">تعديل بند مرتب</h4>
<form asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <partial name="_Form" model="Model" />
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">حفظ</button>
        <a asp-action="Index" class="btn btn-light">رجوع</a>
    </div>
</form>

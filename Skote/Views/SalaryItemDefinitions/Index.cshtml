@model List<InfrastructureManagmentWebFramework.Models.Payroll.SalaryItems.SalaryItemDefinitionListItemVm>
@{
    ViewData["Title"] = "مفردات المرتب";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">مفردات المرتب</h4>
    <a asp-action="Create" class="btn btn-primary">إضافة بند</a>
</div>
<table class="table table-bordered table-striped align-middle">
    <thead><tr><th>الاسم</th><th>النوع</th><th>طريقة الحساب</th><th>القيمة الافتراضية</th><th>نشط</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.ItemType</td>
            <td>@item.CalculationMethod</td>
            <td>@(item.DefaultValue?.ToString("N2") ?? "-")</td>
            <td>@(item.IsActive ? "نعم" : "لا")</td>
            <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">تعديل</a></td>
        </tr>
    }
    </tbody>
</table>

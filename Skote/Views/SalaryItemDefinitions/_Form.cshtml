@model InfrastructureManagmentWebFramework.Models.Payroll.SalaryItems.CreateSalaryItemDefinitionVm
<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="ItemType" class="form-label"></label>
        <select asp-for="ItemType" asp-items="Model.ItemTypes" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="CalculationMethod" class="form-label"></label>
        <select asp-for="CalculationMethod" asp-items="Model.CalculationMethods" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="DefaultValue" class="form-label"></label>
        <input asp-for="DefaultValue" class="form-control" />
    </div>
    <div class="col-md-3 form-check mt-4 ms-3">
        <input asp-for="IsTaxable" class="form-check-input" />
        <label asp-for="IsTaxable" class="form-check-label"></label>
    </div>
    <div class="col-md-3 form-check mt-4 ms-3">
        <input asp-for="IsInsuranceIncluded" class="form-check-input" />
        <label asp-for="IsInsuranceIncluded" class="form-check-label"></label>
    </div>
    <div class="col-md-3 form-check mt-4 ms-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>
</div>

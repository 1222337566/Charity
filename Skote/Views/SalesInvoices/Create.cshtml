@using InfrastructureManagmentWebFramework.Models.Sale;
@model CreateSalesInvoiceVm

@{
    ViewData["Title"] = "إضافة فاتورة إيراد ذاتي / بيع";
}

<style>
    :root {
        --primary: #1a56db;
        --primary-dark: #1240a8;
        --primary-light: #ebf0ff;
        --accent: #0ea5e9;
        --success: #16a34a;
        --danger: #dc2626;
        --warning: #d97706;
        --surface: #ffffff;
        --surface-alt: #f8fafc;
        --border: #e2e8f0;
        --border-focus: #93c5fd;
        --text: #0f172a;
        --text-muted: #64748b;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
        --shadow-md: 0 4px 12px rgba(0,0,0,.08), 0 2px 6px rgba(0,0,0,.04);
        --radius: 10px;
        --radius-sm: 6px;
    }

    body { background: #f1f5f9; }

    .invoice-page { max-width: 1100px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }

    /* ── Header ── */
    .invoice-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 1.5rem;
        background: var(--surface);
        border-radius: var(--radius);
        padding: 1.25rem 1.5rem;
        box-shadow: var(--shadow-sm);
        border-top: 4px solid var(--primary);
    }
    .invoice-header-title { display: flex; align-items: center; gap: .75rem; }
    .invoice-header-icon {
        width: 44px; height: 44px; border-radius: 10px;
        background: var(--primary-light); color: var(--primary);
        display: flex; align-items: center; justify-content: center; font-size: 1.25rem;
    }
    .invoice-header h4 { margin: 0; font-size: 1.15rem; font-weight: 700; color: var(--text); }
    .invoice-header small { color: var(--text-muted); font-size: .78rem; }

    /* ── Card ── */
    .inv-card {
        background: var(--surface);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        margin-bottom: 1.25rem;
    }
    .inv-card-header {
        padding: .85rem 1.25rem;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: .6rem;
        background: var(--surface-alt);
        border-radius: var(--radius) var(--radius) 0 0;
    }
    .inv-card-header .section-icon {
        width: 28px; height: 28px; border-radius: 6px;
        background: var(--primary-light); color: var(--primary);
        display: flex; align-items: center; justify-content: center; font-size: .85rem;
    }
    .inv-card-header h6 { margin: 0; font-size: .9rem; font-weight: 700; color: var(--text); }
    .inv-card-body { padding: 1.25rem; }

    /* ── Form controls ── */
    .form-label { font-size: .8rem; font-weight: 600; color: var(--text-muted); margin-bottom: .35rem; display: block; }
    .form-control, .form-select {
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        padding: .5rem .75rem;
        font-size: .875rem;
        color: var(--text);
        background: var(--surface);
        transition: border-color .2s, box-shadow .2s;
        width: 100%;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26,86,219,.12);
        outline: none;
    }
    textarea.form-control { resize: vertical; min-height: 80px; }

    /* ── Info alert ── */
    .inv-info {
        background: #eff6ff; border: 1px solid #bfdbfe;
        border-radius: var(--radius-sm); padding: .75rem 1rem;
        color: #1e40af; font-size: .82rem; display: flex; gap: .5rem; align-items: flex-start;
        margin-bottom: 1.25rem;
    }
    .inv-info i { margin-top: .05rem; flex-shrink: 0; }

    /* ── Invoice lines table ── */
    .lines-table-wrapper { overflow-x: auto; border-radius: var(--radius-sm); border: 1px solid var(--border); }
    .lines-table { width: 100%; border-collapse: collapse; min-width: 750px; }
    .lines-table thead th {
        background: #f1f5f9; padding: .6rem .75rem;
        font-size: .75rem; font-weight: 700; color: var(--text-muted);
        text-align: right; white-space: nowrap; border-bottom: 1.5px solid var(--border);
    }
    .lines-table thead th:first-child { border-radius: var(--radius-sm) 0 0 0; }
    .lines-table thead th:last-child { border-radius: 0 var(--radius-sm) 0 0; }
    .lines-table tbody tr { transition: background .15s; }
    .lines-table tbody tr:hover { background: #f8fafc; }
    .lines-table tbody td { padding: .5rem .6rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .lines-table tbody tr:last-child td { border-bottom: none; }
    .lines-table .form-control, .lines-table .form-select {
        padding: .35rem .55rem; font-size: .82rem; min-width: 0;
    }
    .line-total { font-weight: 700; color: var(--primary); font-size: .85rem; white-space: nowrap; }
    .row-num {
        width: 28px; height: 28px; border-radius: 50%;
        background: var(--primary-light); color: var(--primary);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: .75rem; font-weight: 700;
    }
    .btn-remove-line {
        background: none; border: 1.5px solid #fca5a5; color: var(--danger);
        border-radius: var(--radius-sm); width: 28px; height: 28px;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; transition: background .15s, color .15s;
    }
    .btn-remove-line:hover { background: #fee2e2; }

    /* ── Lines footer (add btn + totals) ── */
    .lines-footer {
        display: flex; align-items: flex-start; justify-content: space-between;
        gap: 1rem; flex-wrap: wrap; margin-top: .85rem;
    }
    .btn-add-line {
        display: inline-flex; align-items: center; gap: .4rem;
        background: var(--primary-light); color: var(--primary);
        border: 1.5px dashed var(--primary); border-radius: var(--radius-sm);
        padding: .45rem .85rem; font-size: .82rem; font-weight: 600;
        cursor: pointer; transition: background .2s;
    }
    .btn-add-line:hover { background: #dbeafe; }

    /* ── Totals box ── */
    .totals-box {
        background: var(--surface-alt); border: 1px solid var(--border);
        border-radius: var(--radius-sm); padding: .85rem 1.1rem;
        min-width: 240px;
    }
    .totals-row { display: flex; justify-content: space-between; align-items: center; padding: .25rem 0; font-size: .83rem; color: var(--text-muted); }
    .totals-row.grand { border-top: 2px solid var(--border); margin-top: .35rem; padding-top: .5rem; font-size: .95rem; font-weight: 700; color: var(--text); }
    .totals-row.grand span:last-child { color: var(--primary); font-size: 1.05rem; }

    /* ── Action bar ── */
    .action-bar {
        display: flex; align-items: center; gap: .75rem; justify-content: flex-start;
        margin-top: 1.25rem; padding: 1rem 1.25rem;
        background: var(--surface); border-radius: var(--radius);
        box-shadow: var(--shadow-sm); border: 1px solid var(--border);
        flex-wrap: wrap;
    }
    .btn-save {
        background: var(--primary); color: #fff; border: none;
        border-radius: var(--radius-sm); padding: .6rem 1.5rem;
        font-size: .9rem; font-weight: 700; cursor: pointer;
        display: inline-flex; align-items: center; gap: .5rem;
        transition: background .2s, transform .1s;
        box-shadow: 0 2px 6px rgba(26,86,219,.3);
    }
    .btn-save:hover { background: var(--primary-dark); }
    .btn-save:active { transform: scale(.98); }
    .btn-back {
        background: var(--surface); color: var(--text-muted);
        border: 1.5px solid var(--border); border-radius: var(--radius-sm);
        padding: .6rem 1.25rem; font-size: .88rem; font-weight: 600;
        display: inline-flex; align-items: center; gap: .4rem;
        text-decoration: none; transition: border-color .2s, color .2s;
    }
    .btn-back:hover { border-color: var(--text-muted); color: var(--text); }

    /* ── Status badge ── */
    .status-badge {
        display: inline-flex; align-items: center; gap: .35rem;
        background: #dcfce7; color: #15803d;
        border-radius: 20px; padding: .25rem .75rem; font-size: .75rem; font-weight: 700;
    }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }

    @@media (max-width: 768px) {
        .invoice-header { flex-direction: column; align-items: flex-start; gap: .75rem; }
        .lines-footer { flex-direction: column; }
        .totals-box { width: 100%; }
    }
</style>

<div class="invoice-page" dir="rtl">

    <!-- ── Page Header ── -->
    <div class="invoice-header">
        <div class="invoice-header-title">
            <div class="invoice-header-icon"><i class="bi bi-receipt"></i></div>
            <div>
                <h4>إضافة فاتورة إيراد ذاتي / بيع</h4>
                <small>أدخل بيانات الفاتورة وأسطر البنود ثم احفظ</small>
            </div>
        </div>
        <span class="status-badge"><span class="status-dot"></span> مسودة جديدة</span>
    </div>

    <form asp-action="Create" method="post" id="invoiceForm">
        <input asp-for="CustomerId" type="hidden" id="CustomerIdHidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="inv-info">
            <i class="bi bi-info-circle-fill"></i>
            استخدم هذه الشاشة لإثبات الإيرادات الذاتية أو بيع المنتجات أو رسوم الخدمات، مع إمكانية تمييز العملية بمشروع أو اتفاقية تمويل عند الحاجة.
        </div>

        <!-- ── Section 1: Basic Info ── -->
        <div class="inv-card">
            <div class="inv-card-header">
                <span class="section-icon"><i class="bi bi-file-earmark-text"></i></span>
                <h6>البيانات الأساسية</h6>
            </div>
            <div class="inv-card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="InvoiceNumber" class="form-label"></label>
                        <input asp-for="InvoiceNumber" class="form-control" placeholder="رقم الفاتورة تلقائي" />
                        <span asp-validation-for="InvoiceNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="InvoiceDateUtc" class="form-label"></label>
                        <input asp-for="InvoiceDateUtc" type="datetime-local" class="form-control"
                               value="@(Model.InvoiceDateUtc.ToString("yyyy-MM-ddTHH:mm"))" />
                        <span asp-validation-for="InvoiceDateUtc" class="text-danger small"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="CustomerName" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="CustomerName" class="form-control" id="customerNameInput"
                                   placeholder="ابحث عن عميل..." autocomplete="off" />
                            <button type="button" class="btn btn-outline-secondary btn-sm px-2" id="clearCustomer" title="مسح">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                        <input asp-for="CustomerId" type="hidden" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="WarehouseId" class="form-label"></label>
                        <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select">
                            <option value="">-- اختر المخزن --</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Section 2: Classification ── -->
        <div class="inv-card">
            <div class="inv-card-header">
                <span class="section-icon"><i class="bi bi-tags"></i></span>
                <h6>التصنيف والربط</h6>
            </div>
            <div class="inv-card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="RevenueCategory" class="form-label"></label>
                        <select asp-for="RevenueCategory" class="form-select">
                            <option value="">-- اختر التصنيف --</option>
                            <option value="SelfRevenue">💰 إيراد ذاتي</option>
                            <option value="ServiceRevenue">🔧 رسوم خدمة</option>
                            <option value="ProductRevenue">📦 بيع منتجات</option>
                            <option value="EventRevenue">🎟️ إيراد فعالية</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ProjectId" class="form-label"></label>
                        <select asp-for="ProjectId" asp-items="Model.Projects" class="form-select">
                            <option value="">-- بدون مشروع --</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="GrantAgreementId" class="form-label"></label>
                        <select asp-for="GrantAgreementId" asp-items="Model.GrantAgreements" class="form-select">
                            <option value="">-- بدون اتفاقية --</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Section 3: Invoice Lines ── -->
        <div class="inv-card">
            <div class="inv-card-header">
                <span class="section-icon"><i class="bi bi-list-ul"></i></span>
                <h6>أسطر الفاتورة</h6>
            </div>
            <div class="inv-card-body">

                <div class="lines-table-wrapper">
                    <table class="lines-table" id="linesTable">
                        <thead>
                            <tr>
                                <th style="width:36px">#</th>
                                <th style="min-width:200px">الصنف / الوصف</th>
                                <th style="width:90px">الكمية</th>
                                <th style="width:110px">سعر الوحدة</th>
                                <th style="width:100px">الخصم</th>
                                <th style="width:100px">الضريبة</th>
                                <th style="width:110px">الإجمالي</th>
                                <th style="width:42px"></th>
                            </tr>
                        </thead>
                        <tbody id="linesBody">
                            @for (int i = 0; i < Model.Lines.Count; i++)
                            {
                                <tr class="line-row" data-index="@i">
                                    <td><span class="row-num">@(i + 1)</span></td>
                                    <td>
                                        <select name="Lines[@i].ItemId" class="form-select item-select">
                                            <option value="">-- اختر الصنف --</option>
                                            @foreach (var item in Model.Lines[i].Items)
                                            {
                                                <option value="@item.Value" selected=@(item.Value == Model.Lines[i].ItemId.ToString() ? "selected" : "")>@item.Text</option>
                                            }
                                        </select>
                                    </td>
                                    <td><input name="Lines[@i].Quantity" class="form-control line-qty" type="number" min="0" step="0.01" value="@Model.Lines[i].Quantity" /></td>
                                    <td><input name="Lines[@i].UnitPrice" class="form-control line-price" type="number" min="0" step="0.01" value="@Model.Lines[i].UnitPrice" /></td>
                                    <td><input name="Lines[@i].DiscountAmount" class="form-control line-discount" type="number" min="0" step="0.01" value="@Model.Lines[i].DiscountAmount" /></td>
                                    <td><input name="Lines[@i].TaxAmount" class="form-control line-tax" type="number" min="0" step="0.01" value="@Model.Lines[i].TaxAmount" /></td>
                                    <td><span class="line-total">0.00</span></td>
                                    <td>
                                        <button type="button" class="btn-remove-line" title="حذف السطر">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Footer: add line + totals -->
                <div class="lines-footer">
                    <button type="button" class="btn-add-line" id="addLineBtn">
                        <i class="bi bi-plus-circle"></i> إضافة سطر جديد
                    </button>

                    <div class="totals-box">
                        <div class="totals-row"><span>المجموع الفرعي</span><span id="subtotalDisplay">0.00</span></div>
                        <div class="totals-row"><span>إجمالي الخصومات</span><span id="discountDisplay" class="text-danger">- 0.00</span></div>
                        <div class="totals-row"><span>إجمالي الضرائب</span><span id="taxDisplay">0.00</span></div>
                        <div class="totals-row grand"><span>الإجمالي الكلي</span><span id="grandTotalDisplay">0.00</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Section 4: Notes & Payment ── -->
        <div class="inv-card">
            <div class="inv-card-header">
                <span class="section-icon"><i class="bi bi-chat-text"></i></span>
                <h6>ملاحظات وبيانات إضافية</h6>
            </div>
            <div class="inv-card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">طريقة الدفع</label>
                        <select name="PaymentMethod" class="form-select">
                            <option value="">-- اختر --</option>
                            <option value="Cash">نقداً</option>
                            <option value="BankTransfer">تحويل بنكي</option>
                            <option value="Check">شيك</option>
                            <option value="Credit">آجل</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">تاريخ الاستحقاق</label>
                        <input type="date" name="DueDate" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">المرجع الخارجي</label>
                        <input type="text" name="ExternalRef" class="form-control" placeholder="رقم أمر الشراء أو المرجع..." />
                    </div>
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="أضف أي ملاحظات تتعلق بالفاتورة..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Action Bar ── -->
        <div class="action-bar">
            <button type="submit" class="btn-save">
                <i class="bi bi-check2-circle"></i> حفظ الفاتورة
            </button>
            <button type="submit" name="saveAndPrint" value="true" class="btn btn-outline-primary btn-sm d-inline-flex align-items-center gap-1">
                <i class="bi bi-printer"></i> حفظ وطباعة
            </button>
            <a asp-action="Index" class="btn-back">
                <i class="bi bi-arrow-right"></i> رجوع
            </a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // ── Items list passed from server (to populate new rows) ──
        const serverItems = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
            Model.Lines.Count > 0 ? Model.Lines[0].Items.Select(x => new { value = x.Value, text = x.Text }) : Enumerable.Empty<object>()
        ));

        let lineCount = @Model.Lines.Count;

        // ── Compute totals ──
        function calcLineTotals() {
            let subtotal = 0, discountSum = 0, taxSum = 0;

            document.querySelectorAll('#linesBody .line-row').forEach(row => {
                const qty = parseFloat(row.querySelector('.line-qty')?.value) || 0;
                const price = parseFloat(row.querySelector('.line-price')?.value) || 0;
                const disc = parseFloat(row.querySelector('.line-discount')?.value) || 0;
                const tax = parseFloat(row.querySelector('.line-tax')?.value) || 0;
                const lineTotal = (qty * price) - disc + tax;
                row.querySelector('.line-total').textContent = lineTotal.toFixed(2);
                subtotal += qty * price;
                discountSum += disc;
                taxSum += tax;
            });

            const grand = subtotal - discountSum + taxSum;
            document.getElementById('subtotalDisplay').textContent = subtotal.toFixed(2);
            document.getElementById('discountDisplay').textContent = '- ' + discountSum.toFixed(2);
            document.getElementById('taxDisplay').textContent = taxSum.toFixed(2);
            document.getElementById('grandTotalDisplay').textContent = grand.toFixed(2);
        }

        // ── Re-number rows ──
        function renumberRows() {
            document.querySelectorAll('#linesBody .line-row').forEach((row, i) => {
                row.dataset.index = i;
                row.querySelector('.row-num').textContent = i + 1;
                // Re-name inputs
                row.querySelectorAll('input, select').forEach(el => {
                    if (el.name) el.name = el.name.replace(/Lines\[\d+\]/, `Lines[${i}]`);
                });
            });
            lineCount = document.querySelectorAll('#linesBody .line-row').length;
        }

        // ── Build select options HTML ──
        function buildItemOptions() {
            let opts = '<option value="">-- اختر الصنف --</option>';
            serverItems.forEach(it => { opts += `<option value="${it.value}">${it.text}</option>`; });
            return opts;
        }

        // ── Add new line ──
        document.getElementById('addLineBtn').addEventListener('click', () => {
            const idx = lineCount;
            const tr = document.createElement('tr');
            tr.className = 'line-row';
            tr.dataset.index = idx;
            tr.innerHTML = `
                <td><span class="row-num">${idx + 1}</span></td>
                <td><select name="Lines[${idx}].ItemId" class="form-select item-select">${buildItemOptions()}</select></td>
                <td><input name="Lines[${idx}].Quantity" class="form-control line-qty" type="number" min="0" step="0.01" value="1" /></td>
                <td><input name="Lines[${idx}].UnitPrice" class="form-control line-price" type="number" min="0" step="0.01" value="0" /></td>
                <td><input name="Lines[${idx}].DiscountAmount" class="form-control line-discount" type="number" min="0" step="0.01" value="0" /></td>
                <td><input name="Lines[${idx}].TaxAmount" class="form-control line-tax" type="number" min="0" step="0.01" value="0" /></td>
                <td><span class="line-total">0.00</span></td>
                <td><button type="button" class="btn-remove-line" title="حذف"><i class="bi bi-trash3"></i></button></td>`;
            document.getElementById('linesBody').appendChild(tr);
            lineCount++;
            attachLineEvents(tr);
            calcLineTotals();
            tr.querySelector('.item-select').focus();
        });

        // ── Remove line (delegate) ──
        document.getElementById('linesBody').addEventListener('click', e => {
            const btn = e.target.closest('.btn-remove-line');
            if (!btn) return;
            const rows = document.querySelectorAll('#linesBody .line-row');
            if (rows.length <= 1) { alert('يجب أن تحتوي الفاتورة على سطر واحد على الأقل.'); return; }
            btn.closest('tr').remove();
            renumberRows();
            calcLineTotals();
        });

        // ── Attach calc events to a row ──
        function attachLineEvents(row) {
            row.querySelectorAll('.line-qty, .line-price, .line-discount, .line-tax').forEach(el => {
                el.addEventListener('input', calcLineTotals);
            });
        }

        // ── Attach events to existing rows ──
        document.querySelectorAll('#linesBody .line-row').forEach(attachLineEvents);

        // ── Initial calc ──
        calcLineTotals();

        // ── Clear customer ──
        document.getElementById('clearCustomer')?.addEventListener('click', () => {
            document.getElementById('customerNameInput').value = '';
            document.getElementById('CustomerIdHidden').value = '';
        });
    </script>

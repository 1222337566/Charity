@using InfrastructureManagmentCore.Models.Print;
@model ReceiptPrintVm
@{
    Layout = null;
    var invoice = Model.Invoice;
    var company = Model.Company;
}
@{
    Layout = null;
    var subtotal = invoice.SubTotal;
    var discount = invoice.DiscountAmount;
    var tax = invoice.TaxAmount;
    var net = invoice.NetAmount;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>طباعة فاتورة</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Tahoma, Arial, sans-serif;
            background: #fff;
        }

        .receipt {
            width: 80mm;
            margin: 0 auto;
            padding: 8px;
            color: #000;
            font-size: 12px;
            line-height: 1.5;
        }

        .text-center {
            text-align: center;
        }

        .mb-1 { margin-bottom: 4px; }
        .mb-2 { margin-bottom: 8px; }
        .mt-2 { margin-top: 8px; }

        .title {
            font-size: 16px;
            font-weight: bold;
        }

        .line {
            border-top: 1px dashed #000;
            margin: 8px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 2px 0;
            vertical-align: top;
        }

        .qty, .price, .total {
            text-align: center;
            white-space: nowrap;
        }

        .summary td {
            padding: 3px 0;
        }

        .fw-bold {
            font-weight: bold;
        }

        @@media print {
            body {
                margin: 0;
            }

            .no-print {
                display: none;
            }

            .receipt {
                width: 80mm;
                margin: 0;
                padding: 0;
            }
        }
    </style>
</head>
<body>
    <div class="receipt">
        <div class="text-center mb-2">
            <div class="title">@(company?.CompanyNameAr ?? "اسم المنشأة")</div>

            @if (!string.IsNullOrWhiteSpace(company?.ReceiptHeaderText))
            {
                <div>@company.ReceiptHeaderText</div>
            }

            @if (!string.IsNullOrWhiteSpace(company?.Phone))
            {
                <div>تليفون: @company.Phone</div>
            }

            @if (!string.IsNullOrWhiteSpace(company?.Address))
            {
                <div>@company.Address</div>
            }

            @if (!string.IsNullOrWhiteSpace(company?.TaxNumber))
            {
                <div>الرقم الضريبي: @company.TaxNumber</div>
            }

            <div>فاتورة بيع</div>
        </div>
    </div>

        <div class="mb-1"><strong>رقم الفاتورة:</strong> @invoice.InvoiceNumber</div>
        <div class="mb-1"><strong>التاريخ:</strong> @invoice.InvoiceDateUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
        <div class="mb-1"><strong>العميل:</strong> @invoice.CustomerName</div>
        <div class="mb-1"><strong>المخزن:</strong> @(invoice.Warehouse?.WarehouseNameAr ?? "-")</div>

        <div class="line"></div>

        <table>
            <thead>
                <tr>
                    <th>الصنف</th>
                    <th class="qty">ك</th>
                    <th class="price">سعر</th>
                    <th class="total">إجمالي</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in invoice.Lines)
                {
                    <tr>
                        <td>
                            @(line.Item?.ItemNameAr ?? "-")
                        </td>
                        <td class="qty">@line.Quantity</td>
                        <td class="price">@line.UnitPrice</td>
                        <td class="total">@line.LineTotal</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="line"></div>

        <table class="summary">
            <tr>
                <td>الإجمالي</td>
                <td class="text-center">@subtotal</td>
            </tr>
            <tr>
                <td>الخصم</td>
                <td class="text-center">@discount</td>
            </tr>
            <tr>
                <td>الضريبة</td>
                <td class="text-center">@tax</td>
            </tr>
            <tr class="fw-bold">
                <td>الصافي</td>
                <td class="text-center">@net</td>
            </tr>
        </table>
    @if (invoice.Payments != null && invoice.Payments.Any())
    {
        <div class="line"></div>
        <div class="fw-bold mb-1">طرق الدفع</div>
        <table>
            <tbody>
                @foreach (var payment in invoice.Payments)
                {
                    <tr>
                        <td>@(payment.PaymentMethod?.MethodNameAr ?? "-")</td>
                        <td class="text-center">@payment.Amount</td>
                    </tr>
                }
            </tbody>
        </table>
    }
        @if (!string.IsNullOrWhiteSpace(invoice.Notes))
        {
            <div class="line"></div>
            <div><strong>ملاحظات:</strong> @invoice.Notes</div>
        }

        <div class="line"></div>

    <div class="text-center mt-2">
        @(!string.IsNullOrWhiteSpace(company?.ReceiptFooterText) ? company.ReceiptFooterText : "شكراً لتعاملكم معنا")
    </div>

        <div class="text-center mt-2 no-print">
            <button onclick="window.print()">طباعة</button>
            <button onclick="window.close()">إغلاق</button>
        </div>
    </div>

    <script>
        window.onload = function () {
            setTimeout(function () {
                window.print();
            }, 400);
        };
    </script>
</body>
</html>
@model SalesReportPageVm
@using InfrastructureManagmentWebFramework.Helpers
@using InfrastructureManagmentWebFramework.Models.Optics.Reports

@{
    ViewData["Title"] = "تقرير الإيرادات الذاتية";
}

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-header">
            <h4 class="mb-0">تقرير الإيرادات الذاتية</h4>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">من تاريخ</label>
                    <input asp-for="Filter.DateFrom" type="date" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">إلى تاريخ</label>
                    <input asp-for="Filter.DateTo" type="date" class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">العميل</label>
                    <select asp-for="Filter.CustomerId" asp-items="Model.Filter.Customers" class="form-select">
                        <option value="">-- كل العملاء --</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">المخزن</label>
                    <select asp-for="Filter.WarehouseId" asp-items="Model.Filter.Warehouses" class="form-select">
                        <option value="">-- كل المخازن --</option>
                    </select>
                </div>

                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Report != null)
    {
        <div class="row mb-3">
            <div class="col-xl-2 col-md-4">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted">عدد الفواتير</div>
                    <div class="fs-4 fw-bold">@Model.Report.InvoiceCount</div>
                </div>
            </div>

            <div class="col-xl-2 col-md-4">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted">إجمالي الصافي</div>
                    <div class="fs-4 fw-bold">@Model.Report.NetAmountTotal</div>
                </div>
            </div>

            <div class="col-xl-2 col-md-4">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted">إجمالي المدفوع</div>
                    <div class="fs-4 fw-bold">@Model.Report.TotalPaid</div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted">فواتير مرتبطة بروشتة</div>
                    <div class="fs-4 fw-bold">@Model.Report.PrescriptionInvoicesCount</div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted">أوامر الشغل</div>
                    <div class="fs-4 fw-bold">@Model.Report.WorkOrdersCount</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h4 class="mb-0">تفاصيل التقرير</h4>

                <button type="button" class="btn btn-dark btn-sm" onclick="window.print()">
                    طباعة
                </button>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>رقم الفاتورة</th>
                                <th>التاريخ</th>
                                <th>العميل</th>
                                <th>المخزن</th>
                                <th>التصنيف</th>
                                <th>المشروع</th>
                                <th>التمويل</th>
                                <th>Prescription</th>
                                <th>الصافي</th>
                                <th>المدفوع</th>
                                <th>طرق الدفع</th>
                                <th>أمر شغل</th>
                                <th>الإجراء</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Report.Rows.Any())
                            {
                                foreach (var item in Model.Report.Rows)
                                {
                                    var tags = CharityOperationNoteTags.Parse(item.Notes);
                                    <tr>
                                        <td>@item.InvoiceNumber</td>
                                        <td>@item.InvoiceDateUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                        <td>@item.CustomerName</td>
                                        <td>@item.WarehouseName</td>
                                        <td>@(string.IsNullOrWhiteSpace(tags.CategoryText) ? "-" : tags.CategoryText)</td>
                                        <td>@(string.IsNullOrWhiteSpace(tags.ProjectName) ? "-" : tags.ProjectName)</td>
                                        <td>@(string.IsNullOrWhiteSpace(tags.GrantAgreementNumber) ? "-" : tags.GrantAgreementNumber)</td>
                                        <td>@(item.PrescriptionText ?? "-")</td>
                                        <td>@item.NetAmount</td>
                                        <td>@item.TotalPaid</td>
                                        <td>@item.PaymentMethodsText</td>
                                        <td>@(item.WorkOrderNumber ?? "-")</td>
                                        <td>
                                            <div class="d-flex gap-1 flex-wrap">
                                                <a asp-controller="SalesInvoices" asp-action="PrintReceipt" asp-route-id="@item.SalesInvoiceId" class="btn btn-sm btn-primary">
                                                    طباعة
                                                </a>

                                                @if (item.HasWorkOrder && !string.IsNullOrWhiteSpace(item.WorkOrderNumber))
                                                {
                                                    <span class="badge bg-success align-self-center">له أمر شغل</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary align-self-center">بدون أمر شغل</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="13" class="text-center text-muted">لا توجد بيانات</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<style>
    @@media print {
        .btn, form, .card-header .btn {
            display: none !important;
        }

        body {
            background: #fff !important;
        }
    }
</style>
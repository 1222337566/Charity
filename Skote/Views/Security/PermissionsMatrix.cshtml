@model Skote.ViewModels.Security.PermissionsMatrixVm
@{
    ViewData["Title"] = "صلاحيات النظام";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0">صلاحيات النظام</h4>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">المستخدم الحالي</h5>
                    <p class="mb-2"><strong>الاسم:</strong> @Model.CurrentUserName</p>
                    <p class="mb-2"><strong>الأدوار:</strong> @(Model.CurrentUserRoles.Any() ? string.Join(" ، ", Model.CurrentUserRoles) : "لا يوجد")</p>
                    <p class="mb-0"><strong>الصلاحيات Claims:</strong> @(Model.CurrentUserPermissions.Any() ? string.Join(" ، ", Model.CurrentUserPermissions) : "لا يوجد")</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">ملاحظات</h5>
                    <ul class="mb-0">
                        <li>المشرف العام <code>Admin</code> يمر على كل الصلاحيات تلقائيًا.</li>
                        <li>كل Policy تسمح إمّا بدور مناسب أو Claim من النوع <code>permission</code>.</li>
                        <li>الـ sidebar والكنترولرات غير المعرّفة يدويًا أصبحت تعتمد على نفس خريطة السياسات بالأسفل.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">مصفوفة السياسات</h5>
            <div class="table-responsive">
                <table class="table table-bordered table-striped align-middle">
                    <thead>
                        <tr>
                            <th>المجموعة</th>
                            <th>Policy</th>
                            <th>Permission Claim</th>
                            <th>الأدوار الافتراضية</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Policies)
                    {
                        <tr>
                            <td>@item.Group</td>
                            <td><code>@item.PolicyName</code></td>
                            <td><code>@item.PermissionName</code></td>
                            <td>@item.DefaultRolesCsv</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">خريطة الربط بين الكنترولرات والصلاحيات</h5>
            <p class="text-muted">هذه الخريطة هي التي تُستخدم لإظهار الروابط في القائمة الجانبية، وكذلك لحماية الكنترولرات التي لم يُكتب عليها <code>[Authorize]</code> يدويًا.</p>
            <div class="table-responsive">
                <table class="table table-bordered table-striped align-middle">
                    <thead>
                        <tr>
                            <th>المجموعة</th>
                            <th>الكنترولر</th>
                            <th>الاسم الظاهر</th>
                            <th>سياسة العرض</th>
                            <th>سياسة الإدارة</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.ControllerAccesses)
                    {
                        <tr>
                            <td>@item.Group</td>
                            <td><code>@item.ControllerName</code></td>
                            <td>@item.DisplayName</td>
                            <td><code>@item.ViewPolicy</code></td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(item.ManagePolicy))
                                {
                                    <span class="text-muted">—</span>
                                }
                                else
                                {
                                    <code>@item.ManagePolicy</code>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

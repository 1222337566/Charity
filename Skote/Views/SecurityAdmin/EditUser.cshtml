@model Skote.ViewModels.Security.EditUserPermissionsVm
@{
    ViewData["Title"] = "تعديل صلاحيات المستخدم";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0">تعديل أدوار وصلاحيات المستخدم</h4>
                <div>
                    <a asp-action="Users" class="btn btn-light">الرجوع لقائمة المستخدمين</a>
                </div>
            </div>
        </div>
    </div>

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4"><strong>اسم المستخدم:</strong> @Model.UserName</div>
                <div class="col-md-4"><strong>الاسم الظاهر:</strong> @Model.DisplayName</div>
                <div class="col-md-4"><strong>البريد:</strong> @Model.Email</div>
            </div>
        </div>
    </div>

    <form asp-action="EditUser" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="UserId" type="hidden" />
        <input asp-for="UserName" type="hidden" />
        <input asp-for="DisplayName" type="hidden" />
        <input asp-for="Email" type="hidden" />

        <div class="row g-3">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">الأدوار</h5>
                        <p class="text-muted">يمكنك إسناد أكثر من دور للمستخدم.</p>

                        @for (int i = 0; i < Model.Roles.Count; i++)
                        {
                            <div class="form-check mb-2">
                                <input asp-for="Roles[i].Selected" class="form-check-input" />
                                <label class="form-check-label" asp-for="Roles[i].Selected">@Model.Roles[i].RoleName</label>
                                <input asp-for="Roles[i].RoleName" type="hidden" />
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">الصلاحيات المباشرة</h5>
                        <p class="text-muted">هذه الصلاحيات تضاف مباشرة للمستخدم كـ claims، وتُستخدم عند الحاجة لاستثناءات خاصة.</p>

                        <div class="row">
                            @for (int i = 0; i < Model.Permissions.Count; i++)
                            {
                                <div class="col-md-6 mb-2">
                                    <div class="form-check">
                                        <input asp-for="Permissions[i].Selected" class="form-check-input" />
                                        <label class="form-check-label" asp-for="Permissions[i].Selected">@Model.Permissions[i].DisplayName</label>
                                        <input asp-for="Permissions[i].Permission" type="hidden" />
                                        <input asp-for="Permissions[i].DisplayName" type="hidden" />
                                    </div>
                                    <div class="small text-muted">@Model.Permissions[i].Permission</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary">حفظ</button>
            <a asp-action="Users" class="btn btn-light">إلغاء</a>
        </div>
    </form>
</div>

@using Skote.Helpers
@{
    ViewData["Title"] = "إدارة الصلاحيات";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0">إدارة الصلاحيات</h4>
            </div>
        </div>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success">@ok</div>
    }

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">تهيئة الأدوار والصلاحيات الافتراضية</h5>
                    <p class="text-muted mb-3">
                        هذه العملية تنشئ أدوار الجمعية الأساسية، وتضيف لكل دور صلاحياته الافتراضية على شكل claims من النوع
                        <code>@CharityPermissions.Type</code>.
                    </p>
                    <form asp-action="SeedDefaults" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">تشغيل التهيئة الافتراضية</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">إدارة المستخدمين</h5>
                    <p class="text-muted mb-3">
                        من هذه الشاشة تستطيع مراجعة المستخدمين، وإسناد الأدوار، ومنح صلاحيات مباشرة لأي مستخدم عند الحاجة.
                    </p>
                    <a asp-action="Users" class="btn btn-outline-primary">فتح قائمة المستخدمين</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">الأدوار المقترحة</h5>
            <div class="row">
                @foreach (var role in CharityRoles.All)
                {
                    <div class="col-md-4 col-lg-3 mb-2">
                        <span class="badge bg-soft-primary text-primary fs-6">@role</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

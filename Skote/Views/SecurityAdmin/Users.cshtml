@model Skote.ViewModels.Security.SecurityUsersVm
@{
    ViewData["Title"] = "مستخدمو الصلاحيات";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box d-sm-flex align-items-center justify-content-between">
                <h4 class="mb-sm-0">المستخدمون والصلاحيات</h4>
                <div>
                    <a asp-action="Index" class="btn btn-light">الرجوع</a>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success">@ok</div>
    }

    <div class="card">
        <div class="card-body">
            <form method="get" class="row g-2 mb-3">
                <div class="col-md-4">
                    <input class="form-control" type="text" name="search" value="@Model.Search" placeholder="ابحث باسم المستخدم أو البريد أو الاسم الظاهر" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">بحث</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead>
                        <tr>
                            <th>اسم المستخدم</th>
                            <th>الاسم الظاهر</th>
                            <th>البريد</th>
                            <th>الأدوار</th>
                            <th>صلاحيات مباشرة</th>
                            <th style="width: 140px;">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Users.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">لا يوجد مستخدمون مطابقون.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.Users)
                            {
                                <tr>
                                    <td>@item.UserName</td>
                                    <td>@item.DisplayName</td>
                                    <td>@item.Email</td>
                                    <td>
                                        @if (item.Roles.Count == 0)
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                        else
                                        {
                                            @foreach (var role in item.Roles)
                                            {
                                                <span class="badge bg-soft-primary text-primary me-1">@role</span>
                                            }
                                        }
                                    </td>
                                    <td>
                                        @if (item.DirectPermissions.Count == 0)
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                        else
                                        {
                                            @foreach (var permission in item.DirectPermissions)
                                            {
                                                <span class="badge bg-soft-success text-success me-1">@permission</span>
                                            }
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="EditUser" asp-route-id="@item.UserId" class="btn btn-sm btn-primary">تعديل الصلاحيات</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

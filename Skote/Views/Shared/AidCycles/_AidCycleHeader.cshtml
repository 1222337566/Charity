<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h4 class="mb-1">@ViewBag.AidCycleNumber - @ViewBag.AidCycleTitle</h4>
                <div class="text-muted">الحالة: @ViewBag.AidCycleStatus</div>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="AidCycles" asp-action="Details" asp-route-id="@ViewBag.AidCycleId" class="btn btn-outline-secondary btn-sm">ملف الدورة</a>
                <a asp-controller="AidCycleBeneficiaries" asp-action="Index" asp-route-aidCycleId="@ViewBag.AidCycleId" class="btn btn-outline-secondary btn-sm">المستحقون</a>
                <a asp-controller="AidCycleBeneficiaries" asp-action="BatchDisburse" asp-route-aidCycleId="@ViewBag.AidCycleId" class="btn btn-primary btn-sm">صرف جماعي</a>
            </div>
        </div>
    </div>
</div>

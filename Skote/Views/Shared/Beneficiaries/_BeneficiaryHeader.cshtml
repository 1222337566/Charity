@using Skote.Helpers
@model InfrastructureManagmentWebFramework.Models.Charity.BeneficiaryProfile.Shared.BeneficiaryHeaderVm

@if (Model != null)
{
    var canManageBeneficiaries = User.HasCharityPermission(CharityPermissions.BeneficiariesManage);
    var canReviewResearch = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.ResearchReview);
    var canViewAidOps = User.IsInRole(CharityRoles.Admin) || User.HasCharityPermission(CharityPermissions.AidDisbursementView) || User.HasCharityPermission(CharityPermissions.AidDisbursementManage);
    var hasApprovedCommitteeDecision = ViewBag.HasApprovedCommitteeDecision is bool v ? v : true;
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h4 class="mb-1">@Model.FullName</h4>
                    <div class="text-muted small">
                        كود: @Model.Code |
                        الرقم القومي: @Model.NationalId |
                        الحالة: @Model.StatusName |
                        الهاتف: @Model.PhoneNumber
                    </div>
                </div>
            </div>

            <hr />

            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-secondary btn-sm" asp-controller="Beneficiaries" asp-action="Details" asp-route-id="@Model.Id">البيانات الأساسية</a>
                <a class="btn btn-outline-secondary btn-sm" asp-controller="BeneficiaryDocuments" asp-action="Index" asp-route-beneficiaryId="@Model.Id">المستندات</a>
                @if (canManageBeneficiaries || canReviewResearch)
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="BeneficiaryHumanitarianResearchs" asp-action="Index" asp-route-beneficiaryId="@Model.Id">استمارات البحث الإنساني</a>
                }
                @if (canManageBeneficiaries && hasApprovedCommitteeDecision)
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="BeneficiaryAidRequests" asp-action="Index" asp-route-beneficiaryId="@Model.Id">طلبات المساعدة</a>
                }
                @if (canViewAidOps && hasApprovedCommitteeDecision)
                {
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="BeneficiaryAidDisbursements" asp-action="Index" asp-route-beneficiaryId="@Model.Id">سجل الصرف</a>
                }
            </div>
        </div>
    </div>
}

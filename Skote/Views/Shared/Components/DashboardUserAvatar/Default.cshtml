@model DashboardUserAvatarViewComponent.Vm2
@{
    var size = (Model?.Size ?? "xl").ToLowerInvariant();
    // كلاس مقاس الصورة (Skote/Bootstrap) + fallback ستايل لضبط المقاس بالضبط
    var imgClass = size switch
    {
        "sm" => "avatar-sm",
        "md" => "avatar-md",
        "lg" => "avatar-lg",
        _ => "avatar-xl"
    };
    var px = size switch { "sm" => 40, "md" => 56, "lg" => 64, _ => 80 }; // أبعاد تقريبية
}
<div class="avatar-md profile-user-wid mb-4">
            <img 
                 src="@Model?.Photo"
                 alt="Avatar"
                 class="img-thumbnail rounded-circle" />
                 </div>
    <h5 class="font-size-15 text-truncate">@Model?.Name</h5>
    <p class="text-muted mb-0 text-truncate">@Model?.job</p>
        
        
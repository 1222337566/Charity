@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile
@model DonorHeaderVm
<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h4 class="mb-1">@Model.FullName</h4>
                <div class="text-muted">كود: @Model.Code | النوع: @Model.DonorType | الهاتف: @Model.PhoneNumber</div>
            </div>
            <div>
                <a asp-controller="Donors" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">تعديل</a>
            </div>
        </div>
        <hr />
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary btn-sm" asp-controller="Donors" asp-action="Details" asp-route-id="@Model.Id">البيانات الأساسية</a>
            <a class="btn btn-outline-secondary btn-sm" asp-controller="Donations" asp-action="Index" asp-route-donorId="@Model.Id">التبرعات</a>
            <a class="btn btn-outline-secondary btn-sm" asp-controller="Donations" asp-action="Create" asp-route-donorId="@Model.Id">تسجيل تبرع</a>
        </div>
    </div>
</div>

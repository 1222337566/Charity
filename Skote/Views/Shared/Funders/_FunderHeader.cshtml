@using InfrastructureManagmentWebFramework.Models.Charity.FunderProfile
@model FunderHeaderVm
<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h4 class="mb-1">@Model.Name</h4>
                <div class="text-muted small">
                    كود: @Model.Code |
                    النوع: @Model.FunderType |
                    مسؤول التواصل: @(string.IsNullOrWhiteSpace(Model.ContactPerson) ? "-" : Model.ContactPerson) |
                    الهاتف: @(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "-" : Model.PhoneNumber)
                </div>
            </div>
            <div>
                <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "نشط" : "غير نشط")</span>
            </div>
        </div>
        <hr />
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-primary btn-sm" asp-controller="Funders" asp-action="Details" asp-route-id="@Model.Id">الملف</a>
            <a class="btn btn-outline-primary btn-sm" asp-controller="GrantAgreements" asp-action="Index" asp-route-funderId="@Model.Id">الاتفاقيات</a>
        </div>
    </div>
</div>

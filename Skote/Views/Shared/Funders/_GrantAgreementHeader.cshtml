@using InfrastructureManagmentWebFramework.Models.Charity.FunderProfile
@model GrantAgreementHeaderVm
<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h4 class="mb-1">@Model.Title</h4>
                <div class="text-muted small">
                    الاتفاقية: @Model.AgreementNumber |
                    الممول: @Model.FunderName |
                    الحالة: @Model.Status |
                    القيمة: @Model.TotalAmount.ToString("N2") @Model.Currency
                </div>
            </div>
            <div>
                <a class="btn btn-outline-secondary btn-sm" asp-controller="GrantAgreements" asp-action="Index" asp-route-funderId="@Model.FunderId">رجوع للاتفاقيات</a>
            </div>
        </div>
        <hr />
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-primary btn-sm" asp-controller="GrantInstallments" asp-action="Index" asp-route-grantAgreementId="@Model.Id">الدفعات</a>
            <a class="btn btn-outline-primary btn-sm" asp-controller="GrantConditions" asp-action="Index" asp-route-grantAgreementId="@Model.Id">الشروط</a>
        </div>
    </div>
</div>

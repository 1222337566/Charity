@{
    Layout = null;
    var title = ViewData["Title"]?.ToString() ?? "تقرير";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <style>
        body { font-family: Tahoma, Arial, sans-serif; margin: 24px; color: #222; }
        h1,h2,h3,h4 { margin: 0 0 10px; }
        .meta { margin-bottom: 16px; color: #555; font-size: 13px; }
        .table { width: 100%; border-collapse: collapse; margin-top: 12px; }
        .table th, .table td { border: 1px solid #bbb; padding: 8px; font-size: 13px; }
        .table th { background: #f2f2f2; }
        .summary { display: flex; gap: 12px; margin: 12px 0; }
        .summary .box { border: 1px solid #ccc; padding: 10px 12px; min-width: 160px; }
        .text-center { text-align:center; }
        .text-start { text-align:right; }
        .fw-bold { font-weight:bold; }
        .mt-3 { margin-top: 16px; }
       /*  media print {
            .no-print { display:none !important; }
            body { margin: 0; }
        } */
    </style>
</head>
<body>
    <div class="no-print" style="margin-bottom:12px;">
        <button onclick="window.print()">طباعة</button>
        <button onclick="window.close()">إغلاق</button>
    </div>
    @RenderBody()
</body>
</html>

@using InfrastrfuctureManagmentCore.Domains.Charity.Volunteers
@{
    var volunteer = ViewBag.Volunteer as Volunteer;
}
@if (volunteer != null)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h4 class="mb-1">@volunteer.FullName</h4>
                    <div class="text-muted">
                        كود: @volunteer.VolunteerCode
                        @if (!string.IsNullOrWhiteSpace(volunteer.PhoneNumber))
                        {
                            <span> | الهاتف: @volunteer.PhoneNumber</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(volunteer.PreferredArea))
                        {
                            <span> | المجال: @volunteer.PreferredArea</span>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-controller="Volunteers" asp-action="Details" asp-route-id="@volunteer.Id" class="btn btn-outline-secondary btn-sm">الملف</a>
                    <a asp-controller="VolunteerProjectAssignments" asp-action="Index" asp-route-volunteerId="@volunteer.Id" class="btn btn-outline-primary btn-sm">الإسنادات</a>
                    <a asp-controller="VolunteerHourLogs" asp-action="Index" asp-route-volunteerId="@volunteer.Id" class="btn btn-outline-success btn-sm">الساعات</a>
                    <a asp-controller="VolunteerSkills" asp-action="Index" asp-route-volunteerId="@volunteer.Id" class="btn btn-outline-info btn-sm">المهارات</a>
<a asp-controller="VolunteerAvailabilitySlots" asp-action="Index" asp-route-volunteerId="@volunteer.Id" class="btn btn-outline-dark btn-sm">التوفر</a>
                
                </div>
            </div>
        </div>
    </div>
}

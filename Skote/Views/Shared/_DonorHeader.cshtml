@using InfrastructureManagmentWebFramework.Models.Charity.DonorProfile
@model DonorHeaderVm
<style>
.dh-hero{background:linear-gradient(135deg,#1a3c5e,#0e6f73);border-radius:18px;padding:14px 20px;color:#fff;margin-bottom:14px;position:relative;overflow:hidden}
.dh-hero::after{content:'';position:absolute;top:-40px;left:-40px;width:160px;height:160px;background:rgba(255,255,255,.04);border-radius:50%}
.dh-avatar{width:46px;height:46px;border-radius:12px;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.dh-code{background:rgba(255,255,255,.2);padding:2px 8px;border-radius:6px;font-size:.68rem;font-weight:700}
.dh-nav{display:flex;flex-wrap:wrap;gap:4px;padding:9px 14px;background:#fafbfc;border-bottom:.5px solid rgba(14,111,115,.07)}
.dh-btn{padding:4px 12px;border-radius:20px;font-size:.77rem;font-weight:600;text-decoration:none;color:#4a6080;border:.5px solid rgba(14,111,115,.12);background:#fff;transition:all .18s;white-space:nowrap}
.dh-btn:hover{background:rgba(14,111,115,.08);color:#0e6f73;border-color:rgba(14,111,115,.25)}
.dh-btn.active{background:#0e6f73;color:#fff;border-color:#0e6f73}
.dh-btn.success{background:rgba(52,195,143,.08);color:#1a7a55;border-color:rgba(52,195,143,.2)}
.dh-btn.success:hover,.dh-btn.success.active{background:#34c38f;color:#fff;border-color:#34c38f}
</style>
<div class="dh-hero">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        <div class="dh-avatar"><i class="bx bx-user"></i></div>
        <div class="flex-1">
            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                <span class="fw-bold" style="font-size:.97rem">@Model.FullName</span>
                <span class="dh-code">@Model.Code</span>
                @if(!string.IsNullOrEmpty(Model.DonorType)){<span style="background:rgba(255,255,255,.15);padding:1px 8px;border-radius:5px;font-size:.68rem">@Model.DonorType</span>}
            </div>
            @if(!string.IsNullOrEmpty(Model.PhoneNumber)){<div style="opacity:.8;font-size:.78rem"><i class="bx bx-phone me-1"></i>@Model.PhoneNumber</div>}
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Donors" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm" style="background:rgba(255,255,255,.2);color:#fff;border-radius:9px;font-size:.78rem">تعديل</a>
        </div>
    </div>
</div>
<div class="card mb-3" style="border-radius:14px;border:.5px solid rgba(14,111,115,.1);overflow:hidden;box-shadow:0 2px 10px rgba(14,111,115,.05)">
    <div class="dh-nav">
        @{ var ctrl=ViewContext.RouteData.Values["controller"]?.ToString()??""; }
        <a class="dh-btn @(ctrl=="Donors"?"active":"")" asp-controller="Donors" asp-action="Details" asp-route-id="@Model.Id"><i class="bx bx-user me-1"></i>البيانات</a>
        <a class="dh-btn @(ctrl=="Donations"?"active":"")" asp-controller="Donations" asp-action="Index" asp-route-donorId="@Model.Id"><i class="bx bx-gift me-1"></i>التبرعات</a>
        <a class="dh-btn success" asp-controller="Donations" asp-action="Create" asp-route-donorId="@Model.Id"><i class="bx bx-plus me-1"></i>تسجيل تبرع</a>
        <a class="dh-btn" asp-controller="DonationAllocations" asp-action="GeneralCreate"><i class="bx bx-transfer-alt me-1"></i>تخصيص عام نقدي</a>
        <a class="dh-btn" asp-controller="DonationAllocations" asp-action="InKindGeneralCreate"><i class="bx bx-package me-1"></i>تخصيص عام عيني</a>
    </div>
</div>

<!-- سكريبتنا -->
<script src="~/assets/js/realtime.js"></script>
 <script>
    (function () {
      const hubUrl = "https://localhost:5243/hubs/chat"; // مشروع SignalR
      const log = document.getElementById("log");
      const roomSel = document.getElementById("room");
      const userInp = document.getElementById("user");
      const msgInp  = document.getElementById("msg");
      const sendBtn = document.getElementById("send");
      const typingEl= document.getElementById("typing");

      const connection = new signalR.HubConnectionBuilder()
        .withUrl(hubUrl /* , { accessTokenFactory: () => "<JWT>" } */)
        .withAutomaticReconnect()
        .build();

      function append(msgHtml) {
        const div = document.createElement("div");
        div.innerHTML = msgHtml;
        log.appendChild(div);
        log.scrollTop = log.scrollHeight;
      }

      // استلام رسالة عامة (للRoom)
      connection.on("ReceiveMessage", payload => {
        const {room, user, message, at} = payload;
        append(`<small class="text-muted">${new Date(at).toLocaleTimeString()}</small>
                <b class="ms-2">[${room}] ${user}</b>: ${message}`);
      });

      // مؤشر الكتابة
      connection.on("UserTyping", ({room, user, isTyping}) => {
        if (isTyping) {
          typingEl.style.display = "inline";
          typingEl.textContent = `${user} is typing...`;
        } else {
          typingEl.style.display = "none";
        }
      });

      // رسالة خاصة (لو فعلتها)
      connection.on("ReceivePrivate", ({fromUser, message, at}) => {
        append(`<span class="badge bg-info me-2">Private</span>
                <small class="text-muted">${new Date(at).toLocaleTimeString()}</small>
                <b class="ms-2">${fromUser}</b>: ${message}`);
      });

      // اتصال
      async function start() {
        await connection.start();
        console.log("Connected");
        // انضم افتراضيًا للغرفة الحالية
        await connection.invoke("JoinRoom", roomSel.value);
        append(`<i class="text-success">Joined room: ${roomSel.value}</i>`);
      }

      // تبديل الغرفة
      roomSel.addEventListener("change", async () => {
        try {
          await connection.invoke("LeaveRoom", "general");
          await connection.invoke("LeaveRoom", "it");
          await connection.invoke("LeaveRoom", "security");
          await connection.invoke("JoinRoom", roomSel.value);
          append(`<i class="text-primary">Switched to room: ${roomSel.value}</i>`);
        } catch (e) { console.error(e); }
      });

      // إرسال رسالة
      sendBtn.addEventListener("click", async () => {
        const user = userInp.value?.trim() || "Guest";
        const message = msgInp.value?.trim();
        if (!message) return;
        try {
          await connection.invoke("SendToRoom", roomSel.value, user, message);
          msgInp.value = "";
          await connection.invoke("Typing", roomSel.value, user, false);
        } catch (e) { console.error(e); }
      });

      // Enter لإرسال
      msgInp.addEventListener("keydown", async (e) => {
        const user = userInp.value?.trim() || "Guest";
        if (e.key === "Enter") {
          sendBtn.click();
        } else {
          // إشعار كتابة
          try { await connection.invoke("Typing", roomSel.value, user, true); } catch {}
          // إخفاء المؤشر بعد 1.2 ثانية بدون كتابة
          clearTimeout(window.__typingTimer);
          window.__typingTimer = setTimeout(async () => {
            try { await connection.invoke("Typing", roomSel.value, user, false); } catch {}
          }, 1200);
        }
      });

      // إعادة اتصال تلقائي
      connection.onreconnected(() => append(`<i class="text-warning">Reconnected</i>`));
      connection.onclose(() => append(`<i class="text-danger">Disconnected</i>`));

      start().catch(console.error);
    })();
</script>

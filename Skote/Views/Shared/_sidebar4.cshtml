@using Microsoft.AspNetCore.Authorization
@using Skote.Helpers
@inject IAuthorizationService AuthorizationService
@{
    Task<bool> allow(string controller, string action = "Index") => AuthorizationService.CanAccessCharityAsync(User, controller, action);

    var canDashboard = await allow("Dashboard3");
    var canDailySummary = await allow("DailySummary");
    var canTreasuryBank = await allow("TreasuryBank");
    var canSearch = await allow("Search");
    var canWorkspace = await allow("CharityWorkspace");
    var canCharityDashboard = await allow("CharityDashboard");
    var showHome = canDashboard || canDailySummary || canSearch || canWorkspace || canCharityDashboard;
    var canExpenses = await allow("Expenses");
    var canExpenseCategories = await allow("ExpenseCategories");
    var showExpenses = canExpenses || canExpenseCategories;
    var canBeneficiaries = await allow("Beneficiaries");
    var canAidCycles = await allow("AidCycles");
    var canAidDisbursements = await allow("BeneficiaryAidDisbursements");
    var canAidRequests = await allow("BeneficiaryAidRequests");
    var canResearch = await allow("BeneficiaryHumanitarianResearchs");
    var canBeneficiaryCard = await allow("BeneficiaryCard");
    var showBeneficiaries = canBeneficiaries || canAidCycles || canAidDisbursements || canAidRequests || canResearch || canBeneficiaryCard;

    var canDonors = await allow("Donors");
    var canDonations = await allow("Donations");
    var canFunders = await allow("Funders");
    var canGrantAgreements = await allow("GrantAgreements");
    var canGrantInstallments = await allow("GrantInstallments");
    var showFunding = canDonors || canDonations || canFunders || canGrantAgreements || canGrantInstallments;

    var canKafalaSponsors = await allow("KafalaSponsors");
    var canKafalaCases = await allow("KafalaCases");
    var canKafalaPayments = await allow("KafalaPayments");
    var showKafala = canKafalaSponsors || canKafalaCases || canKafalaPayments;

    var canProjects = await allow("CharityProjects");
    var canProjectPhases = await allow("ProjectPhases");
    var canProjectGoals = await allow("ProjectGoals");
    var canProjectProposals = await allow("ProjectProposals");
    var canProjectTracking = await allow("ProjectTrackingLogs");
    var canProjectExpenseLinks = await allow("ProjectPhaseExpenseLinks");
    var canProjectStoreLinks = await allow("ProjectPhaseStoreIssueLinks");
    var showProjects = canProjects || canProjectPhases || canProjectGoals || canProjectProposals || canProjectTracking;

    var canVolunteers = await allow("Volunteers");
    var canVolunteerDirectory = await allow("VolunteerDirectory");
    var canVolunteerSkills = await allow("VolunteerSkillDefinitions");
    var canVolunteerAssignments = await allow("VolunteerProjectAssignments");
    var canVolunteerHours = await allow("VolunteerHourLogs");
    var showVolunteers = canVolunteers || canVolunteerDirectory || canVolunteerSkills || canVolunteerAssignments || canVolunteerHours;

    var canItems = await allow("Items");
    var canWarehouses = await allow("Warehouses");
    var canReceipts = await allow("CharityStoreReceipts");
    var canIssues = await allow("CharityStoreIssues");
    var canNeedRequests = await allow("StockNeedRequests");
    var canReturns = await allow("StockReturnVouchers");
    var canDisposals = await allow("StockDisposalVouchers");
    var canTransfers = await allow("StockTransfers");
    var canItemCard = await allow("StockItemCard");
    var showStores = canItems || canWarehouses || canReceipts || canIssues || canNeedRequests;

    var canSuppliers = await allow("Suppliers");
    var canPurchaseInvoices = await allow("PurchaseInvoices");
    var showProcurement = canSuppliers || canPurchaseInvoices;

    var canSalesInvoices = await allow("SalesInvoices");
    var canFindSales = await allow("FindSales");
    var canSalesReports = await allow("SalesReports");
    var canSalesReturns = await allow("SalesReturns");
    var showSales = canSalesInvoices || canFindSales || canSalesReports || canSalesReturns;

    var canHrEmployees = await allow("HrEmployees");
    var canHrAttendance = await allow("HrAttendanceRecords");
    var canPayrollMonths = await allow("PayrollMonths");
    var canHrMovements = await allow("HrEmployeeMovements");
    var canHrSanctions = await allow("HrSanctionRecords");
    var canHrOutRequests = await allow("HrOutRequests");
    var canHrPerformance = await allow("HrPerformanceEvaluations");
    var canHrContracts = await allow("HrEmployeeContracts");
    var canHrBonuses = await allow("HrEmployeeBonuses");

    var canBoardFollowUps = await allow("BoardDecisionFollowUps");
    var showMinutes = canBoardMeetings || canBoardDecisions || canBoardFollowUps;

    var canCharityReports = await allow("CharityReports");
    var canReportsCompare = await allow("ReportsCompare");
    var canCashFlow = await allow("CashFlow");
    var canBulkMessage = await allow("BulkMessage");
    var canNotifications = await allow("NotificationCenter");
    var canWorkflow = await allow("WorkflowBoard");
    var canAidCycleAlerts = await allow("AidCycleAlerts");
    var canUserPreferences = await allow("UserPreferences");
    var canRfpReports = await allow("RfpReports");
    var showReports = canCharityReports || canReportsCompare || canNotifications || canWorkflow || canAidCycleAlerts || canCashFlow || canBulkMessage;

    var canSecurityAdmin = await allow("SecurityAdmin");
    var canSecurityMatrix = await allow("Security");
    var canDemoData = await allow("DemoData");
    var canQaAudit = await allow("QaAudit");
    var showAdmin = canSecurityAdmin || canSecurityMatrix || canDemoData || canQaAudit;

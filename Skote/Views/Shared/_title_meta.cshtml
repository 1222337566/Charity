@{
    var pageTitle = string.IsNullOrWhiteSpace(ViewBag.Title as string)
        ? "Joud Charity"
        : $"{ViewBag.Title} | Joud Charity";
}
<meta charset="utf-8" />
<title>@pageTitle</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Joud Charity digital platform for beneficiaries, aid cycles, projects, governance, and smart reporting." />
<meta name="author" content="Joud Charity" />
<meta name="theme-color" content="#0e6f73" />
<link rel="icon" type="image/svg+xml" href="~/assets/images/joud/joud-favicon.svg">
<link rel="shortcut icon" href="~/assets/images/joud/joud-favicon.svg">
<link rel="apple-touch-icon" href="~/assets/images/joud/joud-square-logo.svg">

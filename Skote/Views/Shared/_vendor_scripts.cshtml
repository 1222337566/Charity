<!-- JAVASCRIPT -->
<script src="~/assets/libs/jquery/jquery.min.js"></script>
<script src="~/assets/libs/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="~/assets/libs/metismenu/metisMenu.min.js"></script>
<script src="~/assets/libs/simplebar/simplebar.min.js"></script>
<script src="~/assets/libs/node-waves/waves.min.js"></script>
<script>
(function(){
  var inp = document.getElementById('topbar-search');
  var box = document.getElementById('topbar-search-results');
  if(!inp || !box) return;
  var timer;
  var icons = {Beneficiary:'👤',Donor:'💰',Funder:'🏢',KafalaSponsor:'🤝',Project:'🏗',default:'📋'};
  var types = {Beneficiary:'مستفيد',Donor:'متبرع',Funder:'ممول',KafalaSponsor:'كفيل',Project:'مشروع'};

  inp.addEventListener('input', function(){
    clearTimeout(timer);
    var q = inp.value.trim();
    if(q.length < 2){ box.style.display='none'; return; }
    timer = setTimeout(function(){
      fetch('/api/search?q='+encodeURIComponent(q)+'&take=8')
        .then(function(r){ return r.json(); })
        .then(function(data){
          if(!data.results || !data.results.length){ box.innerHTML='<div style="padding:16px;text-align:center;color:#adb5bd;font-size:.82rem">لا نتائج</div>'; box.style.display=''; return; }
          box.innerHTML = data.results.map(function(r){
            var icon = icons[r.type] || icons.default;
            var type = types[r.type] || r.type;
            return '<a href="'+(r.url||'#')+'" style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:.5px solid rgba(14,111,115,.07);text-decoration:none;transition:.1s" onmouseover="this.style.background=\'#f5faf9\'" onmouseout="this.style.background=\'\'">'+
              '<span style="width:32px;height:32px;border-radius:9px;background:rgba(14,111,115,.08);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0">'+icon+'</span>'+
              '<div><div style="font-size:.84rem;font-weight:600;color:#15363a">'+r.name+'</div><div style="font-size:.7rem;color:#6b7d80">'+type+' · '+(r.sub||'')+'</div></div></a>';
          }).join('');
          box.style.display='';
        }).catch(function(){ box.style.display='none'; });
    }, 280);
  });
  document.addEventListener('click', function(e){ if(!inp.contains(e.target) && !box.contains(e.target)) box.style.display='none'; });
})();
</script>

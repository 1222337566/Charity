@model CreateOpeningBalanceVm
@using InfrastructureManagmentWebFramework.Models.Stock

@{
    ViewData["Title"] = "إضافة رصيد افتتاحي";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">إضافة رصيد افتتاحي</h4>
        </div>
        <div class="card-body">
            <form asp-action="OpeningBalance" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ItemId" class="form-label"></label>
                        <select asp-for="ItemId" asp-items="Model.Items" class="form-select">
                            <option value="">-- اختر الصنف --</option>
                        </select>
                        <span asp-validation-for="ItemId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="WarehouseId" class="form-label"></label>
                        <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select">
                            <option value="">-- اختر المخزن --</option>
                        </select>
                        <span asp-validation-for="WarehouseId" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Quantity" class="form-label"></label>
                        <input asp-for="Quantity" class="form-control" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="UnitCost" class="form-label"></label>
                        <input asp-for="UnitCost" class="form-control" />
                        <span asp-validation-for="UnitCost" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="TransactionDateUtc" class="form-label"></label>
                        <input asp-for="TransactionDateUtc" type="datetime-local" class="form-control"
                               value="@(Model.TransactionDateUtc?.ToString("yyyy-MM-ddTHH:mm"))" />
                        <span asp-validation-for="TransactionDateUtc" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="ReferenceNumber" class="form-label"></label>
                        <input asp-for="ReferenceNumber" class="form-control" />
                        <span asp-validation-for="ReferenceNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">حفظ</button>
                <a asp-action="Index" class="btn btn-secondary">رجوع</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model IEnumerable<InfrastrfuctureManagmentCore.Domains.Warehouses.StockTransaction>
<h4 class="mb-3">كارت الصنف</h4>
<form method="get" class="row g-3 mb-3">
<div class="col-md-4"><select name="itemId" class="form-select" asp-items="ViewBag.Items"><option value="">اختر الصنف</option></select></div>
<div class="col-md-4"><select name="warehouseId" class="form-select" asp-items="ViewBag.Warehouses"><option value="">اختر المخزن</option></select></div>
<div class="col-md-2"><button class="btn btn-primary w-100">عرض</button></div>
</form>
<table class="table table-sm table-bordered"><thead><tr><th>التاريخ</th><th>الحركة</th><th>الكمية</th><th>التكلفة</th><th>المرجع</th><th>ملاحظات</th></tr></thead><tbody>
@foreach (var x in Model) { <tr><td>@x.TransactionDateUtc.ToString("yyyy-MM-dd HH:mm")</td><td>@x.TransactionType</td><td>@x.Quantity</td><td>@x.UnitCost</td><td>@x.ReferenceNumber</td><td>@x.Notes</td></tr> }
</tbody></table>

@model InfrastrfuctureManagmentCore.Domains.Charity.StockAdvanced.StockNeedRequest
<h4 class="mb-3">طلب احتياج جديد</h4>
<form method="post"><div class="row g-3">
<div class="col-md-3"><label class="form-label">التاريخ</label><input asp-for="RequestDate" type="date" class="form-control" /></div>
<div class="col-md-3"><label class="form-label">النوع</label><input asp-for="RequestType" class="form-control" /></div>
<div class="col-md-3"><label class="form-label">مقدم الطلب</label><input asp-for="RequestedByName" class="form-control" /></div>
<div class="col-md-12"><label class="form-label">ملاحظات</label><textarea asp-for="Notes" class="form-control"></textarea></div>
<div class="col-md-6"><label class="form-label">الصنف</label><select name="Lines[0].ItemId" class="form-select" asp-items="ViewBag.Items"></select></div>
<div class="col-md-3"><label class="form-label">الكمية المطلوبة</label><input name="Lines[0].RequestedQuantity" class="form-control" /></div>
<div class="col-md-12"><button class="btn btn-primary">حفظ</button></div></div></form>

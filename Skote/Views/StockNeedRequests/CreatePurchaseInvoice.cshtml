@using InfrastructureManagmentWebFramework.Models.Purchase
@model CreatePurchaseInvoiceVm
@{
    ViewData["Title"] = "إنشاء فاتورة شراء من طلب الاحتياج";
    var needReq = ViewBag.NeedRequest as InfrastrfuctureManagmentCore.Domains.Charity.StockAdvanced.StockNeedRequest;
    var needId  = (Guid)ViewBag.NeedRequestId;
    var suppliers = ViewBag.Suppliers as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
    var items    = ViewBag.Items as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<style>
.pi-hero{background:linear-gradient(135deg,#1e3a5f,#2d5282);border-radius:16px;padding:18px 24px;color:#fff;margin-bottom:18px}
.pi-card{background:#fff;border-radius:16px;border:.5px solid rgba(30,58,95,.1);box-shadow:0 2px 10px rgba(30,58,95,.05);margin-bottom:16px}
.pi-head{padding:14px 18px 12px;border-bottom:.5px solid rgba(30,58,95,.08);font-size:.92rem;font-weight:700;color:#1e3a5f}
.pi-body{padding:16px 18px}
.pi-line{background:#f8fbfc;border-radius:10px;padding:12px 14px;margin-bottom:8px;border:.5px solid rgba(30,58,95,.07)}
.total-row{background:rgba(14,111,115,.06);border-radius:10px;padding:12px 16px;font-weight:700}
</style>

<div class="pi-hero">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h5 class="fw-bold mb-1 text-white">
        <i class="bx bx-receipt me-2"></i>إنشاء فاتورة شراء
      </h5>
      <div style="opacity:.75;font-size:.8rem">
        من طلب الاحتياج:
        <strong>@needReq?.RequestNumber</strong>
        — بعد الترحيل ستُضاف الكميات للمخزن تلقائياً
      </div>
    </div>
    <a asp-action="Details" asp-route-id="@needId"
       class="btn btn-light btn-sm fw-bold" style="border-radius:10px">
      <i class="bx bx-arrow-back me-1"></i>رجوع
    </a>
  </div>
</div>

<form asp-action="CreatePurchaseInvoice" asp-route-needRequestId="@needId" method="post">
  @Html.AntiForgeryToken()

  <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"
       style="border-radius:12px;font-size:.85rem"></div>

  @* الفاتورة - Header *@
  <div class="pi-card">
    <div class="pi-head"><i class="bx bx-file-blank me-2"></i>بيانات الفاتورة</div>
    <div class="pi-body">
      <div class="row g-3">
        <div class="col-md-3">
          <label asp-for="InvoiceNumber" class="form-label fw-semibold"></label>
          <input asp-for="InvoiceNumber" class="form-control" style="border-radius:10px"/>
          <span asp-validation-for="InvoiceNumber" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
          <label asp-for="InvoiceDateUtc" class="form-label fw-semibold"></label>
          <input asp-for="InvoiceDateUtc" type="date" class="form-control" style="border-radius:10px"/>
        </div>
        <div class="col-md-3">
          <label asp-for="WarehouseId" class="form-label fw-semibold"></label>
          <select asp-for="WarehouseId" asp-items="Model.Warehouses"
                  class="form-select" style="border-radius:10px">
            <option value="">-- اختر المخزن --</option>
          </select>
          <span asp-validation-for="WarehouseId" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
          <label asp-for="SupplierInvoiceNumber" class="form-label fw-semibold"></label>
          <input asp-for="SupplierInvoiceNumber" class="form-control" style="border-radius:10px"
                 placeholder="رقم فاتورة المورد"/>
        </div>

        @* المورد *@
        <div class="col-md-4">
          <label class="form-label fw-semibold">المورد</label>
          <select asp-for="SupplierId" asp-items="suppliers"
                  class="form-select" style="border-radius:10px"
                  onchange="fillSupplierName(this)">
            <option value="">-- اختر من القائمة أو اكتب يدوياً --</option>
          </select>
        </div>
        <div class="col-md-4">
          <label asp-for="SupplierName" class="form-label fw-semibold"></label>
          <input asp-for="SupplierName" class="form-control" style="border-radius:10px"
                 placeholder="اسم المورد"/>
          <span asp-validation-for="SupplierName" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
          <label asp-for="Notes" class="form-label fw-semibold"></label>
          <input asp-for="Notes" class="form-control" style="border-radius:10px"/>
        </div>
      </div>
    </div>
  </div>

  @* الأصناف *@
  <div class="pi-card">
    <div class="pi-head d-flex justify-content-between align-items-center">
      <span><i class="bx bx-list-ul me-2"></i>أصناف الفاتورة</span>
      <button type="button" class="btn btn-sm fw-bold"
              style="border-radius:9px;background:rgba(14,111,115,.1);color:#0e6f73;border:none"
              onclick="addLine()">
        <i class="bx bx-plus me-1"></i>إضافة صنف
      </button>
    </div>
    <div class="pi-body">
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse;min-width:700px" id="lines-table">
          <thead>
            <tr style="background:#f8fbfb">
              <th style="padding:8px 10px;font-size:.76rem;font-weight:700;color:#6b7d80;text-align:right">الصنف</th>
              <th style="padding:8px 10px;font-size:.76rem;font-weight:700;color:#6b7d80;text-align:center">الكمية</th>
              <th style="padding:8px 10px;font-size:.76rem;font-weight:700;color:#6b7d80;text-align:center">سعر الوحدة</th>
              <th style="padding:8px 10px;font-size:.76rem;font-weight:700;color:#6b7d80;text-align:center">خصم</th>
              <th style="padding:8px 10px;font-size:.76rem;font-weight:700;color:#6b7d80;text-align:center">ضريبة</th>
              <th style="padding:8px 10px;font-size:.76rem;font-weight:700;color:#6b7d80;text-align:center">الإجمالي</th>
              <th style="padding:8px 10px"></th>
            </tr>
          </thead>
          <tbody id="lines-body">
            @for (int i = 0; i < Model.Lines.Count; i++)
            {
              <tr class="line-row" data-index="@i">
                <td style="padding:6px 8px">
                  <select name="Lines[@i].ItemId"
                          class="form-select form-select-sm js-item-sel"
                          style="border-radius:8px;min-width:180px"
                          onchange="calcRow(this)"
                          asp-items="@(new SelectList(items, "Value", "Text", Model.Lines[i].ItemId.ToString()))">
                    <option value="">-- اختر --</option>
                  </select>
                </td>
                <td style="padding:6px 8px">
                  <input type="number" name="Lines[@i].Quantity" value="@Model.Lines[i].Quantity"
                         step="0.001" min="0.001" class="form-control form-control-sm js-qty"
                         style="border-radius:8px;width:90px;text-align:center" onchange="calcRow(this)"/>
                </td>
                <td style="padding:6px 8px">
                  <input type="number" name="Lines[@i].UnitCost" value="@Model.Lines[i].UnitCost"
                         step="0.01" min="0" class="form-control form-control-sm js-cost"
                         style="border-radius:8px;width:100px;text-align:center" onchange="calcRow(this)"/>
                </td>
                <td style="padding:6px 8px">
                  <input type="number" name="Lines[@i].DiscountAmount" value="0"
                         step="0.01" min="0" class="form-control form-control-sm js-disc"
                         style="border-radius:8px;width:80px;text-align:center" onchange="calcRow(this)"/>
                </td>
                <td style="padding:6px 8px">
                  <input type="number" name="Lines[@i].TaxAmount" value="0"
                         step="0.01" min="0" class="form-control form-control-sm js-tax"
                         style="border-radius:8px;width:80px;text-align:center" onchange="calcRow(this)"/>
                </td>
                <td style="padding:6px 8px;text-align:center;font-weight:700;color:#0e6f73" class="js-total">0.00</td>
                <td style="padding:6px 8px">
                  <button type="button" class="btn btn-sm" onclick="removeLine(this)"
                          style="border-radius:8px;background:rgba(244,106,106,.1);color:#f46a6a;border:none">
                    <i class="bx bx-trash"></i>
                  </button>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>

      @* الإجماليات *@
      <div class="total-row mt-3 d-flex justify-content-between align-items-center">
        <span>الإجمالي قبل الضريبة: <strong id="sub-total">0.00</strong></span>
        <span>الضريبة: <strong id="tax-total">0.00</strong></span>
        <span>الخصم: <strong id="disc-total">0.00</strong></span>
        <span style="font-size:1rem;color:#0e6f73">
          صافي الفاتورة: <strong id="net-total">0.00</strong>
        </span>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary fw-bold" style="border-radius:12px">
      <i class="bx bx-save me-1"></i>حفظ الفاتورة (مسودة)
    </button>
    <a asp-action="Details" asp-route-id="@needId"
       class="btn btn-light fw-bold" style="border-radius:12px">إلغاء</a>
  </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial"/>
<script>
var itemsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    (ViewBag.Items as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
     ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
    .Select(x => new { v = x.Value, t = x.Text })));

var suppliersData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    (ViewBag.Suppliers as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
     ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
    .Select(x => new { v = x.Value, t = x.Text })));

var lineIndex = @Model.Lines.Count;

function getVal(inp) { return parseFloat(inp?.value || '0') || 0; }
function fmt(n) { return n.toFixed(2); }

function calcRow(el) {
    var row  = el.closest('tr');
    var qty  = getVal(row.querySelector('.js-qty'));
    var cost = getVal(row.querySelector('.js-cost'));
    var disc = getVal(row.querySelector('.js-disc'));
    var tax  = getVal(row.querySelector('.js-tax'));
    var tot  = qty * cost - disc + tax;
    row.querySelector('.js-total').textContent = fmt(Math.max(tot, 0));
    refreshTotals();
}

function refreshTotals() {
    var rows = document.querySelectorAll('.line-row');
    var sub = 0, tax = 0, disc = 0;
    rows.forEach(function(row) {
        sub  += getVal(row.querySelector('.js-qty'))  * getVal(row.querySelector('.js-cost'));
        disc += getVal(row.querySelector('.js-disc'));
        tax  += getVal(row.querySelector('.js-tax'));
    });
    document.getElementById('sub-total').textContent  = fmt(sub);
    document.getElementById('disc-total').textContent = fmt(disc);
    document.getElementById('tax-total').textContent  = fmt(tax);
    document.getElementById('net-total').textContent  = fmt(sub - disc + tax);
}

function addLine() {
    var i    = lineIndex++;
    var opts = itemsData.map(function(x) {
        return '<option value="' + x.v + '">' + x.t + '</option>';
    }).join('');

    var tr = document.createElement('tr');
    tr.className = 'line-row';
    tr.dataset.index = i;
    tr.innerHTML =
        '<td style="padding:6px 8px"><select name="Lines[' + i + '].ItemId" class="form-select form-select-sm js-item-sel" style="border-radius:8px;min-width:180px" onchange="calcRow(this)"><option value="">-- اختر --</option>' + opts + '</select>' +
        '</td>' +
        '<td style="padding:6px 8px"><input type="number" name="Lines[' + i + '].Quantity" value="1" step="0.001" min="0.001" class="form-control form-control-sm js-qty" style="border-radius:8px;width:90px;text-align:center" onchange="calcRow(this)"/></td>' +
        '<td style="padding:6px 8px"><input type="number" name="Lines[' + i + '].UnitCost" value="0" step="0.01" min="0" class="form-control form-control-sm js-cost" style="border-radius:8px;width:100px;text-align:center" onchange="calcRow(this)"/></td>' +
        '<td style="padding:6px 8px"><input type="number" name="Lines[' + i + '].DiscountAmount" value="0" step="0.01" min="0" class="form-control form-control-sm js-disc" style="border-radius:8px;width:80px;text-align:center" onchange="calcRow(this)"/></td>' +
        '<td style="padding:6px 8px"><input type="number" name="Lines[' + i + '].TaxAmount" value="0" step="0.01" min="0" class="form-control form-control-sm js-tax" style="border-radius:8px;width:80px;text-align:center" onchange="calcRow(this)"/></td>' +
        '<td style="padding:6px 8px;text-align:center;font-weight:700;color:#0e6f73" class="js-total">0.00</td>' +
        '<td style="padding:6px 8px"><button type="button" class="btn btn-sm" onclick="removeLine(this)" style="border-radius:8px;background:rgba(244,106,106,.1);color:#f46a6a;border:none"><i class="bx bx-trash"></i></button></td>';
    document.getElementById('lines-body').appendChild(tr);
}

function removeLine(btn) {
    var row = btn.closest('tr');
    if (document.querySelectorAll('.line-row').length > 1) {
        row.remove();
        refreshTotals();
    }
}

function fillSupplierName(sel) {
    var opt = sel.options[sel.selectedIndex];
    if (opt && opt.value) {
        document.querySelector('[name="SupplierName"]').value = opt.text;
    }
}

document.addEventListener('DOMContentLoaded', refreshTotals);
</script>
}

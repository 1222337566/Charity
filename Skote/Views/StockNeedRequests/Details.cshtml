@using InfrastrfuctureManagmentCore.Domains.Charity.StockAdvanced
@using InfrastrfuctureManagmentCore.Domains.Charity.Workflow
@model StockNeedRequest
@{
    ViewData["Title"] = "طلب الاحتياج";
    var steps   = ViewBag.WorkflowSteps as List<WorkflowStep> ?? new();
    var invoice = ViewBag.LinkedInvoice as InfrastrfuctureManagmentCore.Domains.Purchase.PurchaseInvoice;
    string StatusBg(string s) => s switch {
        "Draft"              => "#e2e8f0",
        "Submitted"          => "#dbeafe",
        "Approved"           => "#d1fae5",
        "Ordered"            => "#fef3c7",
        "PartiallyFulfilled" => "#fce7f3",
        "Fulfilled"          => "#34c38f",
        "Rejected"           => "#fee2e2",
        "Cancelled"          => "#f3f4f6",
        _                    => "#e2e8f0"
    };
    string StatusAr(string s) => s switch {
        "Draft"              => "مسودة",
        "Submitted"          => "مُقدَّم",
        "Approved"           => "مُعتمَد",
        "Ordered"            => "تم الطلب",
        "PartiallyFulfilled" => "مُنجَز جزئياً",
        "Fulfilled"          => "مُنجَز",
        "Rejected"           => "مرفوض",
        "Cancelled"          => "ملغى",
        _                    => s
    };
    string StatusFg(string s) => s switch {
        "Fulfilled" => "#fff", "Approved" => "#065f46",
        "Rejected" => "#991b1b", "Ordered" => "#92400e", _ => "#374151"
    };
}

<style>
.doc-cycle{display:flex;align-items:center;gap:0;margin-bottom:20px;flex-wrap:wrap}
.doc-step{padding:10px 20px;border-radius:0;text-align:center;flex:1;min-width:100px;font-size:.78rem;font-weight:700;position:relative}
.doc-step:first-child{border-radius:12px 0 0 12px}
.doc-step:last-child{border-radius:0 12px 12px 0}
.doc-step.done{background:#0e6f73;color:#fff}
.doc-step.current{background:#f1b44c;color:#fff}
.doc-step.pending{background:#f1f5f9;color:#94a3b8}
.doc-arrow{color:#94a3b8;font-size:1.2rem;flex-shrink:0}
.snr-card{background:#fff;border-radius:16px;border:.5px solid rgba(14,111,115,.12);box-shadow:0 2px 10px rgba(14,111,115,.05);margin-bottom:16px;overflow:hidden}
.snr-head{padding:14px 18px 12px;border-bottom:.5px solid rgba(14,111,115,.08);font-size:.92rem;font-weight:700;color:#0a5f63;display:flex;align-items:center;justify-content:space-between}
.snr-body{padding:16px 18px}
.wf-step{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:.5px dashed rgba(14,111,115,.08)}
.wf-step:last-child{border-bottom:none}
.wf-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
</style>

@* ── دورة مستندية مرئية ── *@
<div class="doc-cycle mb-3">
  @{
    var cycleSteps = new[] {
        ("Draft",    "مسودة",         "bx-file"),
        ("Approved", "اعتماد",        "bx-check-shield"),
        ("Ordered",  "فاتورة شراء",   "bx-receipt"),
        ("Fulfilled","إضافة للمخزن",  "bx-archive-in")
    };
    int stepIdx = cycleSteps.ToList().FindIndex(x => x.Item1 == Model.Status);
    if (stepIdx < 0) stepIdx = 0;
  }
  @for (int i = 0; i < cycleSteps.Length; i++)
  {
    var cs   = cycleSteps[i];
    string cls = i < stepIdx ? "done" : i == stepIdx ? "current" : "pending";
    <div class="doc-step @cls">
      <i class="bx @cs.Item3" style="font-size:1.1rem;display:block;margin-bottom:4px"></i>
      @cs.Item2
    </div>
    @if (i < cycleSteps.Length - 1)
    {
      <span class="doc-arrow">›</span>
    }
  }
</div>

@if (TempData["Success"] != null)
{
  <div class="alert alert-success" style="border-radius:12px">
    <i class="bx bx-check-circle me-2"></i>@TempData["Success"]
  </div>
}
@if (TempData["Warning"] != null)
{
  <div class="alert alert-warning" style="border-radius:12px">@TempData["Warning"]</div>
}

@* ── معلومات الطلب ── *@
<div class="snr-card">
  <div class="snr-head">
    <span><i class="bx bx-file-blank me-2"></i>طلب الاحتياج — @Model.RequestNumber</span>
    <span style="padding:4px 14px;border-radius:20px;font-size:.75rem;font-weight:700;background:@StatusBg(Model.Status);color:@StatusFg(Model.Status)">
      @StatusAr(Model.Status)
    </span>
  </div>
  <div class="snr-body">
    <div class="row g-3">
      <div class="col-md-3">
        <div style="font-size:.72rem;color:#6b7d80">التاريخ</div>
        <div class="fw-semibold">@Model.RequestDate.ToString("d/M/yyyy")</div>
      </div>
      <div class="col-md-3">
        <div style="font-size:.72rem;color:#6b7d80">النوع</div>
        <div class="fw-semibold">@Model.RequestType</div>
      </div>
      <div class="col-md-3">
        <div style="font-size:.72rem;color:#6b7d80">مقدّم من</div>
        <div class="fw-semibold">@(Model.RequestedByName ?? "—")</div>
      </div>
      <div class="col-md-3">
        <div style="font-size:.72rem;color:#6b7d80">عدد الأصناف</div>
        <div class="fw-semibold">@Model.Lines.Count</div>
      </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
      <div class="mt-2" style="font-size:.83rem;color:#6b7d80">@Model.Notes</div>
    }
  </div>
</div>

@* ── الأصناف المطلوبة ── *@
<div class="snr-card">
  <div class="snr-head"><span><i class="bx bx-list-ul me-2"></i>الأصناف المطلوبة</span></div>
  <div style="overflow-x:auto">
    <table style="width:100%;border-collapse:collapse">
      <thead>
        <tr style="background:#f8fbfb">
          <th style="padding:10px 14px;font-size:.78rem;font-weight:700;color:#6b7d80;text-align:right">الصنف</th>
          <th style="padding:10px 14px;font-size:.78rem;font-weight:700;color:#6b7d80;text-align:center">الكمية المطلوبة</th>
          <th style="padding:10px 14px;font-size:.78rem;font-weight:700;color:#6b7d80;text-align:center">الكمية المعتمدة</th>
          <th style="padding:10px 14px;font-size:.78rem;font-weight:700;color:#6b7d80;text-align:center">المُنفَّذ</th>
          <th style="padding:10px 14px;font-size:.78rem;font-weight:700;color:#6b7d80;text-align:right">ملاحظات</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var line in Model.Lines)
        {
          <tr style="border-top:.5px solid rgba(14,111,115,.06)">
            <td style="padding:10px 14px;font-weight:600;font-size:.86rem">@line.ItemId</td>
            <td style="padding:10px 14px;text-align:center">@line.RequestedQuantity.ToString("N2")</td>
            <td style="padding:10px 14px;text-align:center;color:#0e6f73;font-weight:600">@line.ApprovedQuantity.ToString("N2")</td>
            <td style="padding:10px 14px;text-align:center;color:#34c38f">@line.FulfilledQuantity.ToString("N2")</td>
            <td style="padding:10px 14px;font-size:.78rem;color:#6b7d80">@(line.Notes ?? "—")</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>

@* ── مسار الموافقة ── *@
@if (steps.Any())
{
  <div class="snr-card">
    <div class="snr-head"><span><i class="bx bx-git-branch me-2"></i>مسار الموافقة</span></div>
    <div class="snr-body">
      @foreach (var s in steps.OrderBy(x => x.StepOrder))
      {
        string dotColor = s.Status switch {
            "Approved" => "#34c38f", "Rejected" => "#f46a6a",
            "Pending"  => "#f1b44c", "Waiting"  => "#e2e8f0", _ => "#adb5bd"
        };
        <div class="wf-step">
          <div class="wf-dot" style="background:@dotColor"></div>
          <div class="flex-grow-1">
            <span class="fw-semibold" style="font-size:.87rem">@s.StepName</span>
            <span style="font-size:.75rem;color:#6b7d80;margin-right:8px">@s.AssignedRole</span>
          </div>
          <span style="font-size:.73rem;padding:2px 8px;border-radius:5px;background:@dotColor + "22";color:@dotColor;font-weight:700">
            @(s.Status switch { "Approved"=>"معتمد","Rejected"=>"مرفوض","Pending"=>"قيد المراجعة","Waiting"=>"في الانتظار",_ => s.Status })
          </span>
        </div>
      }
    </div>
  </div>
}

@* ── فاتورة الشراء المرتبطة ── *@
@if (invoice != null)
{
  <div class="snr-card">
    <div class="snr-head">
      <span><i class="bx bx-receipt me-2"></i>فاتورة الشراء المرتبطة</span>
      <a asp-controller="PurchaseInvoices" asp-action="Details" asp-route-id="@invoice.Id"
         class="btn btn-sm fw-bold" style="border-radius:9px;background:rgba(14,111,115,.1);color:#0e6f73;border:none">
        عرض الفاتورة
      </a>
    </div>
    <div class="snr-body">
      <div class="row g-3">
        <div class="col-md-3">
          <div style="font-size:.72rem;color:#6b7d80">رقم الفاتورة</div>
          <div class="fw-semibold">@invoice.InvoiceNumber</div>
        </div>
        <div class="col-md-3">
          <div style="font-size:.72rem;color:#6b7d80">المورد</div>
          <div class="fw-semibold">@invoice.SupplierName</div>
        </div>
        <div class="col-md-3">
          <div style="font-size:.72rem;color:#6b7d80">الإجمالي</div>
          <div class="fw-semibold" style="color:#0e6f73">@invoice.NetAmount.ToString("N2")</div>
        </div>
        <div class="col-md-3">
          <div style="font-size:.72rem;color:#6b7d80">الحالة</div>
          <div class="fw-semibold">@invoice.Status</div>
        </div>
      </div>
    </div>
  </div>
}

@* ── الإجراءات ── *@
<div class="d-flex gap-2 flex-wrap mt-3">
  @if (Model.Status == "Draft" || Model.Status == "Submitted")
  {
    <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="d-inline">
      @Html.AntiForgeryToken()
      <button type="submit" class="btn btn-success fw-bold" style="border-radius:12px">
        <i class="bx bx-check-shield me-1"></i>اعتماد الطلب
      </button>
    </form>
    <button type="button" class="btn btn-outline-danger fw-bold" style="border-radius:12px"
            data-bs-toggle="modal" data-bs-target="#rejectModal">
      <i class="bx bx-x-circle me-1"></i>رفض
    </button>
  }

  @if (Model.Status == "Approved")
  {
    <a asp-action="CreatePurchaseInvoice" asp-route-id="@Model.Id"
       class="btn btn-primary fw-bold" style="border-radius:12px">
      <i class="bx bx-receipt me-1"></i>إنشاء فاتورة شراء
    </a>
  }
    @if (Model.Status == "Ordered" && Model.LinkedPurchaseInvoiceId.HasValue)
    {
        <form asp-action="CreateStoreReceiptFromPurchase" asp-route-id="@Model.Id" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-info fw-bold" style="border-radius:12px">
                <i class="bx bx-archive-in me-1"></i>إنشاء إذن إضافة مخزني
            </button>
        </form>
    }

    @if (Model.Status == "ReceiptPending")
    {
        <span class="badge bg-warning text-dark align-self-center" style="border-radius:10px;padding:10px 12px">
            تم إنشاء إذن الإضافة وبانتظار الاعتماد
        </span>
    }

    @if (Model.Status == "Fulfilled" || Model.Status == "PartiallyFulfilled")
    {
        <a asp-controller="BeneficiaryAidDisbursements" asp-action="Index" asp-route-beneficiaryId="@Model.BeneficiaryId"
           class="btn btn-outline-success fw-bold" style="border-radius:12px">
            <i class="bx bx-gift me-1"></i>عرض سجل الصرف المتاح
        </a>
    }
  <a asp-action="Index" class="btn btn-light fw-bold" style="border-radius:12px">
    <i class="bx bx-list-ul me-1"></i>قائمة الطلبات
  </a>
</div>

@* Reject Modal *@
<div class="modal fade" id="rejectModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:16px">
      <div class="modal-header" style="border-radius:16px 16px 0 0;background:#fee2e2;border:none">
        <h5 class="modal-title fw-bold text-danger">رفض طلب الاحتياج</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="modal-body p-4">
          <label class="form-label fw-semibold">سبب الرفض</label>
          <textarea name="reason" class="form-control" rows="3" style="border-radius:10px"
                    placeholder="اكتب سبب الرفض..." required></textarea>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-danger fw-bold" style="border-radius:10px">تأكيد الرفض</button>
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">إلغاء</button>
        </div>
      </form>
    </div>
  </div>
</div>

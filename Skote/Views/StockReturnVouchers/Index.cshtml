@model IEnumerable<InfrastrfuctureManagmentCore.Domains.Charity.StockAdvanced.StockReturnVoucher>
<div class="d-flex justify-content-between align-items-center mb-3"><h4>المرتجعات المخزنية</h4><a asp-action="Create" class="btn btn-primary">مرتجع جديد</a></div>
<table class="table table-bordered"><thead><tr><th>الرقم</th><th>التاريخ</th><th>النوع</th><th>عدد الأصناف</th></tr></thead><tbody>
@foreach (var x in Model) { <tr><td>@x.VoucherNumber</td><td>@x.VoucherDate.ToString("yyyy-MM-dd")</td><td>@x.ReturnType</td><td>@x.Lines.Count</td></tr> }
</tbody></table>

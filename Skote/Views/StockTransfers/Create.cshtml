@model InfrastrfuctureManagmentCore.Domains.Warehouses.StockTransferRequest
<h4 class="mb-3">تحويل مخزني</h4>
<form method="post"><div class="row g-3">
<div class="col-md-3"><label class="form-label">الصنف</label><select asp-for="ItemId" class="form-select" asp-items="ViewBag.Items"></select></div>
<div class="col-md-3"><label class="form-label">من مخزن</label><select asp-for="FromWarehouseId" class="form-select" asp-items="ViewBag.Warehouses"></select></div>
<div class="col-md-3"><label class="form-label">إلى مخزن</label><select asp-for="ToWarehouseId" class="form-select" asp-items="ViewBag.Warehouses"></select></div>
<div class="col-md-3"><label class="form-label">التاريخ</label><input asp-for="TransactionDateUtc" type="datetime-local" class="form-control" /></div>
<div class="col-md-3"><label class="form-label">الكمية</label><input asp-for="Quantity" class="form-control" /></div>
<div class="col-md-3"><label class="form-label">تكلفة الوحدة</label><input asp-for="UnitCost" class="form-control" /></div>
<div class="col-md-3"><label class="form-label">رقم المرجع</label><input asp-for="ReferenceNumber" class="form-control" /></div>
<div class="col-md-12"><label class="form-label">ملاحظات</label><textarea asp-for="Notes" class="form-control"></textarea></div>
<div class="col-md-12"><button class="btn btn-primary">تنفيذ التحويل</button></div></div></form>

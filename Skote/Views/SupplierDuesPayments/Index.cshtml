@model InfrastructureManagmentWebFramework.Models.SupplierDuesPayments.SupplierDuesPaymentsPageVm

@{
    ViewData["Title"] = "مدفوعات ومستحقات الموردين";
}

<style>
.dp-hero{background:linear-gradient(135deg,#3b2f0b,#b7791f);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.dp-stat{background:rgba(255,255,255,.14);border-radius:12px;padding:10px 14px;text-align:center;flex:1;min-width:110px}
.dp-stat .n{font-size:1.2rem;font-weight:800;line-height:1}
.dp-stat .l{font-size:.7rem;opacity:.85;margin-top:2px}
.dp-card{background:#fff;border-radius:16px;border:.5px solid rgba(183,121,31,.12);box-shadow:0 2px 8px rgba(183,121,31,.05);overflow:hidden;margin-bottom:16px}
.dp-head{padding:12px 18px;border-bottom:.5px solid rgba(183,121,31,.08);font-size:.9rem;font-weight:700;color:#8a5a10;background:rgba(183,121,31,.03)}
.dp-row{display:grid;grid-template-columns:1fr 1fr 1fr 1fr 90px;gap:0;padding:10px 16px;border-bottom:.5px solid rgba(183,121,31,.05);font-size:.84rem;align-items:center}
.dp-row:hover{background:rgba(183,121,31,.03)}
.dp-row:last-child{border-bottom:none}
.due-red{color:#f46a6a;font-weight:700}
.due-green{color:#34c38f;font-weight:700}
.pay-btn{background:#b7791f;color:#fff;border:none;border-radius:8px;padding:4px 12px;font-size:.75rem;font-weight:600;cursor:pointer;text-decoration:none;white-space:nowrap}
.pay-btn:hover{background:#8a5a10;color:#fff}
</style>

<div class="dp-hero">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-1 text-white"><i class="bx bx-store me-2"></i>مدفوعات ومستحقات الموردين</h4>
            <div style="opacity:.78;font-size:.8rem">متابعة فواتير الشراء والمدفوعات والرصيد المستحق لكل مورد</div>
        </div>
        <a asp-controller="Suppliers" asp-action="Create" class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">
            <i class="bx bx-plus me-1"></i>مورد جديد
        </a>
    </div>

    <div class="d-flex gap-3 flex-wrap">
        <div class="dp-stat"><div class="n">@Model.Rows.Count</div><div class="l">الموردون</div></div>
        <div class="dp-stat" style="background:rgba(244,106,106,.22)"><div class="n" style="color:#fecaca">@Model.TotalDue.ToString("N0")</div><div class="l">إجمالي المستحق</div></div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="dp-card">
    <div class="dp-head">الموردون وأرصدتهم</div>
    <div style="padding:8px 16px;background:#fffaf0;border-bottom:.5px solid rgba(183,121,31,.08);display:grid;grid-template-columns:1fr 1fr 1fr 1fr 90px;font-size:.76rem;font-weight:700;color:#6b7d80">
        <div>المورد</div><div style="text-align:center">إجمالي الفواتير</div><div style="text-align:center">المدفوع</div><div style="text-align:center">المستحق</div><div></div>
    </div>

    @foreach (var r in Model.Rows)
    {
        <a asp-action="Index" asp-route-supplierId="@r.SupplierId" style="text-decoration:none;color:inherit">
            <div class="dp-row" style="@(Model.SupplierId == r.SupplierId ? "background:rgba(183,121,31,.06);border-right:3px solid #b7791f" : "")">
                <div>
                    <div class="fw-semibold" style="color:#8a5a10">@r.SupplierName</div>
                    <div style="font-size:.72rem;color:#adb5bd">@r.SupplierNumber @if(!string.IsNullOrWhiteSpace(r.MobileNo)){<span> · @r.MobileNo</span>}</div>
                </div>
                <div style="text-align:center">@r.Invoiced.ToString("N2")</div>
                <div style="text-align:center;color:#34c38f">@r.Paid.ToString("N2")</div>
                <div style="text-align:center" class="@(r.Due > 0 ? "due-red" : "due-green")">@r.Due.ToString("N2")</div>
                <div>
                    @if (r.Due > 0)
                    {
                        <a asp-controller="SupplierPayments" asp-action="Pay" asp-route-supplierId="@r.SupplierId" class="pay-btn" onclick="event.stopPropagation()">سداد</a>
                    }
                </div>
            </div>
        </a>
    }
</div>

@if (Model.SelectedSupplier != null)
{
    <div class="row g-3 mt-1">
        <div class="col-md-6">
            <div class="dp-card">
                <div class="dp-head d-flex justify-content-between align-items-center">
                    <span><i class="bx bx-file me-2"></i>فواتير @Model.SelectedSupplier.SupplierName</span>
                    <a asp-controller="PurchaseInvoices" asp-action="Create" class="btn btn-sm btn-outline-primary fw-bold" style="border-radius:8px;font-size:.75rem">فاتورة شراء</a>
                </div>
                @if (Model.Invoices.Any())
                {
                    @foreach (var inv in Model.Invoices)
                    {
                        <div style="padding:9px 16px;border-bottom:.5px solid rgba(183,121,31,.05);font-size:.83rem;display:flex;justify-content:space-between;align-items:center">
                            <div>
                                <div class="fw-semibold">@inv.InvoiceNumber</div>
                                <div style="font-size:.72rem;color:#adb5bd">@inv.InvoiceDateUtc.ToLocalTime().ToString("d/M/yyyy") · مدفوع @inv.Paid.ToString("N2")</div>
                            </div>
                            <div>
                                <div class="fw-bold">@inv.NetAmount.ToString("N2")</div>
                                <div style="font-size:.72rem;color:@(inv.Due > 0 ? "#f46a6a" : "#34c38f")">متبقي @inv.Due.ToString("N2")</div>
                            </div>
                            @if (inv.Due > 0)
                            {
                                <a asp-controller="SupplierPayments" asp-action="Pay"
                                   asp-route-supplierId="@Model.SelectedSupplier.SupplierId"
                                   asp-route-invoiceId="@inv.Id"
                                   class="btn btn-sm" style="border-radius:7px;background:rgba(183,121,31,.1);color:#8a5a10;border:none;font-size:.72rem">سداد</a>
                            }
                        </div>
                    }
                }
                else
                {
                    <div style="padding:20px;text-align:center;color:#adb5bd">لا توجد فواتير</div>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="dp-card">
                <div class="dp-head d-flex justify-content-between align-items-center">
                    <span><i class="bx bx-money me-2"></i>مدفوعات المورد</span>
                    <a asp-controller="SupplierPayments" asp-action="Pay" asp-route-supplierId="@Model.SelectedSupplier.SupplierId"
                       class="btn btn-sm btn-success fw-bold" style="border-radius:8px;font-size:.75rem">+ سداد جديد</a>
                </div>
                @if (Model.Payments.Any())
                {
                    @foreach (var p in Model.Payments)
                    {
                        <div style="padding:9px 16px;border-bottom:.5px solid rgba(183,121,31,.05);font-size:.83rem">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <div class="fw-semibold">@p.PaymentNumber</div>
                                    <div style="font-size:.72rem;color:#adb5bd">
                                        @p.PaymentDateUtc.ToLocalTime().ToString("d/M/yyyy")
                                        @if(!string.IsNullOrWhiteSpace(p.PaymentMethodName)){<span> · @p.PaymentMethodName</span>}
                                        @if(!string.IsNullOrWhiteSpace(p.InvoiceNumber)){<span> · فاتورة @p.InvoiceNumber</span>}
                                    </div>
                                </div>
                                <div class="fw-bold" style="color:#34c38f">@p.Amount.ToString("N2")</div>
                            </div>
                            @if(!string.IsNullOrWhiteSpace(p.Notes))
                            {
                                <div style="font-size:.72rem;color:#adb5bd;margin-top:2px">@p.Notes</div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div style="padding:20px;text-align:center;color:#adb5bd">لا توجد مدفوعات</div>
                }
            </div>
        </div>
    </div>
}

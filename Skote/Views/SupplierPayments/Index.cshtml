@{
    ViewData["Title"] = "مستحقات الموردين";
    var rows       = ViewBag.Rows as dynamic;
    var selId      = ViewBag.SupplierId as Guid?;
    var supplier   = ViewBag.Supplier as InfrastrfuctureManagmentCore.Domains.Suppliers.Supplier;
    var invoices   = ViewBag.Invoices as List<InfrastrfuctureManagmentCore.Domains.Purchase.PurchaseInvoice>;
    var payments   = ViewBag.Payments as List<InfrastrfuctureManagmentCore.Domains.Suppliers.SupplierPayment>;
}

<style>
.sp-hero{background:linear-gradient(135deg,#1e3a5f,#2d5282);border-radius:18px;padding:18px 24px;color:#fff;margin-bottom:20px}
.sp-stat{background:rgba(255,255,255,.12);border-radius:12px;padding:10px 14px;text-align:center;flex:1;min-width:80px}
.sp-stat .n{font-size:1.2rem;font-weight:800;line-height:1}
.sp-stat .l{font-size:.67rem;opacity:.8;margin-top:2px}
.sp-card{background:#fff;border-radius:16px;border:.5px solid rgba(30,58,95,.1);box-shadow:0 2px 8px rgba(30,58,95,.05);overflow:hidden;margin-bottom:16px}
.sp-head{padding:12px 18px;border-bottom:.5px solid rgba(30,58,95,.07);font-size:.9rem;font-weight:700;color:#1e3a5f;background:rgba(30,58,95,.02)}
.sp-row{display:grid;grid-template-columns:1fr 1fr 1fr 1fr 80px;gap:0;padding:10px 16px;border-bottom:.5px solid rgba(30,58,95,.04);font-size:.84rem;align-items:center}
.sp-row:hover{background:rgba(30,58,95,.02)}
.sp-row:last-child{border-bottom:none}
.balance-red{color:#f46a6a;font-weight:700}
.balance-green{color:#34c38f;font-weight:700}
.pay-btn{background:#1e3a5f;color:#fff;border:none;border-radius:8px;padding:4px 12px;font-size:.75rem;font-weight:600;cursor:pointer;text-decoration:none;white-space:nowrap}
.pay-btn:hover{background:#2d5282;color:#fff}
</style>

@* Hero *@
<div class="sp-hero">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h4 class="fw-bold mb-1 text-white"><i class="bx bx-wallet me-2"></i>مستحقات الموردين</h4>
      <div style="opacity:.72;font-size:.8rem">إدارة المدفوعات والأرصدة لكل مورد</div>
    </div>
    <a asp-controller="Suppliers" asp-action="Create"
       class="btn btn-warning btn-sm fw-bold" style="border-radius:10px">
      <i class="bx bx-plus me-1"></i>مورد جديد
    </a>
  </div>
  <div class="d-flex gap-3 flex-wrap">
    <div class="sp-stat"><div class="n">@((rows as IEnumerable<dynamic>)?.Count() ?? 0)</div><div class="l">الموردون</div></div>
    <div class="sp-stat" style="background:rgba(244,106,106,.2)">
      <div class="n" style="color:#fca5a5">@ViewBag.TotalDue?.ToString("N0")</div>
      <div class="l">إجمالي المستحقات</div>
    </div>
  </div>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success alert-dismissible fade show" style="border-radius:12px">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

@* جدول الموردين مع أرصدتهم *@
<div class="sp-card">
  <div class="sp-head">الموردون وأرصدتهم</div>
  <div style="padding:8px 16px;background:#f8fbfb;border-bottom:.5px solid rgba(30,58,95,.08);display:grid;grid-template-columns:1fr 1fr 1fr 1fr 80px;font-size:.76rem;font-weight:700;color:#6b7d80">
    <div>المورد</div><div style="text-align:center">إجمالي الفواتير</div>
    <div style="text-align:center">المدفوع</div><div style="text-align:center">المستحق</div><div></div>
  </div>
  @if (rows != null)
  {
    @foreach (var r in rows)
    {
      var bal = (decimal)r.Balance;
      <a asp-action="Index" asp-route-supplierId="@r.Supplier.Id"
         style="text-decoration:none;color:inherit">
        <div class="sp-row @(selId == r.Supplier.Id ? "selected" : "")"
             style="@(selId == r.Supplier.Id ? "background:rgba(30,58,95,.05);border-right:3px solid #1e3a5f" : "")">
          <div>
            <div class="fw-semibold" style="color:#1e3a5f">@r.Supplier.NameAr</div>
            <div style="font-size:.72rem;color:#adb5bd">@r.Supplier.SupplierNumber</div>
          </div>
          <div style="text-align:center">@((decimal)r.Invoiced).ToString("N2")</div>
          <div style="text-align:center;color:#34c38f">@((decimal)r.Paid).ToString("N2")</div>
          <div style="text-align:center" class="@(bal > 0 ? "balance-red" : "balance-green")">
            @bal.ToString("N2")
          </div>
          <div>
            @if (bal > 0)
            {
              <a asp-action="Pay" asp-route-supplierId="@r.Supplier.Id" class="pay-btn"
                 onclick="event.stopPropagation()">دفع</a>
            }
          </div>
        </div>
      </a>
    }
  }
</div>

@* تفاصيل المورد المحدد *@
@if (supplier != null)
{
  <div class="row g-3 mt-1">
    @* فواتير المورد *@
    <div class="col-md-6">
      <div class="sp-card">
        <div class="sp-head d-flex justify-content-between align-items-center">
          <span><i class="bx bx-file me-2"></i>فواتير @supplier.NameAr</span>
          <a asp-controller="PurchaseInvoices" asp-action="Create"
             class="btn btn-sm btn-outline-primary fw-bold" style="border-radius:8px;font-size:.75rem">
            فاتورة جديدة
          </a>
        </div>
        <div style="padding:0">
          @if (invoices?.Any() == true)
          {
            @foreach (var inv in invoices)
            {
              <div style="padding:9px 16px;border-bottom:.5px solid rgba(30,58,95,.04);font-size:.83rem;display:flex;justify-content:space-between;align-items:center">
                <div>
                  <div class="fw-semibold">@inv.InvoiceNumber</div>
                  <div style="font-size:.72rem;color:#adb5bd">@inv.InvoiceDateUtc.ToString("d/M/yyyy")</div>
                </div>
                <div class="fw-bold">@inv.NetAmount.ToString("N2")</div>
                <a asp-action="Pay" asp-route-supplierId="@supplier.Id"
                   asp-route-invoiceId="@inv.Id"
                   class="btn btn-sm" style="border-radius:7px;background:rgba(30,58,95,.08);color:#1e3a5f;border:none;font-size:.72rem">
                  دفع
                </a>
              </div>
            }
          }
          else
          { <div style="padding:20px;text-align:center;color:#adb5bd">لا توجد فواتير</div> }
        </div>
      </div>
    </div>

    @* سجل الدفعات *@
    <div class="col-md-6">
      <div class="sp-card">
        <div class="sp-head d-flex justify-content-between align-items-center">
          <span><i class="bx bx-money me-2"></i>سجل الدفعات</span>
          <a asp-action="Pay" asp-route-supplierId="@supplier.Id"
             class="btn btn-sm btn-success fw-bold" style="border-radius:8px;font-size:.75rem">
            + دفعة جديدة
          </a>
        </div>
        <div style="padding:0">
          @if (payments?.Any() == true)
          {
            @foreach (var p in payments)
            {
              <div style="padding:9px 16px;border-bottom:.5px solid rgba(30,58,95,.04);font-size:.83rem">
                <div class="d-flex justify-content-between">
                  <div>
                    <div class="fw-semibold">@p.PaymentNumber</div>
                    <div style="font-size:.72rem;color:#adb5bd">
                      @p.PaymentDate.ToString("d/M/yyyy") · @p.PaymentMethod
                    </div>
                  </div>
                  <div class="fw-bold" style="color:#34c38f">@p.Amount.ToString("N2")</div>
                </div>
                @if (!string.IsNullOrWhiteSpace(p.Notes))
                { <div style="font-size:.72rem;color:#adb5bd;margin-top:2px">@p.Notes</div> }
              </div>
            }
          }
          else
          { <div style="padding:20px;text-align:center;color:#adb5bd">لا توجد دفعات</div> }
        </div>
      </div>
    </div>
  </div>
}

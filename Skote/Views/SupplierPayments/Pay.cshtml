@model InfrastrfuctureManagmentCore.Domains.Suppliers.SupplierPayment
@{
    ViewData["Title"] = "تسجيل دفعة للمورد";
    var supplier = ViewBag.Supplier as InfrastrfuctureManagmentCore.Domains.Suppliers.Supplier;
}

<div style="background:linear-gradient(135deg,#1e3a5f,#2d5282);border-radius:16px;padding:16px 22px;color:#fff;margin-bottom:18px">
  <h5 class="fw-bold mb-1 text-white"><i class="bx bx-money me-2"></i>تسجيل دفعة</h5>
  <div style="opacity:.75;font-size:.8rem">المورد: <strong>@supplier?.NameAr</strong></div>
</div>

<div class="card" style="border-radius:16px;border:.5px solid rgba(30,58,95,.1)">
  <div class="card-body p-4">
    <form asp-action="Pay" method="post">
      @Html.AntiForgeryToken()
      <input asp-for="SupplierId" type="hidden"/>
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">رقم الدفعة</label>
          <input asp-for="PaymentNumber" class="form-control" style="border-radius:10px"
                 value="@ViewBag.PaymentNumber"/>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">تاريخ الدفع</label>
          <input asp-for="PaymentDate" type="date" class="form-control" style="border-radius:10px"
                 value="@DateTime.Today.ToString("yyyy-MM-dd")"/>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">المبلغ</label>
          <input asp-for="Amount" type="number" step="0.01" class="form-control" style="border-radius:10px"
                 value="@ViewBag.SuggestedAmount"/>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold" style="font-size:.83rem">طريقة الدفع</label>
          <select asp-for="PaymentMethod" class="form-select" style="border-radius:10px"
                  onchange="toggleCheque(this.value)">
            <option value="Cash">نقدي</option>
            <option value="BankTransfer">تحويل بنكي</option>
            <option value="Cheque">شيك</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold" style="font-size:.83rem">الفاتورة المرتبطة (اختياري)</label>
          <select asp-for="PurchaseInvoiceId" class="form-select" style="border-radius:10px">
            <option value="">-- بدون ربط فاتورة --</option>
            @if (ViewBag.Invoices is List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> invs)
            { @foreach (var i in invs) { <option value="@i.Value" sselected=@(i.Selected)>@i.Text</option> } }
          </select>
        </div>
        <div class="col-md-4" id="cheque-wrap" style="display:none">
          <label class="form-label fw-semibold" style="font-size:.83rem">رقم الشيك / البنك</label>
          <div class="d-flex gap-2">
            <input asp-for="ChequeNumber" class="form-control" style="border-radius:10px" placeholder="رقم الشيك"/>
            <input asp-for="BankName" class="form-control" style="border-radius:10px" placeholder="اسم البنك"/>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold" style="font-size:.83rem">الحالة</label>
          <select asp-for="Status" class="form-select" style="border-radius:10px">
            <option value="Paid">مدفوع</option>
            <option value="Pending">معلق</option>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label fw-semibold" style="font-size:.83rem">ملاحظات</label>
          <textarea asp-for="Notes" class="form-control" rows="2" style="border-radius:10px"></textarea>
        </div>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-success fw-bold" style="border-radius:12px">
          <i class="bx bx-save me-1"></i>حفظ الدفعة
        </button>
        <a asp-action="Index" asp-route-supplierId="@Model.SupplierId"
           class="btn btn-light fw-bold" style="border-radius:12px">إلغاء</a>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
function toggleCheque(v) {
    document.getElementById('cheque-wrap').style.display =
        (v === 'Cheque' || v === 'BankTransfer') ? '' : 'none';
}
</script>
}

@model CreateSupplierVm
@using InfrastructureManagmentWebFramework.Models.Optics

@{
    ViewData["Title"] = "إضافة مورد";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">إضافة مورد</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label asp-for="SupplierNumber" class="form-label"></label>
                        <input asp-for="SupplierNumber" class="form-control" />
                    </div>

                    <div class="col-md-5 mb-3">
                        <label asp-for="NameAr" class="form-label"></label>
                        <input asp-for="NameAr" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="NameEn" class="form-label"></label>
                        <input asp-for="NameEn" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="ContactPerson" class="form-label"></label>
                        <input asp-for="ContactPerson" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Tel" class="form-label"></label>
                        <input asp-for="Tel" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="MobileNo" class="form-label"></label>
                        <input asp-for="MobileNo" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="TaxNumber" class="form-label"></label>
                        <input asp-for="TaxNumber" class="form-control" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Remarks" class="form-label"></label>
                        <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">حفظ</button>
                <a asp-action="Index" class="btn btn-secondary">رجوع</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
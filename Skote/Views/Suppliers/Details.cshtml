@model SupplierDetailsVm
@using InfrastructureManagmentWebFramework.Helpers
@using InfrastructureManagmentWebFramework.Models.Optics

@{
    ViewData["Title"] = "ملف المورد";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">ملف المورد</h4>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">تعديل</a>
        </div>

        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-3">
                    <label class="form-label">رقم المورد</label>
                    <input class="form-control" value="@Model.SupplierNumber" readonly />
                </div>
                <div class="col-md-5">
                    <label class="form-label">الاسم</label>
                    <input class="form-control" value="@Model.NameAr" readonly />
                </div>
                <div class="col-md-4">
                    <label class="form-label">الشخص المسؤول</label>
                    <input class="form-control" value="@Model.ContactPerson" readonly />
                </div>

                <div class="col-md-3 mt-3">
                    <label class="form-label">تليفون</label>
                    <input class="form-control" value="@Model.Tel" readonly />
                </div>
                <div class="col-md-3 mt-3">
                    <label class="form-label">موبايل</label>
                    <input class="form-control" value="@Model.MobileNo" readonly />
                </div>
                <div class="col-md-3 mt-3">
                    <label class="form-label">الرقم الضريبي</label>
                    <input class="form-control" value="@Model.TaxNumber" readonly />
                </div>
                <div class="col-md-3 mt-3">
                    <label class="form-label">الحالة</label>
                    <input class="form-control" value="@(Model.IsActive ? "نشط" : "غير نشط")" readonly />
                </div>

                <div class="col-md-12 mt-3">
                    <label class="form-label">العنوان</label>
                    <input class="form-control" value="@Model.Address" readonly />
                </div>

                <div class="col-md-12 mt-3">
                    <label class="form-label">ملاحظات</label>
                    <input class="form-control" value="@Model.Remarks" readonly />
                </div>
            </div>

            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#purchases" role="tab">المشتريات والتوريدات</a>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-3">
                <div class="tab-pane active" id="purchases" role="tabpanel">
                    <div class="d-flex justify-content-between mb-3">
                        <h5 class="mb-0">المشتريات والتوريدات</h5>
                        <div class="d-flex gap-2">
                            <span class="badge bg-primary">@Model.PurchasesCount</span>
                            <a asp-controller="PurchaseInvoices" asp-action="CreateForSupplier" asp-route-supplierId="@Model.Id" class="btn btn-sm btn-primary">
                                إضافة فاتورة
                            </a>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>التاريخ</th>
                                    <th>رقم الفاتورة</th>
                                    <th>المخزن</th>
                                    <th>التصنيف</th>
                                    <th>المشروع</th>
                                    <th>الصافي</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Purchases.Any())
                                {
                                    foreach (var item in Model.Purchases.Take(10))
                                    {
                                        var tags = CharityOperationNoteTags.Parse(item.Notes);
                                        <tr>
                                            <td>@item.InvoiceDateUtc.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                            <td>@item.InvoiceNumber</td>
                                            <td>@item.WarehouseName</td>
                                            <td>@(string.IsNullOrWhiteSpace(tags.CategoryText) ? "-" : tags.CategoryText)</td>
                                            <td>@(string.IsNullOrWhiteSpace(tags.ProjectName) ? "-" : tags.ProjectName)</td>
                                            <td>@item.NetAmount</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted">لا توجد مشتريات مرتبطة بهذا المورد حتى الآن</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
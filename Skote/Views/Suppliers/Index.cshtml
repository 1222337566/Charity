@model List<SupplierListItemVm>
@using InfrastructureManagmentWebFramework.Models.Optics


@{
    ViewData["Title"] = "الموردون وجهات التوريد";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">الموردون وجهات التوريد</h4>
            <a asp-action="Create" class="btn btn-primary btn-sm">إضافة مورد / جهة توريد</a>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>رقم المورد</th>
                            <th>الاسم</th>
                            <th>المسؤول</th>
                            <th>تليفون</th>
                            <th>موبايل</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.SupplierNumber</td>
                                <td>@item.NameAr</td>
                                <td>@(item.ContactPerson ?? "-")</td>
                                <td>@(item.Tel ?? "-")</td>
                                <td>@(item.MobileNo ?? "-")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">غير نشط</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">الملف</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">تعديل</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@model KanbanIndexVm   
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    ViewBag.Title = "Kanban Board";
    ViewBag.pTitle = "Kanban Board";
    ViewBag.pageTitle = "Tasks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    Layout = "_Layout";
}

@section Styles {
    <style>
        /* مساحة إسقاط ثابتة للسحب */
        #upcoming-task, #inprogress-task, #complete-task {
            min-height: 220px;
        }

        .kanban-empty {
            color: var(--bs-secondary);
            font-style: italic;
            padding: 12px 8px;
            text-align: center;
            border: 1px dashed #ddd;
            border-radius: .5rem;
            margin: 8px 0;
        }

        .gu-over {
            outline: 2px dashed var(--bs-primary);
            outline-offset: 4px;
            background: rgba(13,110,253,.06);
        }

        .gu-mirror {
            opacity: .85;
        }

        .task-box {
            cursor: grab;
            touch-action: none;
        }
    </style>
}

<div class="page-title-box d-sm-flex align-items-center justify-content-between">
    <h4 class="mb-sm-0">Kanban Board</h4>
</div>

<!-- حقن الـBase والـBoard للـJS -->
<div id="page-data"
     data-api-base="@Config["Realtime:BaseUrl"]"
     data-board="@(Context.Request.Query["board"])"></div>

<!-- بانر اتصال SignalR (اختياري) -->
<div id="kanban-connection-banner" class="alert alert-warning shadow"
     style="position:fixed;bottom:16px;right:16px;display:none;z-index:1050">
    Connection lost… trying to reconnect
</div>

<!-- فلاتر بسيطة (اختياري) -->
<div class="row g-2 mb-3">
    <div class="col-auto">
        <input id="kanban-filter" class="form-control" placeholder="Filter by title...">
    </div>
    <div class="col-auto">
        <select id="kanban-status" class="form-select">
            <option value="">All</option>
            <option value="ToDo">To Do</option>
            <option value="InProgress">In Progress</option>
            <option value="Done">Done</option>
        </select>
    </div>
</div>

<div class="row">
    <div class="col-xl-4">
        <div class="card">
            <div class="card-body">
                <h5 class="mb-3">
                    To Do
                    <span data-count="todo" class="badge bg-secondary align-middle">0</span>
                </h5>
                <div id="upcoming-task" class="tasks-list"></div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card">
            <div class="card-body">
                <h5 class="mb-3">
                    In Progress
                    <span data-count="inprogress" class="badge bg-primary align-middle">0</span>
                </h5>
                <div id="inprogress-task" class="tasks-list"></div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card">
            <div class="card-body">
                <h5 class="mb-3">
                    Done
                    <span data-count="done" class="badge bg-success align-middle">0</span>
                </h5>
                <div id="complete-task" class="tasks-list"></div>
            </div>
        </div>
    </div>
</div>

<!-- مودال إنشاء مهمة (Skote) -->
<div class="modal fade bs-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="task-form" onsubmit="return false;">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input id="taskname" class="form-control" placeholder="Task title">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="taskdesc" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select id="TaskStatus" class="form-select">
                            <option>ToDo</option>
                            <option>InProgress</option>
                            <option>Done</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button id="addtask" type="button" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>



@section scripts{
    <!-- dragula plugins -->
    <script src="~/assets/libs/dragula/dragula.min.js"></script>

    <!-- jquery-validation -->
    <script src="~/assets/libs/jquery-validation/jquery.validate.min.js"></script>

    <script src="~/assets/js/pages/task-kanban.init.js"></script>

    <script src="~/assets/js/pages/task-form.init.js"></script>
    <!-- الأدابتر بتاعنا (آخر واحد) -->
    <script src="~/assets/js/kanban.skote.adapter.js"></script>


    <script src="~/assets/js/app.js"></script>

}



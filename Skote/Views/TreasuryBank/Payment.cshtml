@using InfrastructureManagmentWebFramework.Models.TreasuryBank
@model CreateCashBankVoucherVm
@{
    ViewData["Title"] = "سند صرف";
}

<div class="container-fluid" dir="rtl">
    <div class="card">
        <div class="card-header"><h4 class="mb-0">سند صرف</h4></div>
        <div class="card-body">
            <form asp-action="Payment" method="post">
                <partial name="_VoucherForm" model="Model" />
                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-danger" type="submit">حفظ وترحيل</button>
                    <a asp-action="Index" class="btn btn-light">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

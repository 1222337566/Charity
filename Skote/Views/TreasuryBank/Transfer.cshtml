@using InfrastructureManagmentWebFramework.Models.TreasuryBank
@model CreateTreasuryBankTransferVm
@{
    ViewData["Title"] = "تحويل خزينة / بنك";
}

<div class="container-fluid" dir="rtl">
    <div class="card">
        <div class="card-header"><h4 class="mb-0">تحويل بين خزينة وبنك</h4></div>
        <div class="card-body">
            <form asp-action="Transfer" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="TransferDate" class="form-label"></label>
                        <input asp-for="TransferDate" type="date" class="form-control" />
                        <span asp-validation-for="TransferDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="FromFinancialAccountId" class="form-label"></label>
                        <select asp-for="FromFinancialAccountId" asp-items="Model.CashBankAccounts" class="form-select">
                            <option value="">-- من حساب --</option>
                        </select>
                        <span asp-validation-for="FromFinancialAccountId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="ToFinancialAccountId" class="form-label"></label>
                        <select asp-for="ToFinancialAccountId" asp-items="Model.CashBankAccounts" class="form-select">
                            <option value="">-- إلى حساب --</option>
                        </select>
                        <span asp-validation-for="ToFinancialAccountId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-primary" type="submit">حفظ وترحيل</button>
                    <a asp-action="Index" class="btn btn-light">رجوع</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

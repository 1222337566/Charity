@using InfrastructureManagmentWebFramework.Models.TreasuryBank
@model CreateCashBankVoucherVm

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="VoucherDate" class="form-label"></label>
        <input asp-for="VoucherDate" type="date" class="form-control" />
        <span asp-validation-for="VoucherDate" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="FinancialAccountId" class="form-label"></label>
        <select asp-for="FinancialAccountId" asp-items="Model.CashBankAccounts" class="form-select">
            <option value="">-- اختر حساب خزينة أو بنك --</option>
        </select>
        <span asp-validation-for="FinancialAccountId" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="OppositeAccountId" class="form-label"></label>
        <select asp-for="OppositeAccountId" asp-items="Model.OppositeAccounts" class="form-select">
            <option value="">-- اختر الحساب المقابل --</option>
        </select>
        <span asp-validation-for="OppositeAccountId" class="text-danger"></span>
    </div>

    <div class="col-md-4 mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="col-md-8 mb-3">
        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="col-md-12 mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>
</div>

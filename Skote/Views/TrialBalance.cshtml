@using InfrastructureManagmentWebFramework.Models.AccountingReports
@model TrialBalancePageVm

@{
    ViewData["Title"] = "ميزان المراجعة";
}

<div class="container-fluid">
    <div class="card mb-3">
        <div class="card-header"><h4 class="mb-0">ميزان المراجعة</h4></div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">الفترة المالية</label>
                    <select asp-for="Filter.FiscalPeriodId" asp-items="Model.Filter.FiscalPeriods" class="form-select">
                        <option value="">الكل</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">من تاريخ</label>
                    <input asp-for="Filter.FromDate" class="form-control" type="date" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">إلى تاريخ</label>
                    <input asp-for="Filter.ToDate" class="form-control" type="date" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">عرض</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Rows.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>كود الحساب</th>
                                <th>اسم الحساب</th>
                                <th>الفئة</th>
                                <th>إجمالي مدين</th>
                                <th>إجمالي دائن</th>
                                <th>صافي الرصيد</th>
                                <th>الحركة</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Rows)
                            {
                                <tr>
                                    <td>@row.AccountCode</td>
                                    <td>@row.AccountNameAr</td>
                                    <td>@row.Category</td>
                                    <td>@row.TotalDebit.ToString("N2")</td>
                                    <td>@row.TotalCredit.ToString("N2")</td>
                                    <td>@row.NetBalance.ToString("N2")</td>
                                    <td>
                                        <a asp-action="AccountStatement"
                                           asp-route-accountId="@row.AccountId"
                                           asp-route-fiscalPeriodId="@Model.Filter.FiscalPeriodId"
                                           asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")"
                                           asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")"
                                           class="btn btn-sm btn-outline-primary">
                                            كشف الحساب
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="3">الإجمالي</td>
                                <td>@Model.TotalDebit.ToString("N2")</td>
                                <td>@Model.TotalCredit.ToString("N2")</td>
                                <td>@(Model.TotalDebit - Model.TotalCredit).ToString("N2")</td>
                                <td>-</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">لا توجد بيانات لعرضها حسب الفلاتر المحددة.</div>
            }
        </div>
    </div>
</div>

@model EditUnitVm
@using InfrastructureManagmentWebFramework.Models.FinancialAccounting;

@{
    ViewData["Title"] = "تعديل وحدة";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4 class="mb-0">تعديل وحدة</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="UnitCode" class="form-label"></label>
                        <input asp-for="UnitCode" class="form-control" />
                        <span asp-validation-for="UnitCode" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 mb-3">
                        <label asp-for="UnitNameAr" class="form-label"></label>
                        <input asp-for="UnitNameAr" class="form-control" />
                        <span asp-validation-for="UnitNameAr" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="UnitNameEn" class="form-label"></label>
                        <input asp-for="UnitNameEn" class="form-control" />
                        <span asp-validation-for="UnitNameEn" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Symbol" class="form-label"></label>
                        <input asp-for="Symbol" class="form-control" />
                        <span asp-validation-for="Symbol" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">حفظ التعديل</button>
                <a asp-action="Index" class="btn btn-secondary">رجوع</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
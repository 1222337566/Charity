@model Skote.ViewModels.Audit.UserActivityLogIndexVm
@{
    ViewData["Title"] = "سجل المتابعة";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-1">سجل المتابعة</h4>
                <div class="text-muted">تتبع عمليات المستخدمين على الطلبات والسجلات والفواتير والقرارات مع اسم من نفذ الإجراء.</div>
            </div>
            <a class="btn btn-outline-primary"
               href="@Url.Action("ExportCsv", new { query = Model.Query, action = Model.Action, userId = Model.UserId, ipAddress = Model.IpAddress, fromUtc = Model.FromUtc, toUtc = Model.ToUtc, take = Model.Take })">
                تصدير CSV
            </a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">إجمالي السجلات</div><div class="h3 mb-0">@Model.Summary.TotalCount</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">اليوم</div><div class="h3 mb-0">@Model.Summary.TodayCount</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">آخر 7 أيام</div><div class="h3 mb-0">@Model.Summary.Last7DaysCount</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">مستخدمون مميزون</div><div class="h3 mb-0">@Model.Summary.DistinctUsers</div></div></div></div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">بحث</label>
                    <input name="query" value="@Model.Query" class="form-control" placeholder="اسم المستخدم / الشاشة / رقم السجل / الوصف" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">الإجراء</label>
                    <select name="action" class="form-select">
                        <option value="">الكل</option>
                        @foreach (var action in Model.AvailableActions)
                        {
                            if (string.Equals(Model.Action, action, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@action" selected>@action</option>
                            }
                            else
                            {
                                <option value="@action">@action</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">معرف المستخدم</label>
                    <input name="userId" value="@Model.UserId" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">IP</label>
                    <input name="ipAddress" value="@Model.IpAddress" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">من</label>
                    <input type="date" name="fromUtc" value="@(Model.FromUtc?.ToString("yyyy-MM-dd"))" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">إلى</label>
                    <input type="date" name="toUtc" value="@(Model.ToUtc?.ToString("yyyy-MM-dd"))" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">العدد</label>
                    <input type="number" min="20" max="1000" name="take" value="@Model.Take" class="form-control" />
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">بحث</button>
                    <a href="@Url.Action("Index")" class="btn btn-light">إعادة تعيين</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>من قام بالإجراء</th>
                        <th>الإجراء</th>
                        <th>الشاشة</th>
                        <th>الكيان/السجل</th>
                        <th>التاريخ والوقت</th>
                        <th>IP</th>
                        <th>الوصف</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-muted">لا توجد سجلات مطابقة.</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>
                                <div>@item.UserName</div>
                                <small class="text-muted">@item.UserId</small>
                            </td>
                            <td><span class="badge bg-soft-primary text-primary">@item.Action</span></td>
                            <td>
                                <div>@item.ControllerName</div>
                                <small class="text-muted">@item.ActionName</small>
                            </td>
                            <td>
                                <div>@item.EntityName</div>
                                <small class="text-muted">@item.EntityId</small>
                            </td>
                            <td>@item.OccurredAtUtc.ToLocalTime().ToString("yyyy-MM-dd hh:mm tt")</td>
                            <td>@item.IpAddress</td>
                            <td style="max-width:360px; white-space:normal">@item.Description</td>
                            <td><a class="btn btn-sm btn-outline-secondary" href="@Url.Action("Details", new { id = item.Id })">تفاصيل</a></td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

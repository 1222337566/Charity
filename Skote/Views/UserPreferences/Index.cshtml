@using Microsoft.AspNetCore.Mvc.Rendering
@model Skote.Controllers.UserPreferencesVm
@{
    ViewData["Title"] = "تفضيلاتي";
}

<div class="row justify-content-center">
    <div class="col-xl-7 col-lg-9">
        <div class="card" style="border-radius:18px;border:.5px solid rgba(14,111,115,.12)">
            <div class="card-body p-4">
                <h4 class="mb-1 fw-bold" style="color:#0a5f63">
                    <i class="bx bx-cog me-2"></i>تفضيلات المستخدم
                </h4>
                <p class="text-muted mb-4">تخصيص تجربة استخدام النظام</p>

                @if (TempData["PrefsMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        @TempData["PrefsMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="Save" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4 p-3 rounded-3" style="background:#f5faf9">
                        <h6 class="fw-bold mb-3" style="color:#0a5f63">المظهر والواجهة</h6>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <div class="fw-semibold">الوضع المظلم</div>
                                <div class="text-muted small">تغيير مظهر النظام للوضع الداكن</div>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="DarkMode"
                                       id="darkmode" @(Model.DarkMode ? "checked" : "") style="width:44px;height:24px" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <div class="fw-semibold">طريقة عرض المهام الافتراضية</div>
                                <div class="text-muted small">الصفحة التي تظهر عند فتح "مهامي"</div>
                            </div>
                            <select name="DefaultView" class="form-select" style="width:140px;border-radius:10px"
                                    asp-items="@(new SelectList(new[]{
                        new {V="Kanban",  T="Kanban"},
                        new {V="List",    T="قائمة"},
                        new {V="Calendar",T="تقويم"}
                      }, "V", "T", Model.DefaultView))">
                            </select>
                        </div>
                    </div>

                    <div class="mb-4 p-3 rounded-3" style="background:#f5faf9">
                        <h6 class="fw-bold mb-3" style="color:#0a5f63">التنبيهات والإشعارات</h6>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <div class="fw-semibold">إشعارات الصوت</div>
                                <div class="text-muted small">تشغيل صوت عند وصول إشعار جديد</div>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="SoundNotifications"
                                       id="soundnotify" @(Model.SoundNotifications ? "checked" : "") style="width:44px;height:24px" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <div class="fw-semibold">الملخص اليومي الصباحي</div>
                                <div class="text-muted small">إرسال ملخص المهام في الساعة 8 صباحاً</div>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="DailySummary"
                                       id="dailysummary" @(Model.DailySummary ? "checked" : "") style="width:44px;height:24px" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <div class="fw-semibold">تنبيه الاستحقاق المبكر</div>
                                <div class="text-muted small">إشعار قبل موعد الاستحقاق بـ</div>
                            </div>
                            <select name="DueAlertDays" class="form-select" style="width:130px;border-radius:10px"
                                    asp-items="@(new SelectList(new[]{
                        new {V="1", T="يوم واحد"},
                        new {V="3", T="3 أيام"},
                        new {V="7", T="أسبوع"},
                        new {V="14",T="أسبوعان"}
                      }, "V", "T", Model.DueAlertDays.ToString()))">
                            </select>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold" style="border-radius:14px;padding:12px">
                        <i class="bx bx-save me-2"></i>حفظ التفضيلات
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

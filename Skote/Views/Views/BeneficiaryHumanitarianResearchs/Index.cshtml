@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.HumanitarianResearch.BeneficiaryHumanitarianResearchListItemVm>
@{
    ViewData["Title"] = "استمارات البحث الإنساني";
    Guid? beneficiaryId = ViewBag.BeneficiaryId as Guid?;
    string beneficiaryName = ViewBag.BeneficiaryName as string ?? string.Empty;
}

<div class="page-title-box d-sm-flex align-items-center justify-content-between">
    <div>
        <h4 class="mb-sm-0">استمارات البحث الإنساني</h4>
        @if (beneficiaryId.HasValue)
        {
            <div class="text-muted mt-1">المستفيد: @beneficiaryName</div>
        }
    </div>
    <div class="page-title-right d-flex gap-2">
        <a asp-action="Create" asp-route-beneficiaryId="@beneficiaryId" class="btn btn-primary">إنشاء استمارة جديدة</a>
        <a asp-controller="Beneficiaries" asp-action="Index" class="btn btn-light">رجوع</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead>
                    <tr>
                        <th>رقم الاستمارة</th>
                        <th>اسم الحالة</th>
                        <th>مقدم الطلب</th>
                        <th>تاريخ الطلب</th>
                        <th>الحالة</th>
                        <th>الأولوية</th>
                        <th style="width:220px;">إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ResearchNumber</td>
                        <td>@item.FullName</td>
                        <td>@item.ApplicantName</td>
                        <td>@item.RequestDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.Status</td>
                        <td>@item.PriorityLevel</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">عرض</a>
                                <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-sm btn-warning">مراجعة</a>
                                <a asp-action="Committee" asp-route-id="@item.Id" class="btn btn-sm btn-info">اللجنة</a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

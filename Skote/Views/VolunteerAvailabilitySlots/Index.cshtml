@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Volunteers.VolunteerAvailabilitySlotListItemVm>
@await Html.PartialAsync("~/Views/Shared/Volunteers/_VolunteerHeader.cshtml")
@{
    var showVolunteerColumn = ViewBag.ShowVolunteerColumn as bool? == true;
    var volunteerNamesBySlotId = ViewBag.VolunteerNamesBySlotId as IDictionary<Guid, string>;
    var volunteerIdsBySlotId = ViewBag.VolunteerIdsBySlotId as IDictionary<Guid, Guid>;
}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <div>
            <h4 class="mb-0">أوقات التوفر</h4>
            @if (ViewBag.Volunteer == null)
            {
                <small class="text-muted">عرض عام لأوقات توفر المتطوعين.</small>
            }
        </div>
        @if (ViewBag.Volunteer != null)
        {
            <a asp-action="Create" asp-route-volunteerId="@ViewBag.Volunteer.Id" class="btn btn-primary">إضافة وقت توفر</a>
        }
        else
        {
            <a asp-controller="Volunteers" asp-action="Index" class="btn btn-outline-primary">اختيار متطوع</a>
        }
    </div>
    <div class="card-body table-responsive">
        <table class="table table-striped align-middle">
            <thead><tr>@if (showVolunteerColumn) { <th>المتطوع</th> }<th>اليوم</th><th>الوقت</th><th>النوع</th><th>المنطقة</th><th>عن بعد</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    @if (showVolunteerColumn)
                    {
                        <td>
                            @if (volunteerIdsBySlotId != null && volunteerIdsBySlotId.TryGetValue(item.Id, out var volunteerId))
                            {
                                <a asp-controller="Volunteers" asp-action="Details" asp-route-id="@volunteerId">
                                    @(volunteerNamesBySlotId != null && volunteerNamesBySlotId.TryGetValue(item.Id, out var volunteerName) ? volunteerName : "-")
                                </a>
                            }
                        </td>
                    }
                    <td>@item.DayOfWeekName</td><td>@item.TimeText</td><td>@item.AvailabilityType</td><td>@item.Area</td><td>@(item.IsRemoteAllowed ? "نعم" : "لا")</td>
                    <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@model InfrastructureManagmentWebFramework.Models.Charity.Volunteers.VolunteerDirectorySearchVm
@{ ViewData["Title"] = "دليل المتطوعين"; }
<div class="card mb-3"><div class="card-body">
    <h4 class="mb-3">دليل المتطوعين</h4>
    <form method="get" class="row g-3">
        <div class="col-md-4"><input name="q" value="@Model.Q" class="form-control" placeholder="اسم / كود / هاتف" /></div>
        <div class="col-md-3"><select name="skillDefinitionId" asp-items="Model.SkillDefinitions" class="form-select"><option value="">كل المهارات</option></select></div>
        <div class="col-md-3"><input name="area" value="@Model.Area" class="form-control" placeholder="المنطقة" /></div>
        <div class="col-md-1 form-check mt-2"><input name="activeOnly" value="true" type="checkbox" class="form-check-input" @(Model.ActiveOnly ? "checked" : "") /><label class="form-check-label">نشط</label></div>
        <div class="col-md-1"><button class="btn btn-primary w-100">بحث</button></div>
    </form>
</div></div>

<div class="card"><div class="card-body table-responsive">
    <table class="table table-striped align-middle">
        <thead><tr><th>الكود</th><th>الاسم</th><th>الهاتف</th><th>المجال</th><th>الإسنادات</th><th>الساعات</th><th></th></tr></thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.VolunteerCode</td>
                <td>@item.FullName</td>
                <td>@item.PhoneNumber</td>
                <td>@item.PreferredArea</td>
                <td>@item.AssignmentsCount</td>
                <td>@item.TotalHours</td>
                <td><a asp-action="Profile" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">الملف</a></td>
            </tr>
        }
        </tbody>
    </table>
</div></div>

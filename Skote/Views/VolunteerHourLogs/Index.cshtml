@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Volunteers.VolunteerHourLogListItemVm>
@await Html.PartialAsync("~/Views/Shared/Volunteers/_VolunteerHeader.cshtml")
@{
    var showVolunteerColumn = ViewBag.ShowVolunteerColumn as bool? == true;
    var volunteerNamesByLogId = ViewBag.VolunteerNamesByLogId as IDictionary<Guid, string>;
    var volunteerIdsByLogId = ViewBag.VolunteerIdsByLogId as IDictionary<Guid, Guid>;
}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-3 flex-wrap">
        <div>
            <h4 class="mb-0">ساعات التطوع</h4>
            @if (ViewBag.Volunteer == null)
            {
                <small class="text-muted">عرض عام لكل ساعات التطوع.</small>
            }
        </div>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <span class="badge bg-success">الإجمالي: @ViewBag.TotalHours ساعة</span>
            @if (ViewBag.Volunteer != null)
            {
                <a asp-action="Create" asp-route-volunteerId="@ViewBag.Volunteer.Id" class="btn btn-primary">إضافة ساعات</a>
            }
            else
            {
                <a asp-controller="Volunteers" asp-action="Index" class="btn btn-outline-primary">اختيار متطوع</a>
            }
        </div>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    @if (showVolunteerColumn) { <th>المتطوع</th> }
                    <th>التاريخ</th>
                    <th>الساعات</th>
                    <th>النشاط</th>
                    <th>المشروع</th>
                    <th>النتيجة</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    @if (showVolunteerColumn)
                    {
                        <td>
                            @if (volunteerIdsByLogId != null && volunteerIdsByLogId.TryGetValue(item.Id, out var volunteerId))
                            {
                                <a asp-controller="Volunteers" asp-action="Details" asp-route-id="@volunteerId">
                                    @(volunteerNamesByLogId != null && volunteerNamesByLogId.TryGetValue(item.Id, out var volunteerName) ? volunteerName : "-")
                                </a>
                            }
                        </td>
                    }
                    <td>@item.WorkDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.Hours</td>
                    <td>@item.ActivityTitle</td>
                    <td>@item.ProjectName</td>
                    <td>@item.Outcome</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

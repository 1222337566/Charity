@model InfrastructureManagmentWebFramework.Models.Charity.Volunteers.CreateVolunteerHourLogVm
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="AssignmentId" class="form-label"></label>
        <select asp-for="AssignmentId" asp-items="Model.Assignments" class="form-select">
            <option value="">-- بدون إسناد --</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="ProjectId" class="form-label"></label>
        <select asp-for="ProjectId" asp-items="Model.Projects" class="form-select">
            <option value="">-- بدون مشروع --</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="WorkDate" class="form-label"></label>
        <input asp-for="WorkDate" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Hours" class="form-label"></label>
        <input asp-for="Hours" class="form-control" />
        <span asp-validation-for="Hours" class="text-danger"></span>
    </div>
    <div class="col-md-9">
        <label asp-for="ActivityTitle" class="form-label"></label>
        <input asp-for="ActivityTitle" class="form-control" />
        <span asp-validation-for="ActivityTitle" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Outcome" class="form-label"></label>
        <input asp-for="Outcome" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
    </div>
</div>

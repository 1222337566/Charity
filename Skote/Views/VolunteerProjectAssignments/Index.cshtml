@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Volunteers.VolunteerAssignmentListItemVm>
@await Html.PartialAsync("~/Views/Shared/Volunteers/_VolunteerHeader.cshtml")
@{
    var showVolunteerColumn = ViewBag.ShowVolunteerColumn as bool? == true;
    var volunteerNamesByAssignmentId = ViewBag.VolunteerNamesByAssignmentId as IDictionary<Guid, string>;
    var volunteerIdsByAssignmentId = ViewBag.VolunteerIdsByAssignmentId as IDictionary<Guid, Guid>;
}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <div>
            <h4 class="mb-0">إسنادات المتطوع</h4>
            @if (ViewBag.Volunteer == null)
            {
                <small class="text-muted">عرض عام لكل الإسنادات. اختر متطوعًا من الملف لإضافة إسناد جديد.</small>
            }
        </div>
        @if (ViewBag.Volunteer != null)
        {
            <a asp-action="Create" asp-route-volunteerId="@ViewBag.Volunteer.Id" class="btn btn-primary">إضافة إسناد</a>
        }
        else
        {
            <a asp-controller="Volunteers" asp-action="Index" class="btn btn-outline-primary">اختيار متطوع</a>
        }
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    @if (showVolunteerColumn) { <th>المتطوع</th> }
                    <th>المشروع</th>
                    <th>الدور</th>
                    <th>النوع</th>
                    <th>من</th>
                    <th>إلى</th>
                    <th>الساعات المستهدفة</th>
                    <th>الحالة</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    @if (showVolunteerColumn)
                    {
                        <td>
                            @if (volunteerIdsByAssignmentId != null && volunteerIdsByAssignmentId.TryGetValue(item.Id, out var volunteerId))
                            {
                                <a asp-controller="Volunteers" asp-action="Details" asp-route-id="@volunteerId">
                                    @(volunteerNamesByAssignmentId != null && volunteerNamesByAssignmentId.TryGetValue(item.Id, out var volunteerName) ? volunteerName : "-")
                                </a>
                            }
                        </td>
                    }
                    <td>@item.ProjectName</td>
                    <td>@item.RoleTitle</td>
                    <td>@item.AssignmentType</td>
                    <td>@item.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.EndDate?.ToString("yyyy-MM-dd")</td>
                    <td>@item.TargetHours</td>
                    <td>@item.Status</td>
                    <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

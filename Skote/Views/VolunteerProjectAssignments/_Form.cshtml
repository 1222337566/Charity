@model InfrastructureManagmentWebFramework.Models.Charity.Volunteers.CreateVolunteerProjectAssignmentVm
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="ProjectId" class="form-label"></label>
        <select asp-for="ProjectId" asp-items="Model.Projects" class="form-select">
            <option value="">بدون مشروع</option>
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="RoleTitle" class="form-label"></label>
        <input asp-for="RoleTitle" class="form-control" />
        <span asp-validation-for="RoleTitle" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="AssignmentType" class="form-label"></label>
        <select asp-for="AssignmentType" asp-items="Model.AssignmentTypes" class="form-select"></select>
    </div>
    <div class="col-md-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="TargetHours" class="form-label"></label>
        <input asp-for="TargetHours" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Model.Statuses" class="form-select"></select>
    </div>
    <div class="col-12">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
    </div>
</div>

@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Volunteers.VolunteerSkillDefinitionListItemVm>
@{
    ViewData["Title"] = "تعريف مهارات المتطوعين";
}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">تعريف مهارات المتطوعين</h4>
        <a asp-action="Create" class="btn btn-primary">إضافة مهارة</a>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-striped align-middle">
            <thead><tr><th>المهارة</th><th>الفئة</th><th>الترتيب</th><th>الحالة</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td><td>@item.Category</td><td>@item.SortOrder</td><td>@(item.IsActive ? "نشط" : "موقوف")</td>
                    <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Volunteers.VolunteerSkillListItemVm>
@await Html.PartialAsync("~/Views/Shared/Volunteers/_VolunteerHeader.cshtml")
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">مهارات المتطوع</h4>
        <a asp-action="Create" asp-route-volunteerId="@ViewBag.Volunteer.Id" class="btn btn-primary">إضافة مهارة</a>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-striped align-middle">
            <thead><tr><th>المهارة</th><th>الفئة</th><th>المستوى</th><th>ملاحظات</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.SkillName</td><td>@item.Category</td><td>@item.SkillLevel</td><td>@item.Notes</td>
                    <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">تعديل</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

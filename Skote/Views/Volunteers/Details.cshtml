@model InfrastructureManagmentWebFramework.Models.Charity.Volunteers.VolunteerListItemVm
@using InfrastrfuctureManagmentCore.Domains.Charity.Volunteers
@{
    ViewData["Title"] = "ملف المتطوع";
    var entity = ViewBag.Entity as Volunteer;
}
@if (entity != null)
{
    @await Html.PartialAsync("~/Views/Shared/Volunteers/_VolunteerHeader.cshtml")
    <div class="row">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header"><h5 class="mb-0">البيانات الأساسية</h5></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">الاسم</dt><dd class="col-sm-8">@entity.FullName</dd>
                        <dt class="col-sm-4">المؤهل</dt><dd class="col-sm-8">@entity.Qualification</dd>
                        <dt class="col-sm-4">العنوان</dt><dd class="col-sm-8">@entity.AddressLine</dd>
                        <dt class="col-sm-4">الجنسية</dt><dd class="col-sm-8">@entity.Nationality</dd>
                        <dt class="col-sm-4">رقم البطاقة</dt><dd class="col-sm-8">@entity.NationalId</dd>
                        <dt class="col-sm-4">الهاتف</dt><dd class="col-sm-8">@entity.PhoneNumber</dd>
                        <dt class="col-sm-4">البريد</dt><dd class="col-sm-8">@entity.Email</dd>
                        <dt class="col-sm-4">الحالة</dt><dd class="col-sm-8">@(entity.IsActive ? "نشط" : "غير نشط")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card text-center"><div class="card-body"><h6>الإسنادات</h6><h3>@Model.AssignmentsCount</h3></div></div>
                </div>
                <div class="col-md-6">
                    <div class="card text-center"><div class="card-body"><h6>إجمالي الساعات</h6><h3>@Model.TotalHours</h3></div></div>
                </div>
                <div class="col-12">
                    <div class="card">
                        <div class="card-header"><h5 class="mb-0">التوفر والمجال</h5></div>
                        <div class="card-body">
                            <p class="mb-2"><strong>المجال المفضل:</strong> @entity.PreferredArea</p>
                            <p class="mb-0"><strong>التوفر:</strong> @entity.AvailabilityNotes</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

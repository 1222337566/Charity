@model InfrastructureManagmentWebFramework.Models.Charity.Volunteers.EditVolunteerVm
@{
    ViewData["Title"] = "تعديل متطوع";
}
<div class="card">
    <div class="card-header"><h4 class="mb-0">تعديل متطوع</h4></div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />

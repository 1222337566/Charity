@model IEnumerable<InfrastructureManagmentWebFramework.Models.Charity.Volunteers.VolunteerListItemVm>
@{
    ViewData["Title"] = "المتطوعون";
}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">المتطوعون</h4>
        <a asp-action="Create" class="btn btn-primary">إضافة متطوع</a>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-striped align-middle">
            <thead>
                <tr>
                    <th>الكود</th>
                    <th>الاسم</th>
                    <th>الهاتف</th>
                    <th>المجال</th>
                    <th>الإسنادات</th>
                    <th>إجمالي الساعات</th>
                    <th>الحالة</th>
                    <th style="width:220px;">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.VolunteerCode</td>
                    <td>@item.FullName</td>
                    <td>@item.PhoneNumber</td>
                    <td>@item.PreferredArea</td>
                    <td>@item.AssignmentsCount</td>
                    <td>@item.TotalHours</td>
                    <td>@(item.IsActive ? "نشط" : "غير نشط")</td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">ملف</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">تعديل</a>
                            <a asp-controller="VolunteerProjectAssignments" asp-action="Index" asp-route-volunteerId="@item.Id" class="btn btn-sm btn-outline-info">إسنادات</a>
                            <a asp-controller="VolunteerHourLogs" asp-action="Index" asp-route-volunteerId="@item.Id" class="btn btn-sm btn-outline-success">ساعات</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

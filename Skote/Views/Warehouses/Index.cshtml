@model List<WarehouseListItemVm>
@using InfrastructureManagmentWebFramework.Models.FinancialAccounting;

@{
    ViewData["Title"] = "المخازن";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">المخازن</h4>
            <a asp-action="Create" class="btn btn-primary btn-sm">إضافة مخزن</a>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>الكود</th>
                            <th>الاسم</th>
                            <th>العنوان</th>
                            <th>رئيسي</th>
                            <th>الحالة</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.WarehouseCode</td>
                                <td>@item.WarehouseNameAr</td>
                                <td>@(item.Address ?? "-")</td>
                                <td>
                                    @if (item.IsMain)
                                    {
                                        <span class="badge bg-info">نعم</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">غير نشط</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                            تعديل
                                        </a>

                                        <form asp-action="ToggleActive" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />

                                            @if (item.IsActive)
                                            {
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                        onclick="return confirm('هل تريد تعطيل المخزن؟');">
                                                    تعطيل
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-success"
                                                        onclick="return confirm('هل تريد تفعيل المخزن؟');">
                                                    تفعيل
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>